{
  "name": "therealmofpatterns",
  "version": "1.0.0",
  "description": "Cosmic Identity Cartography - 100% Cloudflare Native",
  "main": "public/index.html",
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "deploy": "astro build && wrangler pages deploy dist --project-name=therealmofpatterns",
    "dev:legacy": "wrangler pages dev public --d1=DB --kv=CACHE --r2=STORAGE --ai",
    "db:migrate": "wrangler d1 execute therealmofpatterns-db --file=src/db/schema.sql",
    "db:seed": "wrangler d1 execute therealmofpatterns-db --file=src/db/seed.sql",
    "db:query": "wrangler d1 execute therealmofpatterns-db",
    "lint": "eslint \"functions/**/*.ts\" \"src/**/*.ts\"",
    "typecheck": "astro check && tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:prod": "BASE_URL=https://therealmofpatterns.com playwright test"
  },
  "keywords": [
    "cloudflare",
    "pages",
    "workers",
    "d1",
    "r2",
    "astrology",
    "identity",
    "cosmic"
  ],
  "author": "Hadi Servat (FRC 893 Series)",
  "license": "MIT",
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240117.0",
    "@playwright/test": "^1.58.1",
    "@types/node": "^20.11.0",
    "@types/react": "^19.2.10",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.54.0",
    "@typescript-eslint/parser": "^8.54.0",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^8.56.0",
    "happy-dom": "^20.5.0",
    "typescript": "^5.3.3",
    "vitest": "^4.0.18",
    "wrangler": "^4.61.1"
  },
  "dependencies": {
    "@astrojs/cloudflare": "^12.6.12",
    "@astrojs/react": "^4.4.2",
    "@astrojs/tailwind": "^6.0.2",
    "@nanostores/react": "^1.0.0",
    "astro": "^5.17.1",
    "jspdf": "^2.5.1",
    "jspdf-autotable": "^3.8.4",
    "nanostores": "^1.1.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwindcss": "^3.4.19"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
