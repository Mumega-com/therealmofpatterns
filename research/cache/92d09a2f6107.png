<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1024 1024">
  <defs>
    <radialGradient id="bg" cx="50%" cy="50%" r="70%">
      <stop offset="0%" style="stop-color:#FFFAFA;stop-opacity:0.8"/>
      <stop offset="100%" style="stop-color:#0a0a1a;stop-opacity:1"/>
    </radialGradient>
    <radialGradient id="glow" cx="50%" cy="50%" r="50%">
      <stop offset="0%" style="stop-color:#C0C0C0;stop-opacity:1.0"/>
      <stop offset="100%" style="stop-color:#C0C0C0;stop-opacity:0"/>
    </radialGradient>
    <filter id="blur">
      <feGaussianBlur stdDeviation="3"/>
    </filter>
  </defs>

  <!-- Background -->
  <rect width="1024" height="1024" fill="url(#bg)"/>

  <!-- Central glow -->
  <circle cx="512" cy="512" r="300" fill="url(#glow)" filter="url(#blur)"/>

  <!-- Vesica Piscis -->
  <circle cx="412" cy="512" r="200" fill="none" stroke="#C0C0C0" stroke-width="3" opacity="1.0"/>
  <circle cx="612" cy="512" r="200" fill="none" stroke="#C0C0C0" stroke-width="3" opacity="1.0"/>
  <ellipse cx="512" cy="512" rx="75" ry="150" fill="#C0C0C0" opacity="0.2"/>
</svg>