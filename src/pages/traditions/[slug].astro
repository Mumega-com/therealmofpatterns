      { tradition: 'Lamat (Star)', frc: 'Growth (Jupiter)', meaning: 'Abundance, ripening' },
    ],
    practicalBridge: [
      'Your Mayan day sign indicates your primary Identity configuration',
      'The tone number (1-13) suggests dimensional intensity levels',
      'Portal days correlate with high Awareness dimension sensitivity',
      'Galactic cycles align with longer-term energy pattern shifts',
      'The uinal (20-day period) creates a mini-cycle of dimensional emphasis',
    ],
    culturalInsight: 'Mayan timekeeping was deeply integrated with ceremony and cosmic awareness. The calendar wasn\'t just for tracking days—it was a spiritual technology for alignment. Our system shares this vision of time as meaningful pattern, not mere measurement.',
    callToAction: 'Find your Mayan day sign and see its dimensional signature.',
  },
  'western': {
    name: 'Western Astrology',
    nativeName: 'Horoscopic Astrology',
    title: 'Western Astrology & The Pattern System',
    subtitle: 'Building on the Hellenistic Foundation with Dimensional Precision',
    intro: 'Western astrology, rooted in Hellenistic, Medieval, and Renaissance traditions, remains the most widely practiced astrological system in the modern world. Our pattern system builds directly on this foundation while adding mathematical precision to archetypal insights.',
    keyPrinciples: [
      {
        name: 'Twelve Signs',
        frcMapping: 'Identity modifiers',
        description: 'The zodiac signs color how each planet/dimension expresses. Our system honors this but adds quantitative precision to qualitative descriptions.',
      },
      {
        name: 'Planetary Aspects',
        frcMapping: 'Dimensional harmonics',
        description: 'Conjunctions, squares, trines map to dimensional interactions. Our system computes these as alignment score relationships between dimensions.',
      },
      {
        name: 'Houses',
        frcMapping: 'Life area focus',
        description: 'The 12 houses indicate where dimensions manifest in life. Our context-aware readings adapt to similar life-area specificity.',
      },
      {
        name: 'Transits',
        frcMapping: 'Current transits',
        description: 'Transit analysis is core to both systems. Our real-time transit tracking provides daily, hourly precision for optimal timing.',
      },
    ],
    dimensionMappings: [
      { tradition: 'Sun', frc: 'Identity (Sun)', meaning: 'Core identity, ego, vitality' },
      { tradition: 'Moon', frc: 'Awareness (Neptune)', meaning: 'Emotions, intuition, the unconscious' },
      { tradition: 'Mercury', frc: 'Mind (Mercury)', meaning: 'Mind, communication, learning' },
      { tradition: 'Venus', frc: 'Connection (Moon)', meaning: 'Love, beauty, values, pleasure' },
      { tradition: 'Mars', frc: 'Drive (Mars)', meaning: 'Drive, assertion, energy' },
      { tradition: 'Jupiter', frc: 'Growth (Jupiter)', meaning: 'Growth, meaning, optimism' },
      { tradition: 'Saturn', frc: 'Structure (Saturn)', meaning: 'Structure, limits, responsibility' },
      { tradition: 'Uranus/Neptune/Pluto', frc: 'Heart (Venus) + Awareness (Neptune)', meaning: 'Transpersonal dimensions' },
    ],
    practicalBridge: [
      'Your Sun sign indicates your Identity dimension baseline',
      'Moon sign reveals Awareness dimension sensitivity patterns',
      'Mercury placement shows Mind dimension strengths',
      'Venus aspects correlate with Connection dimension harmony',
      'Saturn transits often challenge Structure dimension stability',
    ],
    culturalInsight: 'Western astrology excels at psychological depth and individual focus. Its modern forms integrate Jungian archetypes and humanistic values. Our system extends this psychological sophistication with daily practical guidance.',
    callToAction: 'Enter your birth data to see your Western chart as an energy profile.',
  },
  'celtic': {
    name: 'Celtic Tree Calendar',
    nativeName: 'Beth-Luis-Nion',
    title: 'The Celtic Tree Calendar & The Pattern System',
    subtitle: 'Druidic Wisdom and the Natural Rhythms of Pattern',
    intro: 'The Celtic tree calendar (Beth-Luis-Nion) assigns sacred trees to lunar months, connecting human nature to the wisdom of the forest. This nature-based system offers a grounded approach to pattern understanding that complements our cosmic mathematics.',
    keyPrinciples: [
      {
        name: '13 Lunar Months',
        frcMapping: 'Monthly pattern cycles',
        description: 'Each tree governs a lunar month (28 days). Our system tracks similar monthly patterns in dimensional activation.',
      },
      {
        name: 'Ogham Alphabet',
        frcMapping: 'Symbolic dimension keys',
        description: 'The Ogham letters encode tree wisdom. Each letter\'s shape and meaning parallel dimensional qualities.',
      },
      {
        name: 'Seasonal Festivals',
        frcMapping: 'Macro-transition points',
        description: 'The 8 Celtic festivals mark seasonal thresholds. Our system recognizes similar collective transition points in the cosmic field.',
      },
      {
        name: 'Tree Spirit Archetypes',
        frcMapping: 'Identity configurations',
        description: 'Each tree carries an archetypal energy. Your birth tree suggests Identity dimension qualities.',
      },
    ],
    dimensionMappings: [
      { tradition: 'Oak (Duir)', frc: 'Structure (Saturn)', meaning: 'Strength, endurance, protection' },
      { tradition: 'Birch (Beith)', frc: 'Identity (Sun)', meaning: 'New beginnings, purification' },
      { tradition: 'Willow (Saille)', frc: 'Awareness (Neptune)', meaning: 'Intuition, moon magic, flow' },
      { tradition: 'Hazel (Coll)', frc: 'Mind (Mercury)', meaning: 'Wisdom, inspiration, knowledge' },
      { tradition: 'Vine (Muin)', frc: 'Connection (Moon)', meaning: 'Joy, celebration, connection' },
      { tradition: 'Holly (Tinne)', frc: 'Drive (Mars)', meaning: 'Challenge, warrior spirit' },
      { tradition: 'Ash (Nion)', frc: 'Growth (Jupiter)', meaning: 'World tree, connection, growth' },
      { tradition: 'Yew (Idho)', frc: 'Heart (Venus)', meaning: 'Transformation, ancestors' },
    ],
    practicalBridge: [
      'Your Celtic birth tree reveals core Identity characteristics',
      'Oak periods favor Structure dimension grounding',
      'Willow moons heighten Awareness dimension sensitivity',
      'Hazel times support Mind dimension clarity',
      'Festival days mark powerful dimensional transition points',
    ],
    culturalInsight: 'The Celtic tradition grounds cosmic patterns in living nature. Trees are seen as ancestors, teachers, and allies. Our system honors this earth-centered spirituality while adding precision timing. Where Celtic wisdom excels in nature connection, our system adds daily practical guidance.',
    callToAction: 'Discover your Celtic tree sign and its dimensional resonance.',
  },
};

const { slug } = Astro.props;
const content = TRADITIONS[slug];

if (!content) {
  return Astro.redirect('/404');
}
---

<BaseLayout title={content.title} description={content.subtitle + '. ' + content.intro.slice(0, 100)}>
  <article class="tradition-article">
    <div class="article-container">
      <header class="article-header">
        <span class="native-name">{content.nativeName}</span>
        <h1>{content.title}</h1>
        <p class="subtitle">{content.subtitle}</p>
      </header>

      <div class="article-content">
        <section class="intro-section">
          <p class="intro-text">{content.intro}</p>
        </section>

        <section class="principles-section">
          <h2>Key Principles & Energy Mappings</h2>
          <div class="principles-grid">
            {content.keyPrinciples.map((principle) => (
              <div class="principle-card">
                <h3>{principle.name}</h3>
                <span class="frc-mapping">{principle.frcMapping}</span>
                <p>{principle.description}</p>
              </div>
            ))}
          </div>
        </section>

        <section class="mappings-section">
          <h2>Dimension Correspondences</h2>
          <div class="mappings-table">
            <div class="table-header">
              <span>{content.name}</span>
              <span>Energy Dimension</span>
              <span>Meaning</span>
            </div>
            {content.dimensionMappings.map((mapping) => (
              <div class="table-row">
                <span class="tradition-term">{mapping.tradition}</span>
                <span class="frc-term">{mapping.frc}</span>
                <span class="meaning">{mapping.meaning}</span>
              </div>
            ))}
          </div>
        </section>

        <section class="bridge-section">
          <h2>Practical Bridge</h2>
          <p class="bridge-intro">How to use {content.name} knowledge with our pattern system:</p>
          <ul class="bridge-list">
            {content.practicalBridge.map((item) => (
              <li>{item}</li>
            ))}
          </ul>
        </section>

        <section class="insight-section">
          <h2>Cultural Insight</h2>
          <blockquote>{content.culturalInsight}</blockquote>
        </section>

        <section class="cta-section">
          <h3>Explore Your Pattern</h3>
          <p>{content.callToAction}</p>
          <div class="cta-buttons">
            <a href="/sol/checkin" class="cta-primary">See My Pattern</a>
            <a href="/traditions" class="cta-secondary">Explore Other Traditions</a>
          </div>
        </section>
      </div>

      <!-- Related Traditions -->
      <nav class="related-traditions">
        <h3>Other Traditions</h3>
        <div class="related-grid">
          {Object.entries(TRADITIONS)
            .filter(([key]) => key !== slug)
            .map(([key, tradition]) => (
              <a href={`/traditions/${key}`} class="related-card">
                <span class="related-native">{tradition.nativeName}</span>
                <span class="related-name">{tradition.name}</span>
              </a>
            ))}
        </div>
      </nav>
    </div>
  </article>
</BaseLayout>

<style>
  .tradition-article {
    --gold: #d4a854;
    --dark: #0a0908;
    --dark-surface: #141210;
    --text: #f0e8d8;
    --text-muted: rgba(240, 232, 216, 0.6);

    font-family: 'Cormorant Garamond', Georgia, serif;
    background: var(--dark);
    color: var(--text);
    min-height: 100vh;
    padding: 6rem 2rem 4rem;
  }

  .article-container {
    max-width: 800px;
    margin: 0 auto;
  }

  .article-header {
    text-align: center;
    margin-bottom: 3rem;
    padding-bottom: 2rem;
    border-bottom: 1px solid rgba(212, 168, 84, 0.2);
  }

  .native-name {
    display: inline-block;
    font-size: 1.25rem;
    color: var(--gold);
    margin-bottom: 0.75rem;
    letter-spacing: 0.1em;
  }

  .article-header h1 {
    font-size: 2.25rem;
    font-weight: 300;
    color: var(--text);
    margin-bottom: 0.75rem;
    line-height: 1.3;
  }

  .subtitle {
    font-size: 1.1rem;
    color: var(--text-muted);
    font-style: italic;
  }

  .article-content section {
    margin-bottom: 3rem;
  }

  .intro-text {
    font-size: 1.15rem;
    line-height: 1.8;
    color: var(--text);
  }

  h2 {
    font-size: 1.5rem;
    font-weight: 400;
    color: var(--gold);
    margin-bottom: 1.25rem;
  }

  .principles-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.25rem;
  }

  @media (max-width: 640px) {
    .principles-grid {
      grid-template-columns: 1fr;
    }
  }

  .principle-card {
    padding: 1.5rem;
    background: var(--dark-surface);
    border: 1px solid rgba(212, 168, 84, 0.15);
  }

  .principle-card h3 {
    font-size: 1.1rem;
    color: var(--text);
    margin-bottom: 0.5rem;
    font-weight: 500;
  }

  .frc-mapping {
    display: inline-block;
    font-size: 0.75rem;
    color: var(--gold);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: 0.75rem;
    padding: 0.25rem 0.5rem;
    background: rgba(212, 168, 84, 0.1);
  }

  .principle-card p {
    font-size: 0.95rem;
    color: var(--text-muted);
    line-height: 1.6;
  }

  .mappings-table {
    background: var(--dark-surface);
    border: 1px solid rgba(212, 168, 84, 0.15);
  }

  .table-header {
    display: grid;
    grid-template-columns: 1fr 1fr 2fr;
    gap: 1rem;
    padding: 1rem 1.25rem;
    background: rgba(212, 168, 84, 0.08);
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--gold);
  }

  .table-row {
    display: grid;
    grid-template-columns: 1fr 1fr 2fr;
    gap: 1rem;
    padding: 0.875rem 1.25rem;
    border-top: 1px solid rgba(212, 168, 84, 0.1);
  }

  .tradition-term {
    color: var(--text);
    font-weight: 500;
  }

  .frc-term {
    color: var(--gold);
  }

  .meaning {
    color: var(--text-muted);
    font-size: 0.9rem;
  }

  @media (max-width: 640px) {
    .table-header, .table-row {
      grid-template-columns: 1fr;
      gap: 0.5rem;
    }
    .table-header span:last-child,
    .table-row .meaning {
      display: none;
    }
  }

  .bridge-intro {
    color: var(--text-muted);
    margin-bottom: 1rem;
  }

  .bridge-list {
    padding-left: 1.25rem;
  }

  .bridge-list li {
    font-size: 1rem;
    color: var(--text-muted);
    line-height: 1.7;
    margin-bottom: 0.75rem;
  }

  .bridge-list li::marker {
    color: var(--gold);
  }

  blockquote {
    padding: 1.5rem 2rem;
    background: rgba(212, 168, 84, 0.05);
    border-left: 4px solid var(--gold);
    font-size: 1.1rem;
    color: var(--text);
    line-height: 1.7;
    font-style: italic;
  }

  .cta-section {
    text-align: center;
    padding: 2.5rem;
    background: var(--dark-surface);
    border: 1px solid rgba(212, 168, 84, 0.2);
  }

  .cta-section h3 {
    font-size: 1.5rem;
    font-weight: 400;
    color: var(--text);
    margin-bottom: 0.5rem;
  }

  .cta-section > p {
    color: var(--text-muted);
    margin-bottom: 1.5rem;
  }

  .cta-buttons {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  .cta-primary {
    padding: 0.875rem 1.5rem;
    background: var(--gold);
    color: var(--dark);
    text-decoration: none;
    font-weight: 500;
    transition: all 0.2s;
  }

  .cta-primary:hover {
    background: #e5b964;
    box-shadow: 0 0 20px rgba(212, 168, 84, 0.3);
  }

  .cta-secondary {
    padding: 0.875rem 1.5rem;
    border: 1px solid var(--gold);
    color: var(--gold);
    text-decoration: none;
    transition: all 0.2s;
  }

  .cta-secondary:hover {
    background: rgba(212, 168, 84, 0.1);
  }

  .related-traditions {
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px solid rgba(212, 168, 84, 0.1);
  }

  .related-traditions h3 {
    font-size: 1.25rem;
    color: var(--text-muted);
    margin-bottom: 1.25rem;
    text-align: center;
  }

  .related-grid {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    justify-content: center;
  }

  .related-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 1rem 1.5rem;
    background: var(--dark-surface);
    border: 1px solid rgba(212, 168, 84, 0.15);
    text-decoration: none;
    transition: all 0.2s;
  }

  .related-card:hover {
    border-color: var(--gold);
    transform: translateY(-2px);
  }

  .related-native {
    font-size: 0.9rem;
    color: var(--gold);
    margin-bottom: 0.25rem;
  }

  .related-name {
    font-size: 0.85rem;
    color: var(--text-muted);
  }
</style>
