    dimensionMappings: [
      { tradition: 'Surya (Sun)', frc: 'Identity (Sun)', meaning: 'Soul, identity, life purpose' },
      { tradition: 'Chandra (Moon)', frc: 'Awareness (Neptune)', meaning: 'Mind, emotions, intuition' },
      { tradition: 'Mangala (Mars)', frc: 'Drive (Mars)', meaning: 'Energy, courage, will' },
      { tradition: 'Budha (Mercury)', frc: 'Mind (Mercury)', meaning: 'Intellect, communication' },
