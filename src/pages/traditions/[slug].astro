      {
        name: 'Wu Xing (Five Elements)',
        frcMapping: 'Maps to 5 core dimensions',
        description: 'Wood (Growth/Jupiter), Fire (Drive/Mars), Earth (Structure/Saturn), Metal (Mind/Mercury), Water (Awareness/Neptune). The generative and controlling cycles mirror dimensional harmonics.',
      },
      {
        name: 'Twelve Animals',
        frcMapping: 'Identity archetypes',
        description: 'Each animal represents an Identity (Sun) configuration. Your birth animal indicates your core identity pattern, much like the system\'s Identity dimension.',
      },
      {
        name: 'Yin-Yang Balance',
        frcMapping: 'Natal/transit polarity',
        description: 'The yin-yang dynamic maps directly to the system\'s natal pattern (karma) and current transits (dharma) structure.',
      },
      {
        name: 'Four Pillars (BaZi)',
        frcMapping: '4 temporal dimensions',
        description: 'Year, Month, Day, Hour pillars parallel our temporal dimension analysis, both recognizing that time-of-birth specificity increases reading accuracy.',
      },
    ],
    dimensionMappings: [
      { tradition: 'Wood (木)', frc: 'Growth (Jupiter)', meaning: 'Growth, vision, new beginnings' },
      { tradition: 'Fire (火)', frc: 'Drive (Mars)', meaning: 'Energy, transformation, will' },
      { tradition: 'Earth (土)', frc: 'Structure (Saturn)', meaning: 'Stability, nourishment, grounding' },
      { tradition: 'Metal (金)', frc: 'Mind (Mercury)', meaning: 'Precision, clarity, structure' },
      { tradition: 'Water (水)', frc: 'Awareness (Neptune)', meaning: 'Wisdom, flow, collective connection' },
