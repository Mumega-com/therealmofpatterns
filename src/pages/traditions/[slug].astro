---
import BaseLayout from '../../layouts/BaseLayout.astro';

export function getStaticPaths() {
  return [
    { params: { slug: 'chinese' }, props: { slug: 'chinese' } },
    { params: { slug: 'vedic' }, props: { slug: 'vedic' } },
    { params: { slug: 'mayan' }, props: { slug: 'mayan' } },
    { params: { slug: 'western' }, props: { slug: 'western' } },
    { params: { slug: 'celtic' }, props: { slug: 'celtic' } },
  ];
}

interface TraditionContent {
  name: string;
  nativeName: string;
  title: string;
  subtitle: string;
  intro: string;
  keyPrinciples: { name: string; frcMapping: string; description: string }[];
  dimensionMappings: { tradition: string; frc: string; meaning: string }[];
  practicalBridge: string[];
  culturalInsight: string;
  callToAction: string;
}

const TRADITIONS: Record<string, TraditionContent> = {
  'chinese': {
    name: 'Chinese Astrology',
    nativeName: '中國占星術',
    title: 'Chinese Astrology & Energy Patterns',
    subtitle: 'Bridging the Five Elements with 8-Dimension Energy Pattern Analysis',
    intro: 'Chinese astrology, with its 5,000-year history, maps human nature through the interplay of Five Elements (Wu Xing), Twelve Animals, and Heavenly Stems. Our pattern system honors this wisdom while adding dimensional precision to ancient insights.',
