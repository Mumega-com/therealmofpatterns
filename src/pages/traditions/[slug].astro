---
import BaseLayout from '../../layouts/BaseLayout.astro';

export function getStaticPaths() {
  return [
    { params: { slug: 'chinese' }, props: { slug: 'chinese' } },
    { params: { slug: 'vedic' }, props: { slug: 'vedic' } },
    { params: { slug: 'mayan' }, props: { slug: 'mayan' } },
    { params: { slug: 'western' }, props: { slug: 'western' } },
    { params: { slug: 'celtic' }, props: { slug: 'celtic' } },
  ];
}

interface TraditionContent {
  name: string;
  nativeName: string;
  title: string;
  subtitle: string;
  intro: string;
  keyPrinciples: { name: string; frcMapping: string; description: string }[];
  dimensionMappings: { tradition: string; frc: string; meaning: string }[];
  practicalBridge: string[];
  culturalInsight: string;
  callToAction: string;
}

const TRADITIONS: Record<string, TraditionContent> = {
  'chinese': {
    name: 'Chinese Astrology',
    nativeName: '中國占星術',
    title: 'Chinese Astrology & The FRC Framework',
    subtitle: 'Bridging the Five Elements with 16-Dimensional Pattern Analysis',
    intro: 'Chinese astrology, with its 5,000-year history, maps human nature through the interplay of Five Elements (Wu Xing), Twelve Animals, and Heavenly Stems. The FRC framework honors this wisdom while adding dimensional precision to ancient insights.',
    keyPrinciples: [
      {
        name: 'Wu Xing (Five Elements)',
        frcMapping: 'Maps to 5 core dimensions',
        description: 'Wood (Expansion/μ₅), Fire (Action/μ₆), Earth (Existence/μ₂), Metal (Cognition/μ₃), Water (Field/μ₈). The generative and controlling cycles mirror dimensional harmonics.',
      },
      {
        name: 'Twelve Animals',
        frcMapping: 'Phase archetypes',
        description: 'Each animal represents a Phase (μ₁) configuration. Your birth animal indicates your core identity pattern, much like FRC\'s Phase dimension.',
      },
      {
        name: 'Yin-Yang Balance',
        frcMapping: 'Inner/Outer Octave polarity',
        description: 'The yin-yang dynamic maps directly to FRC\'s Inner Octave (karma/natal) and Outer Octave (dharma/transit) structure.',
      },
      {
        name: 'Four Pillars (BaZi)',
        frcMapping: '4 temporal dimensions',
        description: 'Year, Month, Day, Hour pillars parallel FRC\'s temporal dimension analysis, both recognizing that time-of-birth specificity increases reading accuracy.',
      },
    ],
    dimensionMappings: [
      { tradition: 'Wood (木)', frc: 'Expansion (μ₅)', meaning: 'Growth, vision, new beginnings' },
      { tradition: 'Fire (火)', frc: 'Action (μ₆)', meaning: 'Energy, transformation, will' },
      { tradition: 'Earth (土)', frc: 'Existence (μ₂)', meaning: 'Stability, nourishment, grounding' },
      { tradition: 'Metal (金)', frc: 'Cognition (μ₃)', meaning: 'Precision, clarity, structure' },
      { tradition: 'Water (水)', frc: 'Field (μ₈)', meaning: 'Wisdom, flow, collective connection' },
    ],
    practicalBridge: [
      'If your BaZi shows Wood dominance, expect high Expansion dimension scores',
      'Fire year transits correlate with Action dimension activation',
      'Earth element imbalance often shows as low Existence/grounding scores',
      'Metal personalities typically score high on Cognition dimension',
      'Water-dominant charts align with Field dimension sensitivity',
