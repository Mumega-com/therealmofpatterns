      {
        name: '13 Tones (Numbers)',
        frcMapping: 'Intensity modifiers',
        description: 'The 13 galactic tones modify each day sign\'s expression. FRC similarly uses dimensional intensity scores to show how strongly each dimension manifests.',
      },
      {
        name: 'Long Count',
        frcMapping: 'Macro-cycle tracking',
        description: 'The Long Count tracks vast time cycles. FRC\'s historical pattern database recognizes similar macro-patterns across longer timeframes.',
      },
    ],
    dimensionMappings: [
      { tradition: 'Imix (Dragon)', frc: 'Field (μ₈)', meaning: 'Primordial energy, source' },
      { tradition: 'Ik (Wind)', frc: 'Cognition (μ₃)', meaning: 'Breath, spirit, communication' },
      { tradition: 'Akbal (Night)', frc: 'Phase (μ₁)', meaning: 'Transformation, dreaming' },
      { tradition: 'Kan (Seed)', frc: 'Value (μ₄)', meaning: 'Potential, intention, targeting' },
