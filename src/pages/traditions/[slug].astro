        name: '20 Day Signs (Nawales)',
        frcMapping: 'Identity archetypes',
        description: 'Each nawal represents a distinct energy pattern. Like the Identity dimension configurations, they describe core identity flavors.',
      },
      {
        name: '13 Tones (Numbers)',
        frcMapping: 'Intensity modifiers',
        description: 'The 13 galactic tones modify each day sign\'s expression. Our system similarly uses dimensional intensity scores to show how strongly each dimension manifests.',
      },
      {
        name: 'Long Count',
        frcMapping: 'Macro-cycle tracking',
        description: 'The Long Count tracks vast time cycles. Our historical pattern database recognizes similar macro-patterns across longer timeframes.',
      },
    ],
    dimensionMappings: [
      { tradition: 'Imix (Dragon)', frc: 'Awareness (Neptune)', meaning: 'Primordial energy, source' },
      { tradition: 'Ik (Wind)', frc: 'Mind (Mercury)', meaning: 'Breath, spirit, communication' },
      { tradition: 'Akbal (Night)', frc: 'Identity (Sun)', meaning: 'Transformation, dreaming' },
      { tradition: 'Kan (Seed)', frc: 'Heart (Venus)', meaning: 'Potential, intention, targeting' },
      { tradition: 'Chicchan (Serpent)', frc: 'Drive (Mars)', meaning: 'Life force, kundalini' },
      { tradition: 'Cimi (Transformer)', frc: 'Structure (Saturn)', meaning: 'Death/rebirth, grounding' },
