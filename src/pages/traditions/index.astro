---
import BaseLayout from '../../layouts/BaseLayout.astro';

const TRADITIONS = [
  {
    slug: 'chinese',
    name: 'Chinese Astrology',
    nativeName: '中國占星術',
    symbol: '☯',
    description: 'Five Elements, Twelve Animals, and the wisdom of 5,000 years',
    highlight: 'Wu Xing ↔ 5 Energy Dimensions',
  },
  {
    slug: 'vedic',
    name: 'Vedic Astrology',
    nativeName: 'Jyotish (ज्योतिष)',
    symbol: 'ॐ',
    description: 'The science of light — nakshatras, dashas, and karmic patterns',
    highlight: 'Navagraha ↔ Core Energy Dimensions',
  },
  {
    slug: 'mayan',
    name: 'Mayan Calendar',
    nativeName: "Tzolk'in",
    symbol: '☼',
    description: 'The 260-day sacred calendar and 20 day signs',
    highlight: 'Nawales ↔ Identity Archetypes',
  },
  {
    slug: 'western',
    name: 'Western Astrology',
    nativeName: 'Horoscopic Astrology',
    symbol: '☽',
    description: 'The Hellenistic tradition of signs, houses, and aspects',
    highlight: 'Planets ↔ Dimensions',
  },
  {
    slug: 'celtic',
    name: 'Celtic Tree Calendar',
    nativeName: 'Beth-Luis-Nion',
    symbol: '🌳',
    description: 'Druidic wisdom connecting human nature to sacred trees',
    highlight: 'Trees ↔ Energy Qualities',
  },
];
---

<BaseLayout
  title="World Traditions & Energy Patterns"
  description="Explore how ancient wisdom traditions from around the world connect to your energy profile. Chinese, Vedic, Mayan, Western, and Celtic astrology mapped to 8 energy dimensions."
>
  <div class="traditions-page">
    <div class="page-container">
      <header class="page-header">
        <h1>World Wisdom Traditions</h1>
        <p class="subtitle">How different cultures understood the same energy patterns — and how they all connect.</p>
      </header>

      <div class="intro-section">
        <p>
          For millennia, cultures around the world have developed sophisticated systems for understanding
          human nature through cosmic patterns. Our framework doesn't replace these traditions — it
          reveals the shared structure they all point toward.
        </p>
        <p>
          Explore how your existing knowledge of any tradition enhances your understanding of
          your energy profile, and how our system adds precision to ancient wisdom.
        </p>
      </div>

      <div class="traditions-grid">
        {TRADITIONS.map((tradition) => (
          <a href={`/traditions/${tradition.slug}`} class="tradition-card">
            <div class="card-symbol">{tradition.symbol}</div>
            <div class="card-content">
              <span class="native-name">{tradition.nativeName}</span>
              <h2>{tradition.name}</h2>
              <p class="card-description">{tradition.description}</p>
              <span class="card-highlight">{tradition.highlight}</span>
            </div>
          </a>
        ))}
      </div>

      <section class="philosophy-section">
        <h2>One Pattern, Many Languages</h2>
        <div class="philosophy-content">
          <p>
            Our energy profile system is not competing with ancient wisdom.
            It's a way to make explicit what traditions around the world
            have always known: human nature follows cosmic patterns.
          </p>
          <p>
            Whether you work with the Five Elements, the Navagraha, the Tzolk'in, or
            the Western zodiac, you're working with the same underlying reality. The 8 energy
            dimensions provide a bridge that connects them all.
          </p>
        </div>
      </section>

      <section class="cta-section">
        <h3>See Your Pattern</h3>
        <p>No matter which system you know, your energy pattern is uniquely yours.</p>
        <a href="/discover" class="cta-btn">Discover Your Pattern</a>
      </section>
    </div>
  </div>
</BaseLayout>

<style>
  .traditions-page {
    --gold: #d4a854;
    --dark: #0a0908;
    --dark-surface: #141210;
    --text: #f0e8d8;
    --text-muted: rgba(240, 232, 216, 0.6);

    font-family: 'Cormorant Garamond', Georgia, serif;
    background: var(--dark);
    color: var(--text);
    min-height: 100vh;
    padding: 6rem 2rem 4rem;
  }

  .page-container {
    max-width: 900px;
    margin: 0 auto;
  }

  .page-header {
    text-align: center;
    margin-bottom: 2rem;
  }

  .page-header h1 {
    font-size: 2.5rem;
    font-weight: 300;
    color: var(--text);
    margin-bottom: 0.75rem;
  }

  .subtitle {
    font-size: 1.1rem;
    color: var(--text-muted);
    max-width: 600px;
    margin: 0 auto;
  }

  .intro-section {
    text-align: center;
    margin-bottom: 3rem;
    padding: 2rem;
    background: rgba(212, 168, 84, 0.05);
    border-left: 4px solid var(--gold);
  }

  .intro-section p {
    font-size: 1.05rem;
    color: var(--text-muted);
    line-height: 1.7;
    margin-bottom: 1rem;
  }

  .intro-section p:last-child {
    margin-bottom: 0;
  }

  .traditions-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 1.25rem;
    margin-bottom: 3rem;
  }

  .tradition-card {
    display: flex;
    gap: 1.25rem;
    padding: 1.5rem;
    background: var(--dark-surface);
    border: 1px solid rgba(212, 168, 84, 0.15);
    text-decoration: none;
    transition: all 0.3s;
  }

  .tradition-card:hover {
    border-color: var(--gold);
    transform: translateY(-2px);
    box-shadow: 0 4px 20px rgba(212, 168, 84, 0.15);
  }

  .card-symbol {
    flex-shrink: 0;
    font-size: 2rem;
    width: 56px;
    height: 56px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(212, 168, 84, 0.1);
    border-radius: 50%;
  }

  .card-content {
    flex: 1;
    min-width: 0;
  }

  .native-name {
    display: block;
    font-size: 0.9rem;
    color: var(--gold);
    margin-bottom: 0.25rem;
  }

  .card-content h2 {
    font-size: 1.25rem;
    font-weight: 500;
    color: var(--text);
    margin-bottom: 0.5rem;
  }

  .card-description {
    font-size: 0.9rem;
    color: var(--text-muted);
    line-height: 1.5;
    margin-bottom: 0.75rem;
  }

  .card-highlight {
    display: inline-block;
    font-size: 0.75rem;
    color: var(--gold);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding: 0.25rem 0.5rem;
    background: rgba(212, 168, 84, 0.1);
  }

  .philosophy-section {
    margin-bottom: 3rem;
    text-align: center;
  }

  .philosophy-section h2 {
    font-size: 1.5rem;
    font-weight: 400;
    color: var(--gold);
    margin-bottom: 1.25rem;
  }

  .philosophy-content p {
    font-size: 1.05rem;
    color: var(--text-muted);
    line-height: 1.8;
    margin-bottom: 1rem;
    max-width: 700px;
    margin-left: auto;
    margin-right: auto;
  }

  .cta-section {
    text-align: center;
    padding: 2.5rem;
    background: var(--dark-surface);
    border: 1px solid rgba(212, 168, 84, 0.2);
  }

  .cta-section h3 {
    font-size: 1.5rem;
    font-weight: 400;
    color: var(--text);
    margin-bottom: 0.75rem;
  }

  .cta-section p {
    font-size: 1rem;
    color: var(--text-muted);
    margin-bottom: 1.5rem;
    max-width: 500px;
    margin-left: auto;
    margin-right: auto;
  }

  .cta-btn {
    display: inline-block;
    padding: 0.875rem 1.5rem;
    background: var(--gold);
    color: var(--dark);
    text-decoration: none;
    font-weight: 500;
    transition: all 0.2s;
  }

  .cta-btn:hover {
    background: #e5b964;
    box-shadow: 0 0 20px rgba(212, 168, 84, 0.3);
  }
</style>
