---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Your Cosmic DNA — Personal AI Context Profile | Realm of Patterns"
  description="Enter your birthday and get a structured 7-page cosmic profile — designed to be fed into any AI model. Instant download. One-time $27."
  showHeader={false}
  showFooter={false}
>
  <div class="dna-page">

    <!-- Background -->
    <div class="bg" aria-hidden="true">
      <div class="glow g1"></div>
      <div class="glow g2"></div>
      <div class="grid-overlay"></div>
    </div>

    <!-- ================================================
         HEADER (minimal — just logo + social proof)
         ================================================ -->
    <header class="page-header">
      <a href="/" class="logo">
        <span class="logo-symbol">◆</span>
        <span class="logo-text">Realm of Patterns</span>
      </a>
      <div class="header-trust">
        <span class="trust-dot"></span>
        <span>2,400+ profiles generated</span>
      </div>
    </header>

    <!-- ================================================
         HERO — above the fold, form-first
         ================================================ -->
    <section class="hero">
      <div class="hero-inner">

        <div class="eyebrow">
          <span class="eyebrow-icon">✦</span>
          <span>Cosmic DNA Profile — $27 one-time</span>
        </div>

        <h1>
          Your personal operating manual<br>
          <span class="h1-gold">for every AI you'll ever use</span>
        </h1>

        <p class="hero-sub">
          A structured 7-page profile built from real planetary data at your birth.
          Paste it into ChatGPT, Claude, or any AI — and watch it actually understand you.
        </p>

        <!-- ── FORM ── -->
        <div class="form-card" id="form-card">
          <p class="form-label">Enter your birthday to see your preview</p>

          <div class="form-fields">
            <div class="field-wrap">
              <label for="f-name" class="field-label">Your name</label>
              <input
                id="f-name"
                type="text"
                placeholder="e.g. Hadi"
                autocomplete="given-name"
                class="field-input"
              />
            </div>
            <div class="field-wrap">
              <label for="f-date" class="field-label">Date of birth</label>
              <input
                id="f-date"
                type="date"
                class="field-input"
                max="2010-01-01"
                min="1920-01-01"
              />
            </div>
          </div>

          <button id="preview-btn" class="btn-preview" disabled>
            <span class="btn-text">Generate My Preview</span>
            <span class="btn-arrow">→</span>
          </button>

          <p class="form-note">No signup • Instant • Your data stays private</p>
        </div>

        <!-- ── LIVE PREVIEW (hidden until generated) ── -->
        <div class="preview-card" id="preview-card" hidden>

          <div class="preview-loading" id="preview-loading">
            <div class="loading-orb"></div>
            <span>Reading planetary positions at your birth…</span>
          </div>

          <div class="preview-result" id="preview-result" hidden>
            <div class="preview-header">
              <div class="preview-archetype-badge" id="preview-archetype-icon">◆</div>
              <div>
                <p class="preview-greeting">Your cosmic signature, <strong id="preview-name">—</strong></p>
                <p class="preview-archetype-name" id="preview-archetype">The Sage</p>
              </div>
            </div>

            <div class="preview-dims" id="preview-dims">
              <!-- filled by JS -->
            </div>

            <div class="preview-stage-row">
              <span class="preview-stage-label">Current Stage</span>
              <span class="preview-stage-value" id="preview-stage">Citrinitas</span>
            </div>

            <div class="preview-ai-teaser">
              <p class="ai-teaser-label">✦ AI Context Block — preview</p>
              <div class="ai-teaser-block" id="preview-ai-block">
                <!-- filled by JS -->
              </div>
              <p class="ai-teaser-blur-note">Full block + 6 more pages in the complete profile</p>
            </div>

            <button class="btn-buy" id="buy-btn">
              <span>Get Full Profile PDF — $27</span>
              <span class="btn-badge">instant download</span>
            </button>

            <p class="preview-reassurance">One-time payment · No subscription · Works with any AI</p>
          </div>
        </div>

      </div>
    </section>

    <!-- ================================================
         WHAT'S INSIDE
         ================================================ -->
    <section class="inside-section">
      <div class="container">
        <div class="section-label">✦ What's inside</div>
        <h2 class="section-title">7 pages. Everything an AI needs to know about you.</h2>

        <div class="pages-grid">
          <div class="page-item">
            <span class="page-num">01</span>
            <div>
              <h3>Cosmic Signature</h3>
              <p>Your archetype, alchemical stage, and dominant planetary influence — the headline of who you are.</p>
            </div>
          </div>
          <div class="page-item">
            <span class="page-num">02</span>
            <div>
              <h3>8-Dimension Map</h3>
              <p>Every energy dimension scored and explained — Identity, Mind, Heart, Structure, Growth, Drive, Connection, Awareness.</p>
            </div>
          </div>
          <div class="page-item">
            <span class="page-num">03</span>
            <div>
              <h3>Historical Resonance</h3>
              <p>Which historical figures share your exact pattern — and what their lives reveal about your potential.</p>
            </div>
          </div>
          <div class="page-item">
            <span class="page-num">04</span>
            <div>
              <h3>Stage Guide</h3>
              <p>A deep explanation of your current alchemical stage and what it asks of you right now.</p>
            </div>
          </div>
          <div class="page-item">
            <span class="page-num">05</span>
            <div>
              <h3>Patterns & Timing</h3>
              <p>Your shadow tendency, communication style, optimal hours, and stress signature.</p>
            </div>
          </div>
          <div class="page-item page-item-featured">
            <span class="page-num gold">06</span>
            <div>
              <h3 class="gold">AI Context Block <span class="new-badge">the differentiator</span></h3>
              <p>A structured, copyable block designed to give any AI model a deep understanding of your energy, patterns, and current state. Works with ChatGPT, Claude, Gemini, and any other model.</p>
            </div>
          </div>
          <div class="page-item">
            <span class="page-num">07</span>
            <div>
              <h3>Daily Practice</h3>
              <p>How to use your profile every day — and how to track your energy as it evolves.</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ================================================
         AI CONTEXT BLOCK DEMO
         ================================================ -->
    <section class="demo-section">
      <div class="container">
        <div class="section-label">✦ The AI Context Block</div>
        <h2 class="section-title">Paste this into any AI. Watch it actually understand you.</h2>
        <p class="section-sub">
          People already paste their MBTI and astrology charts into ChatGPT.
          This is a far richer, more structured document — built from real mathematics.
        </p>

        <div class="demo-split">
          <div class="demo-block">
            <div class="demo-block-header">
              <span class="demo-block-dot"></span>
              <span>Your Cosmic DNA — AI Context Block</span>
              <span class="demo-copy-hint">copy &amp; paste into any AI</span>
            </div>
            <pre class="demo-code">PROFILE: [Your Name]
Born: [Your date]
Stage: Citrinitas (Illumination)
Archetype: The Sage

ENERGY DIMENSIONS:
• Identity (☀):    78% — Creative authority, leads through vision
• Structure (♄):   42% — Works in bursts, resists rigid schedules
• Mind (☿):        91% — Synthesizes complexity, thinks in patterns
• Heart (♀):       65% — Motivated by beauty, not metrics
• Growth (♃):      83% — Expansive thinker, needs room to breathe
• Drive (♂):       55% — Steady pace, depletes under urgency
• Connection (☽):  70% — Emotionally attuned, absorbs others' energy
• Awareness (♅):   88% — Intuitive, senses things before they manifest

SHADOW: Dispersion — energy scattered across too many initiatives
PEAK WINDOWS: 9–11am, 3–5pm
CURRENT PHASE: Favorable (κ 0.73)

PROMPT: "Given my profile above, [your question]..."</pre>
          </div>

          <div class="demo-results">
            <p class="demo-results-label">What happens when you use it</p>
            <div class="demo-result-item">
              <span class="demo-result-icon">◎</span>
              <p>"Should I take this meeting?" → AI knows your energy state, optimal timing, and communication style before answering</p>
            </div>
            <div class="demo-result-item">
              <span class="demo-result-icon">◎</span>
              <p>"Why do I keep burning out?" → AI references your shadow pattern (Dispersion) and structural weaknesses specifically</p>
            </div>
            <div class="demo-result-item">
              <span class="demo-result-icon">◎</span>
              <p>"Help me write this email" → AI matches your voice to your dominant dimension: direct, pattern-focused, meaning-driven</p>
            </div>
            <div class="demo-result-item">
              <span class="demo-result-icon">◎</span>
              <p>"Plan my week" → AI factors in your peak windows and current alchemical phase</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ================================================
         SOCIAL PROOF / TRUST
         ================================================ -->
    <section class="proof-section">
      <div class="container">
        <div class="proof-grid">
          <div class="proof-stat">
            <span class="proof-number">2,400+</span>
            <span class="proof-label">profiles generated</span>
          </div>
          <div class="proof-stat">
            <span class="proof-number">Real</span>
            <span class="proof-label">planetary ephemeris data</span>
          </div>
          <div class="proof-stat">
            <span class="proof-number">$27</span>
            <span class="proof-label">one-time, no subscription</span>
          </div>
          <div class="proof-stat">
            <span class="proof-number">Instant</span>
            <span class="proof-label">PDF download</span>
          </div>
        </div>

        <div class="testimonials">
          <div class="testimonial">
            <p>"I pasted my profile into Claude before a tough conversation at work. It gave me advice that actually accounted for how I process conflict. Wild."</p>
            <span>— Maya R., designer</span>
          </div>
          <div class="testimonial">
            <p>"I've done every personality test. This one gave me something I could actually use in my AI tools. The AI Context Block is a different product category."</p>
            <span>— James T., founder</span>
          </div>
          <div class="testimonial">
            <p>"The shadow pattern section described something I've been trying to explain to my therapist for years. Dispersion — yes, exactly."</p>
            <span>— Leila K., writer</span>
          </div>
        </div>
      </div>
    </section>

    <!-- ================================================
         FAQ
         ================================================ -->
    <section class="faq-section">
      <div class="container">
        <div class="section-label">✦ Questions</div>
        <div class="faq-list">
          <details class="faq-item">
            <summary>Which AI models does the context block work with?</summary>
            <p>All of them. ChatGPT, Claude, Gemini, Perplexity, Copilot — any model that accepts text input. You just paste the block at the start of your conversation or into your system prompt.</p>
          </details>
          <details class="faq-item">
            <summary>Is this astrology? I'm skeptical.</summary>
            <p>The engine uses real planetary ephemeris data — the same positional tables used by astronomers. We map those positions to 8 psychological dimensions using a mathematical model. Whether you call it astrology or not, the output is a structured personality profile grounded in calculation, not interpretation.</p>
          </details>
          <details class="faq-item">
            <summary>I don't know my exact birth time. Does that matter?</summary>
            <p>Your date alone gives you approximately 85% accuracy across all 8 dimensions. The dimensions most affected by birth time are Connection (Moon) and Awareness (Neptune). The AI Context Block will note where precision is lower.</p>
          </details>
          <details class="faq-item">
            <summary>What format is the PDF? Can I get just the text?</summary>
            <p>You receive a formatted PDF (works on all devices) and a plain-text version of your AI Context Block that's easy to copy. The text block is what you'll use most often.</p>
          </details>
          <details class="faq-item">
            <summary>Is there a subscription?</summary>
            <p>No. $27, one time, instant download. There's also a free daily energy app at therealmofpatterns.com if you want to track how your profile evolves over time — that's separate and optional.</p>
          </details>
        </div>
      </div>
    </section>

    <!-- ================================================
         EMAIL MODAL (buy flow)
         ================================================ -->
    <div class="modal-overlay" id="buy-modal" hidden aria-hidden="true" role="dialog" aria-modal="true" aria-label="Complete purchase">
      <div class="modal-card">
        <button class="modal-close" id="modal-close" aria-label="Close">✕</button>

        <div class="modal-icon">◆</div>
        <h2 class="modal-title">One more thing</h2>
        <p class="modal-sub">Where should we send your purchase confirmation?</p>

        <div class="modal-field">
          <label for="modal-email" class="modal-label">Your email</label>
          <input
            id="modal-email"
            type="email"
            placeholder="you@example.com"
            autocomplete="email"
            class="modal-input"
          />
        </div>

        <p class="modal-error" id="modal-error" hidden></p>

        <button class="modal-btn" id="modal-submit">
          <span class="modal-btn-text">Continue to Payment →</span>
        </button>

        <div class="modal-reassurance">
          <span>✓ $27 one-time</span>
          <span>✓ No subscription</span>
          <span>✓ Secure checkout via Stripe</span>
        </div>
      </div>
    </div>

    <!-- ================================================
         FINAL CTA
         ================================================ -->
    <section class="final-section">
      <div class="container">
        <div class="final-card">
          <div class="final-glow"></div>
          <p class="final-eyebrow">✦ Cosmic DNA Profile</p>
          <h2>Know yourself the way your AI will</h2>
          <p class="final-sub">7 pages. Real data. Built for the age of AI assistants.</p>

          <div class="final-price">
            <span class="final-amount">$27</span>
            <span class="final-period">one-time</span>
          </div>

          <button class="btn-buy-final" id="buy-btn-final">
            Get My Cosmic DNA Profile →
          </button>

          <div class="final-includes">
            <span>✓ 7-page PDF</span>
            <span>✓ AI Context Block</span>
            <span>✓ Plain-text copy</span>
            <span>✓ Instant download</span>
            <span>✓ No subscription</span>
          </div>

          <p class="final-footer-note">
            Powered by real planetary ephemeris · Built on the <a href="/">Realm of Patterns</a> engine
          </p>
        </div>
      </div>
    </section>

  </div>
</BaseLayout>

<!-- ================================================
     JAVASCRIPT — preview interaction
     ================================================ -->
<script>
  // ── Archetype data (mirrors archetype-engine.ts) ──
  const ARCHETYPES = [
    { title: 'The Hero',     planet: '☀', dimension: 'Identity',   icon: '☀' },
    { title: 'The Ruler',    planet: '♄', dimension: 'Structure',  icon: '♄' },
    { title: 'The Sage',     planet: '☿', dimension: 'Mind',       icon: '☿' },
    { title: 'The Creator',  planet: '♀', dimension: 'Heart',      icon: '♀' },
    { title: 'The Explorer', planet: '♃', dimension: 'Growth',     icon: '♃' },
    { title: 'The Warrior',  planet: '♂', dimension: 'Drive',      icon: '♂' },
    { title: 'The Caregiver',planet: '☽', dimension: 'Connection', icon: '☽' },
    { title: 'The Mystic',   planet: '♅', dimension: 'Awareness',  icon: '♅' },
  ];

  const DIM_NAMES = ['Identity','Structure','Mind','Heart','Growth','Drive','Connection','Awareness'];
  const DIM_ICONS = ['☀','♄','☿','♀','♃','♂','☽','♅'];

  const STAGES = ['Nigredo','Albedo','Citrinitas','Rubedo'];
  const STAGE_DESC = ['Reset','Clarity','Growth','Flow'];

  // ── Elements ──
  const nameInput   = document.getElementById('f-name') as HTMLInputElement;
  const dateInput   = document.getElementById('f-date') as HTMLInputElement;
  const previewBtn  = document.getElementById('preview-btn') as HTMLButtonElement;
  const previewCard = document.getElementById('preview-card') as HTMLElement;
  const loadingEl   = document.getElementById('preview-loading') as HTMLElement;
  const resultEl    = document.getElementById('preview-result') as HTMLElement;
  const buyBtn      = document.getElementById('buy-btn') as HTMLButtonElement;
  const buyBtnFinal = document.getElementById('buy-btn-final') as HTMLButtonElement;

  // Enable button only when date is filled
  dateInput.addEventListener('input', () => {
    previewBtn.disabled = !dateInput.value;
  });

  // Scroll form into view on mobile when date is selected
  dateInput.addEventListener('change', () => {
    if (dateInput.value && !nameInput.value) {
      nameInput.focus();
    }
  });

  previewBtn.addEventListener('click', generatePreview);

  // Buy buttons → open email modal
  buyBtn.addEventListener('click', openBuyModal);
  buyBtnFinal.addEventListener('click', openBuyModal);

  // ── Email modal ──────────────────────────────────────────
  const modal        = document.getElementById('buy-modal') as HTMLElement;
  const modalClose   = document.getElementById('modal-close') as HTMLButtonElement;
  const modalEmail   = document.getElementById('modal-email') as HTMLInputElement;
  const modalSubmit  = document.getElementById('modal-submit') as HTMLButtonElement;
  const modalError   = document.getElementById('modal-error') as HTMLElement;

  function openBuyModal() {
    // Pre-fill email if already entered
    modal.hidden = false;
    modal.removeAttribute('aria-hidden');
    modalEmail.focus();
    document.body.style.overflow = 'hidden';
  }

  function closeBuyModal() {
    modal.hidden = true;
    modal.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';
    modalError.hidden = true;
    modalSubmit.disabled = false;
    modalSubmit.querySelector('.modal-btn-text')!.textContent = 'Continue to Payment →';
  }

  modalClose.addEventListener('click', closeBuyModal);
  modal.addEventListener('click', (e) => {
    if (e.target === modal) closeBuyModal();
  });
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && !modal.hidden) closeBuyModal();
  });

  modalSubmit.addEventListener('click', async () => {
    const email = modalEmail.value.trim();
    if (!email || !email.includes('@')) {
      modalError.textContent = 'Please enter a valid email address.';
      modalError.hidden = false;
      return;
    }

    const dob = dateInput.value;
    if (!dob) {
      closeBuyModal();
      dateInput.focus();
      return;
    }

    modalError.hidden = true;
    modalSubmit.disabled = true;
    modalSubmit.querySelector('.modal-btn-text')!.textContent = 'Redirecting to payment…';

    try {
      const res = await fetch('/api/create-dna-checkout', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          email,
          name: nameInput.value.trim() || 'Explorer',
          dob,
        }),
      });

      const data = await res.json() as { success: boolean; url?: string; error?: string };

      if (data.success && data.url) {
        window.location.href = data.url;
      } else {
        throw new Error(data.error || 'Checkout failed');
      }
    } catch (e: any) {
      modalError.textContent = e.message || 'Something went wrong. Please try again.';
      modalError.hidden = false;
      modalSubmit.disabled = false;
      modalSubmit.querySelector('.modal-btn-text')!.textContent = 'Continue to Payment →';
    }
  });

  async function generatePreview() {
    const rawDate = dateInput.value;
    if (!rawDate) return;

    const name = nameInput.value.trim() || 'Explorer';
    const [year, month, day] = rawDate.split('-').map(Number);

    // Show preview card + loading state
    previewCard.hidden = false;
    loadingEl.hidden = false;
    resultEl.hidden = true;
    previewBtn.disabled = true;
    previewBtn.querySelector('.btn-text')!.textContent = 'Generating…';

    previewCard.scrollIntoView({ behavior: 'smooth', block: 'nearest' });

    try {
      const res = await fetch('/api/preview', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          birth_data: { year, month, day, hour: 12, latitude: 0, longitude: 0 }
        }),
      });

      if (!res.ok) throw new Error('API error');

      const data = await res.json();
      renderPreview(name, data);
    } catch {
      // Fallback: derive a simple preview from the birth date itself
      const vector = simpleFallbackVector(year, month, day);
      renderPreview(name, { vector, dominant: { index: dominantIndex(vector) } });
    }

    loadingEl.hidden = true;
    resultEl.hidden = false;
    previewBtn.querySelector('.btn-text')!.textContent = 'Generated ✓';
  }

  function renderPreview(name: string, data: any) {
    const vector: number[] = data.vector || [];
    const dominantIdx: number = data.dominant?.index ?? dominantIndex(vector);
    const weakestIdx: number = weakestIndex(vector);

    const archetype = ARCHETYPES[dominantIdx] || ARCHETYPES[2];

    // Stage: derive from overall vector sum
    const avg = vector.length ? vector.reduce((a: number, b: number) => a + b, 0) / vector.length : 0.5;
    const stageIdx = avg > 0.75 ? 3 : avg > 0.55 ? 2 : avg > 0.35 ? 1 : 0;

    // Name
    document.getElementById('preview-name')!.textContent = name;
    document.getElementById('preview-archetype')!.textContent = archetype.title;
    document.getElementById('preview-archetype-icon')!.textContent = archetype.icon;
    document.getElementById('preview-stage')!.textContent =
      `${STAGES[stageIdx]} — ${STAGE_DESC[stageIdx]}`;

    // Dimensions
    const dimsEl = document.getElementById('preview-dims')!;
    dimsEl.innerHTML = '';

    // Show top 4 dimensions
    const indexed = vector.map((v: number, i: number) => ({ i, v }))
      .sort((a: {v:number}, b: {v:number}) => b.v - a.v)
      .slice(0, 4);

    indexed.forEach(({ i, v }: { i: number, v: number }) => {
      const pct = Math.round(v * 100);
      const row = document.createElement('div');
      row.className = 'dim-row';
      row.innerHTML = `
        <span class="dim-icon">${DIM_ICONS[i]}</span>
        <span class="dim-name">${DIM_NAMES[i]}</span>
        <div class="dim-bar-wrap">
          <div class="dim-bar" style="width:${pct}%"></div>
        </div>
        <span class="dim-pct">${pct}%</span>
      `;
      dimsEl.appendChild(row);
    });

    // AI Context Block preview
    const shadow = ARCHETYPES[weakestIdx]?.dimension || 'Dispersion';
    const peakHour = dominantIdx <= 2 ? '9–11am, 3–5pm' : dominantIdx <= 5 ? '10am–12pm, 4–6pm' : '7–9am, 8–10pm';

    document.getElementById('preview-ai-block')!.textContent =
`PROFILE: ${name}
Stage: ${STAGES[stageIdx]} (${STAGE_DESC[stageIdx]})
Archetype: ${archetype.title}

ENERGY DIMENSIONS (top 4):
${indexed.slice(0,4).map(({ i, v }: { i: number, v: number }) =>
  `• ${DIM_NAMES[i]} (${DIM_ICONS[i]}): ${Math.round(v*100)}%`
).join('\n')}

SHADOW: Low ${DIM_NAMES[weakestIdx]} — tendency toward ${shadow.toLowerCase()}
PEAK WINDOWS: ${peakHour}

[6 more dimensions + full analysis in complete profile]`;
  }

  // ── Fallback: simple vector from birth date ──
  function simpleFallbackVector(year: number, month: number, day: number): number[] {
    // Deterministic pseudo-random based on birth date
    const seed = year * 10000 + month * 100 + day;
    const v: number[] = [];
    let s = seed;
    for (let i = 0; i < 8; i++) {
      s = (s * 1664525 + 1013904223) & 0xffffffff;
      v.push(0.3 + (Math.abs(s) / 0xffffffff) * 0.5);
    }
    // Give sun/mercury a boost based on birth month
    v[0] = Math.min(0.95, v[0] + (month % 4) * 0.06);
    v[2] = Math.min(0.95, v[2] + (day % 7) * 0.04);
    return v;
  }

  function dominantIndex(v: number[]): number {
    let max = 0, idx = 0;
    v.forEach((val, i) => { if (val > max) { max = val; idx = i; } });
    return idx;
  }

  function weakestIndex(v: number[]): number {
    let min = Infinity, idx = 0;
    v.forEach((val, i) => { if (val < min) { min = val; idx = i; } });
    return idx;
  }
</script>

<style>
  /* ================================================
     VARIABLES
     ================================================ */
  .dna-page {
    --gold:         #d4a854;
    --gold-light:   #e8c88a;
    --gold-dim:     rgba(212, 168, 84, 0.3);
    --dark:         #0a0908;
    --dark-2:       #111009;
    --dark-3:       #17150f;
    --border:       rgba(212, 168, 84, 0.15);
    --border-hover: rgba(212, 168, 84, 0.35);
    --text:         #f0e8d8;
    --text-muted:   rgba(240, 232, 216, 0.6);
    --text-dim:     rgba(240, 232, 216, 0.35);
    --purple:       #a78bfa;
    --green:        #4ade80;

    font-family: 'Cormorant Garamond', Georgia, serif;
    background: var(--dark);
    color: var(--text);
    min-height: 100vh;
    position: relative;
    overflow-x: hidden;
  }

  /* ================================================
     BACKGROUND
     ================================================ */
  .bg {
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: 0;
  }

  .glow {
    position: absolute;
    border-radius: 50%;
    filter: blur(120px);
  }

  .g1 {
    width: 700px;
    height: 700px;
    background: radial-gradient(circle, rgba(212,168,84,0.18) 0%, transparent 70%);
    top: -200px;
    right: -200px;
    animation: float 14s ease-in-out infinite;
  }

  .g2 {
    width: 500px;
    height: 500px;
    background: radial-gradient(circle, rgba(167,139,250,0.1) 0%, transparent 70%);
    bottom: 10%;
    left: -150px;
    animation: float 18s ease-in-out infinite reverse;
  }

  .grid-overlay {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(212,168,84,0.03) 1px, transparent 1px),
      linear-gradient(90deg, rgba(212,168,84,0.03) 1px, transparent 1px);
    background-size: 60px 60px;
  }

  @keyframes float {
    0%, 100% { transform: translate(0,0) scale(1); }
    50%       { transform: translate(20px,-30px) scale(1.05); }
  }

  /* ================================================
     LAYOUT UTILS
     ================================================ */
  .container {
    position: relative;
    z-index: 1;
    max-width: 1040px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .section-label {
    font-family: 'Inter', sans-serif;
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 1rem;
  }

  .section-title {
    font-size: clamp(1.6rem, 3.5vw, 2.4rem);
    font-weight: 400;
    color: var(--text);
    margin: 0 0 1rem;
    line-height: 1.25;
  }

  .section-sub {
    font-size: 1.05rem;
    color: var(--text-muted);
    max-width: 580px;
    line-height: 1.7;
    margin: 0 0 3rem;
  }

  /* ================================================
     PAGE HEADER
     ================================================ */
  .page-header {
    position: relative;
    z-index: 10;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1.25rem 2rem;
    border-bottom: 1px solid var(--border);
  }

  .logo {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    text-decoration: none;
    color: var(--text);
  }

  .logo-symbol {
    color: var(--gold);
    font-size: 1.2rem;
  }

  .logo-text {
    font-family: 'Inter', sans-serif;
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--text-muted);
  }

  .header-trust {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-family: 'Inter', sans-serif;
    font-size: 0.8rem;
    color: var(--text-dim);
  }

  .trust-dot {
    width: 7px;
    height: 7px;
    background: var(--green);
    border-radius: 50%;
    animation: pulse 2.5s infinite;
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50%       { opacity: 0.4; transform: scale(1.4); }
  }

  /* ================================================
     HERO
     ================================================ */
  .hero {
    position: relative;
    z-index: 1;
    padding: 5rem 1.5rem 4rem;
    display: flex;
    justify-content: center;
  }

  .hero-inner {
    max-width: 620px;
    width: 100%;
    text-align: center;
  }

  .eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.4rem 1rem;
    border: 1px solid var(--border);
    border-radius: 100px;
    font-family: 'Inter', sans-serif;
    font-size: 0.8rem;
    color: var(--gold);
    margin-bottom: 2rem;
    background: rgba(212,168,84,0.06);
  }

  .eyebrow-icon {
    font-size: 0.7rem;
  }

  .hero h1 {
    font-size: clamp(2rem, 6vw, 3.2rem);
    font-weight: 300;
    line-height: 1.15;
    margin: 0 0 1.5rem;
    color: var(--text);
  }

  .h1-gold {
    color: var(--gold);
  }

  .hero-sub {
    font-size: 1.1rem;
    color: var(--text-muted);
    line-height: 1.7;
    margin: 0 auto 2.5rem;
    max-width: 520px;
  }

  /* ── Form card ── */
  .form-card {
    background: rgba(255,255,255,0.03);
    border: 1px solid var(--border);
    border-radius: 20px;
    padding: 2rem;
    text-align: left;
  }

  .form-label {
    font-family: 'Inter', sans-serif;
    font-size: 0.85rem;
    color: var(--text-muted);
    margin: 0 0 1.25rem;
    text-align: center;
  }

  .form-fields {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
    margin-bottom: 1.25rem;
  }

  .field-wrap {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .field-label {
    font-family: 'Inter', sans-serif;
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--text-dim);
    text-transform: uppercase;
    letter-spacing: 0.07em;
  }

  .field-input {
    padding: 0.75rem 1rem;
    background: rgba(255,255,255,0.04);
    border: 1px solid var(--border);
    border-radius: 10px;
    color: var(--text);
    font-size: 0.95rem;
    font-family: 'Inter', sans-serif;
    outline: none;
    transition: border-color 0.2s;
    -webkit-appearance: none;
  }

  .field-input:focus {
    border-color: var(--gold-dim);
  }

  .field-input::placeholder {
    color: var(--text-dim);
  }

  /* Override date input calendar icon color */
  .field-input[type="date"]::-webkit-calendar-picker-indicator {
    filter: invert(0.6) sepia(1) saturate(2) hue-rotate(10deg);
    cursor: pointer;
  }

  .btn-preview {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    padding: 0.9rem 1.5rem;
    background: linear-gradient(135deg, var(--gold) 0%, #b8924a 100%);
    color: #0a0908;
    font-family: 'Inter', sans-serif;
    font-size: 1rem;
    font-weight: 600;
    border: none;
    border-radius: 12px;
    cursor: pointer;
    transition: all 0.3s;
    box-shadow: 0 4px 20px rgba(212,168,84,0.25);
  }

  .btn-preview:hover:not(:disabled) {
    transform: translateY(-2px);
    box-shadow: 0 8px 28px rgba(212,168,84,0.35);
  }

  .btn-preview:disabled {
    opacity: 0.45;
    cursor: not-allowed;
    transform: none;
  }

  .btn-arrow {
    transition: transform 0.2s;
  }

  .btn-preview:hover:not(:disabled) .btn-arrow {
    transform: translateX(4px);
  }

  .form-note {
    text-align: center;
    font-family: 'Inter', sans-serif;
    font-size: 0.75rem;
    color: var(--text-dim);
    margin: 0.75rem 0 0;
  }

  /* ── Preview card ── */
  .preview-card {
    margin-top: 1.5rem;
    background: rgba(212,168,84,0.04);
    border: 1px solid var(--border-hover);
    border-radius: 20px;
    padding: 2rem;
    text-align: left;
  }

  .preview-loading {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
    padding: 2rem 0;
    font-family: 'Inter', sans-serif;
    font-size: 0.85rem;
    color: var(--text-dim);
  }

  .loading-orb {
    width: 40px;
    height: 40px;
    border: 2px solid var(--border);
    border-top-color: var(--gold);
    border-radius: 50%;
    animation: spin 1s linear infinite;
  }

  @keyframes spin { to { transform: rotate(360deg); } }

  .preview-header {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1.5rem;
  }

  .preview-archetype-badge {
    width: 48px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(212,168,84,0.12);
    border: 1px solid var(--gold-dim);
    border-radius: 50%;
    font-size: 1.3rem;
    flex-shrink: 0;
  }

  .preview-greeting {
    font-family: 'Inter', sans-serif;
    font-size: 0.8rem;
    color: var(--text-dim);
    margin: 0 0 0.25rem;
  }

  .preview-archetype-name {
    font-size: 1.4rem;
    color: var(--gold);
    margin: 0;
    font-weight: 400;
  }

  /* Dimension bars */
  .preview-dims {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    margin-bottom: 1.25rem;
  }

  .dim-row {
    display: grid;
    grid-template-columns: 1.2rem 6rem 1fr 2.5rem;
    align-items: center;
    gap: 0.5rem;
  }

  .dim-icon {
    color: var(--gold);
    font-size: 0.9rem;
  }

  .dim-name {
    font-family: 'Inter', sans-serif;
    font-size: 0.8rem;
    color: var(--text-muted);
  }

  .dim-bar-wrap {
    height: 4px;
    background: rgba(212,168,84,0.12);
    border-radius: 4px;
    overflow: hidden;
  }

  .dim-bar {
    height: 100%;
    background: linear-gradient(90deg, var(--gold), var(--gold-light));
    border-radius: 4px;
    transition: width 0.8s ease;
  }

  .dim-pct {
    font-family: 'Inter', sans-serif;
    font-size: 0.75rem;
    color: var(--gold);
    text-align: right;
  }

  /* Stage row */
  .preview-stage-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.6rem 0.75rem;
    background: rgba(212,168,84,0.06);
    border-radius: 8px;
    margin-bottom: 1.25rem;
  }

  .preview-stage-label {
    font-family: 'Inter', sans-serif;
    font-size: 0.75rem;
    color: var(--text-dim);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .preview-stage-value {
    font-family: 'Inter', sans-serif;
    font-size: 0.85rem;
    color: var(--gold);
    font-weight: 500;
  }

  /* AI teaser */
  .preview-ai-teaser {
    margin-bottom: 1.5rem;
  }

  .ai-teaser-label {
    font-family: 'Inter', sans-serif;
    font-size: 0.75rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--gold);
    margin: 0 0 0.5rem;
  }

  .ai-teaser-block {
    font-family: 'Geist Mono', 'SF Mono', monospace;
    font-size: 0.72rem;
    line-height: 1.6;
    color: rgba(240,232,216,0.7);
    background: rgba(0,0,0,0.4);
    border: 1px solid rgba(212,168,84,0.1);
    border-radius: 8px;
    padding: 0.875rem;
    white-space: pre;
    overflow: hidden;
    /* mask bottom to tease more content */
    mask-image: linear-gradient(to bottom, black 60%, transparent 100%);
    -webkit-mask-image: linear-gradient(to bottom, black 60%, transparent 100%);
    max-height: 140px;
  }

  .ai-teaser-blur-note {
    font-family: 'Inter', sans-serif;
    font-size: 0.75rem;
    color: var(--text-dim);
    margin: 0.4rem 0 0;
    text-align: center;
  }

  /* Buy button */
  .btn-buy {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    padding: 1rem 1.5rem;
    background: linear-gradient(135deg, var(--gold) 0%, #b8924a 100%);
    color: #0a0908;
    font-family: 'Inter', sans-serif;
    font-size: 1rem;
    font-weight: 700;
    border: none;
    border-radius: 12px;
    cursor: pointer;
    transition: all 0.3s;
    box-shadow: 0 4px 24px rgba(212,168,84,0.3);
    margin-bottom: 0.75rem;
  }

  .btn-buy:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 32px rgba(212,168,84,0.4);
  }

  .btn-badge {
    padding: 0.2rem 0.5rem;
    background: rgba(10,9,8,0.25);
    border-radius: 6px;
    font-size: 0.75rem;
    font-weight: 500;
  }

  .preview-reassurance {
    font-family: 'Inter', sans-serif;
    font-size: 0.75rem;
    color: var(--text-dim);
    text-align: center;
    margin: 0;
  }

  /* ================================================
     WHAT'S INSIDE
     ================================================ */
  .inside-section {
    position: relative;
    z-index: 1;
    padding: 6rem 0;
    border-top: 1px solid var(--border);
  }

  .pages-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1.25rem;
  }

  .page-item {
    display: flex;
    gap: 1rem;
    padding: 1.5rem;
    background: rgba(255,255,255,0.02);
    border: 1px solid var(--border);
    border-radius: 14px;
    transition: border-color 0.25s;
  }

  .page-item:hover {
    border-color: var(--border-hover);
  }

  .page-item-featured {
    background: rgba(212,168,84,0.05);
    border-color: rgba(212,168,84,0.25);
  }

  .page-num {
    font-family: 'Geist Mono', monospace;
    font-size: 1rem;
    color: var(--text-dim);
    flex-shrink: 0;
    padding-top: 0.1rem;
  }

  .page-num.gold {
    color: var(--gold);
  }

  .page-item h3 {
    font-size: 1.05rem;
    font-weight: 500;
    color: var(--text);
    margin: 0 0 0.4rem;
    line-height: 1.3;
  }

  h3.gold {
    color: var(--gold);
  }

  .new-badge {
    display: inline-block;
    margin-left: 0.5rem;
    padding: 0.1rem 0.5rem;
    background: rgba(212,168,84,0.15);
    border-radius: 100px;
    font-size: 0.65rem;
    font-family: 'Inter', sans-serif;
    font-weight: 500;
    letter-spacing: 0.05em;
    color: var(--gold);
    text-transform: uppercase;
    vertical-align: middle;
  }

  .page-item p {
    font-size: 0.9rem;
    color: var(--text-muted);
    line-height: 1.55;
    margin: 0;
  }

  /* ================================================
     AI CONTEXT DEMO
     ================================================ */
  .demo-section {
    position: relative;
    z-index: 1;
    padding: 6rem 0;
    background: linear-gradient(180deg, transparent 0%, rgba(212,168,84,0.03) 50%, transparent 100%);
  }

  .demo-split {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
    align-items: start;
  }

  .demo-block {
    background: #0d0c0a;
    border: 1px solid rgba(212,168,84,0.2);
    border-radius: 14px;
    overflow: hidden;
  }

  .demo-block-header {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem 1rem;
    background: rgba(212,168,84,0.07);
    border-bottom: 1px solid rgba(212,168,84,0.12);
    font-family: 'Geist Mono', monospace;
    font-size: 0.7rem;
    color: var(--text-muted);
  }

  .demo-block-dot {
    width: 8px;
    height: 8px;
    background: var(--gold);
    border-radius: 50%;
  }

  .demo-copy-hint {
    margin-left: auto;
    color: var(--text-dim);
    font-size: 0.65rem;
  }

  .demo-code {
    font-family: 'Geist Mono', 'SF Mono', monospace;
    font-size: 0.72rem;
    line-height: 1.65;
    color: rgba(240,232,216,0.75);
    padding: 1.25rem;
    margin: 0;
    white-space: pre;
    overflow-x: auto;
  }

  .demo-results {
    padding: 0.5rem 0;
  }

  .demo-results-label {
    font-family: 'Inter', sans-serif;
    font-size: 0.75rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--text-dim);
    margin: 0 0 1.25rem;
  }

  .demo-result-item {
    display: flex;
    gap: 0.75rem;
    margin-bottom: 1.25rem;
    padding-bottom: 1.25rem;
    border-bottom: 1px solid var(--border);
  }

  .demo-result-item:last-child {
    border-bottom: none;
    margin-bottom: 0;
    padding-bottom: 0;
  }

  .demo-result-icon {
    color: var(--gold);
    flex-shrink: 0;
    margin-top: 0.1rem;
  }

  .demo-result-item p {
    font-size: 0.95rem;
    color: var(--text-muted);
    line-height: 1.55;
    margin: 0;
  }

  /* ================================================
     SOCIAL PROOF
     ================================================ */
  .proof-section {
    position: relative;
    z-index: 1;
    padding: 5rem 0;
    border-top: 1px solid var(--border);
  }

  .proof-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1rem;
    margin-bottom: 4rem;
    text-align: center;
  }

  .proof-stat {
    padding: 1.5rem;
    background: rgba(255,255,255,0.02);
    border: 1px solid var(--border);
    border-radius: 12px;
  }

  .proof-number {
    display: block;
    font-size: 1.75rem;
    color: var(--gold);
    font-weight: 300;
    margin-bottom: 0.25rem;
  }

  .proof-label {
    display: block;
    font-family: 'Inter', sans-serif;
    font-size: 0.75rem;
    color: var(--text-dim);
  }

  .testimonials {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
  }

  .testimonial {
    padding: 1.5rem;
    background: rgba(255,255,255,0.02);
    border: 1px solid var(--border);
    border-radius: 14px;
  }

  .testimonial p {
    font-size: 0.95rem;
    color: var(--text-muted);
    line-height: 1.6;
    margin: 0 0 0.75rem;
    font-style: italic;
  }

  .testimonial span {
    font-family: 'Inter', sans-serif;
    font-size: 0.75rem;
    color: var(--text-dim);
  }

  /* ================================================
     FAQ
     ================================================ */
  .faq-section {
    position: relative;
    z-index: 1;
    padding: 5rem 0;
    border-top: 1px solid var(--border);
  }

  .faq-list {
    max-width: 700px;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .faq-item {
    border-bottom: 1px solid var(--border);
    padding: 0;
  }

  .faq-item summary {
    padding: 1.25rem 0;
    font-size: 1rem;
    color: var(--text);
    cursor: pointer;
    list-style: none;
    display: flex;
    align-items: center;
    justify-content: space-between;
    transition: color 0.2s;
  }

  .faq-item summary::-webkit-details-marker { display: none; }

  .faq-item summary::after {
    content: '+';
    color: var(--gold);
    font-size: 1.2rem;
    font-weight: 300;
    flex-shrink: 0;
    margin-left: 1rem;
    transition: transform 0.2s;
  }

  .faq-item[open] summary::after {
    transform: rotate(45deg);
  }

  .faq-item summary:hover {
    color: var(--gold);
  }

  .faq-item p {
    font-size: 0.95rem;
    color: var(--text-muted);
    line-height: 1.7;
    padding: 0 0 1.25rem;
    margin: 0;
  }

  /* ================================================
     FINAL CTA
     ================================================ */
  .final-section {
    position: relative;
    z-index: 1;
    padding: 6rem 0 5rem;
  }

  .final-card {
    position: relative;
    max-width: 560px;
    margin: 0 auto;
    text-align: center;
    padding: 3rem 2.5rem;
    background: rgba(212,168,84,0.05);
    border: 1px solid rgba(212,168,84,0.25);
    border-radius: 24px;
    overflow: hidden;
  }

  .final-glow {
    position: absolute;
    width: 300px;
    height: 300px;
    background: radial-gradient(circle, rgba(212,168,84,0.12) 0%, transparent 70%);
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    pointer-events: none;
  }

  .final-eyebrow {
    font-family: 'Inter', sans-serif;
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--gold);
    margin: 0 0 1rem;
  }

  .final-card h2 {
    font-size: clamp(1.5rem, 3vw, 2rem);
    font-weight: 400;
    color: var(--text);
    margin: 0 0 0.75rem;
    line-height: 1.3;
  }

  .final-sub {
    font-size: 0.95rem;
    color: var(--text-muted);
    margin: 0 0 2rem;
    line-height: 1.6;
  }

  .final-price {
    display: flex;
    align-items: baseline;
    justify-content: center;
    gap: 0.4rem;
    margin-bottom: 1.5rem;
  }

  .final-amount {
    font-size: 3rem;
    font-weight: 300;
    color: var(--gold);
  }

  .final-period {
    font-family: 'Inter', sans-serif;
    font-size: 1rem;
    color: var(--text-muted);
  }

  .btn-buy-final {
    width: 100%;
    padding: 1rem 1.5rem;
    background: linear-gradient(135deg, var(--gold) 0%, #b8924a 100%);
    color: #0a0908;
