---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Admin Dashboard - The Realm of Patterns" description="Administrative dashboard for managing The Realm of Patterns.">
  <div class="admin-page">
    <!-- Auth Gate -->
    <div class="auth-gate" id="authGate">
      <div class="auth-box">
        <h2>Admin Access Required</h2>
        <p>Enter admin credentials to continue.</p>
        <form id="authForm">
          <input type="password" id="adminKey" placeholder="Admin Key" required />
          <button type="submit">Access Dashboard</button>
        </form>
        <p class="auth-error" id="authError"></p>
      </div>
    </div>

    <!-- Dashboard Content -->
    <div class="dashboard" id="dashboard" style="display: none;">
      <header class="dash-header">
        <h1>Admin Dashboard</h1>
        <div class="header-actions">
          <span class="last-updated" id="lastUpdated">Last updated: -</span>
          <button class="refresh-btn" id="refreshBtn">Refresh</button>
          <button class="logout-btn" id="logoutBtn">Logout</button>
        </div>
      </header>

      <!-- KPI Cards -->
      <section class="kpi-grid">
        <div class="kpi-card">
          <div class="kpi-label">Total Users</div>
          <div class="kpi-value" id="totalUsers">-</div>
          <div class="kpi-change positive" id="usersChange">-</div>
        </div>
        <div class="kpi-card">
          <div class="kpi-label">Active Today</div>
          <div class="kpi-value" id="activeToday">-</div>
          <div class="kpi-change" id="activeChange">-</div>
        </div>
        <div class="kpi-card">
          <div class="kpi-label">Check-ins Today</div>
          <div class="kpi-value" id="checkinsToday">-</div>
          <div class="kpi-change" id="checkinsChange">-</div>
        </div>
        <div class="kpi-card">
          <div class="kpi-label">Conversion Rate</div>
          <div class="kpi-value" id="conversionRate">-</div>
          <div class="kpi-change" id="conversionChange">-</div>
        </div>
      </section>

      <!-- Subscription Breakdown -->
      <section class="dash-section">
        <h2>Subscription Tiers</h2>
        <div class="tier-grid">
          <div class="tier-card">
            <div class="tier-name">Witness (Free)</div>
            <div class="tier-count" id="witnessCount">-</div>
            <div class="tier-bar">
              <div class="bar-fill witness" id="witnessBar"></div>
            </div>
          </div>
          <div class="tier-card">
            <div class="tier-name">Pattern-Keeper ($19/mo)</div>
            <div class="tier-count" id="keeperCount">-</div>
            <div class="tier-bar">
              <div class="bar-fill keeper" id="keeperBar"></div>
            </div>
          </div>
          <div class="tier-card">
            <div class="tier-name">Circle ($49/seat/mo)</div>
            <div class="tier-count" id="circleCount">-</div>
            <div class="tier-bar">
              <div class="bar-fill circle" id="circleBar"></div>
            </div>
          </div>
        </div>
        <div class="revenue-summary">
          <div class="revenue-item">
            <span class="rev-label">MRR</span>
            <span class="rev-value" id="mrr">$0</span>
          </div>
          <div class="revenue-item">
            <span class="rev-label">ARR</span>
            <span class="rev-value" id="arr">$0</span>
          </div>
        </div>
      </section>

      <!-- Mode Distribution -->
      <section class="dash-section">
        <h2>Mode Preferences</h2>
        <div class="mode-grid">
          <div class="mode-card">
            <div class="mode-icon kasra">K</div>
            <div class="mode-info">
              <div class="mode-name">Kasra</div>
              <div class="mode-percent" id="kasraPercent">-</div>
            </div>
          </div>
          <div class="mode-card">
            <div class="mode-icon river">R</div>
            <div class="mode-info">
              <div class="mode-name">River</div>
              <div class="mode-percent" id="riverPercent">-</div>
            </div>
          </div>
          <div class="mode-card">
            <div class="mode-icon sol">S</div>
            <div class="mode-info">
              <div class="mode-name">Sol</div>
              <div class="mode-percent" id="solPercent">-</div>
            </div>
          </div>
        </div>
      </section>

      <!-- Check-in Trends -->
      <section class="dash-section">
        <h2>Check-in Trends (7 Days)</h2>
        <div class="chart-container">
          <div class="simple-chart" id="checkinChart">
            <!-- Generated by JS -->
          </div>
          <div class="chart-labels" id="chartLabels"></div>
        </div>
        <div class="trend-stats">
          <div class="stat">
            <span class="stat-label">Avg per day</span>
            <span class="stat-value" id="avgCheckins">-</span>
          </div>
          <div class="stat">
            <span class="stat-label">Peak hour</span>
            <span class="stat-value" id="peakHour">-</span>
          </div>
          <div class="stat">
            <span class="stat-label">Completion rate</span>
            <span class="stat-value" id="completionRate">-</span>
          </div>
        </div>
      </section>

      <!-- Recent Activity -->
      <section class="dash-section">
        <h2>Recent Activity</h2>
        <div class="activity-list" id="activityList">
          <!-- Generated by JS -->
        </div>
      </section>

      <!-- System Health -->
      <section class="dash-section">
        <h2>System Health</h2>
        <div class="health-grid">
          <div class="health-item">
            <span class="health-dot green"></span>
            <span class="health-label">API</span>
            <span class="health-status">Operational</span>
          </div>
          <div class="health-item">
            <span class="health-dot green"></span>
            <span class="health-label">Database</span>
            <span class="health-status">Operational</span>
          </div>
          <div class="health-item">
            <span class="health-dot green"></span>
            <span class="health-label">Stripe</span>
            <span class="health-status">Connected</span>
          </div>
          <div class="health-item">
            <span class="health-dot green"></span>
            <span class="health-label">CDN</span>
            <span class="health-status">Operational</span>
          </div>
        </div>
      </section>

      <!-- Quick Actions -->
      <section class="dash-section">
        <h2>Quick Actions</h2>
        <div class="actions-grid">
          <button class="action-btn" id="exportUsersBtn">
            <span class="action-icon">↓</span>
            Export Users
          </button>
          <button class="action-btn" id="clearCacheBtn">
            <span class="action-icon">↻</span>
            Clear Cache
          </button>
          <button class="action-btn" id="sendBroadcastBtn">
            <span class="action-icon">✉</span>
            Send Broadcast
          </button>
          <a href="/admin/users" class="action-btn">
            <span class="action-icon">◎</span>
            Manage Users
          </a>
        </div>
      </section>
    </div>
  </div>
</BaseLayout>

<script>
  // Simple admin key check (in production, use proper auth)
  const ADMIN_KEY_HASH = 'admin123'; // Replace with actual hashed key

  function checkAuth(): boolean {
    const storedKey = sessionStorage.getItem('admin_auth');
    return storedKey === ADMIN_KEY_HASH;
  }

  function showDashboard() {
    document.getElementById('authGate')!.style.display = 'none';
    document.getElementById('dashboard')!.style.display = 'block';
    loadDashboardData();
  }

  // Auth form
  document.getElementById('authForm')?.addEventListener('submit', (e) => {
    e.preventDefault();
    const key = (document.getElementById('adminKey') as HTMLInputElement).value;

    if (key === ADMIN_KEY_HASH) {
      sessionStorage.setItem('admin_auth', ADMIN_KEY_HASH);
      showDashboard();
    } else {
      document.getElementById('authError')!.textContent = 'Invalid admin key';
    }
  });

  // Logout
  document.getElementById('logoutBtn')?.addEventListener('click', () => {
    sessionStorage.removeItem('admin_auth');
    window.location.reload();
  });

  // Load dashboard data
  function loadDashboardData() {
    // In production, fetch from API
    // For now, generate sample data

    const data = generateSampleData();

    // KPI cards
    document.getElementById('totalUsers')!.textContent = data.totalUsers.toLocaleString();
    document.getElementById('usersChange')!.textContent = `+${data.newUsersToday} today`;
    document.getElementById('activeToday')!.textContent = data.activeToday.toLocaleString();
    document.getElementById('activeChange')!.textContent = `${data.activePercent}% of total`;
    document.getElementById('checkinsToday')!.textContent = data.checkinsToday.toLocaleString();
    document.getElementById('checkinsChange')!.textContent = `${data.checkinsVsYesterday > 0 ? '+' : ''}${data.checkinsVsYesterday}% vs yesterday`;
    document.getElementById('conversionRate')!.textContent = `${data.conversionRate}%`;
    document.getElementById('conversionChange')!.textContent = `${data.conversionChange > 0 ? '+' : ''}${data.conversionChange}% this month`;

    // Tier breakdown
    const total = data.tiers.witness + data.tiers.keeper + data.tiers.circle;
    document.getElementById('witnessCount')!.textContent = data.tiers.witness.toLocaleString();
    document.getElementById('keeperCount')!.textContent = data.tiers.keeper.toLocaleString();
    document.getElementById('circleCount')!.textContent = data.tiers.circle.toLocaleString();
    (document.getElementById('witnessBar') as HTMLElement).style.width = `${(data.tiers.witness / total) * 100}%`;
    (document.getElementById('keeperBar') as HTMLElement).style.width = `${(data.tiers.keeper / total) * 100}%`;
    (document.getElementById('circleBar') as HTMLElement).style.width = `${(data.tiers.circle / total) * 100}%`;

    // Revenue
    const mrr = (data.tiers.keeper * 19) + (data.tiers.circle * 49 * 3); // Assume avg 3 seats
    document.getElementById('mrr')!.textContent = `$${mrr.toLocaleString()}`;
    document.getElementById('arr')!.textContent = `$${(mrr * 12).toLocaleString()}`;

    // Mode distribution
    document.getElementById('kasraPercent')!.textContent = `${data.modes.kasra}%`;
    document.getElementById('riverPercent')!.textContent = `${data.modes.river}%`;
    document.getElementById('solPercent')!.textContent = `${data.modes.sol}%`;

    // Check-in chart
    renderChart(data.checkinsWeek);

    // Trend stats
    document.getElementById('avgCheckins')!.textContent = Math.round(data.checkinsWeek.reduce((a, b) => a + b, 0) / 7).toString();
    document.getElementById('peakHour')!.textContent = '9-10 AM';
    document.getElementById('completionRate')!.textContent = '87%';

    // Activity list
    renderActivityList(data.recentActivity);

    // Last updated
    document.getElementById('lastUpdated')!.textContent = `Last updated: ${new Date().toLocaleTimeString()}`;
  }

  function generateSampleData() {
    return {
      totalUsers: 2847,
      newUsersToday: 23,
      activeToday: 412,
      activePercent: 14.5,
      checkinsToday: 387,
      checkinsVsYesterday: 12,
      conversionRate: 4.2,
      conversionChange: 0.3,
      tiers: {
        witness: 2527,
        keeper: 284,
        circle: 36,
      },
      modes: {
        kasra: 22,
        river: 51,
        sol: 27,
      },
      checkinsWeek: [312, 287, 345, 298, 356, 401, 387],
      recentActivity: [
        { type: 'signup', user: 'user_2847', time: '2 min ago' },
        { type: 'upgrade', user: 'user_2831', tier: 'keeper', time: '15 min ago' },
        { type: 'checkin', user: 'user_2799', time: '18 min ago' },
        { type: 'signup', user: 'user_2846', time: '23 min ago' },
        { type: 'milestone', user: 'user_2654', milestone: 'first-streak', time: '31 min ago' },
        { type: 'checkin', user: 'user_2812', time: '35 min ago' },
        { type: 'upgrade', user: 'user_2789', tier: 'circle', time: '1 hour ago' },
      ],
    };
  }

  function renderChart(data: number[]) {
    const container = document.getElementById('checkinChart')!;
    const labels = document.getElementById('chartLabels')!;
    const max = Math.max(...data);
    const days = ['Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat', 'Sun'];
    const today = new Date().getDay();

    container.innerHTML = data.map((val, i) => {
      const height = (val / max) * 100;
      const isToday = i === (today === 0 ? 6 : today - 1);
      return `<div class="chart-bar ${isToday ? 'today' : ''}" style="height: ${height}%">
        <span class="bar-value">${val}</span>
      </div>`;
    }).join('');

    labels.innerHTML = days.map((d, i) => {
      const isToday = i === (today === 0 ? 6 : today - 1);
      return `<span class="${isToday ? 'today' : ''}">${d}</span>`;
    }).join('');
  }

  function renderActivityList(activities: { type: string; user: string; time: string; tier?: string; milestone?: string }[]) {
    const container = document.getElementById('activityList')!;

    const icons: Record<string, string> = {
      signup: '◎',
      upgrade: '★',
      checkin: '✓',
      milestone: '◆',
    };

    const labels: Record<string, (a: typeof activities[0]) => string> = {
      signup: () => 'New user signed up',
      upgrade: (a) => `Upgraded to ${a.tier}`,
      checkin: () => 'Completed check-in',
      milestone: (a) => `Unlocked ${a.milestone}`,
    };

    container.innerHTML = activities.map(a => `
      <div class="activity-item">
        <span class="activity-icon ${a.type}">${icons[a.type]}</span>
        <span class="activity-user">${a.user}</span>
        <span class="activity-label">${labels[a.type](a)}</span>
        <span class="activity-time">${a.time}</span>
      </div>
    `).join('');
  }

  // Refresh
  document.getElementById('refreshBtn')?.addEventListener('click', () => {
    loadDashboardData();
  });

  // Quick actions
  document.getElementById('exportUsersBtn')?.addEventListener('click', () => {
    alert('Exporting users... (In production, this would download a CSV)');
  });

  document.getElementById('clearCacheBtn')?.addEventListener('click', () => {
    localStorage.clear();
    sessionStorage.setItem('admin_auth', ADMIN_KEY_HASH);
    alert('Cache cleared!');
  });

  document.getElementById('sendBroadcastBtn')?.addEventListener('click', () => {
    const message = prompt('Enter broadcast message:');
    if (message) {
      alert(`Broadcast sent: "${message}" (In production, this would send to all users)`);
    }
  });

  // Initialize
  if (checkAuth()) {
    showDashboard();
  }
</script>

<style>
  .admin-page {
    --gold: #d4a854;
    --dark: #0a0908;
    --dark-surface: #141210;
    --text: #f0e8d8;
    --text-muted: rgba(240, 232, 216, 0.6);
    --green: #22c55e;
    --yellow: #eab308;
    --red: #ef4444;

    font-family: 'Inter', -apple-system, sans-serif;
    background: var(--dark);
    color: var(--text);
    min-height: 100vh;
    padding: 2rem;
  }

  /* Auth Gate */
  .auth-gate {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: calc(100vh - 4rem);
  }

  .auth-box {
    background: var(--dark-surface);
    border: 1px solid rgba(212, 168, 84, 0.2);
    padding: 2rem;
    width: 100%;
    max-width: 360px;
    text-align: center;
  }

  .auth-box h2 {
    font-size: 1.25rem;
    color: var(--gold);
    margin-bottom: 0.5rem;
  }

  .auth-box p {
    font-size: 0.9rem;
    color: var(--text-muted);
    margin-bottom: 1.5rem;
  }

  #authForm {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  #authForm input {
    padding: 0.75rem;
    background: var(--dark);
    border: 1px solid rgba(212, 168, 84, 0.2);
    color: var(--text);
    font-size: 0.95rem;
    text-align: center;
  }

  #authForm button {
    padding: 0.75rem;
    background: var(--gold);
    color: var(--dark);
    border: none;
    font-weight: 500;
    cursor: pointer;
    transition: background 0.2s;
  }

  #authForm button:hover {
    background: #e5b964;
  }

  .auth-error {
    color: var(--red);
    font-size: 0.85rem;
    margin-top: 0.5rem;
  }

  /* Dashboard */
  .dashboard {
    max-width: 1200px;
    margin: 0 auto;
  }

  .dash-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 2rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid rgba(212, 168, 84, 0.2);
  }

  .dash-header h1 {
    font-size: 1.5rem;
    font-weight: 500;
    color: var(--text);
  }

  .header-actions {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .last-updated {
    font-size: 0.8rem;
    color: var(--text-muted);
  }

  .refresh-btn, .logout-btn {
    padding: 0.5rem 1rem;
    background: transparent;
    border: 1px solid rgba(212, 168, 84, 0.3);
    color: var(--text);
    font-size: 0.85rem;
    cursor: pointer;
    transition: all 0.2s;
  }

  .refresh-btn:hover, .logout-btn:hover {
    border-color: var(--gold);
    color: var(--gold);
  }

  /* KPI Grid */
  .kpi-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 1rem;
    margin-bottom: 2rem;
  }

  .kpi-card {
    background: var(--dark-surface);
    border: 1px solid rgba(212, 168, 84, 0.15);
    padding: 1.25rem;
  }

  .kpi-label {
    font-size: 0.8rem;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 0.5rem;
  }

  .kpi-value {
    font-size: 2rem;
    font-weight: 300;
    color: var(--gold);
    margin-bottom: 0.25rem;
  }

  .kpi-change {
    font-size: 0.85rem;
    color: var(--text-muted);
  }

  .kpi-change.positive {
    color: var(--green);
  }

  /* Sections */
  .dash-section {
    background: var(--dark-surface);
    border: 1px solid rgba(212, 168, 84, 0.15);
    padding: 1.5rem;
    margin-bottom: 1.5rem;
  }

  .dash-section h2 {
    font-size: 1rem;
    font-weight: 500;
    color: var(--gold);
    margin-bottom: 1rem;
    padding-bottom: 0.75rem;
    border-bottom: 1px solid rgba(212, 168, 84, 0.1);
  }

  /* Tier Grid */
  .tier-grid {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    margin-bottom: 1.5rem;
  }

  .tier-card {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 0.5rem 1rem;
    align-items: center;
  }

  .tier-name {
    font-size: 0.9rem;
    color: var(--text);
  }

  .tier-count {
    font-size: 1.1rem;
    font-weight: 500;
    color: var(--gold);
    text-align: right;
  }

  .tier-bar {
    grid-column: 1 / -1;
    height: 6px;
    background: rgba(212, 168, 84, 0.1);
    overflow: hidden;
  }

  .bar-fill {
    height: 100%;
    transition: width 0.5s;
  }

  .bar-fill.witness { background: rgba(255, 255, 255, 0.3); }
  .bar-fill.keeper { background: var(--gold); }
  .bar-fill.circle { background: var(--green); }

  .revenue-summary {
    display: flex;
    gap: 2rem;
    padding-top: 1rem;
    border-top: 1px solid rgba(212, 168, 84, 0.1);
  }

  .revenue-item {
    display: flex;
    align-items: baseline;
    gap: 0.5rem;
  }

  .rev-label {
    font-size: 0.8rem;
    color: var(--text-muted);
  }

  .rev-value {
    font-size: 1.25rem;
    color: var(--green);
    font-weight: 500;
  }

  /* Mode Grid */
  .mode-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
  }

  .mode-card {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.75rem;
    background: rgba(212, 168, 84, 0.05);
  }

  .mode-icon {
    width: 40px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.1rem;
    font-weight: 600;
  }

  .mode-icon.kasra { background: #00ffff20; color: #00ffff; }
  .mode-icon.river { background: #9333ea20; color: #9333ea; }
  .mode-icon.sol { background: #f59e0b20; color: #f59e0b; }

  .mode-name {
    font-size: 0.9rem;
    color: var(--text);
  }

  .mode-percent {
    font-size: 1.1rem;
    font-weight: 500;
    color: var(--gold);
  }

  /* Chart */
  .chart-container {
    margin-bottom: 1rem;
  }

  .simple-chart {
    display: flex;
    align-items: flex-end;
    gap: 0.5rem;
    height: 120px;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid rgba(212, 168, 84, 0.1);
  }

  .chart-bar {
    flex: 1;
    background: rgba(212, 168, 84, 0.3);
    position: relative;
    min-height: 4px;
    transition: background 0.2s;
  }

  .chart-bar:hover {
    background: var(--gold);
  }

  .chart-bar.today {
    background: var(--gold);
  }

  .bar-value {
    position: absolute;
    top: -20px;
    left: 50%;
    transform: translateX(-50%);
    font-size: 0.7rem;
    color: var(--text-muted);
    opacity: 0;
    transition: opacity 0.2s;
  }

  .chart-bar:hover .bar-value {
    opacity: 1;
  }

  .chart-labels {
    display: flex;
    gap: 0.5rem;
    padding-top: 0.5rem;
  }

  .chart-labels span {
    flex: 1;
    text-align: center;
    font-size: 0.75rem;
    color: var(--text-muted);
  }

  .chart-labels span.today {
    color: var(--gold);
    font-weight: 500;
  }

  .trend-stats {
    display: flex;
    gap: 2rem;
  }

  .stat {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .stat-label {
    font-size: 0.75rem;
    color: var(--text-muted);
  }

  .stat-value {
    font-size: 1rem;
    color: var(--text);
  }

  /* Activity List */
  .activity-list {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    max-height: 300px;
    overflow-y: auto;
  }

  .activity-item {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.5rem;
    background: rgba(212, 168, 84, 0.03);
  }

  .activity-icon {
    width: 28px;
    height: 28px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.9rem;
  }

  .activity-icon.signup { color: var(--green); }
  .activity-icon.upgrade { color: var(--gold); }
  .activity-icon.checkin { color: var(--text-muted); }
  .activity-icon.milestone { color: #9333ea; }

  .activity-user {
    font-size: 0.85rem;
    color: var(--text);
    font-family: monospace;
    min-width: 80px;
  }

  .activity-label {
    flex: 1;
    font-size: 0.85rem;
    color: var(--text-muted);
  }

