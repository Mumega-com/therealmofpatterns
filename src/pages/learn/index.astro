---
import BaseLayout from '../../layouts/BaseLayout.astro';

// Static links for SEO crawling - all 8 dimensions × 6 languages
const dimensions = [
  { slug: 'phase', name: 'Phase', symbol: 'P', domain: 'Identity, Will' },
  { slug: 'existence', name: 'Existence', symbol: 'E', domain: 'Structure, Form' },
  { slug: 'cognition', name: 'Cognition', symbol: 'μ', domain: 'Mind, Communication' },
  { slug: 'value', name: 'Value', symbol: 'V', domain: 'Beauty, Harmony' },
  { slug: 'expansion', name: 'Expansion', symbol: 'N', domain: 'Growth, Meaning' },
  { slug: 'action', name: 'Action', symbol: 'Δ', domain: 'Force, Movement' },
  { slug: 'relation', name: 'Relation', symbol: 'R', domain: 'Connection, Care' },
  { slug: 'field', name: 'Field', symbol: 'Φ', domain: 'Unity, Witness' },
];

const figures = [
  { slug: 'jung', name: 'Carl Jung' },
  { slug: 'rumi', name: 'Rumi' },
  { slug: 'frida-kahlo', name: 'Frida Kahlo' },
  { slug: 'tesla', name: 'Nikola Tesla' },
  { slug: 'marcus-aurelius', name: 'Marcus Aurelius' },
];

const jungianConcepts = [
  { slug: 'shadow', name: 'The Shadow' },
  { slug: 'anima', name: 'Anima' },
  { slug: 'animus', name: 'Animus' },
  { slug: 'persona', name: 'Persona' },
  { slug: 'self', name: 'The Self' },
  { slug: 'individuation', name: 'Individuation' },
  { slug: 'archetype', name: 'Archetypes' },
  { slug: 'complex', name: 'Complexes' },
  { slug: 'projection', name: 'Projection' },
  { slug: 'synchronicity', name: 'Synchronicity' },
];

const languages = [
  { code: 'en', name: 'English' },
  { code: 'pt-br', name: 'Português (Brasil)' },
  { code: 'es-mx', name: 'Español (México)' },
  { code: 'es-ar', name: 'Español (Argentina)' },
  { code: 'es-es', name: 'Español (España)' },
  { code: 'pt-pt', name: 'Português (Portugal)' },
];
---

<BaseLayout
  title="Learn - Cosmic Identity Framework"
  description="Explore the 16D framework: dimension guides, historical figures, and Jungian concepts. Deep-dive into cosmic identity cartography."
>
  <main class="min-h-screen bg-gradient-to-b from-[#0a0908] to-[#1a1814] pt-20 pb-16">
    <div class="max-w-6xl mx-auto px-4">
      <!-- Hero -->
      <section class="text-center py-12">
        <h1 class="text-4xl md:text-5xl font-serif text-[#f0e8d8] mb-4">
          The <span class="text-[#d4a854]">Pattern</span> Library
        </h1>
        <p class="text-[#f0e8d8]/70 text-lg max-w-2xl mx-auto">
          Deep-dive into the 16D framework. Explore dimensions, discover historical cosmic signatures,
          and understand Jungian archetypes through the FRC lens.
        </p>
      </section>

      <!-- Dimensions Grid -->
      <section class="mb-16">
        <h2 class="text-2xl font-serif text-[#d4a854] mb-6 flex items-center gap-3">
          <span class="text-3xl">◎</span>
          The 8 Dimensions
        </h2>
        <p class="text-[#f0e8d8]/60 mb-6 max-w-2xl">
          Each dimension represents a fundamental aspect of consciousness. Your cosmic signature
          is a unique combination of all eight, shaped by planetary positions at birth.
        </p>

        <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4">
          {dimensions.map((dim) => (
            <a
              href={`/en/dimension/${dim.slug}`}
              class="group p-5 rounded-xl border border-[rgba(212,168,84,0.15)] bg-[rgba(26,24,20,0.5)] hover:border-[#d4a854] hover:bg-[rgba(212,168,84,0.05)] transition-all duration-300"
            >
              <div class="text-3xl text-[#d4a854] mb-2">{dim.symbol}</div>
              <h3 class="text-[#f0e8d8] font-serif text-lg mb-1 group-hover:text-[#d4a854] transition-colors">
                {dim.name}
              </h3>
              <p class="text-[#f0e8d8]/50 text-sm">{dim.domain}</p>
            </a>
          ))}
        </div>

        <!-- All language links for SEO -->
        <details class="mt-6">
          <summary class="text-[#d4a854]/60 text-sm cursor-pointer hover:text-[#d4a854]">
            View in other languages
          </summary>
          <div class="mt-4 grid sm:grid-cols-2 lg:grid-cols-3 gap-2 text-sm">
            {languages.filter(l => l.code !== 'en').map((lang) => (
              <div class="p-3 rounded-lg bg-[rgba(26,24,20,0.3)]">
                <span class="text-[#f0e8d8]/60">{lang.name}:</span>
                <div class="flex flex-wrap gap-2 mt-1">
                  {dimensions.map((dim) => (
                    <a
                      href={`/${lang.code}/dimension/${dim.slug}`}
                      class="text-[#d4a854]/70 hover:text-[#d4a854]"
                    >
                      {dim.symbol}
                    </a>
                  ))}
                </div>
              </div>
            ))}
          </div>
        </details>
      </section>

      <!-- Jungian Concepts -->
      <section class="mb-16">
        <h2 class="text-2xl font-serif text-[#d4a854] mb-6 flex items-center gap-3">
          <span class="text-3xl">◈</span>
          Jungian Concepts
        </h2>
        <p class="text-[#f0e8d8]/60 mb-6 max-w-2xl">
          Carl Jung's framework of archetypes and the collective unconscious maps naturally
          onto the 16D system. Explore how these concepts manifest in your cosmic signature.
        </p>

        <div class="grid sm:grid-cols-2 lg:grid-cols-5 gap-3">
          {jungianConcepts.map((concept) => (
            <a
              href={`/en/jungian/${concept.slug}`}
              class="p-4 rounded-lg border border-[rgba(212,168,84,0.1)] bg-[rgba(26,24,20,0.4)] hover:border-[#8b5cf6]/50 hover:bg-[rgba(139,92,246,0.05)] transition-all duration-300 text-center"
            >
              <span class="text-[#f0e8d8] text-sm">{concept.name}</span>
            </a>
          ))}
        </div>
      </section>

      <!-- Historical Figures -->
      <section class="mb-16">
        <h2 class="text-2xl font-serif text-[#d4a854] mb-6 flex items-center gap-3">
          <span class="text-3xl">☉</span>
          Historical Figures
        </h2>
        <p class="text-[#f0e8d8]/60 mb-6 max-w-2xl">
          Explore the cosmic signatures of notable figures throughout history.
          See how their 16D patterns shaped their contributions to humanity.
        </p>

        <div class="grid sm:grid-cols-2 lg:grid-cols-5 gap-3">
          {figures.map((figure) => (
            <a
              href={`/en/figure/${figure.slug}`}
              class="p-4 rounded-lg border border-[rgba(212,168,84,0.1)] bg-[rgba(26,24,20,0.4)] hover:border-[#fbbf24]/50 hover:bg-[rgba(251,191,36,0.05)] transition-all duration-300 text-center"
            >
              <span class="text-[#f0e8d8] text-sm">{figure.name}</span>
            </a>
          ))}
        </div>
      </section>

      <!-- Alchemical Stages -->
      <section class="mb-16">
        <h2 class="text-2xl font-serif text-[#d4a854] mb-6 flex items-center gap-3">
          <span class="text-3xl">⚗</span>
          Alchemical Stages
        </h2>
        <p class="text-[#f0e8d8]/60 mb-6 max-w-2xl">
          Your Kappa (κ) coefficient indicates which alchemical stage you're in.
          Each stage offers unique wisdom for the transformation process.
        </p>

        <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4">
          <a
            href="/stage/nigredo"
            class="p-5 rounded-xl border border-[rgba(99,102,241,0.2)] bg-gradient-to-br from-[#0a0a12] to-[#15152a] hover:border-[#6366f1] transition-all duration-300"
          >
            <div class="text-2xl mb-2">🌑</div>
            <h3 class="text-[#c0c0c0] font-serif text-lg">Nigredo</h3>
            <p class="text-[#f0e8d8]/40 text-sm">κ < 0.25</p>
            <p class="text-[#f0e8d8]/50 text-xs mt-2">The Dark Night</p>
          </a>

          <a
            href="/stage/albedo"
            class="p-5 rounded-xl border border-[rgba(192,192,192,0.2)] bg-gradient-to-br from-[#1a1a24] to-[#2a2a3e] hover:border-[#c0c0c0] transition-all duration-300"
          >
            <div class="text-2xl mb-2">🌓</div>
            <h3 class="text-[#c0c0c0] font-serif text-lg">Albedo</h3>
            <p class="text-[#f0e8d8]/40 text-sm">0.25 ≤ κ < 0.50</p>
            <p class="text-[#f0e8d8]/50 text-xs mt-2">The Purification</p>
          </a>

          <a
            href="/stage/citrinitas"
            class="p-5 rounded-xl border border-[rgba(251,191,36,0.2)] bg-gradient-to-br from-[#1a1810] to-[#2a2618] hover:border-[#fbbf24] transition-all duration-300"
          >
            <div class="text-2xl mb-2">🌕</div>
            <h3 class="text-[#fbbf24] font-serif text-lg">Citrinitas</h3>
            <p class="text-[#f0e8d8]/40 text-sm">0.50 ≤ κ < 0.75</p>
            <p class="text-[#f0e8d8]/50 text-xs mt-2">The Yellowing</p>
          </a>

          <a
            href="/stage/rubedo"
            class="p-5 rounded-xl border border-[rgba(239,68,68,0.2)] bg-gradient-to-br from-[#1a1012] to-[#2a1818] hover:border-[#ef4444] transition-all duration-300"
          >
            <div class="text-2xl mb-2">🔴</div>
            <h3 class="text-[#ef4444] font-serif text-lg">Rubedo</h3>
            <p class="text-[#f0e8d8]/40 text-sm">κ ≥ 0.75</p>
            <p class="text-[#f0e8d8]/50 text-xs mt-2">The Reddening</p>
          </a>
        </div>
      </section>

      <!-- CTA -->
      <section class="text-center py-12 border-t border-[rgba(212,168,84,0.1)]">
        <h2 class="text-2xl font-serif text-[#f0e8d8] mb-4">
          Ready to discover your own pattern?
        </h2>
        <p class="text-[#f0e8d8]/60 mb-6 max-w-lg mx-auto">
          Take a check-in to see how the 8 dimensions manifest in your life today.
        </p>
        <div class="flex gap-4 justify-center flex-wrap">
          <a
            href="/sol/checkin"
            class="px-6 py-3 bg-[#d4a854] text-[#0a0908] rounded-lg font-medium hover:bg-[#e5b964] transition-colors"
          >
            Start Check-in
          </a>
          <a
            href="/squad"
            class="px-6 py-3 border border-[#d4a854] text-[#d4a854] rounded-lg hover:bg-[rgba(212,168,84,0.1)] transition-colors"
          >
            Meet the Voices
          </a>
        </div>
      </section>
    </div>
  </main>
</BaseLayout>
