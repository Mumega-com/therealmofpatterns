---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Your Cosmic DNA Profile is Ready | Realm of Patterns"
  description="Your purchase is confirmed. Generating your personal AI context document."
  showHeader={false}
  showFooter={false}
>
  <div class="success-page">

    <div class="bg" aria-hidden="true">
      <div class="glow"></div>
    </div>

    <!-- STEP 1: Verifying payment -->
    <div class="step" id="step-verifying">
      <div class="spinner"></div>
      <h1>Verifying your payment…</h1>
      <p>Just a moment.</p>
    </div>

    <!-- STEP 2: Generating profile -->
    <div class="step" id="step-generating" hidden>
      <div class="orb-ring">
        <div class="orb-inner" id="archetype-icon">◆</div>
      </div>
      <h1>Generating your Cosmic DNA Profile…</h1>
      <p id="generating-sub">Computing 8 dimensions from planetary positions at your birth</p>
      <div class="progress-bar">
        <div class="progress-fill" id="progress-fill"></div>
      </div>
    </div>

    <!-- STEP 3: Ready — download -->
    <div class="step" id="step-ready" hidden>
      <div class="ready-icon">✦</div>
      <h1>Your profile is ready, <span id="ready-name">Explorer</span>.</h1>
      <p class="ready-sub">Download your PDF and paste your AI Context Block into any AI assistant.</p>

      <div class="profile-preview" id="profile-preview">
        <!-- filled by JS -->
      </div>

      <button class="btn-download" id="btn-download">
        <span>Download Your Cosmic DNA Profile PDF</span>
        <span class="dl-icon">↓</span>
      </button>

      <div class="ready-next">
        <p class="next-label">✦ What to do with it</p>
        <ol class="next-steps">
          <li>Open the PDF and find <strong>Page 5 — AI Context Block</strong></li>
          <li>Copy the block and paste it at the start of any ChatGPT or Claude conversation</li>
          <li>Ask anything — the AI now understands your energy, timing, and shadow patterns</li>
        </ol>
      </div>

      <div class="ready-links">
        <a href="/sol" class="ready-link">Track your daily energy free →</a>
        <a href="/dna" class="ready-link muted">Back to DNA page</a>
      </div>
    </div>

    <!-- STEP 4: Error -->
    <div class="step" id="step-error" hidden>
      <div class="error-icon">⚠</div>
      <h1>Something went wrong</h1>
      <p id="error-msg">We couldn't verify your payment. Please contact support.</p>
      <div class="error-actions">
        <a href="mailto:support@therealmofpatterns.com" class="btn-support">Contact Support</a>
        <a href="/dna" class="btn-back">Back to DNA Page</a>
      </div>
    </div>

  </div>
</BaseLayout>

<script>
  import { generateDnaPdf } from '../lib/dna-pdf-generator';

  // ── Archetype data ──────────────────────────────────────
  const ARCHETYPES = [
    { title: 'The Hero',      icon: '☀', shadow: 'Ego / hiding your light' },
    { title: 'The Ruler',     icon: '♄', shadow: 'Rigidity / control' },
    { title: 'The Sage',      icon: '☿', shadow: 'Overthinking / detachment' },
    { title: 'The Creator',   icon: '♀', shadow: 'People-pleasing / vanity' },
    { title: 'The Explorer',  icon: '♃', shadow: 'Restlessness / avoidance' },
    { title: 'The Warrior',   icon: '♂', shadow: 'Burnout / aggression' },
    { title: 'The Caregiver', icon: '☽', shadow: 'Martyrdom / boundary loss' },
    { title: 'The Mystic',    icon: '♅', shadow: 'Dissociation / escapism' },
  ];

  const DIM_NAMES = ['Identity','Structure','Mind','Heart','Growth','Drive','Connection','Awareness'];
  const DIM_ICONS = ['☀','♄','☿','♀','♃','♂','☽','♅'];
  const DIM_DESC = [
    'Self-expression, confidence, creative authority',
    'Discipline, stability, structure-building',
    'Communication, analysis, pattern recognition',
    'Beauty, harmony, emotional intelligence',
    'Expansion, meaning, philosophical depth',
    'Action, courage, decisive movement',
    'Empathy, relationships, deep connection',
    'Intuition, presence, field awareness',
  ];
  const STAGES = ['Nigredo','Albedo','Citrinitas','Rubedo'];
  const STAGE_SUB = ['Reset — dissolving the old','Clarity — seeing what is','Growth — stepping into power','Flow — everything integrating'];

  // ── Steps ───────────────────────────────────────────────
  function show(id: string) {
    ['step-verifying','step-generating','step-ready','step-error'].forEach(s => {
      const el = document.getElementById(s);
      if (el) el.hidden = s !== id;
    });
  }

  function setProgress(pct: number) {
    const bar = document.getElementById('progress-fill');
    if (bar) bar.style.width = `${pct}%`;
  }

  function setGeneratingSub(text: string) {
    const el = document.getElementById('generating-sub');
    if (el) el.textContent = text;
  }

  // ── Main flow ───────────────────────────────────────────
  const params = new URLSearchParams(window.location.search);
  const sessionId = params.get('session_id');

  if (!sessionId) {
    document.getElementById('error-msg')!.textContent = 'No session ID found. Please return to the DNA page.';
    show('step-error');
  } else {
    run(sessionId);
  }

  async function run(sid: string) {
    show('step-verifying');

    // 1. Verify payment
    let profile: { name: string; dob: string; email: string } | null = null;
    try {
      const res = await fetch(`/api/dna-verify?session_id=${encodeURIComponent(sid)}`);
      const data = await res.json() as { success: boolean; name?: string; dob?: string; email?: string; error?: string };
      if (!data.success) throw new Error(data.error || 'Verification failed');
      profile = { name: data.name || 'Explorer', dob: data.dob!, email: data.email || '' };
    } catch (e: any) {
      document.getElementById('error-msg')!.textContent = e.message || 'Payment verification failed. Please contact support.';
      show('step-error');
      return;
    }

    // 2. Generate profile
    show('step-generating');
    setProgress(10);

    const [year, month, day] = profile.dob.split('-').map(Number);

    setGeneratingSub('Calculating planetary positions at your birth…');
    setProgress(25);

    let vector: number[] = [];
    let dominantIdx = 2;

    try {
      const res = await fetch('/api/preview', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ birth_data: { year, month, day, hour: 12, latitude: 0, longitude: 0 } }),
      });
      if (res.ok) {
        const data = await res.json() as { vector?: number[]; dominant?: { index: number } };
        vector = data.vector || [];
        dominantIdx = data.dominant?.index ?? findDominant(vector);
      }
    } catch { /* use fallback */ }

    if (vector.length === 0) {
      vector = fallbackVector(year, month, day);
      dominantIdx = findDominant(vector);
    }

    setGeneratingSub('Mapping your 8 dimensions…');
    setProgress(55);

    await delay(600);

    setGeneratingSub('Building your AI Context Block…');
    setProgress(80);

    await delay(500);

    setProgress(100);
    await delay(300);

    // 3. Show ready state
    const archetype = ARCHETYPES[dominantIdx];
    document.getElementById('archetype-icon')!.textContent = archetype.icon;
    document.getElementById('ready-name')!.textContent = profile.name;

    renderProfilePreview(profile.name, vector, dominantIdx, year, month, day);

    show('step-ready');

    // Wire download button
    document.getElementById('btn-download')!.addEventListener('click', () => {
      generateAndDownload(profile!.name, profile!.dob, vector);
    });

    // Auto-trigger after 1 second
    setTimeout(() => generateAndDownload(profile!.name, profile!.dob, vector), 1000);
  }

  // ── Profile preview card ────────────────────────────────
  function renderProfilePreview(name: string, vector: number[], dominantIdx: number, year: number, month: number, day: number) {
    const weakestIdx = findWeakest(vector);
    const archetype = ARCHETYPES[dominantIdx];
    const avg = vector.reduce((a, b) => a + b, 0) / (vector.length || 1);
    const stageIdx = avg > 0.75 ? 3 : avg > 0.55 ? 2 : avg > 0.35 ? 1 : 0;

    const top4 = vector.map((v, i) => ({ i, v })).sort((a, b) => b.v - a.v).slice(0, 4);

    const el = document.getElementById('profile-preview')!;
    el.innerHTML = `
      <div class="pp-header">
        <span class="pp-icon">${archetype.icon}</span>
        <div>
          <p class="pp-name">${name}</p>
          <p class="pp-archetype">${archetype.title} · ${STAGES[stageIdx]}</p>
        </div>
      </div>
      <div class="pp-dims">
        ${top4.map(({ i, v }) => `
          <div class="pp-dim">
            <span class="pp-dim-icon">${DIM_ICONS[i]}</span>
            <span class="pp-dim-name">${DIM_NAMES[i]}</span>
            <div class="pp-dim-bar-wrap">
              <div class="pp-dim-bar" style="width:${Math.round(v*100)}%"></div>
            </div>
            <span class="pp-dim-pct">${Math.round(v*100)}%</span>
          </div>
        `).join('')}
      </div>
      <div class="pp-shadow">
        <span class="pp-shadow-label">Shadow pattern:</span>
        <span class="pp-shadow-val">${archetype.shadow}</span>
      </div>
    `;
  }

  // ── PDF generation ──────────────────────────────────────
  async function generateAndDownload(name: string, dob: string, vector: number[]) {
    const btn = document.getElementById('btn-download') as HTMLButtonElement;
    btn.textContent = 'Generating PDF…';
    btn.disabled = true;
    try {
      generateDnaPdf({ name, dob, vector });
      btn.textContent = 'Downloaded ✓  Generate again';
      btn.disabled = false;
    } catch (err) {
      console.error('PDF generation failed:', err);
      btn.textContent = 'Download failed — try again';
      btn.disabled = false;
    }
  }

  // ── Utils ────────────────────────────────────────────────
  function findDominant(v: number[]): number {
    let max = 0, idx = 0;
    v.forEach((val, i) => { if (val > max) { max = val; idx = i; } });
    return idx;
  }

  function findWeakest(v: number[]): number {
    let min = Infinity, idx = 0;
    v.forEach((val, i) => { if (val < min) { min = val; idx = i; } });
    return idx;
  }

  function fallbackVector(year: number, month: number, day: number): number[] {
    const seed = year * 10000 + month * 100 + day;
    let s = seed;
    return Array.from({ length: 8 }, () => {
      s = (s * 1664525 + 1013904223) & 0xffffffff;
      return 0.3 + (Math.abs(s) / 0xffffffff) * 0.5;
    });
  }

  function delay(ms: number): Promise<void> {
    return new Promise(resolve => setTimeout(resolve, ms));
  }
</script>

<style>
  .success-page {
    --gold:       #d4a854;
    --gold-dim:   rgba(212,168,84,0.25);
    --dark:       #0a0908;
    --border:     rgba(212,168,84,0.15);
    --text:       #f0e8d8;
    --text-muted: rgba(240,232,216,0.6);
    --text-dim:   rgba(240,232,216,0.35);
    --green:      #4ade80;

    font-family: 'Cormorant Garamond', Georgia, serif;
    background: var(--dark);
    color: var(--text);
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 2rem 1.5rem;
    position: relative;
    overflow: hidden;
  }

  .bg {
    position: fixed;
    inset: 0;
    pointer-events: none;
  }

  .glow {
    position: absolute;
    width: 600px;
    height: 600px;
    background: radial-gradient(circle, rgba(212,168,84,0.12) 0%, transparent 70%);
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    filter: blur(60px);
  }

  /* Steps */
  .step {
    position: relative;
    z-index: 1;
    max-width: 560px;
    width: 100%;
    text-align: center;
  }

  .step h1 {
    font-size: clamp(1.5rem, 4vw, 2rem);
    font-weight: 300;
    color: var(--text);
    margin: 1.5rem 0 0.75rem;
  }

  .step > p {
    font-size: 1rem;
    color: var(--text-muted);
    margin: 0;
  }

  /* Spinner */
  .spinner {
    width: 44px;
    height: 44px;
    border: 2px solid var(--border);
    border-top-color: var(--gold);
    border-radius: 50%;
    animation: spin 1s linear infinite;
    margin: 0 auto;
  }

  @keyframes spin { to { transform: rotate(360deg); } }

  /* Generating orb */
  .orb-ring {
    width: 72px;
    height: 72px;
    border: 2px solid var(--gold-dim);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto;
    animation: orbit 3s linear infinite;
  }

  @keyframes orbit {
    0%   { box-shadow: 0 0 0 0 rgba(212,168,84,0.3); }
    50%  { box-shadow: 0 0 30px 10px rgba(212,168,84,0.1); }
    100% { box-shadow: 0 0 0 0 rgba(212,168,84,0.3); }
  }

  .orb-inner {
    font-size: 1.8rem;
    color: var(--gold);
    animation: pulse-icon 2s ease-in-out infinite;
  }

  @keyframes pulse-icon {
    0%, 100% { opacity: 1; transform: scale(1); }
    50%       { opacity: 0.7; transform: scale(1.1); }
  }

  .progress-bar {
    height: 3px;
    background: var(--border);
    border-radius: 3px;
    margin: 1.5rem auto 0;
    max-width: 300px;
    overflow: hidden;
  }

  .progress-fill {
    height: 100%;
    background: linear-gradient(90deg, var(--gold), #e8c88a);
    border-radius: 3px;
    transition: width 0.5s ease;
    width: 0%;
  }

  /* Ready */
  .ready-icon {
    font-size: 2.5rem;
    color: var(--gold);
    animation: pulse-icon 2s ease-in-out infinite;
  }

  .ready-sub {
    font-size: 1rem;
    color: var(--text-muted);
    max-width: 440px;
    margin: 0 auto 1.5rem;
    line-height: 1.6;
  }

  /* Profile preview */
  .profile-preview {
    background: rgba(212,168,84,0.04);
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 1.25rem;
    margin-bottom: 1.5rem;
    text-align: left;
  }

  .pp-header {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 1rem;
    padding-bottom: 0.75rem;
    border-bottom: 1px solid var(--border);
  }

  .pp-icon {
    font-size: 1.5rem;
    color: var(--gold);
  }

  .pp-name {
    font-size: 1rem;
    color: var(--text);
    margin: 0 0 0.2rem;
    font-weight: 500;
  }

  .pp-archetype {
    font-family: 'Inter', sans-serif;
    font-size: 0.78rem;
    color: var(--gold);
    margin: 0;
  }

  .pp-dims {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    margin-bottom: 0.75rem;
  }

  .pp-dim {
    display: grid;
    grid-template-columns: 1.2rem 5.5rem 1fr 2.5rem;
    align-items: center;
    gap: 0.5rem;
  }

  .pp-dim-icon { color: var(--gold); font-size: 0.85rem; }

  .pp-dim-name {
    font-family: 'Inter', sans-serif;
    font-size: 0.78rem;
    color: var(--text-muted);
  }

  .pp-dim-bar-wrap {
    height: 3px;
    background: rgba(212,168,84,0.1);
    border-radius: 3px;
    overflow: hidden;
  }

  .pp-dim-bar {
    height: 100%;
    background: linear-gradient(90deg, var(--gold), #e8c88a);
    border-radius: 3px;
  }

  .pp-dim-pct {
    font-family: 'Inter', sans-serif;
    font-size: 0.72rem;
    color: var(--gold);
    text-align: right;
  }

  .pp-shadow {
    font-family: 'Inter', sans-serif;
    font-size: 0.75rem;
    color: var(--text-dim);
    display: flex;
    gap: 0.4rem;
  }

  .pp-shadow-label { color: rgba(200,100,100,0.7); }
  .pp-shadow-val   { color: var(--text-dim); }

  /* Download button */
  .btn-download {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    width: 100%;
    padding: 1rem 1.5rem;
    background: linear-gradient(135deg, var(--gold) 0%, #b8924a 100%);
    color: #0a0908;
    font-family: 'Inter', sans-serif;
    font-size: 1rem;
    font-weight: 700;
    border: none;
    border-radius: 12px;
    cursor: pointer;
    transition: all 0.3s;
    box-shadow: 0 4px 24px rgba(212,168,84,0.3);
    margin-bottom: 2rem;
  }

  .btn-download:hover:not(:disabled) {
    transform: translateY(-2px);
    box-shadow: 0 8px 32px rgba(212,168,84,0.4);
  }

  .btn-download:disabled {
    opacity: 0.6;
    cursor: wait;
  }

  .dl-icon { font-size: 1.2rem; }

  /* Next steps */
  .ready-next {
    background: rgba(255,255,255,0.02);
    border: 1px solid var(--border);
    border-radius: 14px;
    padding: 1.25rem;
    margin-bottom: 1.5rem;
    text-align: left;
  }

  .next-label {
    font-family: 'Inter', sans-serif;
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--gold);
    margin: 0 0 0.75rem;
  }

  .next-steps {
    padding-left: 1.25rem;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .next-steps li {
    font-size: 0.9rem;
    color: var(--text-muted);
    line-height: 1.5;
  }

  .next-steps strong { color: var(--text); }

  .ready-links {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
  }

  .ready-link {
    font-family: 'Inter', sans-serif;
    font-size: 0.85rem;
    color: var(--gold);
    text-decoration: none;
    transition: opacity 0.2s;
  }

  .ready-link:hover { opacity: 0.75; }
  .ready-link.muted { color: var(--text-dim); }

  /* Error */
  .error-icon {
    font-size: 2.5rem;
    color: rgba(200, 100, 100, 0.8);
    margin-bottom: 0.5rem;
  }

  .error-actions {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
    margin-top: 1.5rem;
  }

  .btn-support {
    padding: 0.875rem 1.5rem;
    background: var(--gold);
    color: #0a0908;
    font-family: 'Inter', sans-serif;
    font-weight: 600;
    font-size: 0.95rem;
    text-decoration: none;
    border-radius: 10px;
    transition: all 0.3s;
  }

  .btn-support:hover { background: #e8c88a; }

  .btn-back {
    font-family: 'Inter', sans-serif;
    font-size: 0.85rem;
    color: var(--text-dim);
    text-decoration: none;
    transition: color 0.2s;
  }

  .btn-back:hover { color: var(--gold); }
</style>
