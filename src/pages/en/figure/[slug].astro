---
import BaseLayout from '../../../layouts/BaseLayout.astro';

// Historical figure data with energy profiles
const FIGURES: Record<string, {
  name: string;
  title: string;
  dates: string;
  birthDate: string;
  portrait: string;
  summary: string;
  biography: string;
  signature: {
    P: number;
    E: number;
    μ: number;
    V: number;
    N: number;
    Δ: number;
    R: number;
    Φ: number;
  };
  dominant: string;
  dominantSymbol: string;
  kappa: number;
  interpretation: string;
  legacy: string;
  quote: string;
}> = {
  jung: {
    name: 'Carl Gustav Jung',
    title: 'Psychiatrist & Analytical Psychologist',
    dates: '1875 - 1961',
    birthDate: 'July 26, 1875',
    portrait: '/assets/figures/jung.jpg',
    summary: 'Founder of analytical psychology, explorer of the collective unconscious and archetypes.',
    biography: 'Carl Jung was a Swiss psychiatrist who founded analytical psychology. His work has been influential in psychiatry, anthropology, archaeology, literature, philosophy, psychology, and religious studies. Jung created concepts including individuation, archetypes, the collective unconscious, and psychological types.',
    signature: { P: 0.72, E: 0.58, μ: 0.85, V: 0.45, N: 0.91, Δ: 0.38, R: 0.67, Φ: 0.95 },
    dominant: 'Awareness',
    dominantSymbol: 'Φ',
    kappa: 0.69,
    interpretation: 'Jung\'s energy profile reveals extraordinary Awareness activation—the witness consciousness that allowed him to perceive the collective unconscious. His high Growth drove the philosophical scope of his work, while strong Mind gave him the conceptual precision to map these inner territories. The relatively lower Drive reflects his contemplative rather than activist nature.',
    legacy: 'His framework of archetypes and the collective unconscious forms the conceptual foundation for the energy profile system itself.',
    quote: 'Who looks outside, dreams; who looks inside, awakes.'
  },
  rumi: {
    name: 'Jalal ad-Din Muhammad Rumi',
    title: 'Poet & Sufi Mystic',
    dates: '1207 - 1273',
    birthDate: 'September 30, 1207',
    portrait: '/assets/figures/rumi.jpg',
    summary: 'Persian poet and Sufi mystic whose poetry speaks of love, unity, and divine connection.',
    biography: 'Rumi was a 13th-century Persian poet, Islamic scholar, and Sufi mystic. His poetry transcends ethnic and geographical boundaries, speaking to the universal human longing for connection with the divine. His works have been translated into many languages and remain among the most widely read poems in history.',
    signature: { P: 0.55, E: 0.32, μ: 0.78, V: 0.92, N: 0.88, Δ: 0.41, R: 0.97, Φ: 0.99 },
    dominant: 'Awareness',
    dominantSymbol: 'Φ',
    kappa: 0.73,
    interpretation: 'Rumi\'s profile shows the highest possible Awareness and Connection activation—the mystic\'s capacity for divine union and universal love. His Heart dimension powered the aesthetic beauty of his poetry. Low Structure reflects his transcendence of material concerns, while moderate Identity shows ego dissolution in service of the beloved.',
    legacy: 'His poetry continues to guide seekers toward the direct experience of unity consciousness.',
    quote: 'You are not a drop in the ocean. You are the entire ocean in a drop.'
  },
  'frida-kahlo': {
    name: 'Frida Kahlo',
    title: 'Painter & Cultural Icon',
    dates: '1907 - 1954',
    birthDate: 'July 6, 1907',
    portrait: '/assets/figures/frida-kahlo.jpg',
    summary: 'Mexican artist known for vivid self-portraits expressing pain, passion, and Mexican identity.',
    biography: 'Frida Kahlo was a Mexican painter known for her many portraits, self-portraits, and works inspired by Mexican popular culture. She used a folk art style to explore questions of identity, postcolonialism, gender, class, and race. Her paintings often featured raw portrayals of pain and passion.',
    signature: { P: 0.89, E: 0.71, μ: 0.52, V: 0.94, N: 0.67, Δ: 0.78, R: 0.85, Φ: 0.61 },
    dominant: 'Heart',
    dominantSymbol: 'V',
    kappa: 0.75,
    interpretation: 'Kahlo\'s profile reveals exceptional Heart and Identity activation—the artist\'s eye combined with fierce individual identity. High Connection and Drive reflect her passionate engagement with life and love despite immense physical suffering. Her moderate Awareness suggests she channeled transcendent insight through embodied, visceral expression rather than abstract mysticism.',
    legacy: 'Her unapologetic self-portraiture opened doors for personal and political expression in art.',
    quote: 'I paint myself because I am so often alone and because I am the subject I know best.'
  },
  tesla: {
    name: 'Nikola Tesla',
    title: 'Inventor & Electrical Engineer',
    dates: '1856 - 1943',
    birthDate: 'July 10, 1856',
    portrait: '/assets/figures/tesla.jpg',
    summary: 'Visionary inventor of AC power, wireless transmission, and technologies ahead of his time.',
    biography: 'Nikola Tesla was a Serbian-American inventor, electrical engineer, and futurist. He is best known for his contributions to the design of the modern alternating current (AC) electrical system. His inventions include the Tesla coil, AC motor, and pioneering work in wireless communication.',
    signature: { P: 0.76, E: 0.88, μ: 0.95, V: 0.48, N: 0.82, Δ: 0.71, R: 0.35, Φ: 0.79 },
    dominant: 'Mind',
    dominantSymbol: 'μ',
    kappa: 0.72,
    interpretation: 'Tesla\'s profile shows exceptional Mind and Structure—the engineer\'s capacity to conceive and manifest revolutionary technology. His high Awareness enabled visualization of complete systems before building them. Low Connection and moderate Heart reflect his famous social isolation and single-minded focus on invention over aesthetics or relationships.',
    legacy: 'His inventions power the modern world, and his vision of wireless energy transmission continues to inspire.',
    quote: 'The present is theirs; the future, for which I really worked, is mine.'
  },
  'marcus-aurelius': {
    name: 'Marcus Aurelius',
    title: 'Roman Emperor & Stoic Philosopher',
    dates: '121 - 180 CE',
    birthDate: 'April 26, 121 CE',
    portrait: '/assets/figures/marcus-aurelius.jpg',
    summary: 'Last of the Five Good Emperors, author of Meditations on Stoic philosophy.',
    biography: 'Marcus Aurelius was Roman Emperor from 161 to 180 CE and a Stoic philosopher. He is considered the last of the Five Good Emperors. His personal writings, later published as Meditations, are considered one of the greatest works of philosophy, offering practical wisdom on virtue, duty, and self-mastery.',
    signature: { P: 0.81, E: 0.86, μ: 0.73, V: 0.52, N: 0.78, Δ: 0.65, R: 0.71, Φ: 0.84 },
    dominant: 'Structure',
    dominantSymbol: 'E',
    kappa: 0.74,
    interpretation: 'Aurelius shows strong Structure and Identity—the ruler\'s capacity to structure reality and maintain identity under pressure. High Awareness enabled his philosophical perspective on impermanence. Balanced dimensions reflect the Stoic ideal of measured response, while moderate Heart shows his famous indifference to luxury despite having access to every pleasure.',
    legacy: 'His Meditations remain a practical guide to equanimity and virtue in challenging times.',
    quote: 'Waste no more time arguing about what a good man should be. Be one.'
  }
};

export function getStaticPaths() {
  return [
    { params: { slug: 'jung' }, props: { slug: 'jung' } },
    { params: { slug: 'rumi' }, props: { slug: 'rumi' } },
    { params: { slug: 'frida-kahlo' }, props: { slug: 'frida-kahlo' } },
    { params: { slug: 'tesla' }, props: { slug: 'tesla' } },
    { params: { slug: 'marcus-aurelius' }, props: { slug: 'marcus-aurelius' } },
  ];
}

const { slug } = Astro.params;
const figure = FIGURES[slug];

if (!figure) {
  return Astro.redirect('/404');
}

const dimensions = ['P', 'E', 'μ', 'V', 'N', 'Δ', 'R', 'Φ'] as const;
const dimensionNames: Record<string, string> = {
  P: 'Identity',
  E: 'Structure',
  μ: 'Mind',
  V: 'Heart',
  N: 'Growth',
  Δ: 'Drive',
  R: 'Connection',
  Φ: 'Awareness'
};
---

<BaseLayout
  title={`${figure.name} - Energy Profile | The Realm of Patterns`}
  description={figure.summary}
>
  <main class="min-h-screen bg-gradient-to-b from-[#0a0908] to-[#1a1814]">
    <!-- Hero -->
    <section class="pt-24 pb-8 px-4">
      <div class="max-w-4xl mx-auto">
        <a href="/about" class="inline-block text-[#d4a854]/70 text-sm mb-6 hover:text-[#d4a854]">
          ← Back to About
        </a>

        <div class="flex flex-col md:flex-row gap-8 items-start">
          <!-- Portrait placeholder -->
          <div class="w-32 h-32 md:w-40 md:h-40 rounded-xl bg-gradient-to-br from-[rgba(251,191,36,0.2)] to-[rgba(212,168,84,0.05)] border border-[rgba(212,168,84,0.2)] flex items-center justify-center text-[#d4a854] text-4xl font-serif shrink-0">
            {figure.name.charAt(0)}
          </div>

          <div class="flex-1">
            <h1 class="text-3xl md:text-4xl font-serif text-[#f0e8d8] mb-2">
              {figure.name}
            </h1>
            <p class="text-[#d4a854] text-lg mb-2">{figure.title}</p>
            <p class="text-[#f0e8d8]/50 text-sm mb-4">{figure.dates}</p>
            <p class="text-[#f0e8d8]/70">
              {figure.summary}
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- Signature Overview -->
    <section class="py-8 px-4">
      <div class="max-w-4xl mx-auto">
        <div class="grid md:grid-cols-3 gap-4">
          <div class="p-4 rounded-xl bg-[rgba(251,191,36,0.05)] border border-[rgba(251,191,36,0.15)] text-center">
            <div class="text-3xl text-[#fbbf24] mb-1">{figure.dominantSymbol}</div>
            <div class="text-[#f0e8d8] font-medium">Dominant: {figure.dominant}</div>
          </div>
          <div class="p-4 rounded-xl bg-[rgba(212,168,84,0.05)] border border-[rgba(212,168,84,0.15)] text-center">
            <div class="text-2xl text-[#d4a854] mb-1 font-mono">{(figure.kappa * 100).toFixed(0)}% aligned</div>
            <div class="text-[#f0e8d8]/70 text-sm">Alignment Score</div>
          </div>
          <div class="p-4 rounded-xl bg-[rgba(139,92,246,0.05)] border border-[rgba(139,92,246,0.15)] text-center">
            <div class="text-[#8b5cf6] text-sm mb-1">Born</div>
            <div class="text-[#f0e8d8]">{figure.birthDate}</div>
          </div>
        </div>
      </div>
    </section>

    <!-- 8D Signature Visualization -->
    <section class="py-8 px-4">
      <div class="max-w-4xl mx-auto">
        <h2 class="text-xl font-serif text-[#d4a854] mb-6">Energy Profile</h2>

        <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
          {dimensions.map((dim) => {
            const value = figure.signature[dim];
            const isHigh = value > 0.7;
            const isDominant = dim === figure.dominantSymbol;
            return (
              <div class={`p-4 rounded-xl border ${isDominant ? 'bg-[rgba(251,191,36,0.1)] border-[#fbbf24]' : 'bg-[rgba(26,24,20,0.4)] border-[rgba(212,168,84,0.1)]'}`}>
                <div class="flex justify-between items-center mb-2">
                  <span class={`text-2xl ${isDominant ? 'text-[#fbbf24]' : 'text-[#d4a854]'}`}>{dim}</span>
                  <span class="text-[#f0e8d8] font-mono text-sm">{(value * 100).toFixed(0)}%</span>
                </div>
                <div class="h-2 bg-[rgba(212,168,84,0.1)] rounded-full overflow-hidden mb-2">
                  <div
                    class={`h-full rounded-full ${isDominant ? 'bg-[#fbbf24]' : 'bg-[#d4a854]'}`}
                    style={`width: ${value * 100}%`}
                  ></div>
                </div>
                <div class="text-[#f0e8d8]/50 text-xs">{dimensionNames[dim]}</div>
              </div>
            );
          })}
        </div>
      </div>
    </section>

    <!-- Interpretation -->
    <section class="py-8 px-4">
      <div class="max-w-3xl mx-auto">
        <h2 class="text-xl font-serif text-[#d4a854] mb-4">Signature Interpretation</h2>
        <p class="text-[#f0e8d8]/70 leading-relaxed mb-8">
          {figure.interpretation}
        </p>

        <!-- Quote -->
        <blockquote class="border-l-4 border-[#fbbf24] pl-6 py-2 mb-8">
          <p class="text-xl font-serif text-[#f0e8d8]/80 italic">
            "{figure.quote}"
          </p>
          <cite class="text-[#d4a854] text-sm mt-2 block not-italic">
            — {figure.name}
          </cite>
        </blockquote>
      </div>
    </section>

    <!-- Biography -->
    <section class="py-8 px-4">
      <div class="max-w-3xl mx-auto">
        <h2 class="text-xl font-serif text-[#d4a854] mb-4">Biography</h2>
        <p class="text-[#f0e8d8]/70 leading-relaxed">
          {figure.biography}
        </p>
      </div>
    </section>

    <!-- Legacy -->
    <section class="py-8 px-4 pb-16">
      <div class="max-w-3xl mx-auto">
        <div class="bg-[rgba(212,168,84,0.05)] border border-[rgba(212,168,84,0.15)] rounded-xl p-6">
          <h2 class="text-lg font-serif text-[#d4a854] mb-3">Legacy</h2>
          <p class="text-[#f0e8d8]/70">
            {figure.legacy}
          </p>
        </div>
      </div>
    </section>

    <!-- Other Figures -->
    <section class="py-8 px-4 border-t border-[rgba(212,168,84,0.1)]">
      <div class="max-w-4xl mx-auto">
        <h2 class="text-lg font-serif text-[#d4a854] mb-4 text-center">Explore Other Profiles</h2>
        <div class="flex flex-wrap justify-center gap-3">
          {Object.entries(FIGURES).filter(([key]) => key !== slug).map(([key, f]) => (
            <a
              href={`/en/figure/${key}`}
              class="px-4 py-2 text-sm text-[#f0e8d8]/70 border border-[rgba(251,191,36,0.2)] rounded-full hover:border-[#fbbf24] hover:text-[#fbbf24] transition-colors"
            >
              {f.dominantSymbol} {f.name.split(' ').slice(-1)[0]}
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="py-12 px-4 text-center">
      <h3 class="text-lg font-serif text-[#f0e8d8] mb-2">
        Discover your own energy profile
      </h3>
      <p class="text-[#f0e8d8]/60 text-sm mb-4 max-w-md mx-auto">
        Take a check-in to explore how your 8 energy dimensions show up in your life.
      </p>
      <a
        href="/sol/checkin"
        class="inline-block px-6 py-2 bg-[#d4a854] text-[#0a0908] rounded-lg font-medium hover:bg-[#e5b964] transition-colors"
      >
        Start Check-in
      </a>
    </section>
  </main>
</BaseLayout>
