---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Enterprise - The Realm of Patterns" description="Custom pattern intelligence solutions for large organizations. SSO, custom integrations, dedicated support.">
  <div class="enterprise-page">
    <div class="page-container">
      <!-- Hero -->
      <section class="hero">
        <div class="hero-badge">Enterprise Solutions</div>
        <h1>Pattern Intelligence at Scale</h1>
        <p class="hero-subtitle">
          Bring cosmic pattern awareness to your entire organization.
          Custom solutions for teams of 50+ practitioners.
        </p>
        <div class="hero-cta">
          <a href="mailto:enterprise@therealmofpatterns.com?subject=Enterprise%20Inquiry" class="primary-btn">
            Schedule a Demo
            <span class="arrow">→</span>
          </a>
          <a href="#features" class="secondary-btn">Learn More</a>
        </div>

        <div class="trusted-by">
          <span>Trusted by forward-thinking teams at</span>
          <div class="logos">
            <span class="logo-placeholder">[ Company 1 ]</span>
            <span class="logo-placeholder">[ Company 2 ]</span>
            <span class="logo-placeholder">[ Company 3 ]</span>
          </div>
        </div>
      </section>

      <!-- Use Cases -->
      <section class="use-cases" id="features">
        <h2>Built for Your Organization</h2>
        <div class="cases-grid">
          <div class="case-card">
            <div class="case-icon">◎</div>
            <h3>Executive Teams</h3>
            <p>
              Optimize leadership dynamics, find ideal meeting windows, and
              understand complementary strengths across your C-suite.
            </p>
          </div>
          <div class="case-card">
            <div class="case-icon">⬡</div>
            <h3>HR & People Ops</h3>
            <p>
              Enhance team formation, improve hiring synergy, and support
              employee wellbeing with pattern-aware scheduling.
            </p>
          </div>
          <div class="case-card">
            <div class="case-icon">◇</div>
            <h3>Coaching Practices</h3>
            <p>
              Scale your coaching with pattern insights. Track client progress,
              identify breakthroughs, and facilitate group sessions.
            </p>
          </div>
          <div class="case-card">
            <div class="case-icon">★</div>
            <h3>Research Organizations</h3>
            <p>
              Study pattern correlations, collect data at scale, and explore
              the framework with API access and custom reports.
            </p>
          </div>
        </div>
      </section>

      <!-- Enterprise Features -->
      <section class="features">
        <h2>Enterprise Capabilities</h2>
        <div class="features-grid">
          <div class="feature-item">
            <div class="feature-header">
              <span class="feature-icon">◆</span>
              <h4>Single Sign-On (SSO)</h4>
            </div>
            <p>SAML 2.0 and OIDC integration with your identity provider. Okta, Azure AD, Google Workspace supported.</p>
          </div>
          <div class="feature-item">
            <div class="feature-header">
              <span class="feature-icon">◆</span>
              <h4>Custom Integrations</h4>
            </div>
            <p>Connect to Slack, Microsoft Teams, Notion, and your HRIS. Push pattern insights where your team works.</p>
          </div>
          <div class="feature-item">
            <div class="feature-header">
              <span class="feature-icon">◆</span>
              <h4>Admin Dashboard</h4>
            </div>
            <p>Centralized user management, seat allocation, usage analytics, and billing controls.</p>
          </div>
          <div class="feature-item">
            <div class="feature-header">
              <span class="feature-icon">◆</span>
              <h4>Priority Support</h4>
            </div>
            <p>Dedicated account manager, 4-hour response SLA, and direct Slack/Teams channel with our team.</p>
          </div>
          <div class="feature-item">
            <div class="feature-header">
              <span class="feature-icon">◆</span>
              <h4>Custom Reports</h4>
            </div>
            <p>Executive dashboards, team health metrics, and scheduled reports delivered to your inbox.</p>
          </div>
          <div class="feature-item">
            <div class="feature-header">
              <span class="feature-icon">◆</span>
              <h4>Training & Workshops</h4>
            </div>
            <p>On-site or virtual training for your team. Facilitated sessions to maximize adoption and value.</p>
          </div>
          <div class="feature-item">
            <div class="feature-header">
              <span class="feature-icon">◆</span>
              <h4>Data Residency</h4>
            </div>
            <p>Choose your data region (US, EU, Asia-Pacific) to meet compliance requirements.</p>
          </div>
          <div class="feature-item">
            <div class="feature-header">
              <span class="feature-icon">◆</span>
              <h4>API Access</h4>
            </div>
            <p>Full API access for custom integrations, bulk operations, and automated workflows.</p>
          </div>
        </div>
      </section>

      <!-- Pricing -->
      <section class="pricing-section">
        <h2>Simple, Transparent Pricing</h2>
        <div class="pricing-card">
          <div class="pricing-header">
            <span class="pricing-from">Starting at</span>
            <div class="pricing-amount">
              <span class="currency">$</span>
              <span class="price">29</span>
              <span class="per">/seat/month</span>
            </div>
            <span class="pricing-note">for 50+ seats, billed annually</span>
          </div>

          <ul class="pricing-includes">
            <li>All Circle features included</li>
            <li>SSO/SAML authentication</li>
            <li>Dedicated account manager</li>
            <li>Priority support (4hr SLA)</li>
            <li>Custom integrations</li>
            <li>Training & onboarding</li>
          </ul>

          <div class="pricing-tiers">
            <div class="tier">
              <span class="tier-range">50-99 seats</span>
              <span class="tier-price">$29/seat</span>
            </div>
            <div class="tier">
              <span class="tier-range">100-249 seats</span>
              <span class="tier-price">$25/seat</span>
            </div>
            <div class="tier">
              <span class="tier-range">250-499 seats</span>
              <span class="tier-price">$21/seat</span>
            </div>
            <div class="tier">
              <span class="tier-range">500+ seats</span>
              <span class="tier-price">Custom</span>
            </div>
          </div>
        </div>
      </section>

      <!-- Security -->
      <section class="security-section">
        <h2>Enterprise-Grade Security</h2>
        <div class="security-grid">
          <div class="security-item">
            <span class="check">✓</span>
            <span>SOC 2 Type II compliant</span>
          </div>
          <div class="security-item">
            <span class="check">✓</span>
            <span>GDPR compliant</span>
          </div>
          <div class="security-item">
            <span class="check">✓</span>
            <span>End-to-end encryption</span>
          </div>
          <div class="security-item">
            <span class="check">✓</span>
            <span>99.9% uptime SLA</span>
          </div>
          <div class="security-item">
            <span class="check">✓</span>
            <span>Regular security audits</span>
          </div>
          <div class="security-item">
            <span class="check">✓</span>
            <span>Data backup & recovery</span>
          </div>
        </div>
      </section>

      <!-- CTA -->
      <section class="final-cta">
        <h2>Ready to bring pattern awareness to your organization?</h2>
        <p>Schedule a demo to see how The Realm of Patterns can support your team.</p>
        <a href="mailto:enterprise@therealmofpatterns.com?subject=Enterprise%20Demo%20Request" class="primary-btn large">
          Schedule a Demo
          <span class="arrow">→</span>
        </a>
        <p class="cta-note">Or email us at enterprise@therealmofpatterns.com</p>
      </section>
    </div>
  </div>
</BaseLayout>

<style>
  .enterprise-page {
    --gold: #d4a854;
    --purple: #9333ea;
    --dark: #0a0908;
    --dark-surface: #141210;
    --text: #f0e8d8;
    --text-muted: rgba(240, 232, 216, 0.6);

    font-family: 'Cormorant Garamond', Georgia, serif;
    background: var(--dark);
    color: var(--text);
    min-height: 100vh;
    padding: 6rem 2rem 4rem;
  }

  .page-container {
    max-width: 1000px;
    margin: 0 auto;
  }

  /* Hero */
  .hero {
    text-align: center;
    padding-bottom: 4rem;
    border-bottom: 1px solid rgba(212, 168, 84, 0.1);
    margin-bottom: 4rem;
  }

  .hero-badge {
    display: inline-block;
    font-size: 0.7rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    padding: 0.5rem 1rem;
    background: linear-gradient(135deg, var(--purple) 0%, var(--gold) 100%);
    color: white;
    margin-bottom: 1.5rem;
  }

  .hero h1 {
    font-size: 3rem;
    font-weight: 300;
    color: var(--text);
    margin-bottom: 1rem;
  }

  .hero-subtitle {
    font-size: 1.25rem;
    color: var(--text-muted);
    max-width: 600px;
    margin: 0 auto 2rem;
    line-height: 1.6;
  }

  .hero-cta {
    display: flex;
    gap: 1rem;
    justify-content: center;
    margin-bottom: 3rem;
  }

  .primary-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 1rem 2rem;
    background: linear-gradient(135deg, var(--purple) 0%, #7c3aed 100%);
    color: white;
    text-decoration: none;
    font-size: 1rem;
    font-family: inherit;
    border: none;
    cursor: pointer;
    transition: all 0.3s;
  }

  .primary-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 30px rgba(147, 51, 234, 0.3);
  }

  .primary-btn.large {
    padding: 1.25rem 2.5rem;
    font-size: 1.1rem;
  }

  .primary-btn .arrow {
    transition: transform 0.3s;
  }

  .primary-btn:hover .arrow {
    transform: translateX(4px);
  }

  .secondary-btn {
    display: inline-flex;
    align-items: center;
    padding: 1rem 2rem;
    background: transparent;
    border: 1px solid rgba(212, 168, 84, 0.3);
    color: var(--text);
    text-decoration: none;
    font-size: 1rem;
    font-family: inherit;
    transition: all 0.3s;
  }

  .secondary-btn:hover {
    border-color: var(--gold);
    color: var(--gold);
  }

  .trusted-by {
    color: var(--text-muted);
    font-size: 0.85rem;
  }

  .trusted-by span {
    display: block;
    margin-bottom: 1rem;
  }

  .logos {
    display: flex;
    gap: 2rem;
    justify-content: center;
    opacity: 0.5;
  }

  .logo-placeholder {
    font-family: 'Inter', sans-serif;
    font-size: 0.8rem;
  }

  /* Sections */
  section {
    margin-bottom: 4rem;
  }

  section h2 {
    text-align: center;
    font-size: 2rem;
    font-weight: 400;
    color: var(--text);
    margin-bottom: 2rem;
  }

  /* Use Cases */
  .cases-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
  }

  @media (max-width: 700px) {
    .cases-grid {
      grid-template-columns: 1fr;
    }
  }

  .case-card {
    background: var(--dark-surface);
    border: 1px solid rgba(212, 168, 84, 0.1);
    padding: 1.5rem;
    transition: all 0.3s;
  }

  .case-card:hover {
    border-color: rgba(212, 168, 84, 0.3);
  }

  .case-icon {
    font-size: 1.5rem;
    color: var(--purple);
    margin-bottom: 0.75rem;
  }

  .case-card h3 {
    font-size: 1.25rem;
    font-weight: 400;
    color: var(--gold);
    margin-bottom: 0.5rem;
  }

  .case-card p {
    font-size: 0.95rem;
    color: var(--text-muted);
    line-height: 1.6;
  }

  /* Features */
  .features-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1rem;
  }

  @media (max-width: 700px) {
    .features-grid {
      grid-template-columns: 1fr;
    }
  }

  .feature-item {
    padding: 1.25rem;
    background: rgba(147, 51, 234, 0.05);
    border-left: 3px solid var(--purple);
  }

  .feature-header {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 0.5rem;
  }

  .feature-icon {
    color: var(--purple);
    font-size: 0.9rem;
  }

  .feature-item h4 {
    font-size: 1rem;
    font-weight: 500;
    color: var(--text);
  }

  .feature-item p {
    font-size: 0.9rem;
    color: var(--text-muted);
    line-height: 1.5;
    font-family: 'Inter', sans-serif;
  }

  /* Pricing */
  .pricing-card {
    max-width: 500px;
    margin: 0 auto;
    background: var(--dark-surface);
    border: 1px solid rgba(147, 51, 234, 0.3);
    padding: 2rem;
  }

  .pricing-header {
    text-align: center;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid rgba(212, 168, 84, 0.1);
    margin-bottom: 1.5rem;
  }

  .pricing-from {
    font-size: 0.9rem;
    color: var(--text-muted);
  }

  .pricing-amount {
    display: flex;
    align-items: baseline;
    justify-content: center;
    gap: 0.25rem;
    margin: 0.5rem 0;
  }

  .pricing-amount .currency {
    font-size: 1.5rem;
    color: var(--purple);
  }

  .pricing-amount .price {
    font-size: 4rem;
    font-weight: 300;
    color: var(--purple);
    font-family: 'Geist Mono', monospace;
    line-height: 1;
  }

  .pricing-amount .per {
    font-size: 1rem;
    color: var(--text-muted);
  }

  .pricing-note {
    font-size: 0.85rem;
    color: var(--text-muted);
  }

  .pricing-includes {
    list-style: none;
    padding: 0;
    margin: 0 0 1.5rem;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0.5rem;
  }

  .pricing-includes li {
    font-size: 0.9rem;
    color: var(--text);
    padding-left: 1.25rem;
    position: relative;
  }

  .pricing-includes li::before {
    content: '✓';
    position: absolute;
    left: 0;
    color: var(--purple);
  }

  .pricing-tiers {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0.5rem;
    padding-top: 1rem;
    border-top: 1px solid rgba(212, 168, 84, 0.1);
  }

  .tier {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.5rem 0.75rem;
    background: rgba(147, 51, 234, 0.1);
    font-size: 0.85rem;
  }

  .tier-range {
    color: var(--text-muted);
  }

  .tier-price {
    color: var(--gold);
    font-weight: 500;
  }

  /* Security */
  .security-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
    max-width: 700px;
    margin: 0 auto;
  }

  @media (max-width: 600px) {
    .security-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  .security-item {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem;
    background: rgba(34, 197, 94, 0.1);
    font-size: 0.9rem;
    color: var(--text);
  }

  .security-item .check {
    color: #22c55e;
  }

  /* Final CTA */
  .final-cta {
    text-align: center;
    padding: 3rem;
    background: linear-gradient(135deg, rgba(147, 51, 234, 0.1) 0%, rgba(212, 168, 84, 0.05) 100%);
    border: 1px solid rgba(147, 51, 234, 0.2);
  }

  .final-cta h2 {
    margin-bottom: 0.75rem;
  }

  .final-cta > p {
    font-size: 1.1rem;
    color: var(--text-muted);
    margin-bottom: 1.5rem;
  }

  .cta-note {
    margin-top: 1rem;
    font-size: 0.85rem;
    color: rgba(240, 232, 216, 0.5);
  }

  @media (max-width: 600px) {
    .hero h1 {
      font-size: 2rem;
    }

    .hero-cta {
      flex-direction: column;
      align-items: center;
    }
  }
</style>
