---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Welcome to Pro - The Realm of Patterns" description="Your subscription is active. Welcome to the full experience.">
  <div class="success-page">
    <div class="success-content">
      <div class="success-icon">✦</div>
      <h1>You're in!</h1>
      <p class="subtitle" id="subtitle">Your subscription is now active.</p>

      <div class="next-steps">
        <h2>What happens next</h2>
        <ol>
          <li>
            <span class="step-num">1</span>
            <div>
              <strong>Check your email</strong>
              <p>A login link is on its way — click it to access Sol on any device.</p>
            </div>
          </li>
          <li>
            <span class="step-num">2</span>
            <div>
              <strong>Do your check-in today</strong>
              <p>Sol reads your field fresh each day. The depth begins with the first check-in.</p>
            </div>
          </li>
          <li>
            <span class="step-num">3</span>
            <div>
              <strong>After seven days, read the arc</strong>
              <p>Sol will offer a weekly synthesis — the pattern across your full week.</p>
            </div>
          </li>
        </ol>
      </div>

      <div class="cta-group">
        <a href="/sol/checkin" class="cta-primary" id="primary-cta">
          <span id="primary-cta-text">Begin today's check-in</span>
          <span class="arrow">&rarr;</span>
        </a>
        <a href="/sol/" class="cta-secondary">Go to Sol</a>
        <a href="/" class="cta-secondary">Back to Home</a>
      </div>

      <p class="note">
        Questions? Email <a href="mailto:support@therealmofpatterns.com">support@therealmofpatterns.com</a>
      </p>
    </div>
  </div>
</BaseLayout>

<script>
  // Personalize based on URL params
  const params = new URLSearchParams(window.location.search);
  const plan    = params.get('plan');
  const product = params.get('product'); // 'founding' for one-time purchase
  const subtitle = document.getElementById('subtitle');

  if (product === 'founding') {
    if (subtitle) subtitle.textContent = "Welcome, founding member. Sol is yours — permanently.";
    // Update step 3 text for founding members
    const steps = document.querySelectorAll('.next-steps li');
    if (steps[2]) {
      const strong = steps[2].querySelector('strong');
      const p = steps[2].querySelector('p');
      if (strong) strong.textContent = 'Your access never expires';
      if (p) p.textContent = 'Founding members keep Pro access forever — no renewals, no expiry.';
    }
  } else if (subtitle && plan === 'squad') {
    subtitle.textContent = 'Your Team plan is active. Invite your members from the dashboard.';
  } else if (subtitle) {
    subtitle.textContent = 'Your Pro trial has started. Enjoy the full experience for 7 days free.';
  }

  // Verify subscription via Stripe session and activate Pro in localStorage
  const sessionId = params.get('session_id');
  if (sessionId) {
    try {
      const res = await fetch('/api/subscription-status', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ sessionId }),
      });
      if (res.ok) {
        const data = await res.json();
        if (data.success && data.isPro) {
          localStorage.setItem('rop_subscription_tier', data.tier);
          const existing = JSON.parse(localStorage.getItem('rop_user') || '{}');
          existing.isPro = true;
          if (data.email) existing.email = data.email;
          localStorage.setItem('rop_user', JSON.stringify(existing));

          // Auto-send magic link so user is authenticated on any device
          if (data.email) {
            fetch('/api/auth/magic', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ email: data.email, redirect: '/sol/' }),
            }).catch(() => {/* silent — user can log in manually if needed */});
          }
        }
      }
    } catch (err) {
      console.warn('[ROP] Could not verify subscription:', err);
    }
  }

  // Smart CTA: go to Sol if birth data exists
  const hasBirthData = localStorage.getItem('rop_birth_data_full');
  if (hasBirthData) {
    const primaryCta = document.getElementById('primary-cta');
    const primaryCtaText = document.getElementById('primary-cta-text');
    if (primaryCta) primaryCta.setAttribute('href', '/sol/checkin');
    if (primaryCtaText) primaryCtaText.textContent = "Begin today's check-in";
  }
</script>

<style>
  .success-page {
    --gold: #d4a854;
    --dark: #0a0908;
    --dark-surface: #141210;
    --text: #f0e8d8;
    --text-muted: rgba(240, 232, 216, 0.6);

    font-family: 'Cormorant Garamond', Georgia, serif;
    background: var(--dark);
    color: var(--text);
    min-height: 100vh;
    padding: 6rem 2rem 4rem;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .success-content {
    max-width: 520px;
    text-align: center;
  }

  .success-icon {
    font-size: 3rem;
    color: var(--gold);
    margin-bottom: 1rem;
    animation: pulse 2s ease-in-out infinite;
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.7; transform: scale(1.1); }
  }

  h1 {
    font-size: 2.5rem;
    font-weight: 300;
    color: var(--text);
    margin: 0 0 0.5rem;
  }

  .subtitle {
    font-size: 1.1rem;
    color: var(--text-muted);
    margin-bottom: 2.5rem;
  }

  .next-steps {
    text-align: left;
    background: var(--dark-surface);
    border: 1px solid rgba(212, 168, 84, 0.15);
    padding: 2rem;
    margin-bottom: 2rem;
  }

  .next-steps h2 {
    font-size: 1rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--gold);
    margin: 0 0 1.5rem;
    font-weight: 400;
  }

  .next-steps ol {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .next-steps li {
    display: flex;
    gap: 1rem;
    align-items: flex-start;
  }

  .step-num {
    width: 28px;
    height: 28px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(212, 168, 84, 0.1);
    border: 1px solid rgba(212, 168, 84, 0.3);
    border-radius: 50%;
    font-size: 0.8rem;
    color: var(--gold);
    flex-shrink: 0;
    font-family: 'Geist Mono', monospace;
  }

  .next-steps strong {
    display: block;
    color: var(--text);
    font-weight: 500;
    margin-bottom: 0.25rem;
  }

  .next-steps p {
    font-size: 0.9rem;
    color: var(--text-muted);
    margin: 0;
    line-height: 1.5;
  }

  .cta-group {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    margin-bottom: 2rem;
  }

  .cta-primary {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    padding: 1rem 2rem;
    background: var(--gold);
    color: var(--dark);
    text-decoration: none;
    font-size: 1.1rem;
    font-weight: 600;
    transition: all 0.3s;
  }

  .cta-primary:hover {
    background: #e5b865;
    box-shadow: 0 0 24px rgba(212, 168, 84, 0.3);
  }

  .cta-primary .arrow {
    transition: transform 0.3s;
  }

  .cta-primary:hover .arrow {
    transform: translateX(4px);
  }

  .cta-secondary {
    padding: 0.75rem;
    color: var(--text-muted);
    text-decoration: none;
    font-size: 0.9rem;
    transition: color 0.2s;
  }

  .cta-secondary:hover {
    color: var(--gold);
  }

  .note {
    font-size: 0.8rem;
    color: rgba(240, 232, 216, 0.4);
  }

  .note a {
    color: var(--gold);
    text-decoration: none;
  }

  .note a:hover {
    text-decoration: underline;
  }
</style>
