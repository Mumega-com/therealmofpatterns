  'daily-checkin-best-practices': {
    title: 'Daily Check-in Best Practices',
    excerpt: 'How to get the most accurate readings from your daily self-assessment.',
    author: 'Sol',
    authorRole: 'Guide',
    date: '2026-01-28',
