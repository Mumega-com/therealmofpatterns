            {post.author.charAt(0)}
          </div>
          <div>
            <div class="text-[#f0e8d8] text-sm font-medium">{post.author}</div>
            <div class="text-[#f0e8d8]/50 text-xs">{post.authorRole} • {formatDate(post.date)}</div>
