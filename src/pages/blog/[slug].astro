              <span class="text-xs text-[#d4a854]/70">{p.category}</span>
              <h3 class="font-serif text-[#f0e8d8] text-sm mt-1 line-clamp-2">{p.title}</h3>
            </a>
          ))}
        </div>
      </div>
    </aside>
  </article>
</BaseLayout>

