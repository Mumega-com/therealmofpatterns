    <!-- Content -->
    <div class="px-4 pb-16">
      <div class="max-w-3xl mx-auto prose prose-invert prose-gold" set:html={renderMarkdown(post.content)} />
    </div>

    <!-- Related Posts -->
    <aside class="px-4 py-12 border-t border-[rgba(212,168,84,0.1)]">
      <div class="max-w-4xl mx-auto">
        <h2 class="text-lg font-serif text-[#d4a854] mb-6 text-center">Continue Reading</h2>
        <div class="grid md:grid-cols-3 gap-4">
          {otherPosts.map(([key, p]) => (
            <a
              href={`/blog/${key}`}
