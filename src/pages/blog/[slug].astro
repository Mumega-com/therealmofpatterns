export function getStaticPaths() {
  return [
    { params: { slug: 'understanding-your-kappa-coefficient' }, props: { slug: 'understanding-your-kappa-coefficient' } },
    { params: { slug: 'the-eight-dimensions-explained' }, props: { slug: 'the-eight-dimensions-explained' } },
    { params: { slug: 'jung-and-the-cosmic-signature' }, props: { slug: 'jung-and-the-cosmic-signature' } },
    { params: { slug: 'navigating-nigredo' }, props: { slug: 'navigating-nigredo' } },
    { params: { slug: 'daily-checkin-best-practices' }, props: { slug: 'daily-checkin-best-practices' } },
  ];
}

const { slug } = Astro.params;
const post = BLOG_POSTS[slug];

if (!post) {
  return Astro.redirect('/404');
}

function formatDate(dateStr: string): string {
  return new Date(dateStr).toLocaleDateString('en-US', {
    month: 'long',
    day: 'numeric',
    year: 'numeric'
  });
}

const otherPosts = Object.entries(BLOG_POSTS)
  .filter(([key]) => key !== slug)
  .slice(0, 3);

// Simple markdown-like rendering for the blog content
function renderMarkdown(content: string): string {
  return content
    // Headers
    .replace(/^## (.+)$/gm, '<h2>$1</h2>')
    .replace(/^### (.+)$/gm, '<h3>$1</h3>')
    // Bold
    .replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>')
    // Italic (single asterisks, but not inside bold)
    .replace(/(?<!\*)\*([^*]+)\*(?!\*)/g, '<em>$1</em>')
    // Code
    .replace(/`(.+?)`/g, '<code>$1</code>')
    // Paragraphs (split by double newlines, wrap non-HTML in <p>)
    .split('\n\n')
    .map(block => {
      const trimmed = block.trim();
      if (!trimmed) return '';
      if (trimmed.startsWith('<h') || trimmed.startsWith('<ul') || trimmed.startsWith('<ol') || trimmed.startsWith('<blockquote')) {
        return trimmed;
      }
      // Handle list items
      if (trimmed.includes('- ')) {
        const items = trimmed.split('\n').map(line => {
          if (line.trim().startsWith('- ')) {
            return `<li>${line.trim().slice(2)}</li>`;
          }
          return line;
        }).join('');
        return `<ul>${items}</ul>`;
      }
      return `<p>${trimmed.replace(/\n/g, ' ')}</p>`;
    })
    .join('\n');
}
