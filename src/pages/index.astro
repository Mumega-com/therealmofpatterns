<script>
  // Kasra mode: Animate metrics
  function animateMetrics() {
    const kappaEl = document.getElementById('kappa-display');
    const ruEl = document.getElementById('ru-display');
    const muEl = document.getElementById('mu-display');

    if (!kappaEl || !ruEl || !muEl) return;

    let kappa = 0;
    let ru = 0;
    let mu = 0;

    const targetKappa = 0.847;
    const targetRU = 127;
    const targetMu = 4.2;

    const duration = 2000;
    const steps = 60;
    const interval = duration / steps;

    let step = 0;

    const animate = setInterval(() => {
      step++;
      const progress = step / steps;
      const eased = 1 - Math.pow(1 - progress, 3);

      kappa = targetKappa * eased;
      ru = Math.round(targetRU * eased);
      mu = targetMu * eased;

      kappaEl.textContent = kappa.toFixed(3);
      ruEl.textContent = ru.toString().padStart(3, '0');
      muEl.textContent = mu.toFixed(1);

      if (step >= steps) {
        clearInterval(animate);
      }
    }, interval);
  }

  // Run animation when Kasra mode is active
  document.addEventListener('DOMContentLoaded', () => {
    if (document.documentElement.dataset.mode === 'kasra') {
      animateMetrics();
    }

    // Re-run on mode change
    const observer = new MutationObserver((mutations) => {
      mutations.forEach((mutation) => {
        if (mutation.attributeName === 'data-mode') {
          if (document.documentElement.dataset.mode === 'kasra') {
            animateMetrics();
          }
        }
      });
    });

    observer.observe(document.documentElement, { attributes: true });
  });
</script>
