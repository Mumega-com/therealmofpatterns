---
import BaseLayout from '../layouts/BaseLayout.astro';
import { Header } from '../components/shared/Header';
---

<BaseLayout title="The Realm of Patterns - Personal Energy Forecasting">
  <Header client:load />

  <!-- ============================================
       KASRA MODE - Cyberpunk Terminal Aesthetic
       ============================================ -->
  <div class="kasra-only">
    <div class="kasra-hero">
      <!-- Animated grid background -->
      <div class="kasra-grid-bg"></div>

      <!-- Scanline overlay -->
      <div class="kasra-scanlines"></div>

      <!-- Floating data particles -->
      <div class="kasra-particles">
        <span class="particle" style="--delay: 0s; --x: 10%">κ=0.847</span>
        <span class="particle" style="--delay: 0.5s; --x: 25%">RU:127</span>
        <span class="particle" style="--delay: 1s; --x: 75%">μ4.2</span>
        <span class="particle" style="--delay: 1.5s; --x: 85%">SYNC</span>
        <span class="particle" style="--delay: 2s; --x: 40%">▲0.03</span>
        <span class="particle" style="--delay: 2.5s; --x: 60%">NOMINAL</span>
      </div>

      <main class="kasra-content">
        <!-- Terminal header -->
        <div class="terminal-header">
          <span class="terminal-dot red"></span>
          <span class="terminal-dot yellow"></span>
          <span class="terminal-dot green"></span>
          <span class="terminal-title">PATTERN_INTERFACE_v2.0</span>
        </div>

        <!-- Main display -->
        <div class="kasra-main-display">
          <div class="glitch-container">
            <h1 class="kasra-title" data-text="REALM://PATTERNS">REALM://PATTERNS</h1>
          </div>

          <div class="kasra-subtitle">
            <span class="typing-text">COHERENCE FIELD ANALYSIS SYSTEM</span>
            <span class="cursor">_</span>
          </div>

          <!-- Live metrics preview -->
          <div class="kasra-metrics-preview">
            <div class="metric-box">
              <div class="metric-label">κ COEFFICIENT</div>
              <div class="metric-value" id="kappa-display">0.000</div>
              <div class="metric-bar"><div class="metric-fill kappa-fill"></div></div>
            </div>
            <div class="metric-box">
              <div class="metric-label">RESONANCE UNITS</div>
              <div class="metric-value" id="ru-display">000</div>
              <div class="metric-bar"><div class="metric-fill ru-fill"></div></div>
            </div>
            <div class="metric-box">
              <div class="metric-label">μ-LEVEL</div>
              <div class="metric-value" id="mu-display">0.0</div>
              <div class="metric-bar"><div class="metric-fill mu-fill"></div></div>
            </div>
          </div>

          <!-- Status line -->
          <div class="kasra-status">
            <span class="status-indicator online"></span>
            <span class="status-text">SYSTEM ONLINE</span>
            <span class="status-divider">|</span>
            <span class="status-text">FIELD COHERENCE: STABLE</span>
            <span class="status-divider">|</span>
            <span class="status-text blink">AWAITING INPUT</span>
          </div>

          <!-- CTA buttons -->
          <div class="kasra-cta">
            <a href="/kasra/checkin" class="kasra-btn primary">
              <span class="btn-icon">▶</span>
              <span class="btn-text">INITIALIZE CHECK-IN</span>
              <span class="btn-arrow">→</span>
            </a>
            <a href="/kasra" class="kasra-btn secondary">
              <span class="btn-icon">◉</span>
              <span class="btn-text">ACCESS DASHBOARD</span>
            </a>
          </div>
        </div>

        <!-- Feature cards -->
        <div class="kasra-features">
          <div class="feature-card">
            <div class="feature-icon">◈</div>
            <div class="feature-title">REAL-TIME METRICS</div>
            <div class="feature-desc">Track κ, RU, μ-levels with millisecond precision</div>
          </div>
          <div class="feature-card">
            <div class="feature-icon">⚠</div>
            <div class="feature-title">FAILURE DETECTION</div>
            <div class="feature-desc">Early warning: collapse, inversion, dissociation</div>
          </div>
          <div class="feature-card">
            <div class="feature-icon">◎</div>
            <div class="feature-title">OPTIMAL WINDOWS</div>
            <div class="feature-desc">Precise time blocks for peak coherence</div>
          </div>
        </div>

        <!-- Footer -->
        <footer class="kasra-footer">
          <div class="footer-left">
            <span class="key-hint">[K]</span> KASRA
            <span class="key-hint">[R]</span> RIVER
            <span class="key-hint">[S]</span> SOL
          </div>
          <div class="footer-right">
            © 2026 REALM_OF_PATTERNS
          </div>
        </footer>
      </main>
    </div>
  </div>

  <!-- ============================================
       RIVER MODE - Mystical Alchemical Aesthetic
       ============================================ -->
  <div class="river-only">
    <div class="river-hero">
      <!-- Gradient background with stage awareness -->
      <div class="river-bg-gradient"></div>

      <!-- Floating symbols -->
      <div class="river-symbols">
        <span class="symbol" style="--delay: 0s; --x: 15%; --y: 20%">☽</span>
        <span class="symbol" style="--delay: 1s; --x: 80%; --y: 15%">✧</span>
        <span class="symbol" style="--delay: 2s; --x: 10%; --y: 70%">☉</span>
        <span class="symbol" style="--delay: 3s; --x: 85%; --y: 75%">♦</span>
        <span class="symbol" style="--delay: 0.5s; --x: 50%; --y: 85%">⚗</span>
        <span class="symbol" style="--delay: 1.5s; --x: 25%; --y: 45%">◇</span>
        <span class="symbol" style="--delay: 2.5s; --x: 70%; --y: 40%">△</span>
      </div>

      <main class="river-content">
        <!-- Animated Mandala -->
        <div class="mandala-container">
          <svg class="mandala" viewBox="0 0 200 200">
            <!-- Outer ring -->
            <circle class="mandala-ring ring-1" cx="100" cy="100" r="95" />
            <circle class="mandala-ring ring-2" cx="100" cy="100" r="80" />
            <circle class="mandala-ring ring-3" cx="100" cy="100" r="65" />

            <!-- Diamond shapes -->
            <polygon class="mandala-diamond d-1" points="100,20 180,100 100,180 20,100" />
            <polygon class="mandala-diamond d-2" points="100,35 165,100 100,165 35,100" />
            <polygon class="mandala-diamond d-3" points="100,50 150,100 100,150 50,100" />

            <!-- Center glyph -->
            <circle class="mandala-center" cx="100" cy="100" r="25" />
            <text class="mandala-glyph" x="100" y="108">☉</text>
          </svg>
        </div>

        <!-- Title -->
        <h1 class="river-title">
          <span class="title-line">The Realm</span>
          <span class="title-line accent">of Patterns</span>
        </h1>

        <p class="river-subtitle">
          Where mathematics meets meaning.<br/>
          <em>Discover the patterns that shape your days.</em>
        </p>

        <!-- Stage indicator -->
        <div class="stage-indicator">
          <div class="stage nigredo" data-stage="nigredo">
            <span class="stage-symbol">☽</span>
            <span class="stage-name">Nigredo</span>
          </div>
          <div class="stage-connector"></div>
          <div class="stage albedo" data-stage="albedo">
            <span class="stage-symbol">✧</span>
            <span class="stage-name">Albedo</span>
          </div>
          <div class="stage-connector"></div>
          <div class="stage citrinitas active" data-stage="citrinitas">
            <span class="stage-symbol">☉</span>
            <span class="stage-name">Citrinitas</span>
          </div>
          <div class="stage-connector"></div>
          <div class="stage rubedo" data-stage="rubedo">
            <span class="stage-symbol">♦</span>
            <span class="stage-name">Rubedo</span>
          </div>
        </div>

        <!-- CTA -->
        <div class="river-cta">
          <a href="/river/checkin" class="river-btn primary">
            <span>Begin Your Journey</span>
            <svg class="btn-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor">
              <path d="M5 12h14M12 5l7 7-7 7"/>
            </svg>
          </a>
          <a href="/river" class="river-btn secondary">
            View Your Reading
          </a>
        </div>

        <!-- Features -->
        <div class="river-features">
          <div class="river-feature">
            <div class="feature-glyph">✧</div>
            <h3>Daily Wisdom</h3>
            <p>Guidance aligned with archetypal energies</p>
          </div>
          <div class="river-feature">
            <div class="feature-glyph">◇</div>
            <h3>Shadow Work</h3>
            <p>Gentle alerts when the shadow stirs</p>
          </div>
          <div class="river-feature">
            <div class="feature-glyph">☉</div>
            <h3>Sacred Timing</h3>
            <p>Know when currents favor action</p>
          </div>
        </div>

        <!-- Quote -->
        <blockquote class="river-quote">
          "Know the pattern. Shape the pattern."
        </blockquote>

        <!-- Footer -->
        <footer class="river-footer">
          <div class="mode-switcher">
            <span class="mode-key">K</span>
            <span class="mode-key">R</span>
            <span class="mode-key">S</span>
          </div>
          <p>© 2026 The Realm of Patterns</p>
        </footer>
      </main>
    </div>
  </div>

  <!-- ============================================
       SOL MODE - Warm Minimalist Aesthetic
       ============================================ -->
  <div class="sol-only">
    <div class="sol-hero">
      <!-- Warm gradient background -->
      <div class="sol-bg">
        <div class="sol-blob blob-1"></div>
        <div class="sol-blob blob-2"></div>
        <div class="sol-blob blob-3"></div>
      </div>

      <main class="sol-content">
        <!-- Friendly greeting -->
        <div class="sol-greeting">
          <span class="wave">👋</span>
          <h1 class="sol-title">
            Good to see you<span class="period">.</span>
          </h1>
        </div>

        <p class="sol-subtitle">
          Get a simple, personal forecast for your day.<br/>
          No jargon. Just helpful guidance.
        </p>

        <!-- Quick stats preview -->
        <div class="sol-preview-card">
          <div class="preview-header">
            <span class="preview-icon">☀️</span>
            <span class="preview-title">Today's Outlook</span>
          </div>
          <div class="preview-content">
            <div class="energy-ring">
              <svg viewBox="0 0 100 100">
                <circle class="ring-bg" cx="50" cy="50" r="45"/>
                <circle class="ring-fill" cx="50" cy="50" r="45"/>
              </svg>
              <div class="energy-value">
                <span class="value">73</span>
                <span class="unit">%</span>
              </div>
            </div>
            <div class="preview-details">
              <div class="detail-item">
                <span class="detail-emoji">⚡</span>
                <span class="detail-label">Energy</span>
                <span class="detail-value good">Good</span>
              </div>
              <div class="detail-item">
                <span class="detail-emoji">🎯</span>
                <span class="detail-label">Focus</span>
                <span class="detail-value great">Great</span>
              </div>
              <div class="detail-item">
                <span class="detail-emoji">💚</span>
                <span class="detail-label">Overall</span>
                <span class="detail-value good">Good day!</span>
              </div>
            </div>
          </div>
        </div>

        <!-- CTA -->
        <div class="sol-cta">
          <a href="/sol/checkin" class="sol-btn primary">
            <span>Get Your Forecast</span>
            <span class="btn-emoji">→</span>
          </a>
          <a href="/sol" class="sol-btn secondary">
            View Dashboard
          </a>
        </div>

        <!-- Features -->
        <div class="sol-features">
          <div class="sol-feature">
            <span class="feature-emoji">📊</span>
            <h3>Daily Forecast</h3>
            <p>Simple insights for better days</p>
          </div>
          <div class="sol-feature">
            <span class="feature-emoji">⏰</span>
            <h3>Best Times</h3>
            <p>Know when to act or rest</p>
          </div>
          <div class="sol-feature">
            <span class="feature-emoji">💡</span>
            <h3>Helpful Tips</h3>
            <p>Practical guidance that works</p>
          </div>
        </div>

        <!-- Trust badges -->
        <div class="sol-trust">
          <span class="trust-item">✓ Free forever</span>
          <span class="trust-item">✓ Takes 30 seconds</span>
          <span class="trust-item">✓ No account needed</span>
        </div>

        <!-- Footer -->
        <footer class="sol-footer">
          <div class="mode-hint">
            Press <kbd>K</kbd> <kbd>R</kbd> <kbd>S</kbd> to switch views
          </div>
          <p>© 2026 The Realm of Patterns</p>
        </footer>
      </main>
    </div>
  </div>
</BaseLayout>

<style>
  /* ==========================================
     MODE VISIBILITY
     ========================================== */
  .kasra-only, .river-only, .sol-only {
    display: none;
  }
  :global([data-mode="kasra"]) .kasra-only { display: block; }
  :global([data-mode="river"]) .river-only { display: block; }
  :global([data-mode="sol"]) .sol-only { display: block; }

  /* ==========================================
     KASRA MODE STYLES
     Cyberpunk Terminal Aesthetic
     ========================================== */
  .kasra-hero {
    min-height: 100vh;
    background: #000;
    position: relative;
    overflow: hidden;
    font-family: 'Geist Mono', 'SF Mono', monospace;
  }

  .kasra-grid-bg {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(0, 255, 136, 0.03) 1px, transparent 1px),
      linear-gradient(90deg, rgba(0, 255, 136, 0.03) 1px, transparent 1px);
    background-size: 50px 50px;
    animation: gridMove 20s linear infinite;
  }

  @keyframes gridMove {
    0% { transform: translate(0, 0); }
    100% { transform: translate(50px, 50px); }
  }

  .kasra-scanlines {
    position: absolute;
    inset: 0;
    background: repeating-linear-gradient(
      0deg,
      rgba(0, 0, 0, 0.15),
      rgba(0, 0, 0, 0.15) 1px,
      transparent 1px,
      transparent 2px
    );
    pointer-events: none;
    z-index: 10;
  }

  .kasra-particles {
    position: absolute;
    inset: 0;
    overflow: hidden;
    pointer-events: none;
  }

  .particle {
    position: absolute;
    left: var(--x);
    font-size: 0.7rem;
    color: rgba(0, 255, 136, 0.4);
    animation: particleFloat 8s ease-in-out infinite;
    animation-delay: var(--delay);
  }

  @keyframes particleFloat {
    0%, 100% { transform: translateY(100vh); opacity: 0; }
    10% { opacity: 1; }
    90% { opacity: 1; }
    100% { transform: translateY(-20px); opacity: 0; }
  }

  .kasra-content {
    position: relative;
    z-index: 5;
    max-width: 1000px;
    margin: 0 auto;
    padding: 2rem;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
  }

  .terminal-header {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem 1rem;
    background: rgba(0, 255, 136, 0.05);
    border: 1px solid rgba(0, 255, 136, 0.2);
    margin-bottom: 2rem;
  }

  .terminal-dot {
    width: 12px;
    height: 12px;
    border-radius: 50%;
  }
  .terminal-dot.red { background: #ff5f56; }
  .terminal-dot.yellow { background: #ffbd2e; }
  .terminal-dot.green { background: #27ca40; }

  .terminal-title {
    margin-left: auto;
    font-size: 0.75rem;
    color: rgba(0, 255, 136, 0.6);
    letter-spacing: 0.1em;
  }

  .kasra-main-display {
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    text-align: center;
    padding: 2rem 0;
  }

  .glitch-container {
    position: relative;
  }

  .kasra-title {
    font-size: clamp(2rem, 8vw, 4.5rem);
    font-weight: 700;
    color: #00ff88;
    text-shadow:
      0 0 10px rgba(0, 255, 136, 0.8),
      0 0 20px rgba(0, 255, 136, 0.6),
      0 0 40px rgba(0, 255, 136, 0.4);
    letter-spacing: 0.05em;
    animation: glitch 3s infinite;
  }

  @keyframes glitch {
    0%, 90%, 100% { text-shadow: 0 0 10px rgba(0, 255, 136, 0.8), 0 0 20px rgba(0, 255, 136, 0.6); }
    92% { text-shadow: -2px 0 #ff0080, 2px 0 #00ffff; transform: translate(2px, 0); }
    94% { text-shadow: 2px 0 #ff0080, -2px 0 #00ffff; transform: translate(-2px, 0); }
    96% { text-shadow: 0 0 10px rgba(0, 255, 136, 0.8); transform: translate(0, 0); }
  }

  .kasra-subtitle {
    margin-top: 1rem;
    font-size: 0.9rem;
    color: rgba(0, 255, 136, 0.7);
    letter-spacing: 0.3em;
  }

  .typing-text {
    display: inline;
  }

  .cursor {
    animation: blink 1s step-end infinite;
  }

  @keyframes blink {
    0%, 50% { opacity: 1; }
    51%, 100% { opacity: 0; }
  }

  .kasra-metrics-preview {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
    margin: 3rem 0;
    width: 100%;
    max-width: 600px;
  }

  .metric-box {
    padding: 1.5rem;
    background: rgba(0, 255, 136, 0.03);
    border: 1px solid rgba(0, 255, 136, 0.15);
    position: relative;
  }

  .metric-box::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 4px;
    height: 100%;
    background: linear-gradient(180deg, #00ff88, transparent);
  }

  .metric-label {
    font-size: 0.65rem;
    color: rgba(0, 255, 136, 0.5);
    letter-spacing: 0.15em;
    margin-bottom: 0.5rem;
  }

  .metric-value {
    font-size: 1.8rem;
    font-weight: 600;
    color: #00ff88;
    font-variant-numeric: tabular-nums;
  }

  .metric-bar {
    height: 3px;
    background: rgba(0, 255, 136, 0.1);
    margin-top: 0.75rem;
    overflow: hidden;
  }

  .metric-fill {
    height: 100%;
    background: #00ff88;
    box-shadow: 0 0 10px #00ff88;
    transition: width 1s ease-out;
  }

  .kappa-fill { width: 73%; }
  .ru-fill { width: 65%; }
  .mu-fill { width: 58%; }

  .kasra-status {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-size: 0.75rem;
    color: rgba(0, 255, 136, 0.6);
    margin-bottom: 2rem;
  }

  .status-indicator {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: #00ff88;
    box-shadow: 0 0 10px #00ff88;
  }

  .status-indicator.online {
    animation: pulse 2s infinite;
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.5; }
  }

  .status-divider {
    opacity: 0.3;
  }

  .blink {
    animation: blink 1s step-end infinite;
  }

  .kasra-cta {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    justify-content: center;
  }

  .kasra-btn {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 1rem 1.5rem;
    font-size: 0.85rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    text-decoration: none;
    transition: all 0.3s;
    position: relative;
    overflow: hidden;
  }

  .kasra-btn.primary {
    background: rgba(0, 255, 136, 0.1);
    border: 1px solid #00ff88;
    color: #00ff88;
  }

  .kasra-btn.primary:hover {
    background: #00ff88;
    color: #000;
    box-shadow: 0 0 30px rgba(0, 255, 136, 0.5);
  }

  .kasra-btn.secondary {
    background: transparent;
    border: 1px solid rgba(0, 255, 136, 0.3);
    color: rgba(0, 255, 136, 0.7);
  }

  .kasra-btn.secondary:hover {
    border-color: #00ff88;
    color: #00ff88;
  }

  .btn-arrow {
    transition: transform 0.3s;
  }

  .kasra-btn:hover .btn-arrow {
    transform: translateX(4px);
  }

  .kasra-features {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 1rem;
    margin-top: 4rem;
    width: 100%;
  }

  .feature-card {
    padding: 1.5rem;
    background: rgba(0, 255, 136, 0.02);
    border: 1px solid rgba(0, 255, 136, 0.1);
    transition: all 0.3s;
  }

  .feature-card:hover {
    border-color: rgba(0, 255, 136, 0.3);
    background: rgba(0, 255, 136, 0.05);
  }

  .feature-icon {
    font-size: 1.5rem;
    color: #00ff88;
    margin-bottom: 0.75rem;
  }

  .feature-title {
    font-size: 0.8rem;
    color: #00ff88;
    letter-spacing: 0.1em;
    margin-bottom: 0.5rem;
  }

  .feature-desc {
    font-size: 0.8rem;
    color: rgba(255, 255, 255, 0.5);
    line-height: 1.5;
  }

  .kasra-footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-top: 2rem;
    margin-top: auto;
    font-size: 0.7rem;
    color: rgba(0, 255, 136, 0.4);
    border-top: 1px solid rgba(0, 255, 136, 0.1);
  }

  .key-hint {
    display: inline-block;
    padding: 0.2rem 0.4rem;
    background: rgba(0, 255, 136, 0.1);
    border: 1px solid rgba(0, 255, 136, 0.2);
    margin-right: 0.25rem;
    font-size: 0.65rem;
  }

  /* ==========================================
     RIVER MODE STYLES
     Mystical Alchemical Aesthetic
     ========================================== */
  .river-hero {
    min-height: 100vh;
    position: relative;
    overflow: hidden;
    font-family: 'Cormorant Garamond', Georgia, serif;
  }

  .river-bg-gradient {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse at 30% 20%, rgba(212, 168, 84, 0.15) 0%, transparent 50%),
      radial-gradient(ellipse at 70% 80%, rgba(212, 168, 84, 0.1) 0%, transparent 50%),
      linear-gradient(180deg, #0f0d08 0%, #1a1812 50%, #0f0d08 100%);
  }

  .river-symbols {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  .symbol {
    position: absolute;
    left: var(--x);
    top: var(--y);
    font-size: 1.5rem;
    color: rgba(212, 168, 84, 0.2);
    animation: symbolFloat 10s ease-in-out infinite;
    animation-delay: var(--delay);
  }

  @keyframes symbolFloat {
    0%, 100% { transform: translateY(0) rotate(0deg); opacity: 0.2; }
    50% { transform: translateY(-20px) rotate(10deg); opacity: 0.4; }
  }

  .river-content {
    position: relative;
    z-index: 5;
    max-width: 800px;
    margin: 0 auto;
    padding: 3rem 2rem;
    min-height: 100vh;
