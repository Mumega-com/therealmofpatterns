---
import BaseLayout from '../layouts/BaseLayout.astro';
import { ModeToggle } from '../components/shared/ModeToggle';
import { HeroSwitcher } from '../components/hero/HeroSwitcher';
---

<BaseLayout
  title="The Realm of Patterns - Witness the Cosmic Dance"
  description="A perpetual theater of AI-generated alchemical scenes, painting cosmic time through archetypal imagery. Personal energy forecasting based on FRC mathematics."
  transparentHeader={true}
>
  <div class="landing-page" id="landing-page">
    <!-- ============================================
         HERO SECTION - Smart switcher based on user state
         First-time: Simple focused hero
         Returning: Full mode-aware hero
         ============================================ -->
    <HeroSwitcher client:load />

    <!-- ============================================
         THEATER PREVIEW
         ============================================ -->
    <section class="theater-preview-section">
      <div class="section-container">
        <!-- Section Header -->
        <div class="section-header">
          <h2 class="section-title kasra-only">
            <span class="title-icon">&#9673;</span>
            COSMIC_CHANNEL
          </h2>
          <h2 class="section-title river-only">
            <span class="title-icon">&#9788;</span>
            The Cosmic Theater
          </h2>
          <h2 class="section-title sol-only">
            <span class="title-icon">&#127912;</span>
            Live Art Generation
          </h2>
        </div>

        <!-- Theater Frame -->
        <div class="theater-frame-wrapper">
          <div class="theater-frame" id="theater-frame">
            <div class="frame-corner tl"></div>
            <div class="frame-corner tr"></div>
            <div class="frame-corner bl"></div>
            <div class="frame-corner br"></div>

            <div class="theater-screen" id="theater-screen">
              <div class="curtain left"></div>
              <div class="curtain right"></div>
              <img id="scene-image" src="" alt="Current cosmic scene" class="scene-image" style="display: none;" />
              <div class="loading-indicator">
                <div class="loader-ring kasra-only"></div>
                <div class="loader-mandala river-only">
                  <svg viewBox="0 0 60 60">
                    <circle cx="30" cy="30" r="25" />
                    <circle cx="30" cy="30" r="15" />
                  </svg>
                </div>
                <div class="loader-spinner sol-only"></div>
              </div>
            </div>

            <div class="theater-info">
              <span class="stage-badge" id="stage-badge">CITRINITAS</span>
              <span class="live-indicator">
                <span class="pulse-dot"></span>
                <span class="kasra-only">LIVE</span>
                <span class="river-only">Live</span>
                <span class="sol-only">Updating</span>
              </span>
            </div>
          </div>

          <a href="/theater" class="theater-cta">
            <span class="kasra-only">&#9654; ENTER_THEATER</span>
            <span class="river-only">&#9654; Enter the Theater</span>
            <span class="sol-only">&#9654; Watch live</span>
          </a>
        </div>

        <!-- Theater Description -->
        <p class="section-description">
          <span class="kasra-only">
            Every hour, the system generates a new alchemical scene based on current planetary positions and field coherence.
          </span>
          <span class="river-only">
            Every hour, a new alchemical scene emerges from the cosmic patterns &mdash;
            24 daily transformations following the ancient stages of the Great Work.
          </span>
          <span class="sol-only">
            Every hour, AI creates new art based on planetary positions. It's like a lava lamp, but cosmic!
          </span>
        </p>
      </div>
    </section>

    <!-- ============================================
         FEATURES / YOUR PATTERN
         ============================================ -->
    <section class="features-section">
      <div class="section-container">
        <div class="section-header">
          <h2 class="section-title kasra-only">
            <span class="title-icon">&#9882;</span>
            PATTERN_ANALYSIS
          </h2>
          <h2 class="section-title river-only">
            <span class="title-icon">&#10022;</span>
            Your Personal Pattern
          </h2>
          <h2 class="section-title sol-only">
            <span class="title-icon">&#9889;</span>
            Know Your Energy
          </h2>
        </div>

        <div class="features-grid">
          <!-- Feature 1: Daily Reading -->
          <div class="feature-card">
            <div class="feature-icon">
              <span class="kasra-only">&#9651;</span>
              <span class="river-only">&#9788;</span>
              <span class="sol-only">&#127774;</span>
            </div>
            <h3 class="feature-title">
              <span class="kasra-only">DAILY_CALIBRATION</span>
              <span class="river-only">Daily Oracle</span>
              <span class="sol-only">Daily Forecast</span>
            </h3>
            <p class="feature-desc">
              <span class="kasra-only">8-dimension coherence scan with κ-coefficient analysis. Takes 60 seconds.</span>
              <span class="river-only">Each dawn brings new patterns. Discover which dimensions are calling you today.</span>
              <span class="sol-only">A quick 1-minute check-in tells you when you'll feel most energized today.</span>
            </p>
          </div>

          <!-- Feature 2: Pattern Tracking -->
          <div class="feature-card">
            <div class="feature-icon">
              <span class="kasra-only">&#9679;</span>
              <span class="river-only">&#10070;</span>
              <span class="sol-only">&#128200;</span>
            </div>
            <h3 class="feature-title">
              <span class="kasra-only">TREND_MONITORING</span>
              <span class="river-only">Pattern Memory</span>
              <span class="sol-only">Track Progress</span>
            </h3>
            <p class="feature-desc">
              <span class="kasra-only">Historical data visualization. Identify recurring field states and failure modes.</span>
              <span class="river-only">Watch how your cosmic signature evolves through the alchemical stages over time.</span>
              <span class="sol-only">See your energy patterns over time. Notice what works for you and what doesn't.</span>
            </p>
          </div>

          <!-- Feature 3: Optimal Windows -->
          <div class="feature-card">
            <div class="feature-icon">
              <span class="kasra-only">&#9201;</span>
              <span class="river-only">&#9200;</span>
              <span class="sol-only">&#127793;</span>
            </div>
            <h3 class="feature-title">
              <span class="kasra-only">OPTIMAL_WINDOWS</span>
              <span class="river-only">Sacred Timing</span>
              <span class="sol-only">Best Times</span>
            </h3>
            <p class="feature-desc">
              <span class="kasra-only">Hourly windows for high-coherence action. Avoid low-κ periods for critical operations.</span>
              <span class="river-only">Know when the currents favor creation, connection, or contemplation.</span>
              <span class="sol-only">Schedule important tasks when your energy is highest. Simple as that.</span>
            </p>
          </div>
        </div>

        <div class="features-cta">
          <a href="/sol/checkin" class="cta-btn primary-action">
            <span class="kasra-only">&#9881; INITIATE_CALIBRATION</span>
            <span class="river-only">&#10022; Receive Your Reading</span>
            <span class="sol-only">&#128640; Get started free</span>
          </a>
          <span class="cta-note">
            <span class="kasra-only">No auth required. Local computation.</span>
            <span class="river-only">No account required &bull; Takes 30 seconds</span>
            <span class="sol-only">No signup needed &bull; 1 minute</span>
          </span>
        </div>
      </div>
    </section>

    <!-- ============================================
         HOW IT WORKS
         ============================================ -->
    <section class="how-it-works-section">
      <div class="section-container">
        <div class="section-header">
          <h2 class="section-title kasra-only">
            <span class="title-icon">&#9881;</span>
            PROTOCOL_SEQUENCE
          </h2>
          <h2 class="section-title river-only">
            <span class="title-icon">&#10047;</span>
            The Practice
          </h2>
          <h2 class="section-title sol-only">
            <span class="title-icon">&#128161;</span>
            How It Works
          </h2>
        </div>

        <p class="section-subtitle">
          <span class="kasra-only">Three-step field calibration protocol.</span>
          <span class="river-only">A simple ritual for daily insight.</span>
          <span class="sol-only">Three easy steps to understand your energy.</span>
        </p>

        <div class="steps-grid">
          <!-- Step 1 -->
          <div class="step-card">
            <div class="step-number">1</div>
            <div class="step-icon">
              <span class="kasra-only">&#9684;</span>
              <span class="river-only">&#9790;</span>
              <span class="sol-only">&#128197;</span>
            </div>
            <h3 class="step-title">
              <span class="kasra-only">INPUT_PARAMETERS</span>
              <span class="river-only">Share Your Birth Moment</span>
              <span class="sol-only">Enter Your Birthday</span>
            </h3>
            <p class="step-desc">
              <span class="kasra-only">Date, time, location coordinates initialize your baseline vector in 16-dimensional space.</span>
              <span class="river-only">The moment you entered this world holds the seed of your pattern. Your cosmic fingerprint.</span>
              <span class="sol-only">Just your birth date, time, and place. This is your unique starting point. Takes 30 seconds.</span>
            </p>
          </div>

          <!-- Step 2 -->
          <div class="step-card">
            <div class="step-number">2</div>
            <div class="step-icon">
              <span class="kasra-only">&#9654;</span>
              <span class="river-only">&#10024;</span>
              <span class="sol-only">&#129302;</span>
            </div>
            <h3 class="step-title">
              <span class="kasra-only">DAILY_CHECKIN</span>
              <span class="river-only">Receive Your Reading</span>
              <span class="sol-only">Check In Daily</span>
            </h3>
            <p class="step-desc">
              <span class="kasra-only">Execute 8-question calibration. System computes current field state and κ-coefficient.</span>
              <span class="river-only">Answer 8 questions about where you are today. The patterns will speak your current truth.</span>
              <span class="sol-only">Answer 8 quick questions about how you're feeling. Takes about 1 minute. That's it!</span>
            </p>
          </div>

          <!-- Step 3 -->
          <div class="step-card">
            <div class="step-number">3</div>
            <div class="step-icon">
              <span class="kasra-only">&#9733;</span>
              <span class="river-only">&#10083;</span>
              <span class="sol-only">&#127919;</span>
            </div>
            <h3 class="step-title">
              <span class="kasra-only">APPLY_INSIGHTS</span>
              <span class="river-only">Live the Pattern</span>
              <span class="sol-only">Use Your Insights</span>
            </h3>
            <p class="step-desc">
              <span class="kasra-only">Receive optimal windows, failure mode warnings, and dimensional recommendations for high-coherence operation.</span>
              <span class="river-only">Know your best hours for action, connection, and rest. Move with the cosmic rhythm, not against it.</span>
              <span class="sol-only">See when you'll have the most energy today. Plan important stuff for your best times. Simple!</span>
            </p>
          </div>
        </div>

        <div class="how-cta">
          <a href="/sol/checkin" class="cta-btn primary-action">
            <span class="kasra-only">&#9881; BEGIN_PROTOCOL</span>
            <span class="river-only">&#10022; Begin the Practice</span>
            <span class="sol-only">&#128640; Try it now — free</span>
          </a>
        </div>
      </div>
    </section>

    <!-- ============================================
         PRICING
         ============================================ -->
    <section class="pricing-section">
      <div class="section-container">
        <div class="section-header">
          <h2 class="section-title kasra-only">
            <span class="title-icon">&#9634;</span>
            ACCESS_TIERS
          </h2>
          <h2 class="section-title river-only">
            <span class="title-icon">&#10038;</span>
            The Practice
          </h2>
          <h2 class="section-title sol-only">
            <span class="title-icon">&#128142;</span>
            Simple Plans
          </h2>
        </div>

        <p class="section-subtitle">
          <span class="kasra-only">Select operational parameters for your deployment.</span>
          <span class="river-only">From insight to integration &mdash; deepen your practice.</span>
          <span class="sol-only">Pick what works for you. Cancel anytime.</span>
        </p>

        <div class="pricing-grid">
          <!-- Free Tier -->
          <div class="pricing-card tier-free">
            <div class="card-badge">
              <span class="kasra-only">FREE_TIER</span>
              <span class="river-only">Always Free</span>
              <span class="sol-only">Free forever</span>
            </div>
            <h3 class="card-title">
              <span class="kasra-only">WITNESS</span>
              <span class="river-only">Witness</span>
              <span class="sol-only">Explorer</span>
            </h3>
            <div class="card-price">
              <span class="price">$0</span>
              <span class="period">
                <span class="kasra-only">/ FOREVER</span>
                <span class="river-only">forever</span>
                <span class="sol-only">free</span>
              </span>
            </div>
            <ul class="card-features">
              <li>
                <span class="check">&#10003;</span>
                <span class="kasra-only">Cosmic Channel access</span>
                <span class="river-only">Watch the Cosmic Theater</span>
                <span class="sol-only">See the live art gallery</span>
              </li>
              <li>
                <span class="check">&#10003;</span>
                <span class="kasra-only">8D daily scan</span>
                <span class="river-only">Daily reading (8 dimensions)</span>
                <span class="sol-only">Daily energy forecast</span>
              </li>
              <li>
                <span class="check">&#10003;</span>
                <span class="kasra-only">Basic dimension readout</span>
                <span class="river-only">Basic dimension breakdown</span>
                <span class="sol-only">See what's influencing you</span>
              </li>
            </ul>
            <a href="/sol/checkin" class="card-btn secondary">
              <span class="kasra-only">INITIALIZE</span>
              <span class="river-only">Start Witnessing</span>
              <span class="sol-only">Try it free</span>
            </a>
          </div>

          <!-- Pro Tier -->
          <div class="pricing-card tier-pro featured">
            <div class="card-badge featured-badge">
              <span class="kasra-only">RECOMMENDED</span>
              <span class="river-only">Most Popular</span>
              <span class="sol-only">Best value</span>
            </div>
            <h3 class="card-title">
              <span class="kasra-only">PATTERN_KEEPER</span>
              <span class="river-only">Pattern-Keeper</span>
              <span class="sol-only">Pro</span>
            </h3>
            <div class="card-price">
              <span class="price">$19</span>
              <span class="period">
                <span class="kasra-only">/ MONTH</span>
                <span class="river-only">/month</span>
                <span class="sol-only">/mo</span>
              </span>
            </div>
            <ul class="card-features">
              <li>
                <span class="check">&#10003;</span>
                <span class="kasra-only">Everything in WITNESS</span>
                <span class="river-only">Everything in Witness</span>
                <span class="sol-only">All free features</span>
              </li>
              <li>
                <span class="check">&#10003;</span>
                <span class="kasra-only">16D + shadow octave analysis</span>
                <span class="river-only">Full 16D with shadow octave</span>
                <span class="sol-only">Deep personality insights</span>
              </li>
              <li>
                <span class="check">&#10003;</span>
                <span class="kasra-only">Hourly optimal windows</span>
                <span class="river-only">Optimal action windows</span>
                <span class="sol-only">Best times for everything</span>
              </li>
              <li>
                <span class="check">&#10003;</span>
                <span class="kasra-only">Failure mode detection</span>
                <span class="river-only">Shadow early warnings</span>
                <span class="sol-only">Bad day alerts</span>
              </li>
              <li>
                <span class="check">&#10003;</span>
                <span class="kasra-only">Historical trend data</span>
                <span class="river-only">Pattern memory & trends</span>
                <span class="sol-only">Progress tracking</span>
              </li>
            </ul>
            <a href="/subscribe?plan=individual" class="card-btn primary">
              <span class="kasra-only">UPGRADE_SYSTEM</span>
              <span class="river-only">Begin Your Practice</span>
              <span class="sol-only">Get Pro</span>
            </a>
          </div>

          <!-- Team Tier -->
          <div class="pricing-card tier-team">
            <div class="card-badge">
              <span class="kasra-only">ENTERPRISE</span>
              <span class="river-only">For Teams</span>
              <span class="sol-only">Team plan</span>
            </div>
            <h3 class="card-title">
              <span class="kasra-only">CIRCLE_OPS</span>
              <span class="river-only">Circle</span>
              <span class="sol-only">Team</span>
            </h3>
            <div class="card-price">
              <span class="price">$49</span>
              <span class="period">
                <span class="kasra-only">/ SEAT / MONTH</span>
                <span class="river-only">/seat/month</span>
                <span class="sol-only">/person/mo</span>
              </span>
            </div>
            <ul class="card-features">
              <li>
                <span class="check">&#10003;</span>
                <span class="kasra-only">Full PATTERN_KEEPER access</span>
                <span class="river-only">Everything in Pattern-Keeper</span>
                <span class="sol-only">All Pro features</span>
              </li>
              <li>
                <span class="check">&#10003;</span>
                <span class="kasra-only">Shared ops dashboard</span>
                <span class="river-only">Shared circle dashboard</span>
                <span class="sol-only">Team dashboard</span>
              </li>
              <li>
                <span class="check">&#10003;</span>
                <span class="kasra-only">Group coherence metrics</span>
                <span class="river-only">Group coherence tracking</span>
                <span class="sol-only">Team sync scores</span>
              </li>
              <li>
                <span class="check">&#10003;</span>
                <span class="kasra-only">API access</span>
                <span class="river-only">API for integrations</span>
                <span class="sol-only">Connect your tools</span>
              </li>
            </ul>
            <a href="/subscribe?plan=squad" class="card-btn secondary">
              <span class="kasra-only">REQUEST_ACCESS</span>
              <span class="river-only">Gather Your Circle</span>
              <span class="sol-only">Start team trial</span>
            </a>
            <span class="card-note">
              <span class="kasra-only">MIN: 3 SEATS</span>
              <span class="river-only">Minimum 3 seats</span>
              <span class="sol-only">3+ people</span>
            </span>
          </div>
        </div>
      </div>
    </section>

    <!-- ============================================
         PHILOSOPHY / CLOSING
         ============================================ -->
    <section class="philosophy-section">
      <div class="section-container">
        <div class="philosophy-content">
          <div class="kasra-only philosophy-kasra">
            <div class="philosophy-cards">
              <div class="phil-card">
                <span class="phil-icon">&#9888;</span>
                <h4>NOT_PREDICTION</h4>
                <p>Pattern analysis, not fortune telling. Mathematical models, not superstition.</p>
              </div>
              <div class="phil-card">
                <span class="phil-icon">&#9878;</span>
                <h4>NOT_PASSIVE</h4>
                <p>Data without action is noise. Daily calibration builds field coherence.</p>
              </div>
            </div>
            <div class="philosophy-quote">
              <code>&gt; know_the_pattern() // shape_the_pattern()</code>
            </div>
          </div>

          <div class="river-only philosophy-river">
            <div class="philosophy-cards">
              <div class="phil-card">
                <span class="phil-icon">&#9830;</span>
                <h4>Not Prediction</h4>
                <p>We map the energetic terrain, not the events. You navigate with awareness, not superstition.</p>
              </div>
              <div class="phil-card">
                <span class="phil-icon">&#9673;</span>
                <h4>Not Passive</h4>
                <p>Knowledge without practice is entertainment. Daily reflection builds genuine coherence.</p>
              </div>
            </div>
            <blockquote class="philosophy-quote">
              "Know the pattern. Shape the pattern."
            </blockquote>
          </div>

          <div class="sol-only philosophy-sol">
            <div class="philosophy-cards">
              <div class="phil-card">
                <span class="phil-icon">&#128161;</span>
                <h4>Science meets intuition</h4>
                <p>Mathematical patterns from astronomy, translated into practical daily guidance.</p>
              </div>
              <div class="phil-card">
                <span class="phil-icon">&#127919;</span>
                <h4>Action-oriented</h4>
                <p>Not just "you'll have a good day" &mdash; specific windows for when to do what.</p>
              </div>
            </div>
            <p class="philosophy-quote">
              Know your patterns, own your days.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- ============================================
         FINAL CTA
         ============================================ -->
    <section class="final-cta-section">
      <div class="section-container">
        <h2 class="final-title">
          <span class="kasra-only">INITIALIZE_SEQUENCE</span>
          <span class="river-only">Begin Your Journey</span>
          <span class="sol-only">Ready to try it?</span>
        </h2>
        <p class="final-subtitle">
          <span class="kasra-only">System operational. Waiting for input.</span>
          <span class="river-only">The theater is always open. The pattern awaits.</span>
          <span class="sol-only">Start free. No credit card needed.</span>
        </p>
        <div class="final-ctas">
          <a href="/theater" class="cta-btn final-secondary">
            <span class="kasra-only">&#9673; COSMIC_CHANNEL</span>
            <span class="river-only">&#9788; Watch the Theater</span>
            <span class="sol-only">&#127912; See the art</span>
          </a>
          <a href="/sol/checkin" class="cta-btn final-primary">
            <span class="kasra-only">&#9881; START_CALIBRATION</span>
            <span class="river-only">&#10022; Get Your Reading</span>
            <span class="sol-only">&#128640; Start now</span>
          </a>
        </div>
      </div>
    </section>
  </div>
</BaseLayout>

<style>
  /* ==========================================
     BASE & MODE VISIBILITY
     ========================================== */
  .landing-page {
    min-height: 100vh;
    position: relative;
    overflow-x: hidden;
  }

  /* Mode-specific visibility */
  .kasra-only,
  .river-only,
  .sol-only {
    display: none;
  }

  [data-mode="kasra"] .kasra-only { display: block; }
  [data-mode="kasra"] span.kasra-only,
  [data-mode="kasra"] em.kasra-only { display: inline; }

  [data-mode="river"] .river-only { display: block; }
  [data-mode="river"] span.river-only,
  [data-mode="river"] em.river-only { display: inline; }

  [data-mode="sol"] .sol-only { display: block; }
  [data-mode="sol"] span.sol-only,
  [data-mode="sol"] em.sol-only { display: inline; }

  /* ==========================================
     HERO BACKGROUNDS
     ========================================== */
  .hero-bg {
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: 0;
    opacity: 0;
    transition: opacity 0.8s ease;
  }

  [data-mode="kasra"] .kasra-bg { opacity: 1; }
  [data-mode="river"] .river-bg { opacity: 1; }
  [data-mode="sol"] .sol-bg { opacity: 1; }

  /* Kasra Background - Cyberpunk Grid */
  .kasra-bg {
    background: #050508;
  }

  .kasra-grid {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(0, 255, 136, 0.03) 1px, transparent 1px),
      linear-gradient(90deg, rgba(0, 255, 136, 0.03) 1px, transparent 1px);
    background-size: 60px 60px;
  }

  .kasra-scan-line {
    position: absolute;
    width: 100%;
    height: 2px;
    background: linear-gradient(90deg, transparent, rgba(0, 255, 136, 0.4), transparent);
    animation: scanMove 8s linear infinite;
  }

  @keyframes scanMove {
    0% { top: -2px; }
    100% { top: 100%; }
  }

  .kasra-glitch-overlay {
    position: absolute;
    inset: 0;
    background: repeating-linear-gradient(
      0deg,
      transparent,
      transparent 2px,
      rgba(0, 255, 136, 0.01) 2px,
      rgba(0, 255, 136, 0.01) 4px
    );
  }

  .kasra-glow-orb {
    position: absolute;
    width: 600px;
    height: 600px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(0, 255, 136, 0.08) 0%, transparent 70%);
    top: -200px;
    right: -200px;
    filter: blur(80px);
    animation: orbPulse 10s ease-in-out infinite;
  }

  @keyframes orbPulse {
    0%, 100% { opacity: 0.5; transform: scale(1); }
    50% { opacity: 0.8; transform: scale(1.1); }
  }

  /* River Background - Mystical */
  .river-bg {
    background: linear-gradient(180deg, #1a1a2e 0%, #0d0d15 100%);
  }

  [data-stage="nigredo"] .river-bg { background: linear-gradient(180deg, #0a0a12 0%, #050508 100%); }
  [data-stage="albedo"] .river-bg { background: linear-gradient(180deg, #1a1a24 0%, #0d0d15 100%); }
  [data-stage="citrinitas"] .river-bg { background: linear-gradient(180deg, #1a1812 0%, #0d0c08 100%); }
  [data-stage="rubedo"] .river-bg { background: linear-gradient(180deg, #1a1214 0%, #0d0808 100%); }

  .river-nebula {
    position: absolute;
    inset: 0;
  }

  .river-nebula::before,
  .river-nebula::after {
    content: '';
    position: absolute;
    border-radius: 50%;
    filter: blur(100px);
    animation: nebulaDrift 25s ease-in-out infinite;
  }

  .river-nebula::before {
    width: 500px;
    height: 500px;
    background: radial-gradient(circle, rgba(139, 92, 246, 0.12) 0%, transparent 70%);
    top: -200px;
    left: -100px;
  }

  .river-nebula::after {
    width: 400px;
    height: 400px;
    background: radial-gradient(circle, rgba(236, 72, 153, 0.08) 0%, transparent 70%);
    bottom: -100px;
    right: -100px;
    animation-delay: -12s;
  }

  @keyframes nebulaDrift {
    0%, 100% { transform: translate(0, 0) scale(1); }
    50% { transform: translate(50px, -30px) scale(1.1); }
  }

  .river-vignette {
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at center, transparent 30%, rgba(0, 0, 0, 0.5) 100%);
  }

  /* Sol Background - Warm Blobs */
  .sol-bg {
    background: linear-gradient(180deg, #faf8f5 0%, #f5f0e8 100%);
  }

  .sol-blob {
    position: absolute;
    border-radius: 50%;
    filter: blur(60px);
    animation: blobFloat 20s ease-in-out infinite;
  }

  .sol-blob-1 {
    width: 400px;
    height: 400px;
    background: radial-gradient(circle, rgba(251, 191, 36, 0.25) 0%, transparent 70%);
    top: -150px;
    right: -100px;
  }

  .sol-blob-2 {
    width: 300px;
    height: 300px;
    background: radial-gradient(circle, rgba(249, 115, 22, 0.15) 0%, transparent 70%);
    bottom: 20%;
    left: -80px;
    animation-delay: -7s;
  }

  .sol-blob-3 {
    width: 250px;
    height: 250px;
    background: radial-gradient(circle, rgba(236, 72, 153, 0.1) 0%, transparent 70%);
    top: 40%;
    right: 10%;
    animation-delay: -14s;
  }

  @keyframes blobFloat {
    0%, 100% { transform: translate(0, 0) scale(1); }
    50% { transform: translate(30px, -20px) scale(1.05); }
  }

  /* ==========================================
     HERO SECTION
     ========================================== */
  .hero {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    position: relative;
    z-index: 1;
    padding: 6rem 1.5rem 3rem;
  }

  .hero-content {
    max-width: 900px;
    margin: 0 auto;
    width: 100%;
  }

  /* Mode Indicator */
  .mode-indicator {
    margin-bottom: 2rem;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5rem;
  }

  [data-mode="kasra"] .mode-indicator {
    font-family: 'Geist Mono', monospace;
    font-size: 0.75rem;
    color: rgba(0, 255, 136, 0.6);
    letter-spacing: 0.1em;
  }

  [data-mode="river"] .mode-indicator {
    font-family: 'Cormorant Garamond', serif;
    font-size: 0.9rem;
    color: rgba(255, 255, 255, 0.5);
    font-style: italic;
  }

  [data-mode="sol"] .mode-indicator {
    font-family: 'Inter', sans-serif;
    font-size: 0.85rem;
    color: #9ca3af;
  }

  .mode-name {
    font-weight: 600;
  }

  [data-mode="kasra"] .mode-name { color: #00ff88; }
  [data-mode="river"] .mode-name { color: rgba(255, 255, 255, 0.8); }
  [data-mode="sol"] .mode-name { color: #f59e0b; }

  .mode-switch-hint {
    width: 100%;
    margin-top: 0.25rem;
    font-size: 0.7rem;
    opacity: 0.5;
  }

  /* Hero Titles */
  .hero-titles {
    margin-bottom: 1.5rem;
  }

  /* Kasra Title */
  .kasra-terminal-header {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 1rem;
    padding: 0.5rem 0.75rem;
    background: rgba(0, 255, 136, 0.05);
    border: 1px solid rgba(0, 255, 136, 0.2);
    width: fit-content;
  }

  .terminal-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
  }

  .terminal-dot.red { background: #ff5f56; }
  .terminal-dot.yellow { background: #ffbd2e; }
  .terminal-dot.green { background: #27ca40; }
  .terminal-dot.blink { animation: dotBlink 2s ease-in-out infinite; }

  @keyframes dotBlink {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.4; }
  }

  .terminal-title {
    font-size: 0.7rem;
    color: rgba(255, 255, 255, 0.4);
    letter-spacing: 0.05em;
  }

  .kasra-h1 {
    font-family: 'Geist Mono', monospace;
    font-size: clamp(2rem, 6vw, 4rem);
    font-weight: 600;
    color: #00ff88;
    letter-spacing: -0.02em;
    text-shadow: 0 0 30px rgba(0, 255, 136, 0.3);
    margin-bottom: 0.5rem;
  }

  .kasra-prefix {
    color: rgba(0, 255, 136, 0.5);
    margin-right: 0.5rem;
  }

  .kasra-cursor {
    animation: cursorBlink 1s step-end infinite;
  }

  @keyframes cursorBlink {
    0%, 100% { opacity: 1; }
    50% { opacity: 0; }
  }

  .kasra-h2 {
    font-family: 'Geist Mono', monospace;
    font-size: clamp(1rem, 3vw, 1.75rem);
    font-weight: 400;
    color: rgba(0, 255, 136, 0.7);
    letter-spacing: 0.05em;
  }

  /* River Title */
  .river-mandala-small {
    width: 80px;
    height: 80px;
    margin-bottom: 1.5rem;
  }

  .river-mandala-small svg {
    width: 100%;
    height: 100%;
    animation: mandalaSpin 60s linear infinite;
  }

  @keyframes mandalaSpin {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
  }

  .mandala-ring {
    fill: none;
    stroke: rgba(255, 255, 255, 0.15);
    stroke-width: 1;
  }

  .mandala-ring.r1 { animation: ringBreathe 4s ease-in-out infinite; }
  .mandala-ring.r2 { animation: ringBreathe 4s ease-in-out infinite 1s; }

  @keyframes ringBreathe {
    0%, 100% { stroke: rgba(255, 255, 255, 0.15); }
    50% { stroke: rgba(139, 92, 246, 0.4); }
  }

  .mandala-center {
    fill: rgba(139, 92, 246, 0.5);
    animation: centerPulse 3s ease-in-out infinite;
  }

  @keyframes centerPulse {
    0%, 100% { fill-opacity: 0.5; }
    50% { fill-opacity: 0.9; }
  }

  .river-h1 {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(2.5rem, 7vw, 5rem);
    font-weight: 400;
    line-height: 1.1;
    margin-bottom: 1rem;
  }

  .river-line-1 {
    display: block;
    color: rgba(255, 255, 255, 0.9);
  }

  .river-line-2 {
    display: block;
    color: var(--river-accent, #d4a854);
    font-style: italic;
  }

  .river-subtitle {
    font-size: 1.25rem;
    color: rgba(255, 255, 255, 0.5);
    font-style: italic;
  }

  /* Sol Title */
  .sol-wave-emoji {
    font-size: 4rem;
    margin-bottom: 1rem;
    animation: waveHand 2.5s ease-in-out infinite;
    transform-origin: 70% 70%;
    display: inline-block;
  }

  @keyframes waveHand {
    0%, 60%, 100% { transform: rotate(0deg); }
    10% { transform: rotate(14deg); }
    20% { transform: rotate(-8deg); }
    30% { transform: rotate(14deg); }
    40% { transform: rotate(-4deg); }
    50% { transform: rotate(10deg); }
  }

  .sol-h1 {
    font-family: 'Inter', sans-serif;
  }

  .sol-greeting {
    display: block;
    font-size: clamp(1.5rem, 4vw, 2.5rem);
    font-weight: 700;
    color: #1f2937;
    margin-bottom: 0.5rem;
  }

  .sol-tagline {
    display: block;
    font-size: clamp(1.75rem, 5vw, 3rem);
    font-weight: 600;
    color: #f59e0b;
    line-height: 1.2;
  }

  /* Hero Description */
  .hero-description {
    margin-bottom: 2rem;
  }

  .hero-description p {
    font-size: 1.125rem;
    line-height: 1.7;
    max-width: 600px;
  }

  [data-mode="kasra"] .hero-description p {
    font-family: 'Geist Mono', monospace;
    font-size: 0.95rem;
    color: rgba(255, 255, 255, 0.6);
    line-height: 1.8;
  }

  .kasra-accent { color: #00ff88; }

  [data-mode="river"] .hero-description p {
    font-family: 'Cormorant Garamond', serif;
    color: rgba(255, 255, 255, 0.7);
    font-size: 1.25rem;
  }

  [data-mode="river"] .hero-description em {
    color: var(--river-accent, #d4a854);
  }

  [data-mode="sol"] .hero-description p {
    font-family: 'Inter', sans-serif;
    color: #6b7280;
  }

  /* Hero CTAs */
  .hero-ctas {
    margin-bottom: 2rem;
  }

  .cta-group {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
  }

  .cta-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    padding: 1rem 1.5rem;
    text-decoration: none;
    font-weight: 500;
    transition: all 0.3s ease;
    border-radius: 2px;
  }

  /* Kasra CTAs */
  .kasra-primary {
    background: #00ff88;
    color: #050508;
    font-family: 'Geist Mono', monospace;
    font-size: 0.85rem;
    letter-spacing: 0.05em;
  }

  .kasra-primary:hover {
    box-shadow: 0 0 30px rgba(0, 255, 136, 0.4);
    transform: translateY(-2px);
  }

  .kasra-secondary {
    background: transparent;
    color: #00ff88;
    border: 1px solid rgba(0, 255, 136, 0.4);
    font-family: 'Geist Mono', monospace;
    font-size: 0.85rem;
    letter-spacing: 0.05em;
  }

  .kasra-secondary:hover {
    background: rgba(0, 255, 136, 0.1);
    border-color: #00ff88;
  }

  /* River CTAs */
  .river-primary {
    background: rgba(139, 92, 246, 0.15);
    color: rgba(255, 255, 255, 0.9);
    border: 1px solid rgba(139, 92, 246, 0.4);
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.1rem;
  }

  .river-primary:hover {
    background: rgba(139, 92, 246, 0.25);
    box-shadow: 0 0 30px rgba(139, 92, 246, 0.2);
  }

  .river-secondary {
    background: transparent;
    color: rgba(255, 255, 255, 0.7);
    border: 1px solid rgba(255, 255, 255, 0.2);
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.1rem;
  }

  .river-secondary:hover {
    background: rgba(255, 255, 255, 0.05);
    border-color: rgba(255, 255, 255, 0.4);
  }

  .btn-symbol {
    font-size: 1.25rem;
    animation: symbolSpin 8s linear infinite;
  }

  @keyframes symbolSpin {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
  }

  /* Sol CTAs */
  .sol-primary {
    background: linear-gradient(135deg, #f59e0b 0%, #d97706 100%);
    color: white;
    font-family: 'Inter', sans-serif;
    border-radius: 16px;
    box-shadow: 0 4px 15px rgba(245, 158, 11, 0.3);
  }

  .sol-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(245, 158, 11, 0.4);
  }

  .sol-secondary {
    background: white;
    color: #374151;
    font-family: 'Inter', sans-serif;
    border-radius: 16px;
    border: 1px solid #e5e7eb;
  }

  .sol-secondary:hover {
    border-color: #d1d5db;
    background: #fafafa;
  }

  .btn-emoji {
    font-size: 1.25rem;
  }

  .btn-badge {
    font-size: 0.75rem;
    padding: 0.2rem 0.5rem;
    background: rgba(255, 255, 255, 0.2);
    border-radius: 8px;
  }

  .btn-arrow {
    transition: transform 0.3s;
  }

  .cta-btn:hover .btn-arrow {
    transform: translateX(4px);
  }

  /* Hero Stats */
  .hero-stats {
    display: flex;
    flex-wrap: wrap;
    gap: 1.5rem;
    align-items: center;
  }

  .stat-item {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  [data-mode="kasra"] .stat-item {
    flex-direction: column;
    text-align: center;
    gap: 0.25rem;
  }

  [data-mode="kasra"] .stat-label {
    font-family: 'Geist Mono', monospace;
    font-size: 0.65rem;
    color: rgba(255, 255, 255, 0.4);
    letter-spacing: 0.1em;
  }

  [data-mode="kasra"] .stat-value {
    font-family: 'Geist Mono', monospace;
    font-size: 1.25rem;
    color: #00ff88;
    font-variant-numeric: tabular-nums;
  }

  .status-nominal {
    animation: statusPulse 2s ease-in-out infinite;
  }

  @keyframes statusPulse {
    0%, 100% { color: #00ff88; }
    50% { color: #00cc6a; }
  }

  [data-mode="river"] .stat-symbol {
    font-size: 1rem;
    color: var(--river-accent, #d4a854);
  }

  [data-mode="river"] .stat-text {
    font-family: 'Cormorant Garamond', serif;
    font-size: 0.95rem;
    color: rgba(255, 255, 255, 0.6);
  }

  [data-mode="sol"] .stat-emoji {
    font-size: 1.25rem;
  }

  [data-mode="sol"] .stat-text {
    font-family: 'Inter', sans-serif;
    font-size: 0.9rem;
    color: #6b7280;
  }

  /* Scroll Hint */
  .scroll-hint {
    position: absolute;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%);
    text-align: center;
    animation: floatUpDown 3s ease-in-out infinite;
  }

  @keyframes floatUpDown {
    0%, 100% { transform: translateX(-50%) translateY(0); }
    50% { transform: translateX(-50%) translateY(-10px); }
  }

  .scroll-text {
    display: block;
    margin-bottom: 0.5rem;
    font-size: 0.8rem;
  }

  [data-mode="kasra"] .scroll-text {
    font-family: 'Geist Mono', monospace;
    color: rgba(0, 255, 136, 0.5);
    letter-spacing: 0.1em;
  }

  [data-mode="river"] .scroll-text {
    font-family: 'Cormorant Garamond', serif;
    color: rgba(255, 255, 255, 0.4);
    font-style: italic;
  }

  [data-mode="sol"] .scroll-text {
    font-family: 'Inter', sans-serif;
    color: #9ca3af;
  }

  .scroll-arrow {
    animation: bounce 2s infinite;
  }

  [data-mode="kasra"] .scroll-arrow { color: #00ff88; }
  [data-mode="river"] .scroll-arrow { color: rgba(255, 255, 255, 0.4); }
  [data-mode="sol"] .scroll-arrow { color: #f59e0b; }

  @keyframes bounce {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(5px); }
  }

  /* ==========================================
     SECTION STYLES
     ========================================== */
  section {
    position: relative;
    z-index: 1;
    padding: 5rem 1.5rem;
  }

  .section-container {
    max-width: 1100px;
    margin: 0 auto;
  }

  .section-header {
    margin-bottom: 2rem;
  }

  .section-title {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.5rem;
  }

  [data-mode="kasra"] .section-title {
    font-family: 'Geist Mono', monospace;
    font-size: 1.25rem;
    color: #00ff88;
    letter-spacing: 0.05em;
  }

  [data-mode="river"] .section-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.75rem;
    color: rgba(255, 255, 255, 0.9);
    font-weight: 400;
  }

  [data-mode="sol"] .section-title {
    font-family: 'Inter', sans-serif;
    font-size: 1.5rem;
    color: #1f2937;
    font-weight: 600;
  }

  .title-icon {
    font-size: 1.25rem;
  }

  [data-mode="kasra"] .title-icon { color: #00ff88; }
  [data-mode="river"] .title-icon { color: var(--river-accent, #d4a854); }
  [data-mode="sol"] .title-icon { color: #f59e0b; }

  .section-description {
    max-width: 600px;
  }

  [data-mode="kasra"] .section-description {
    font-family: 'Geist Mono', monospace;
    font-size: 0.9rem;
    color: rgba(255, 255, 255, 0.5);
    line-height: 1.7;
  }

  [data-mode="river"] .section-description {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.125rem;
    color: rgba(255, 255, 255, 0.6);
    line-height: 1.8;
  }

  [data-mode="sol"] .section-description {
    font-family: 'Inter', sans-serif;
    font-size: 1rem;
    color: #6b7280;
    line-height: 1.6;
  }

  .section-subtitle {
    margin-bottom: 2rem;
  }

  /* ==========================================
     THEATER PREVIEW
     ========================================== */
  .theater-preview-section {
    padding-top: 3rem;
  }

  [data-mode="kasra"] .theater-preview-section {
    background: linear-gradient(180deg, transparent 0%, rgba(0, 255, 136, 0.02) 100%);
  }

  [data-mode="river"] .theater-preview-section {
    background: linear-gradient(180deg, transparent 0%, rgba(139, 92, 246, 0.03) 100%);
  }

  [data-mode="sol"] .theater-preview-section {
    background: linear-gradient(180deg, transparent 0%, rgba(251, 191, 36, 0.05) 100%);
  }

  .theater-frame-wrapper {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
    margin-bottom: 2rem;
  }

  .theater-frame {
    position: relative;
    width: 100%;
    max-width: 600px;
    aspect-ratio: 16/10;
    overflow: hidden;
  }

  [data-mode="kasra"] .theater-frame {
    background: #0a0a0a;
    border: 1px solid rgba(0, 255, 136, 0.3);
    box-shadow: 0 0 40px rgba(0, 255, 136, 0.1);
  }

  [data-mode="river"] .theater-frame {
    background: rgba(13, 13, 21, 0.8);
    border: 1px solid rgba(139, 92, 246, 0.2);
    box-shadow: 0 0 60px rgba(139, 92, 246, 0.1);
  }

  [data-mode="sol"] .theater-frame {
    background: white;
    border-radius: 16px;
    border: 1px solid #e5e7eb;
    box-shadow: 0 10px 40px rgba(0, 0, 0, 0.08);
  }

  .frame-corner {
    position: absolute;
    width: 20px;
    height: 20px;
    border-style: solid;
    border-width: 0;
    z-index: 5;
  }

  [data-mode="kasra"] .frame-corner { border-color: #00ff88; }
  [data-mode="river"] .frame-corner { border-color: var(--river-accent, #d4a854); }
  [data-mode="sol"] .frame-corner { display: none; }

  .frame-corner.tl { top: -1px; left: -1px; border-top-width: 2px; border-left-width: 2px; }
  .frame-corner.tr { top: -1px; right: -1px; border-top-width: 2px; border-right-width: 2px; }
  .frame-corner.bl { bottom: -1px; left: -1px; border-bottom-width: 2px; border-left-width: 2px; }
  .frame-corner.br { bottom: -1px; right: -1px; border-bottom-width: 2px; border-right-width: 2px; }

  .theater-screen {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .curtain {
    position: absolute;
    top: 0;
    bottom: 0;
    width: 50%;
    transition: transform 1.5s cubic-bezier(0.4, 0, 0.2, 1);
    z-index: 3;
  }

  [data-mode="kasra"] .curtain { display: none; }

  [data-mode="river"] .curtain {
    background: linear-gradient(90deg, #2a1515 0%, #3d1f1f 50%, #2a1515 100%);
  }

  [data-mode="sol"] .curtain { display: none; }

  .curtain.left { left: 0; transform-origin: left; }
  .curtain.right { right: 0; transform-origin: right; }

  .theater-screen.open .curtain.left { transform: scaleX(0); }
  .theater-screen.open .curtain.right { transform: scaleX(0); }

  .scene-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .loading-indicator {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .loader-ring {
    width: 50px;
    height: 50px;
    border: 2px solid rgba(0, 255, 136, 0.2);
    border-top-color: #00ff88;
    border-radius: 50%;
    animation: spin 1s linear infinite;
  }

  .loader-mandala {
    width: 60px;
    height: 60px;
    animation: spin 10s linear infinite;
  }

  .loader-mandala svg {
    width: 100%;
    height: 100%;
  }

  .loader-mandala circle {
    fill: none;
    stroke: var(--river-accent, #d4a854);
    stroke-width: 1;
  }

  .loader-spinner {
    width: 40px;
    height: 40px;
    border: 3px solid #e5e7eb;
    border-top-color: #f59e0b;
    border-radius: 50%;
