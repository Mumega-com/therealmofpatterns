  [data-mode="sol"] .philosophy-quote p {
    font-family: 'Inter', sans-serif;
    font-size: 1.25rem;
    color: #f59e0b;
    font-weight: 600;
  }

  /* ==========================================
     FINAL CTA
     ========================================== */
  .final-cta-section {
    padding: 5rem 1.5rem;
    text-align: center;
  }

  [data-mode="kasra"] .final-cta-section {
    background: linear-gradient(180deg, transparent 0%, rgba(0, 255, 136, 0.03) 100%);
  }

  [data-mode="river"] .final-cta-section {
    background: linear-gradient(180deg, transparent 0%, rgba(139, 92, 246, 0.05) 100%);
  }

  [data-mode="sol"] .final-cta-section {
    background: white;
  }

  .final-title {
    margin-bottom: 0.75rem;
  }

  [data-mode="kasra"] .final-title {
    font-family: 'Geist Mono', monospace;
    font-size: clamp(1.5rem, 4vw, 2.5rem);
    color: #00ff88;
  }

  [data-mode="river"] .final-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(2rem, 5vw, 3rem);
    color: rgba(255, 255, 255, 0.9);
  }

  [data-mode="sol"] .final-title {
    font-family: 'Inter', sans-serif;
    font-size: clamp(1.5rem, 4vw, 2.25rem);
    color: #1f2937;
    font-weight: 700;
  }

  .final-subtitle {
    margin-bottom: 2rem;
  }

  [data-mode="kasra"] .final-subtitle {
    font-family: 'Geist Mono', monospace;
    font-size: 0.9rem;
    color: rgba(255, 255, 255, 0.5);
  }

  [data-mode="river"] .final-subtitle {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.15rem;
    color: rgba(255, 255, 255, 0.6);
    font-style: italic;
  }

  [data-mode="sol"] .final-subtitle {
    font-family: 'Inter', sans-serif;
    font-size: 1rem;
    color: #6b7280;
  }

  .final-ctas {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    justify-content: center;
  }

  .final-secondary {
    padding: 1rem 2rem;
  }

  [data-mode="kasra"] .final-secondary {
    border: 1px solid rgba(0, 255, 136, 0.4);
    color: #00ff88;
    font-family: 'Geist Mono', monospace;
  }

  [data-mode="river"] .final-secondary {
    border: 1px solid rgba(255, 255, 255, 0.2);
    color: rgba(255, 255, 255, 0.8);
    font-family: 'Cormorant Garamond', serif;
  }

  [data-mode="sol"] .final-secondary {
    background: white;
    border: 1px solid #e5e7eb;
    color: #374151;
    font-family: 'Inter', sans-serif;
    border-radius: 16px;
  }

  .final-primary {
    padding: 1rem 2rem;
  }

  [data-mode="kasra"] .final-primary {
    background: #00ff88;
    color: #050508;
    font-family: 'Geist Mono', monospace;
  }

  [data-mode="river"] .final-primary {
    background: rgba(139, 92, 246, 0.2);
    border: 1px solid rgba(139, 92, 246, 0.4);
    color: white;
    font-family: 'Cormorant Garamond', serif;
  }

  [data-mode="sol"] .final-primary {
    background: linear-gradient(135deg, #f59e0b 0%, #d97706 100%);
    color: white;
    font-family: 'Inter', sans-serif;
    border-radius: 16px;
    box-shadow: 0 4px 15px rgba(245, 158, 11, 0.3);
  }

  /* ==========================================
     RESPONSIVE
     ========================================== */
  @media (max-width: 768px) {
    .hero {
      padding: 5rem 1rem 2rem;
    }

    .hero-stats {
      justify-content: center;
    }

    section {
      padding: 3rem 1rem;
    }
  }
</style>

<script>
  // Initialize mode from storage or default
  document.addEventListener('DOMContentLoaded', () => {
    const savedMode = localStorage.getItem('rop_mode') || 'sol';
    document.documentElement.dataset.mode = savedMode;

    // Create background effects
    createKasraDataRain();
    createRiverStars();
    createRiverSymbols();
    createSolShapes();

    // Set Sol greeting based on time
    setSolGreeting();

    // Fetch live stats
    fetchLiveStats();

    // Fetch current scene
    fetchCurrentScene();

    // Listen for mode changes
    window.addEventListener('modechange', (e: CustomEvent) => {
      // Re-render effects when mode changes
    });
  });

  function createKasraDataRain() {
    const container = document.getElementById('kasra-data-rain');
    if (!container) return;

    const chars = ['0', '1', 'κ', 'μ', 'Δ', '◆', '▲', '█'];
    for (let i = 0; i < 25; i++) {
      const span = document.createElement('span');
      span.textContent = chars[Math.floor(Math.random() * chars.length)];
      span.style.cssText = `
        position: absolute;
        left: ${Math.random() * 100}%;
        font-family: 'Geist Mono', monospace;
        font-size: ${8 + Math.random() * 6}px;
        color: rgba(0, 255, 136, ${0.1 + Math.random() * 0.2});
        animation: dataFall ${6 + Math.random() * 8}s linear infinite;
        animation-delay: ${Math.random() * 8}s;
      `;
      container.appendChild(span);
    }
  }

  function createRiverStars() {
    const container = document.getElementById('river-stars');
    if (!container) return;

    for (let i = 0; i < 80; i++) {
      const star = document.createElement('span');
      star.style.cssText = `
        position: absolute;
        width: ${1 + Math.random() * 2}px;
        height: ${1 + Math.random() * 2}px;
        background: white;
        border-radius: 50%;
        left: ${Math.random() * 100}%;
        top: ${Math.random() * 100}%;
        opacity: ${0.2 + Math.random() * 0.5};
        animation: twinkle ${2 + Math.random() * 3}s ease-in-out infinite;
        animation-delay: ${Math.random() * 3}s;
      `;
      container.appendChild(star);
    }
  }

  function createRiverSymbols() {
    const container = document.getElementById('river-symbols');
    if (!container) return;

    const symbols = ['☿', '☉', '☽', '♃', '♄', '♀', '♂', '✧', '◆', '△'];
    for (let i = 0; i < 15; i++) {
      const span = document.createElement('span');
      span.textContent = symbols[Math.floor(Math.random() * symbols.length)];
      span.style.cssText = `
        position: absolute;
        left: ${Math.random() * 100}%;
        font-size: ${12 + Math.random() * 16}px;
        color: rgba(255, 255, 255, 0.06);
        animation: symbolRise ${15 + Math.random() * 15}s linear infinite;
        animation-delay: ${Math.random() * 20}s;
      `;
      container.appendChild(span);
    }
  }

  function createSolShapes() {
    const container = document.getElementById('sol-shapes');
    if (!container) return;

    const shapes = ['★', '●', '◆', '○'];
    for (let i = 0; i < 10; i++) {
      const span = document.createElement('span');
      span.innerHTML = shapes[Math.floor(Math.random() * shapes.length)];
      span.style.cssText = `
        position: absolute;
        left: ${Math.random() * 100}%;
        top: ${Math.random() * 100}%;
        font-size: ${14 + Math.random() * 20}px;
        color: ${['#fbbf24', '#f59e0b', '#ec4899', '#8b5cf6'][Math.floor(Math.random() * 4)]};
        opacity: 0.12;
        animation: shapeFloat ${10 + Math.random() * 10}s ease-in-out infinite;
        animation-delay: ${Math.random() * 10}s;
      `;
      container.appendChild(span);
    }
  }

  function setSolGreeting() {
    const greetingEl = document.getElementById('sol-greeting');
    if (!greetingEl) return;

    const hour = new Date().getHours();
    if (hour < 12) greetingEl.textContent = 'Good morning!';
    else if (hour < 17) greetingEl.textContent = 'Good afternoon!';
    else greetingEl.textContent = 'Good evening!';
  }

  function fetchLiveStats() {
    // Simulate live stats (would be real API in production)
    const witnesses = Math.floor(Math.random() * 50) + 10;
    const scenes = Math.floor(Math.random() * 100) + 50;

    ['kasra', 'river', 'sol'].forEach(mode => {
      const witnessEl = document.getElementById(`${mode}-witnesses`);
      const sceneEl = document.getElementById(`${mode}-scenes`);
      if (witnessEl) witnessEl.textContent = witnesses.toString();
      if (sceneEl) sceneEl.textContent = scenes.toString();
    });
  }

  async function fetchCurrentScene() {
    try {
      const response = await fetch('https://cosmic-channel.weathered-scene-2272.workers.dev/scene');
      const data = await response.json();

      if (data.scene?.imageData) {
        const sceneImage = document.getElementById('scene-image') as HTMLImageElement;
        const theaterScreen = document.getElementById('theater-screen');
        const loadingIndicator = document.querySelector('.loading-indicator') as HTMLElement;
        const stageBadge = document.getElementById('stage-badge');

        if (sceneImage) {
          sceneImage.src = data.scene.imageData.startsWith('data:')
            ? data.scene.imageData
            : `data:image/png;base64,${data.scene.imageData}`;

          sceneImage.onload = () => {
            if (loadingIndicator) loadingIndicator.style.display = 'none';
            sceneImage.style.display = 'block';
            theaterScreen?.classList.add('open');
          };
        }

        if (stageBadge && data.scene.stage) {
          stageBadge.textContent = data.scene.stage.toUpperCase();
        }
      }
    } catch (error) {
      console.log('Could not fetch scene');
      const theaterScreen = document.getElementById('theater-screen');
      theaterScreen?.classList.add('open');
    }
  }

  // Add keyframes via JS for dynamic animations
  const style = document.createElement('style');
  style.textContent = `
    @keyframes dataFall {
      0% { transform: translateY(-20px); opacity: 0; }
      10% { opacity: 0.3; }
      90% { opacity: 0.3; }
      100% { transform: translateY(100vh); opacity: 0; }
    }
    @keyframes twinkle {
      0%, 100% { opacity: 0.2; }
      50% { opacity: 0.8; }
    }
    @keyframes symbolRise {
      0% { transform: translateY(100vh) rotate(0deg); opacity: 0; }
      10% { opacity: 0.08; }
      90% { opacity: 0.08; }
      100% { transform: translateY(-50px) rotate(180deg); opacity: 0; }
    }
    @keyframes shapeFloat {
      0%, 100% { transform: translateY(0) rotate(0deg); }
      50% { transform: translateY(-25px) rotate(10deg); }
    }
  `;
  document.head.appendChild(style);
</script>
