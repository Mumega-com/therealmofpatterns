---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="The Realm of Patterns - Know Your Energy, Shape Your Day"
  description="A 1-minute daily check-in reveals your optimal windows for focus, creativity, and connection. Personal energy forecasting based on cosmic patterns."
  transparentHeader={true}
>
  <div class="landing-page">
    <!-- ============================================
         HERO SECTION
         ============================================ -->
    <section class="hero">
      <div class="hero-bg">
        <div class="glow glow-1"></div>
        <div class="glow glow-2"></div>
        <div class="stars"></div>
      </div>

      <div class="hero-content">
        <div class="trust-badge">
          <span class="pulse"></span>
          <span>15,000+ daily readings</span>
        </div>

        <h1>
          <span class="line-1">Know your energy.</span>
          <span class="line-2">Shape your day.</span>
        </h1>

        <p class="subtitle">
          A 1-minute check-in reveals when you'll feel most focused, creative, and connected today.
          No mystical nonsense—just patterns that work.
        </p>

        <a href="/sol/checkin" class="cta-primary">
          <span>Start Your Free Reading</span>
          <span class="badge">1 min</span>
          <span class="arrow">&rarr;</span>
        </a>

        <p class="micro-copy">
          No signup required &bull; Works offline &bull; Your data stays private
        </p>
      </div>

      <div class="scroll-hint">
        <span>Discover how it works</span>
        <span class="arrow">&darr;</span>
      </div>
    </section>

    <!-- ============================================
         COSMIC THEATER PREVIEW
         ============================================ -->
    <section class="theater-section">
      <div class="container">
        <div class="section-header">
          <span class="section-icon">&starf;</span>
          <h2>The Cosmic Theater</h2>
          <p class="section-desc">
            Every hour, AI creates new alchemical art based on planetary positions.
            Watch the cosmic dance unfold in real-time.
          </p>
        </div>

        <div class="theater-preview">
          <div class="theater-frame">
            <div class="frame-glow"></div>
            <div class="theater-content" id="theater-content">
              <img
                id="scene-image"
                src="/assets/theater/placeholder.jpg"
                alt="Current cosmic scene"
                onerror="this.style.display='none'; document.getElementById('theater-placeholder').style.display='flex';"
              />
              <div id="theater-placeholder" class="theater-placeholder">
                <div class="placeholder-icon">&starf;</div>
                <span>Loading cosmic scene...</span>
              </div>
            </div>
            <div class="theater-info">
              <span class="stage-badge" id="stage-badge">CITRINITAS</span>
              <span class="live-dot"></span>
              <span class="live-text">Live</span>
            </div>
          </div>

          <a href="/theater" class="theater-cta">
            <span>&triangleright; Enter the Theater</span>
          </a>
        </div>
      </div>
    </section>

    <!-- ============================================
         FEATURES - WHAT YOU GET
         ============================================ -->
    <section class="features-section">
      <div class="container">
        <div class="section-header">
          <span class="section-icon">&diams;</span>
          <h2>Your Personal Pattern</h2>
          <p class="section-desc">
            Understand your energy rhythms and work with them, not against them.
          </p>
        </div>

        <div class="features-grid">
          <div class="feature-card">
            <div class="feature-icon">&sung;</div>
            <h3>Daily Oracle</h3>
            <p>
              Each morning brings new patterns. A quick check-in reveals which
              energies are strongest for you today—and when to lean into them.
            </p>
          </div>

          <div class="feature-card">
            <div class="feature-icon">&loz;</div>
            <h3>Pattern Memory</h3>
            <p>
              Track how your energy evolves over time. Notice what works,
              what doesn't, and discover your personal rhythms.
            </p>
          </div>

          <div class="feature-card">
            <div class="feature-icon">&watch;</div>
            <h3>Optimal Windows</h3>
            <p>
              Know when the currents favor action, connection, or rest.
              Schedule important tasks when your energy is highest.
            </p>
          </div>
        </div>

        <div class="features-cta">
          <a href="/sol/checkin" class="cta-secondary">
            Receive Your Reading &rarr;
          </a>
          <span class="cta-note">No account required &bull; Takes 60 seconds</span>
        </div>
      </div>
    </section>

    <!-- ============================================
         HOW IT WORKS
         ============================================ -->
    <section class="how-section">
      <div class="container">
        <div class="section-header">
          <span class="section-icon">&oplus;</span>
          <h2>The Practice</h2>
          <p class="section-desc">
            A simple daily ritual for understanding your energy.
          </p>
        </div>

        <div class="steps-grid">
          <div class="step-card">
            <div class="step-number">1</div>
            <div class="step-icon">&female;</div>
            <h3>Share Your Birth Moment</h3>
            <p>
              The moment you entered this world holds the seed of your pattern—your cosmic fingerprint.
              Just birth date, time, and place. Takes 30 seconds.
            </p>
          </div>

          <div class="step-card">
            <div class="step-number">2</div>
            <div class="step-icon">&spades;</div>
            <h3>Daily Check-in</h3>
            <p>
              Answer 6 quick questions about how you're feeling right now.
              The patterns will speak your current truth. Takes about 1 minute.
            </p>
          </div>

          <div class="step-card">
            <div class="step-number">3</div>
            <div class="step-icon">&hearts;</div>
            <h3>Live Your Pattern</h3>
            <p>
              Know your best hours for action, connection, and rest.
              Move with the cosmic rhythm, not against it.
            </p>
          </div>
        </div>

        <div class="how-cta">
          <a href="/sol/checkin" class="cta-primary">
            <span>Begin the Practice</span>
            <span class="arrow">&rarr;</span>
          </a>
        </div>
      </div>
    </section>

    <!-- ============================================
         PRICING
         ============================================ -->
    <section class="pricing-section">
      <div class="container">
        <div class="section-header">
          <span class="section-icon">&starf;</span>
          <h2>Simple Plans</h2>
          <p class="section-desc">
            Start free. Upgrade when you're ready to go deeper.
          </p>
        </div>

        <div class="pricing-grid">
          <!-- Free Tier -->
          <div class="pricing-card">
            <div class="card-header">
              <span class="card-badge">Always Free</span>
              <h3>Witness</h3>
              <div class="card-price">
                <span class="price">$0</span>
                <span class="period">forever</span>
              </div>
            </div>
            <ul class="card-features">
              <li><span class="check">&check;</span> Watch the Cosmic Theater</li>
              <li><span class="check">&check;</span> Daily energy reading</li>
              <li><span class="check">&check;</span> Basic dimension breakdown</li>
            </ul>
            <a href="/sol/checkin" class="card-btn secondary">Start Witnessing</a>
          </div>

          <!-- Pro Tier -->
          <div class="pricing-card featured">
            <div class="card-header">
              <span class="card-badge featured">Most Popular</span>
              <h3>Pattern-Keeper</h3>
              <div class="card-price">
                <span class="price">$19</span>
                <span class="period">/month</span>
              </div>
            </div>
            <ul class="card-features">
              <li><span class="check">&check;</span> Everything in Witness</li>
              <li><span class="check">&check;</span> Full 16D analysis with shadow</li>
              <li><span class="check">&check;</span> Optimal action windows</li>
              <li><span class="check">&check;</span> Early warning alerts</li>
              <li><span class="check">&check;</span> Pattern memory & trends</li>
            </ul>
            <a href="/subscribe?plan=individual" class="card-btn primary">Begin Your Practice</a>
          </div>

          <!-- Team Tier -->
          <div class="pricing-card">
            <div class="card-header">
              <span class="card-badge">For Teams</span>
              <h3>Circle</h3>
              <div class="card-price">
                <span class="price">$49</span>
                <span class="period">/seat/month</span>
              </div>
            </div>
            <ul class="card-features">
              <li><span class="check">&check;</span> Everything in Pattern-Keeper</li>
              <li><span class="check">&check;</span> Shared team dashboard</li>
              <li><span class="check">&check;</span> Group coherence tracking</li>
              <li><span class="check">&check;</span> API for integrations</li>
            </ul>
            <a href="/subscribe?plan=squad" class="card-btn secondary">Gather Your Circle</a>
            <span class="card-note">Minimum 3 seats</span>
          </div>
        </div>
      </div>
    </section>

    <!-- ============================================
         PHILOSOPHY
         ============================================ -->
    <section class="philosophy-section">
      <div class="container">
        <div class="philosophy-content">
          <blockquote>
            "The cosmos is within us. We are made of star-stuff.
            We are a way for the universe to know itself."
          </blockquote>
          <cite>&mdash; Carl Sagan</cite>
        </div>

        <div class="philosophy-cards">
          <div class="phil-card">
            <span class="phil-icon">&diams;</span>
            <h4>Pattern, Not Prediction</h4>
            <p>We don't tell you what will happen. We show you the currents you're swimming in.</p>
          </div>
          <div class="phil-card">
            <span class="phil-icon">&hearts;</span>
            <h4>Your Data, Your Control</h4>
            <p>Everything runs locally. We never sell your information. Delete anytime.</p>
          </div>
          <div class="phil-card">
            <span class="phil-icon">&spades;</span>
            <h4>Learns With You</h4>
            <p>The more you use it, the more accurate it gets. Your patterns are unique.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- ============================================
         FINAL CTA
         ============================================ -->
    <section class="final-cta-section">
      <div class="container">
        <h2>Ready to Know Your Pattern?</h2>
        <p>The theater is always open. The pattern awaits.</p>
        <div class="final-ctas">
          <a href="/theater" class="cta-secondary">&starf; Watch the Theater</a>
          <a href="/sol/checkin" class="cta-primary">
            <span>Get Your Reading</span>
            <span class="arrow">&rarr;</span>
          </a>
        </div>
      </div>
    </section>
  </div>
</BaseLayout>

<script>
  // Load current theater scene
  async function loadTheaterScene() {
    try {
      const response = await fetch('/api/theater/current');
      if (response.ok) {
        const data = await response.json();
        const img = document.getElementById('scene-image') as HTMLImageElement;
        const placeholder = document.getElementById('theater-placeholder');
        const badge = document.getElementById('stage-badge');

        if (data.imageUrl && img) {
          img.src = data.imageUrl;
          img.style.display = 'block';
          if (placeholder) placeholder.style.display = 'none';
        }

        if (data.stage && badge) {
          badge.textContent = data.stage.toUpperCase();
        }
      }
    } catch (error) {
      // Silently fail - placeholder will show
    }
  }

  // Initialize
  loadTheaterScene();
</script>

<style>
  /* ==========================================
     VARIABLES
     ========================================== */
  .landing-page {
    --gold: #d4a854;
    --gold-light: #e8c88a;
    --gold-dark: #b8924a;
    --dark: #0a0908;
    --dark-surface: #141210;
    --dark-border: rgba(212, 168, 84, 0.15);
    --text: #f0e8d8;
    --text-muted: rgba(240, 232, 216, 0.6);
    --text-dim: rgba(240, 232, 216, 0.4);
    --purple: #a78bfa;
    --green: #22c55e;

    font-family: 'Cormorant Garamond', Georgia, serif;
    background: var(--dark);
    color: var(--text);
  }

  .container {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  /* ==========================================
     HERO
     ========================================== */
  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 2rem;
    overflow: hidden;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  .glow {
    position: absolute;
    border-radius: 50%;
    filter: blur(100px);
  }

  .glow-1 {
    width: 600px;
    height: 600px;
    background: radial-gradient(circle, rgba(212, 168, 84, 0.25) 0%, transparent 70%);
    top: 5%;
    left: 15%;
    animation: float 12s ease-in-out infinite;
  }

  .glow-2 {
    width: 500px;
    height: 500px;
    background: radial-gradient(circle, rgba(167, 139, 250, 0.15) 0%, transparent 70%);
    bottom: 10%;
    right: 10%;
    animation: float 15s ease-in-out infinite reverse;
  }

  .stars {
    position: absolute;
    inset: 0;
    background-image: radial-gradient(2px 2px at 20px 30px, rgba(255,255,255,0.3), transparent),
                      radial-gradient(2px 2px at 40px 70px, rgba(255,255,255,0.2), transparent),
                      radial-gradient(1px 1px at 90px 40px, rgba(255,255,255,0.4), transparent),
                      radial-gradient(2px 2px at 130px 80px, rgba(255,255,255,0.2), transparent),
                      radial-gradient(1px 1px at 160px 120px, rgba(255,255,255,0.3), transparent);
    background-size: 200px 200px;
    opacity: 0.5;
  }

  @keyframes float {
    0%, 100% { transform: translate(0, 0); }
    50% { transform: translate(30px, -30px); }
  }

  .hero-content {
    position: relative;
    z-index: 1;
    max-width: 650px;
    text-align: center;
  }

  .trust-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 1rem;
    background: rgba(212, 168, 84, 0.1);
    border: 1px solid rgba(212, 168, 84, 0.2);
    border-radius: 100px;
    font-size: 0.85rem;
    color: var(--text-muted);
    margin-bottom: 2rem;
    font-family: 'Inter', sans-serif;
  }

  .pulse {
    width: 8px;
    height: 8px;
    background: var(--green);
    border-radius: 50%;
    animation: pulse 2s infinite;
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.5; transform: scale(1.3); }
  }

  .hero h1 {
    font-weight: 300;
    line-height: 1.1;
    margin: 0 0 1.5rem;
  }

  .line-1 {
    display: block;
    font-size: clamp(2.5rem, 7vw, 4rem);
    color: var(--text);
  }

  .line-2 {
    display: block;
    font-size: clamp(2rem, 5.5vw, 3.2rem);
    color: var(--gold);
  }

  .subtitle {
    font-size: 1.15rem;
    color: var(--text-muted);
    line-height: 1.7;
    margin-bottom: 2.5rem;
    max-width: 520px;
    margin-left: auto;
    margin-right: auto;
  }

  .cta-primary {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    padding: 1rem 2rem;
    background: linear-gradient(135deg, var(--gold) 0%, var(--gold-dark) 100%);
    color: var(--dark);
    font-size: 1.1rem;
    font-weight: 600;
    text-decoration: none;
    border-radius: 12px;
    box-shadow: 0 4px 24px rgba(212, 168, 84, 0.3);
    transition: all 0.3s ease;
    font-family: 'Inter', sans-serif;
  }

  .cta-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 32px rgba(212, 168, 84, 0.4);
  }

  .cta-primary .badge {
    padding: 0.2rem 0.5rem;
    background: rgba(10, 9, 8, 0.2);
    border-radius: 6px;
    font-size: 0.8rem;
    font-weight: 500;
  }

  .cta-primary .arrow {
    font-size: 1.2rem;
    transition: transform 0.3s;
  }

  .cta-primary:hover .arrow {
    transform: translateX(4px);
  }

  .micro-copy {
    margin-top: 1rem;
    font-size: 0.85rem;
    color: var(--text-dim);
    font-family: 'Inter', sans-serif;
  }

  .scroll-hint {
    position: absolute;
    bottom: 2rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.85rem;
    color: var(--text-dim);
    cursor: pointer;
    transition: color 0.3s;
  }

  .scroll-hint:hover {
    color: var(--gold);
  }

  .scroll-hint .arrow {
    animation: bounce 2s infinite;
  }

  @keyframes bounce {
    0%, 20%, 50%, 80%, 100% { transform: translateY(0); }
    40% { transform: translateY(8px); }
    60% { transform: translateY(4px); }
  }

  /* ==========================================
     SECTIONS COMMON
     ========================================== */
  section {
    padding: 5rem 0;
  }

  .section-header {
    text-align: center;
    margin-bottom: 3rem;
  }

  .section-icon {
    display: block;
    font-size: 1.5rem;
    color: var(--gold);
    margin-bottom: 0.75rem;
  }

  .section-header h2 {
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    font-weight: 400;
    color: var(--text);
    margin: 0 0 1rem;
  }

  .section-desc {
    font-size: 1.1rem;
    color: var(--text-muted);
    max-width: 550px;
    margin: 0 auto;
    line-height: 1.6;
  }

  /* ==========================================
     THEATER SECTION
     ========================================== */
  .theater-section {
    background: linear-gradient(180deg, var(--dark) 0%, var(--dark-surface) 100%);
  }

  .theater-preview {
    max-width: 700px;
    margin: 0 auto;
    text-align: center;
  }

  .theater-frame {
    position: relative;
    aspect-ratio: 16/9;
    background: var(--dark);
    border: 1px solid var(--dark-border);
    border-radius: 12px;
    overflow: hidden;
    margin-bottom: 1.5rem;
  }

  .frame-glow {
    position: absolute;
    inset: -50%;
    background: radial-gradient(circle at center, rgba(212, 168, 84, 0.1) 0%, transparent 50%);
    pointer-events: none;
  }

  .theater-content {
    position: relative;
    width: 100%;
    height: 100%;
  }

  .theater-content img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .theater-placeholder {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    height: 100%;
    color: var(--text-muted);
    font-size: 0.9rem;
  }

  .placeholder-icon {
    font-size: 2.5rem;
    color: var(--gold);
    margin-bottom: 0.75rem;
    animation: pulse 3s infinite;
  }

  .theater-info {
    position: absolute;
    bottom: 1rem;
    left: 1rem;
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-size: 0.8rem;
    font-family: 'Inter', sans-serif;
  }

  .stage-badge {
    padding: 0.3rem 0.6rem;
    background: rgba(212, 168, 84, 0.2);
    border: 1px solid rgba(212, 168, 84, 0.3);
    border-radius: 4px;
    color: var(--gold);
    font-weight: 500;
    letter-spacing: 0.05em;
  }

  .live-dot {
    width: 8px;
    height: 8px;
    background: #ef4444;
    border-radius: 50%;
    animation: pulse 2s infinite;
  }

  .live-text {
    color: var(--text-muted);
  }

  .theater-cta {
    display: inline-flex;
    padding: 0.75rem 1.5rem;
    border: 1px solid var(--dark-border);
    border-radius: 8px;
    color: var(--gold);
    text-decoration: none;
    font-size: 1rem;
    transition: all 0.3s;
  }

  .theater-cta:hover {
    background: rgba(212, 168, 84, 0.1);
    border-color: var(--gold);
  }

  /* ==========================================
     FEATURES SECTION
     ========================================== */
  .features-section {
    background: var(--dark-surface);
  }

  .features-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 1.5rem;
    margin-bottom: 3rem;
  }

  .feature-card {
    padding: 2rem;
    background: rgba(255, 255, 255, 0.02);
    border: 1px solid var(--dark-border);
    border-radius: 16px;
    transition: all 0.3s;
  }

  .feature-card:hover {
    background: rgba(212, 168, 84, 0.05);
    border-color: rgba(212, 168, 84, 0.3);
    transform: translateY(-4px);
  }

  .feature-icon {
    font-size: 2rem;
    color: var(--gold);
    margin-bottom: 1rem;
  }

  .feature-card h3 {
    font-size: 1.3rem;
    font-weight: 400;
    color: var(--text);
    margin: 0 0 0.75rem;
  }

  .feature-card p {
    font-size: 1rem;
    color: var(--text-muted);
    line-height: 1.6;
    margin: 0;
  }

  .features-cta {
    text-align: center;
  }

  .cta-secondary {
    display: inline-flex;
    padding: 0.875rem 1.75rem;
    border: 1px solid var(--gold);
    border-radius: 10px;
    color: var(--gold);
    text-decoration: none;
    font-size: 1.05rem;
    font-weight: 500;
    transition: all 0.3s;
    font-family: 'Inter', sans-serif;
  }

  .cta-secondary:hover {
    background: var(--gold);
    color: var(--dark);
  }

  .cta-note {
    display: block;
    margin-top: 0.75rem;
    font-size: 0.85rem;
    color: var(--text-dim);
    font-family: 'Inter', sans-serif;
  }

  /* ==========================================
     HOW IT WORKS
     ========================================== */
  .how-section {
    background: var(--dark);
  }

  .steps-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 2rem;
    margin-bottom: 3rem;
  }

  .step-card {
    position: relative;
    padding: 2rem;
    background: rgba(255, 255, 255, 0.02);
    border: 1px solid var(--dark-border);
    border-radius: 16px;
    text-align: center;
  }

  .step-number {
    position: absolute;
    top: -0.75rem;
    left: 50%;
    transform: translateX(-50%);
    width: 2rem;
    height: 2rem;
    background: var(--gold);
    color: var(--dark);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.9rem;
    font-weight: 600;
    font-family: 'Inter', sans-serif;
  }

  .step-icon {
    font-size: 2rem;
    color: var(--purple);
    margin: 1rem 0;
  }

  .step-card h3 {
    font-size: 1.2rem;
    font-weight: 400;
    color: var(--text);
    margin: 0 0 0.75rem;
  }

  .step-card p {
    font-size: 0.95rem;
    color: var(--text-muted);
    line-height: 1.6;
    margin: 0;
  }

  .how-cta {
    text-align: center;
  }

  /* ==========================================
     PRICING
     ========================================== */
  .pricing-section {
    background: linear-gradient(180deg, var(--dark) 0%, var(--dark-surface) 100%);
  }

  .pricing-grid {
    display: grid;
