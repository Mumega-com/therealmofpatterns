---
import BaseLayout from '../layouts/BaseLayout.astro';
import { EmailCapture } from '../components/shared/EmailCapture';
---

<BaseLayout
  title="The Realm of Patterns — A Daily Practice with Sol"
  description="A 1-minute daily check-in. Sol reads your natal field and offers a personalized reflection — depth psychology, not horoscopes."
  transparentHeader={true}
>
  <div class="landing-page">
    <!-- ============================================
         HERO SECTION
         ============================================ -->
    <section class="hero">
      <div class="hero-bg">
        <div class="glow glow-1"></div>
        <div class="glow glow-2"></div>
        <div class="stars"></div>
      </div>

      <div class="hero-content">
        <div class="trust-badge">
          <span class="pulse"></span>
          <span>Free — no signup required</span>
        </div>

        <h1>
          <span class="line-1">A daily practice</span>
          <span class="line-2">with your own narrator.</span>
        </h1>

        <p class="subtitle">
          Each day, check in. Sol reads your natal pattern and today's state —
          and offers a reflection rooted in depth psychology.
          No predictions. Real presence.
        </p>

        <a href="/discover" class="cta-primary">
          <span>Begin the practice</span>
          <span class="badge">free</span>
          <span class="arrow">&rarr;</span>
        </a>

        <p class="micro-copy">
          No signup required &bull; Your data stays private &bull; Works offline
        </p>
      </div>

      <div class="scroll-hint">
        <span>Discover how it works</span>
        <span class="arrow">&darr;</span>
      </div>
    </section>

    <!-- ============================================
         TODAY'S READING PREVIEW
         ============================================ -->
    <section class="reading-preview-section">
      <div class="container">
        <div class="reading-preview-card" id="reading-preview">
          <div class="reading-preview-header">
            <span class="reading-preview-icon">☽</span>
            <span class="reading-preview-label">Today's Energy</span>
          </div>
          <p class="reading-preview-text" id="reading-preview-text">
            See what today's planetary alignments mean for you.
          </p>
          <a href="/reading" class="reading-preview-link">
            Read more &rarr;
          </a>
        </div>
      </div>
    </section>

    <!-- ============================================
         FEATURES - WHAT YOU GET
         ============================================ -->
    <section class="features-section">
      <div class="container">
        <div class="section-header">
          <span class="section-icon">&diams;</span>
          <h2>Your Personal Pattern</h2>
          <p class="section-desc">
            Understand your energy rhythms and work with them, not against them.
          </p>
        </div>

        <div class="features-grid">
          <div class="feature-card">
            <div class="feature-icon">&sung;</div>
            <h3>Sol's Daily Reading</h3>
            <p>
              After your check-in, Sol writes a personalized reflection — not a forecast,
              but a mirror. What moves in you today, held in Jungian language.
            </p>
          </div>

          <div class="feature-card">
            <div class="feature-icon">&loz;</div>
            <h3>Your Natal Field</h3>
            <p>
              Your birth data maps to an 8-dimensional pattern — rendered as a living
              3D geometry. Shareable. Unique to you.
            </p>
          </div>

          <div class="feature-card">
            <div class="feature-icon">&watch;</div>
            <h3>The Arc Over Time</h3>
            <p>
              Seven days of check-ins give Sol enough to read the week as a whole —
              the pattern across your days, not just each one in isolation.
            </p>
          </div>
        </div>

        <div class="features-cta">
          <a href="/discover" class="cta-secondary">
            Discover Your Pattern &rarr;
          </a>
          <span class="cta-note">No account required &bull; Takes 60 seconds</span>
        </div>
      </div>
    </section>

    <!-- ============================================
         HOW IT WORKS
         ============================================ -->
    <section class="how-section">
      <div class="container">
        <div class="section-header">
          <span class="section-icon">&oplus;</span>
          <h2>How It Works</h2>
          <p class="section-desc">
            A loop designed to deepen, not just inform.
          </p>
        </div>

        <div class="steps-grid">
          <div class="step-card">
            <div class="step-number">1</div>
            <div class="step-icon">&female;</div>
            <h3>Map Your Natal Field</h3>
            <p>
              Enter your birth date, time, and place. Sol computes your natal geometry —
              a unique 8-dimensional pattern that anchors every reading.
            </p>
          </div>

          <div class="step-card">
            <div class="step-number">2</div>
            <div class="step-icon">&spades;</div>
            <h3>Check In Each Day</h3>
            <p>
              Five questions. One minute. Sol reads your answers alongside your natal pattern
              and writes you a personalized reflection.
            </p>
          </div>

          <div class="step-card">
            <div class="step-number">3</div>
            <div class="step-icon">&hearts;</div>
            <h3>The Pattern Deepens</h3>
            <p>
              After a week, Sol can read the arc — not just the day, but what moved through
              the whole week. The longer you practice, the deeper the field.
            </p>
          </div>
        </div>

        <div class="how-cta">
          <a href="/discover" class="cta-primary">
            <span>Begin the practice</span>
            <span class="arrow">&rarr;</span>
          </a>
        </div>
      </div>
    </section>

    <!-- ============================================
         ARCHETYPE STRIP
         ============================================ -->
    <section class="archetypes-section">
      <div class="container">
        <div class="section-header">
          <span class="section-icon">◈</span>
          <h2>The 8 Energy Archetypes</h2>
          <p class="section-desc">
            Every person carries a dominant pattern. Which one is yours?
          </p>
        </div>

        <div class="archetypes-grid">
          <a href="/archetype/hero" class="archetype-card">
            <span class="arch-symbol">☀</span>
            <span class="arch-name">The Hero</span>
            <span class="arch-planet">Sun</span>
          </a>
          <a href="/archetype/ruler" class="archetype-card">
            <span class="arch-symbol">♄</span>
            <span class="arch-name">The Ruler</span>
            <span class="arch-planet">Saturn</span>
          </a>
          <a href="/archetype/sage" class="archetype-card">
            <span class="arch-symbol">☿</span>
            <span class="arch-name">The Sage</span>
            <span class="arch-planet">Mercury</span>
          </a>
          <a href="/archetype/creator" class="archetype-card">
            <span class="arch-symbol">♀</span>
            <span class="arch-name">The Creator</span>
            <span class="arch-planet">Venus</span>
          </a>
          <a href="/archetype/explorer" class="archetype-card">
            <span class="arch-symbol">♃</span>
            <span class="arch-name">The Explorer</span>
            <span class="arch-planet">Jupiter</span>
          </a>
          <a href="/archetype/warrior" class="archetype-card">
            <span class="arch-symbol">♂</span>
            <span class="arch-name">The Warrior</span>
            <span class="arch-planet">Mars</span>
          </a>
          <a href="/archetype/caregiver" class="archetype-card">
            <span class="arch-symbol">☽</span>
            <span class="arch-name">The Caregiver</span>
            <span class="arch-planet">Moon</span>
          </a>
          <a href="/archetype/mystic" class="archetype-card">
            <span class="arch-symbol">♅</span>
            <span class="arch-name">The Mystic</span>
            <span class="arch-planet">Uranus</span>
          </a>
        </div>

        <div class="archetypes-cta">
          <a href="/hidden-gifts" class="cta-secondary">Find my archetype →</a>
        </div>
      </div>
    </section>

    <!-- ============================================
         PRICING
         ============================================ -->
    <section class="pricing-section">
      <div class="container">
        <div class="section-header">
          <span class="section-icon">&starf;</span>
          <h2>Simple Plans</h2>
          <p class="section-desc">
            Start free. Upgrade when you're ready to go deeper.
          </p>
        </div>

        <div class="pricing-grid">
          <!-- Free Tier -->
          <div class="pricing-card">
            <div class="card-header">
              <span class="card-badge">Always Free</span>
              <h3>Free</h3>
              <div class="card-price">
                <span class="price">$0</span>
                <span class="period">forever</span>
              </div>
            </div>
            <ul class="card-features">
              <li><span class="check">&check;</span> Daily check-in</li>
              <li><span class="check">&check;</span> Sol's daily reading</li>
              <li><span class="check">&check;</span> Soul toroid & sharing</li>
            </ul>
            <a href="/discover" class="card-btn secondary">Get Started Free</a>
          </div>

          <!-- Pro Tier -->
          <div class="pricing-card featured">
            <div class="card-header">
              <span class="card-badge featured">Most Popular</span>
              <h3>Pro</h3>
              <div class="card-price">
                <span class="price">$9</span>
                <span class="period">/month</span>
              </div>
            </div>
            <ul class="card-features">
              <li><span class="check">&check;</span> Everything in Free</li>
              <li><span class="check">&check;</span> Deeper Sol model</li>
              <li><span class="check">&check;</span> Weekly synthesis</li>
              <li><span class="check">&check;</span> Soul field comparison</li>
              <li><span class="check">&check;</span> Support the work</li>
            </ul>
            <a href="/subscribe?plan=individual" class="card-btn primary">Start Free Trial</a>
          </div>

          <!-- Team Tier -->
          <div class="pricing-card">
            <div class="card-header">
              <span class="card-badge">For Teams</span>
              <h3>Team</h3>
              <div class="card-price">
                <span class="price">$29</span>
                <span class="period">/seat/month</span>
              </div>
            </div>
            <ul class="card-features">
              <li><span class="check">&check;</span> Everything in Pro</li>
              <li><span class="check">&check;</span> See when your team is in sync</li>
              <li><span class="check">&check;</span> Optimal meeting windows</li>
              <li><span class="check">&check;</span> Facilitator tools</li>
            </ul>
            <a href="/subscribe?plan=squad" class="card-btn secondary">Start Team Trial</a>
            <span class="card-note">Minimum 3 seats</span>
          </div>
        </div>
      </div>
    </section>

    <!-- ============================================
         PHILOSOPHY
         ============================================ -->
    <section class="philosophy-section">
      <div class="container">
        <div class="philosophy-cards">
          <div class="phil-card">
            <span class="phil-icon">&diams;</span>
            <h4>Awareness, Not Fortune-Telling</h4>
            <p>We don't predict your future. We help you understand the energy you're working with today.</p>
          </div>
          <div class="phil-card">
            <span class="phil-icon">&hearts;</span>
            <h4>Your Data, Your Control</h4>
            <p>Everything runs locally. We never sell your information. Delete anytime.</p>
          </div>
          <div class="phil-card">
            <span class="phil-icon">&spades;</span>
            <h4>Gets Smarter Over Time</h4>
            <p>The more you check in, the more accurate your readings become. Your patterns are unique.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- ============================================
         NEWSLETTER
         ============================================ -->
    <section class="newsletter-section">
      <div class="container">
        <div class="newsletter-wrapper">
          <EmailCapture client:visible variant="card" className="w-full max-w-2xl mx-auto" />
        </div>
      </div>
    </section>

    <!-- ============================================
         FINAL CTA
         ============================================ -->
    <section class="final-cta-section">
      <div class="container">
        <h2>Begin the practice today.</h2>
        <p>Free. No signup required. Your data stays on your device.</p>
        <div class="final-ctas">
          <a href="/sol/" class="cta-secondary">◎ Go to Sol</a>
          <a href="/discover" class="cta-primary">
            <span>Begin the practice</span>
            <span class="arrow">&rarr;</span>
          </a>
        </div>
        <a href="/soul/compare" class="compare-nudge">◈ Compare your soul field with someone →</a>
      </div>
    </section>
  </div>
</BaseLayout>

<script>
  // Load today's reading preview
  async function loadReadingPreview() {
    try {
      const response = await fetch('/api/weather/today');
      if (response.ok) {
        const data = await response.json();
        const textEl = document.getElementById('reading-preview-text');
        if (data.dominant?.description && textEl) {
          textEl.textContent = data.dominant.description;
        }
      }
    } catch {
      // Silently fail - default text will show
    }
  }

  loadReadingPreview();

  // Smart routing: returning users with birth data go to dashboard
  if (localStorage.getItem('rop_birth_data_full')) {
    // Update hero CTA to go to dashboard
    const heroCta = document.querySelector('.hero-content .cta-primary') as HTMLAnchorElement;
    if (heroCta) {
      heroCta.href = '/dashboard';
      const label = heroCta.querySelector('span:first-child');
      if (label) label.textContent = 'Go to Dashboard';
      const badge = heroCta.querySelector('.badge');
      if (badge) badge.textContent = '◎';
    }

    // Update other discover links to checkin
    document.querySelectorAll('a[href="/discover"]').forEach((a) => {
      (a as HTMLAnchorElement).href = '/sol/checkin';
    });

    // Show a welcome-back banner in the hero
    const heroContent = document.querySelector('.hero-content');
    if (heroContent) {
      const trustBadge = heroContent.querySelector('.trust-badge');
      if (trustBadge) {
        trustBadge.innerHTML = '<span class="pulse"></span><span>Welcome back — your dashboard is ready</span>';
      }
    }

    // Show dashboard CTA in final section
    const dashCta = document.querySelector('.dashboard-cta') as HTMLElement;
    if (dashCta) dashCta.style.display = '';
  }
</script>

<style>
  /* ==========================================
     VARIABLES
     ========================================== */
  .landing-page {
    --gold: #d4a854;
    --gold-light: #e8c88a;
    --gold-dark: #b8924a;
    --dark: #0a0908;
    --dark-surface: #141210;
    --dark-border: rgba(212, 168, 84, 0.15);
    --text: #f0e8d8;
    --text-muted: rgba(240, 232, 216, 0.6);
    --text-dim: rgba(240, 232, 216, 0.4);
    --purple: #a78bfa;
    --green: #22c55e;

    font-family: 'Cormorant Garamond', Georgia, serif;
    background: var(--dark);
    color: var(--text);
  }

  .container {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  /* ==========================================
     HERO
     ========================================== */
  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 2rem;
    overflow: hidden;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  .glow {
    position: absolute;
    border-radius: 50%;
    filter: blur(100px);
  }

  .glow-1 {
    width: 600px;
    height: 600px;
    background: radial-gradient(circle, rgba(212, 168, 84, 0.25) 0%, transparent 70%);
    top: 5%;
    left: 15%;
    animation: float 12s ease-in-out infinite;
  }

  .glow-2 {
    width: 500px;
    height: 500px;
    background: radial-gradient(circle, rgba(167, 139, 250, 0.15) 0%, transparent 70%);
    bottom: 10%;
    right: 10%;
    animation: float 15s ease-in-out infinite reverse;
  }

  .stars {
    position: absolute;
    inset: 0;
    background-image: radial-gradient(2px 2px at 20px 30px, rgba(255,255,255,0.3), transparent),
                      radial-gradient(2px 2px at 40px 70px, rgba(255,255,255,0.2), transparent),
                      radial-gradient(1px 1px at 90px 40px, rgba(255,255,255,0.4), transparent),
                      radial-gradient(2px 2px at 130px 80px, rgba(255,255,255,0.2), transparent),
                      radial-gradient(1px 1px at 160px 120px, rgba(255,255,255,0.3), transparent);
    background-size: 200px 200px;
    opacity: 0.5;
  }

  @keyframes float {
    0%, 100% { transform: translate(0, 0); }
    50% { transform: translate(30px, -30px); }
  }

  .hero-content {
    position: relative;
    z-index: 1;
    max-width: 650px;
    text-align: center;
  }

  .trust-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 1rem;
    background: rgba(212, 168, 84, 0.1);
    border: 1px solid rgba(212, 168, 84, 0.2);
    border-radius: 100px;
    font-size: 0.85rem;
    color: var(--text-muted);
    margin-bottom: 2rem;
    font-family: 'Inter', sans-serif;
  }

  .pulse {
    width: 8px;
    height: 8px;
    background: var(--green);
    border-radius: 50%;
    animation: pulse 2s infinite;
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.5; transform: scale(1.3); }
  }

  .hero h1 {
    font-weight: 300;
    line-height: 1.1;
    margin: 0 0 1.5rem;
  }

  .line-1 {
    display: block;
    font-size: clamp(2.5rem, 7vw, 4rem);
    color: var(--text);
  }

  .line-2 {
    display: block;
    font-size: clamp(2rem, 5.5vw, 3.2rem);
    color: var(--gold);
  }

  .subtitle {
    font-size: 1.15rem;
    color: var(--text-muted);
    line-height: 1.7;
    margin-bottom: 2.5rem;
    max-width: 520px;
    margin-left: auto;
    margin-right: auto;
  }

  .cta-primary {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    padding: 1rem 2rem;
    background: linear-gradient(135deg, var(--gold) 0%, var(--gold-dark) 100%);
    color: var(--dark);
    font-size: 1.1rem;
    font-weight: 600;
    text-decoration: none;
    border-radius: 12px;
    box-shadow: 0 4px 24px rgba(212, 168, 84, 0.3);
    transition: all 0.3s ease;
    font-family: 'Inter', sans-serif;
  }

  .cta-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 32px rgba(212, 168, 84, 0.4);
  }

  .cta-primary .badge {
    padding: 0.2rem 0.5rem;
    background: rgba(10, 9, 8, 0.2);
    border-radius: 6px;
    font-size: 0.8rem;
    font-weight: 500;
  }

  .cta-primary .arrow {
    font-size: 1.2rem;
    transition: transform 0.3s;
  }

  .cta-primary:hover .arrow {
    transform: translateX(4px);
  }

  .micro-copy {
    margin-top: 1rem;
    font-size: 0.85rem;
    color: var(--text-dim);
    font-family: 'Inter', sans-serif;
  }

  .scroll-hint {
    position: absolute;
    bottom: 2rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.85rem;
    color: var(--text-dim);
    cursor: pointer;
    transition: color 0.3s;
  }

  .scroll-hint:hover {
    color: var(--gold);
  }

  .scroll-hint .arrow {
    animation: bounce 2s infinite;
  }

  @keyframes bounce {
    0%, 20%, 50%, 80%, 100% { transform: translateY(0); }
    40% { transform: translateY(8px); }
    60% { transform: translateY(4px); }
  }

  /* ==========================================
     SECTIONS COMMON
     ========================================== */
  section {
    padding: 5rem 0;
  }

  .section-header {
    text-align: center;
    margin-bottom: 3rem;
  }

  .section-icon {
    display: block;
    font-size: 1.5rem;
    color: var(--gold);
    margin-bottom: 0.75rem;
  }

  .section-header h2 {
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    font-weight: 400;
    color: var(--text);
    margin: 0 0 1rem;
  }

  .section-desc {
    font-size: 1.1rem;
    color: var(--text-muted);
    max-width: 550px;
    margin: 0 auto;
    line-height: 1.6;
  }

  /* ==========================================
     READING PREVIEW SECTION
     ========================================== */
  .reading-preview-section {
    background: linear-gradient(180deg, var(--dark) 0%, var(--dark-surface) 100%);
    padding: 3rem 0;
  }

  .reading-preview-card {
    max-width: 600px;
    margin: 0 auto;
    padding: 1.5rem 2rem;
    background: rgba(212, 168, 84, 0.06);
    border: 1px solid var(--dark-border);
    border-radius: 12px;
    text-align: center;
  }

  .reading-preview-header {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    margin-bottom: 0.75rem;
  }

  .reading-preview-icon {
    font-size: 1.25rem;
    color: var(--gold);
  }

  .reading-preview-label {
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--gold);
    font-family: 'Inter', sans-serif;
    font-weight: 500;
  }

  .reading-preview-text {
    font-size: 1.1rem;
    color: var(--text-muted);
    line-height: 1.6;
    margin: 0 0 1rem;
  }

  .reading-preview-link {
    font-size: 0.95rem;
    color: var(--gold);
    text-decoration: none;
    font-family: 'Inter', sans-serif;
    transition: opacity 0.3s;
  }

  .reading-preview-link:hover {
    opacity: 0.8;
  }

  /* ==========================================
     FEATURES SECTION
     ========================================== */
  .features-section {
    background: var(--dark-surface);
  }

  .features-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 1.5rem;
    margin-bottom: 3rem;
  }

  .feature-card {
    padding: 2rem;
    background: rgba(255, 255, 255, 0.02);
    border: 1px solid var(--dark-border);
    border-radius: 16px;
    transition: all 0.3s;
  }

  .feature-card:hover {
    background: rgba(212, 168, 84, 0.05);
    border-color: rgba(212, 168, 84, 0.3);
    transform: translateY(-4px);
  }

  .feature-icon {
    font-size: 2rem;
    color: var(--gold);
    margin-bottom: 1rem;
  }

  .feature-card h3 {
    font-size: 1.3rem;
    font-weight: 400;
    color: var(--text);
    margin: 0 0 0.75rem;
  }

  .feature-card p {
    font-size: 1rem;
    color: var(--text-muted);
    line-height: 1.6;
    margin: 0;
  }

  .features-cta {
    text-align: center;
  }

  .cta-secondary {
    display: inline-flex;
    padding: 0.875rem 1.75rem;
    border: 1px solid var(--gold);
    border-radius: 10px;
    color: var(--gold);
    text-decoration: none;
    font-size: 1.05rem;
    font-weight: 500;
    transition: all 0.3s;
    font-family: 'Inter', sans-serif;
  }

  .cta-secondary:hover {
    background: var(--gold);
    color: var(--dark);
  }

  .cta-note {
    display: block;
    margin-top: 0.75rem;
    font-size: 0.85rem;
    color: var(--text-dim);
    font-family: 'Inter', sans-serif;
  }

  /* ==========================================
     HOW IT WORKS
     ========================================== */
