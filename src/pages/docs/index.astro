---
import BaseLayout from '../../layouts/BaseLayout.astro';

const categories = [
  {
    title: 'Architecture',
    icon: '&#128736;',
    color: '#00ff88',
    docs: [
      { title: 'System Architecture', file: 'ARCHITECTURE', description: 'Microkernel + Message-Passing design' },
      { title: 'FRC Cosmology', file: 'FRC-COSMOLOGY', description: 'The operator system and consciousness model' },
      { title: 'Design Vision', file: 'DESIGN-VISION', description: 'Visual language and UI principles' },
      { title: '16D Implementation', file: '16D-IMPLEMENTATION-SPEC', description: 'Full mathematical specification' },
    ],
  },
  {
    title: 'Squad Specs',
    icon: '&#128101;',
    color: '#8b5cf6',
    docs: [
      { title: 'Vision', file: 'squad/00-VISION', description: 'Core identity and purpose' },
      { title: 'Design System', file: 'squad/01-DESIGN-SYSTEM', description: 'Component library spec' },
      { title: 'Technical Architecture', file: 'squad/02-TECHNICAL-ARCHITECTURE', description: 'System structure' },
      { title: 'FRC Translation', file: 'squad/04-FRC-TRANSLATION', description: 'Making cosmology accessible' },
      { title: 'Diamond Ontology', file: 'squad/34-DIAMOND-ONTOLOGY', description: '8D consciousness framework' },
    ],
  },
  {
    title: 'Engineering',
    icon: '&#9881;',
    color: '#fbbf24',
    docs: [
      { title: 'API Reference', file: 'API', description: 'Endpoint documentation' },
      { title: 'Database Schema', file: 'squad/05-DATABASE-SCHEMA', description: 'D1 table structures' },
      { title: 'Security Spec', file: 'squad/06-SECURITY-SPEC', description: 'Authentication and authorization' },
      { title: 'ARL Engine', file: 'squad/08-ARL-ENGINE', description: 'Adaptive Resonance Learning' },
      { title: 'Shadow Detector', file: 'squad/09-SHADOW-DETECTOR', description: 'Failure mode detection' },
    ],
  },
  {
    title: 'Product',
    icon: '&#127919;',
    color: '#dc2626',
    docs: [
      { title: 'Product Strategy', file: 'PRODUCT-STRATEGY', description: 'Business model and positioning' },
      { title: 'Content Strategy', file: 'CONTENT-STRATEGY-2026', description: 'Multi-language content generation' },
      { title: 'Onboarding Flow', file: 'squad/07-ONBOARDING-FLOW', description: 'User journey design' },
      { title: 'FRC Onboarding', file: 'squad/10-FRC-ONBOARDING', description: 'Teaching the framework' },
    ],
  },
  {
    title: 'Reference',
    icon: '&#128218;',
    color: '#d4a854',
    docs: [
      { title: '16D Quick Reference', file: '16D-QUICK-REFERENCE', description: 'Dimension cheat sheet' },
      { title: '16D Math', file: '16D-MATH', description: 'Mathematical foundations' },
      { title: 'FRC Cheat Sheet', file: 'FRC-16D-CHEAT-SHEET', description: 'Quick reference guide' },
      { title: 'Sub-Project Spec', file: 'SUB-PROJECT-SPEC', description: 'Cultural voice adapters' },
    ],
  },
];

const baseUrl = 'https://github.com/hadiservat/therealmofpatterns/blob/main/docs/';
---

<BaseLayout
  title="Documentation - The Realm of Patterns"
  description="Technical documentation, architecture specs, and reference guides for The Realm of Patterns."
>
  <main class="min-h-screen bg-gradient-to-b from-[#0a0908] to-[#1a1814] pt-20 pb-16">
    <div class="max-w-6xl mx-auto px-4">
      <!-- Hero -->
      <section class="text-center py-12">
        <h1 class="text-4xl md:text-5xl font-serif text-[#f0e8d8] mb-4">
          <span class="text-[#d4a854]">Documentation</span>
        </h1>
        <p class="text-[#f0e8d8]/70 text-lg max-w-2xl mx-auto">
          Architecture specs, API reference, and deep-dive documentation for building with The Realm.
        </p>
      </section>

      <!-- Quick Links -->
      <section class="mb-12">
        <div class="flex flex-wrap justify-center gap-3">
          <a
            href="https://github.com/hadiservat/therealmofpatterns"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 px-4 py-2 rounded-lg border border-[#d4a854]/30 text-[#d4a854] hover:bg-[#d4a854]/10 transition-colors text-sm"
          >
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
            GitHub Repository
          </a>
          <a
            href="/admin"
            class="inline-flex items-center gap-2 px-4 py-2 rounded-lg border border-[#d4a854]/30 text-[#d4a854] hover:bg-[#d4a854]/10 transition-colors text-sm"
          >
            <span>&#128202;</span>
            Admin Dashboard
          </a>
          <a
            href="/squad"
            class="inline-flex items-center gap-2 px-4 py-2 rounded-lg border border-[#d4a854]/30 text-[#d4a854] hover:bg-[#d4a854]/10 transition-colors text-sm"
          >
            <span>&#128101;</span>
            Squad Overview
          </a>
        </div>
      </section>

      <!-- Documentation Categories -->
      <section class="space-y-12">
        {categories.map((category) => (
          <div>
            <div class="flex items-center gap-3 mb-4">
              <span class="text-2xl" style={`color: ${category.color};`} set:html={category.icon} />
              <h2 class="text-xl font-serif text-[#f0e8d8]">{category.title}</h2>
            </div>

            <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-3">
              {category.docs.map((doc) => (
                <a
                  href={`${baseUrl}${doc.file}.md`}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="group p-4 rounded-lg border transition-all duration-300 hover:scale-[1.02]"
                  style={`border-color: ${category.color}20; background: linear-gradient(180deg, ${category.color}05 0%, transparent 100%);`}
                >
                  <h3 class="text-[#f0e8d8] font-medium group-hover:text-[#d4a854] transition-colors text-sm">
                    {doc.title}
                  </h3>
                  <p class="text-xs text-[#f0e8d8]/50 mt-1">{doc.description}</p>
                  <span class="text-xs mt-2 inline-block transition-colors" style={`color: ${category.color}80;`}>
                    View on GitHub &rarr;
                  </span>
                </a>
              ))}
            </div>
          </div>
        ))}
      </section>

      <!-- Core Concepts -->
      <section class="mt-16 p-8 rounded-xl border border-[rgba(212,168,84,0.2)] bg-[rgba(26,24,20,0.6)]">
        <h2 class="text-xl font-serif text-[#d4a854] mb-6 text-center">Core Concepts</h2>

        <div class="grid md:grid-cols-3 gap-6 text-sm">
          <div>
            <h3 class="text-[#00ff88] mb-2">16D Universal Vector</h3>
            <p class="text-[#f0e8d8]/60">
              8 inner dimensions (Karma - natal chart) + 8 outer dimensions (Dharma - transits).
              Your cosmic signature computed from planetary positions.
            </p>
          </div>

          <div>
            <h3 class="text-[#8b5cf6] mb-2">Lambda Field (Λ)</h3>
            <p class="text-[#f0e8d8]/60">
              The coherence field. Λ(x) = Λ₀ · ln C(x).
              A scalar field mapping consciousness coherence across dimensions.
            </p>
          </div>

          <div>
            <h3 class="text-[#fbbf24] mb-2">Kappa Coefficient (κ)</h3>
            <p class="text-[#f0e8d8]/60">
              Your current coherence score (0-1). Maps to the four alchemical stages:
              Nigredo, Albedo, Citrinitas, Rubedo.
            </p>
          </div>

          <div>
            <h3 class="text-[#dc2626] mb-2">Alchemical Stages</h3>
            <p class="text-[#f0e8d8]/60">
              From dissolution (Nigredo) through purification (Albedo), illumination (Citrinitas),
              to integration (Rubedo). The transformation journey.
            </p>
          </div>

          <div>
            <h3 class="text-[#d4a854] mb-2">Three Voices</h3>
            <p class="text-[#f0e8d8]/60">
              Kasra (technical), River (archetypal), Sol (accessible).
              Same truth, different layers of understanding.
            </p>
          </div>

          <div>
            <h3 class="text-[#c0c0c0] mb-2">ARL Engine</h3>
            <p class="text-[#f0e8d8]/60">
              Adaptive Resonance Learning. The system learns your patterns over time,
              improving predictions through your check-ins.
            </p>
          </div>
        </div>
      </section>

      <!-- Footer Links -->
      <section class="mt-12 text-center">
        <p class="text-[#f0e8d8]/50 text-sm mb-4">
          "The algorithm is open. The transformation is yours."
        </p>
        <div class="flex justify-center gap-4">
          <a href="/learn" class="text-[#d4a854] text-sm hover:underline">Learn More</a>
          <span class="text-[#f0e8d8]/20">|</span>
          <a href="/squad" class="text-[#d4a854] text-sm hover:underline">The Squad</a>
          <span class="text-[#f0e8d8]/20">|</span>
          <a href="/" class="text-[#d4a854] text-sm hover:underline">Home</a>
        </div>
      </section>
    </div>
  </main>
</BaseLayout>
