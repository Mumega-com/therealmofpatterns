---
import BaseLayout from '../layouts/BaseLayout.astro';
import { SettingsPanel } from '../components/shared/SettingsPanel';
---

<BaseLayout title="Settings - The Realm of Patterns" description="Manage your preferences, data sync, and privacy settings.">
  <div class="settings-page">
    <div class="page-container">
      <header class="page-header">
        <h1>Settings</h1>
        <p class="page-subtitle">Manage your preferences and data</p>
      </header>

      <SettingsPanel client:load />

      <footer class="page-footer">
        <a href="/privacy">Privacy Policy</a>
        <span class="separator">•</span>
        <a href="/terms">Terms of Service</a>
      </footer>
    </div>
  </div>
</BaseLayout>

<style>
  .settings-page {
    min-height: 100vh;
    padding: 2rem 1rem 4rem;
  }

  .page-container {
    max-width: 640px;
    margin: 0 auto;
  }

  .page-header {
    text-align: center;
    margin-bottom: 2rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid rgba(212, 168, 84, 0.15);
  }

  .page-header h1 {
    font-size: 1.75rem;
    font-weight: 400;
    color: #f0e8d8;
    margin-bottom: 0.25rem;
    font-family: 'Cormorant Garamond', Georgia, serif;
  }

  .page-subtitle {
    font-size: 0.9rem;
    color: rgba(240, 232, 216, 0.5);
  }

  .page-footer {
    text-align: center;
    padding-top: 2rem;
    margin-top: 2rem;
    border-top: 1px solid rgba(212, 168, 84, 0.1);
    font-size: 0.85rem;
  }

  .page-footer a {
    color: rgba(240, 232, 216, 0.5);
    text-decoration: none;
    transition: color 0.2s;
  }

  .page-footer a:hover {
    color: #d4a854;
  }

  .separator {
    margin: 0 0.75rem;
    color: rgba(240, 232, 216, 0.2);
  }
</style>
