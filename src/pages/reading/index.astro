---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Today's Reading | Sol"
  description="Sol's personalized daily reading — derived from your natal pattern, today's transits, and your reflection."
>
  <div class="reading-page">
    <nav class="reading-nav">
      <a href="/sol" class="back-link">← Sol</a>
      <span class="nav-title">Today's Reading</span>
      <a href="/sol/checkin" class="checkin-link">Daily reflection</a>
    </nav>

    <main class="reading-main" id="reading-main">
      <!-- Mounted by React -->
    </main>

    <footer class="reading-footer">
      <a href="/sol" class="return-link">Return to Sol</a>
    </footer>
  </div>
</BaseLayout>

<style>
  .reading-page {
    min-height: 100vh;
    background: #0a0908;
    color: #f0e8d8;
    padding: 2rem 1.5rem 4rem;
    font-family: 'Inter', -apple-system, sans-serif;
  }

  .reading-nav {
    max-width: 680px;
    margin: 0 auto 3rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .back-link, .checkin-link {
    font-size: 0.85rem;
    color: rgba(240, 232, 216, 0.35);
    text-decoration: none;
    transition: color 0.2s;
  }
  .back-link:hover, .checkin-link:hover { color: #d4a854; }

  .nav-title {
    font-size: 0.7rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(212, 168, 84, 0.35);
  }

  .reading-main {
    max-width: 680px;
    margin: 0 auto;
    min-height: 300px;
  }

  .reading-footer {
    max-width: 680px;
    margin: 3rem auto 0;
    padding-top: 1.5rem;
    border-top: 1px solid rgba(212, 168, 84, 0.08);
    text-align: center;
  }

  .return-link {
    font-size: 0.875rem;
    color: rgba(212, 168, 84, 0.4);
    text-decoration: none;
    transition: color 0.2s;
  }
  .return-link:hover { color: #d4a854; }
</style>

<script>
  import { createElement } from 'react';
  import { createRoot } from 'react-dom/client';
  import { SolReading } from '../../components/reading/SolReading';

  document.addEventListener('DOMContentLoaded', () => {
    const el = document.getElementById('reading-main');
    if (el) {
      createRoot(el).render(createElement(SolReading));
    }
  });
</script>
