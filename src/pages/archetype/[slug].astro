      { context: 'At work', note: 'You sense what\'s happening in organizations before the data shows it. You\'re rarely wrong — and rarely believed in time.' },
      { context: 'In relationships', note: 'You need someone who wants to go deep and can handle the full complexity of who you are without simplifying you.' },
      { context: 'Under stress', note: 'You withdraw into inner worlds — meditation, reading, solitude. You need this, and must learn when it\'s restoration vs. avoidance.' },
      { context: 'At your best', note: 'You change the frame. You name what was unnamed. You make the invisible visible — and the world shifts.' },
    ],
    relatedArchetypes: ['sage', 'creator', 'caregiver'],
    cta: 'Your Uranus-dominant pattern encodes your perceptual range and the edge you\'re meant to carry. Discover your full 8-dimension map.',
    painParam: 'mystic',
  },
};

export function getStaticPaths() {
  return [
    { params: { slug: 'sage' } },
    { params: { slug: 'hero' } },
    { params: { slug: 'ruler' } },
    { params: { slug: 'creator' } },
    { params: { slug: 'explorer' } },
    { params: { slug: 'warrior' } },
    { params: { slug: 'caregiver' } },
    { params: { slug: 'mystic' } },
  ];
}

const { slug } = Astro.params;
const arch = ARCHETYPES[slug as keyof typeof ARCHETYPES];

if (!arch) {
  return Astro.redirect('/404');
}

const ALL_ARCHETYPES = Object.values(ARCHETYPES);
const relatedArchs = arch.relatedArchetypes.map(id => ARCHETYPES[id as keyof typeof ARCHETYPES]).filter(Boolean);

// JSON-LD structured data
const jsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": arch.headline,
  "description": arch.metaDescription,
  "url": `https://therealmofpatterns.com/archetype/${arch.id}`,
  "author": {
    "@type": "Organization",
    "name": "Realm of Patterns"
  },
  "about": {
    "@type": "Thing",
    "name": `${arch.name} Archetype`,
    "description": arch.metaDescription
  }
});
---

<BaseLayout
  title={arch.searchTitle}
  description={arch.metaDescription}
>
  <script type="application/ld+json" set:html={jsonLd} is:inline />

  <div class="arch-page">

    <div class="bg-layer" aria-hidden="true">
