  }

  .plan-btn {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    padding: 1rem;
    font-size: 1rem;
    font-family: inherit;
    background: transparent;
    color: var(--gold);
    border: 1px solid rgba(212, 168, 84, 0.4);
    cursor: pointer;
    transition: all 0.3s;
  }

  .plan-btn:hover {
    background: rgba(212, 168, 84, 0.1);
    border-color: var(--gold);
  }

  .plan-btn.primary {
    background: var(--gold);
