---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Sol Pro — The Realm of Patterns" description="Go deeper with Sol. Weekly synthesis, a more capable model, and the full arc of your inner pattern.">
  <div class="subscribe-page">
    <div class="subscribe-content">
      <div class="page-header">
        <h1>Sol — the deeper practice</h1>
        <p>Seven days of check-ins isn't where it ends. It's where the real pattern begins.</p>
      </div>

      <!-- Founding Member — one-time option -->
      <div class="founding-block" id="foundingBlock">
        <div class="founding-inner">
          <div class="founding-left">
            <span class="founding-badge">Founding Member</span>
            <p class="founding-headline">One payment. Pro access. Permanent.</p>
            <p class="founding-sub">
              No subscription. No renewal. Lock in before the price goes up —
              and support an independent practice you believe in.
            </p>
            <ul class="founding-features">
              <li>Everything in Sol Pro — forever</li>
              <li>Weekly synthesis, deeper model, soul field comparison</li>
              <li>Your name in the founding member list (optional)</li>
            </ul>
          </div>
          <div class="founding-right">
            <div class="founding-price">
              <span class="founding-amount">$49</span>
              <span class="founding-period">one-time</span>
            </div>
            <button class="founding-btn" id="foundingBtn">
              Become a Founding Member →
            </button>
            <p class="founding-note">Secure checkout via Stripe</p>
          </div>
        </div>
      </div>

      <!-- Founding checkout form -->
      <div class="founding-form" id="foundingForm" style="display:none;">
        <div class="founding-form-inner">
          <p class="founding-form-label">Your email — to send you access confirmation</p>
          <div class="founding-form-row">
            <input type="email" id="foundingEmail" placeholder="you@example.com" class="founding-email-input" />
            <button class="founding-submit-btn" id="foundingSubmit">
              <span id="foundingSubmitText">Pay $49 →</span>
              <span id="foundingSubmitSpinner" style="display:none;">…</span>
            </button>
          </div>
          <p class="founding-cancel-link" id="foundingCancel">← Back to plans</p>
        </div>
      </div>

      <div class="plans-divider">
        <span>or choose a subscription</span>
      </div>

      <!-- Billing Toggle -->
      <div class="billing-toggle">
        <button class="billing-option active" id="monthlyBtn" data-billing="monthly">
          Monthly
        </button>
        <button class="billing-option" id="annualBtn" data-billing="annual">
          Annual
          <span class="save-badge">Save 20%</span>
        </button>
      </div>

      <div class="plans-grid">
        <!-- Pro (Individual) -->
        <div class="plan-card" data-plan="individual">
          <div class="plan-header">
            <h2>Pro</h2>
            <p class="plan-desc">Sol's full depth, for those ready to go further</p>
          </div>

          <div class="plan-price">
            <span class="currency">$</span>
            <span class="amount">9</span>
            <span class="period">/month</span>
          </div>

          <div class="value-highlight">
            <span class="value-icon">◎</span>
            <span>Sol reads deeper — a more capable model, trained to hold complexity</span>
          </div>

          <ul class="plan-features">
            <li>
              <span class="icon">✦</span>
              <span><strong>Deeper model</strong> — Sol uses a more capable AI for Pro members, with richer language and more nuanced reflection</span>
            </li>
            <li>
              <span class="icon">✦</span>
              <span><strong>Weekly synthesis</strong> — after seven check-ins, Sol reads the arc of the week as a whole, not just each day</span>
            </li>
            <li>
              <span class="icon">✦</span>
              <span><strong>Soul field comparison</strong> — compare your natal geometry with anyone else who shares their field</span>
            </li>
            <li>
              <span class="icon">✦</span>
              <span><strong>Longer arc readings</strong> — 30 and 60-day pattern synthesis coming soon</span>
            </li>
            <li>
              <span class="icon">✦</span>
              <span><strong>Everything from the free tier</strong> — daily check-in, Sol's daily reading, soul toroid, soul field sharing</span>
            </li>
            <li>
              <span class="icon">✦</span>
              <span><strong>Support the work</strong> — this is an independent practice. Your membership keeps Sol alive and evolving</span>
            </li>
          </ul>

          <div class="plan-guarantee">
            <span>7-day free trial</span> • <span>Cancel anytime</span>
          </div>

          <button class="plan-btn" id="individualBtn">
            <span>Start Free Trial</span>
            <span class="arrow">→</span>
          </button>
        </div>

        <!-- Team (Squad) -->
        <div class="plan-card featured" data-plan="squad">
          <div class="featured-badge">Best for Teams</div>

          <div class="plan-header">
            <h2>Team</h2>
            <p class="plan-desc">For coaches, teams & communities</p>
          </div>

          <div class="plan-price">
            <span class="currency">$</span>
            <span class="amount">29</span>
            <span class="period">/seat/month</span>
          </div>

          <div class="value-highlight">
            <span class="value-icon">⬡</span>
            <span>Every member gets their own Sol — and you can see how your fields relate</span>
          </div>

          <div class="seats-selector">
            <label>Team size:</label>
            <div class="seats-controls">
              <button class="seats-btn" id="decreaseSeats">−</button>
              <input type="number" id="seatCount" value="3" min="3" max="50" />
              <button class="seats-btn" id="increaseSeats">+</button>
            </div>
            <div class="seats-total">
              <span>Total: </span>
              <span id="totalPrice">$147</span>
              <span>/month</span>
            </div>
          </div>

          <ul class="plan-features">
            <li>
              <span class="icon">✦</span>
              <span><strong>Everything in Pro</strong> — every member gets full individual access</span>
            </li>
            <li>
              <span class="icon">✦</span>
              <span><strong>See when your team is in sync</strong> — group energy dashboard shows alignment</span>
            </li>
            <li>
              <span class="icon">✦</span>
              <span><strong>Share energy profiles</strong> — opt-in to let teammates see your dimensions</span>
            </li>
            <li>
              <span class="icon">✦</span>
              <span><strong>Optimal meeting windows</strong> — find when conditions favor collaboration</span>
            </li>
            <li>
              <span class="icon">✦</span>
              <span><strong>Facilitator tools</strong> — coaching modes for 1:1 and group sessions</span>
            </li>
            <li>
              <span class="icon">✦</span>
              <span><strong>Team dynamics reports</strong> — understand complementary and tension patterns</span>
            </li>
            <li>
              <span class="icon">✦</span>
              <span><strong>API access</strong> — integrate with your tools (Slack, Notion, etc.)</span>
            </li>
          </ul>

          <div class="plan-guarantee">
            <span>14-day team trial</span> • <span>Add/remove seats anytime</span>
          </div>

          <button class="plan-btn primary" id="squadBtn">
            <span>Start Team Trial</span>
            <span class="arrow">→</span>
          </button>
        </div>
      </div>

      <!-- Enterprise Section -->
      <div class="enterprise-section">
        <div class="enterprise-content">
          <div class="enterprise-badge">Enterprise</div>
          <h3>For Large Organizations</h3>
          <p>
            Custom solutions for companies with 50+ practitioners.
            Dedicated support, custom integrations, and volume pricing.
          </p>

          <ul class="enterprise-features">
            <li>
              <span class="icon">◆</span>
              <span><strong>Unlimited Seats</strong> — no per-seat caps</span>
            </li>
            <li>
              <span class="icon">◆</span>
              <span><strong>Dedicated Account Manager</strong> — white-glove onboarding</span>
            </li>
            <li>
              <span class="icon">◆</span>
              <span><strong>Custom API Integrations</strong> — Slack, Teams, HRIS systems</span>
            </li>
            <li>
              <span class="icon">◆</span>
              <span><strong>SSO/SAML Support</strong> — enterprise authentication</span>
            </li>
            <li>
              <span class="icon">◆</span>
              <span><strong>Custom Reports</strong> — executive dashboards, team health metrics</span>
            </li>
            <li>
              <span class="icon">◆</span>
              <span><strong>SLA Guarantee</strong> — 99.9% uptime with priority support</span>
            </li>
            <li>
              <span class="icon">◆</span>
              <span><strong>Training & Workshops</strong> — on-site or virtual facilitation</span>
            </li>
            <li>
              <span class="icon">◆</span>
              <span><strong>Volume Discounts</strong> — tiered pricing for large teams</span>
            </li>
          </ul>

          <a href="mailto:enterprise@therealmofpatterns.com?subject=Enterprise%20Inquiry" class="enterprise-btn">
            <span>Contact Sales</span>
            <span class="arrow">→</span>
          </a>

          <p class="enterprise-note">
            Typically $29/seat/month for 50+ seats. Custom pricing available.
          </p>
        </div>
      </div>

      <!-- Email capture for checkout -->
      <div class="checkout-form" id="checkoutForm" style="display: none;">
        <div class="form-header">
          <h3 id="formTitle">Enter your email to continue</h3>
          <p id="formSubtitle">We'll send your login details after checkout</p>
        </div>

        <form id="emailForm">
          <div class="form-field">
            <label for="email">Email address</label>
            <input
              type="email"
              id="email"
              name="email"
              placeholder="you@example.com"
              required
            />
          </div>

          <div class="form-field" id="circleNameField" style="display: none;">
            <label for="circleName">Circle name</label>
            <input
              type="text"
              id="circleName"
              name="circleName"
              placeholder="e.g., Sunrise Collective"
            />
          </div>

          <button type="submit" class="submit-btn" id="submitBtn">
            <span id="submitText">Continue to Checkout</span>
            <span class="loading" id="loadingSpinner" style="display: none;">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <circle cx="12" cy="12" r="10" opacity="0.25"/>
                <path d="M12 2a10 10 0 0 1 10 10" class="spinner"/>
              </svg>
            </span>
          </button>
        </form>

        <p class="form-note">
          Secure checkout powered by Stripe.
          Cancel anytime with one click.
        </p>
      </div>

      <!-- FAQ -->
      <div class="faq-section">
        <h3>Questions?</h3>

        <div class="faq-item">
          <h4>What's included in the free tier?</h4>
          <p>
            Free members get the full daily check-in, Sol's personalized narrative reading,
            the 3D soul toroid, and the ability to share their soul field with others.
            No account required to begin.
          </p>
        </div>

        <div class="faq-item">
          <h4>What does Pro actually change?</h4>
          <p>
            Pro unlocks a more capable language model for Sol's readings — the difference
            is in depth, nuance, and the quality of reflection. You also get the weekly
            synthesis (Sol reads the arc of seven days) and soul field comparison.
          </p>
        </div>

        <div class="faq-item">
          <h4>How does the free trial work?</h4>
          <p>
            Pro includes a 7-day free trial. Team plans get 14 days.
            You get full access immediately. We only charge after the trial ends,
            and you can cancel anytime before that.
          </p>
        </div>

        <div class="faq-item">
          <h4>Can I cancel anytime?</h4>
          <p>
            Yes, cancel with one click from your dashboard.
            No contracts, no questions asked.
          </p>
        </div>

        <div class="faq-item">
          <h4>Do I need birth data?</h4>
          <p>
            Yes — Sol computes your natal field from your birth date, time, and place.
            The more precise the data, the more resonant the geometry. If you don't know
            your exact birth time, noon is a reasonable starting point.
          </p>
        </div>

        <div class="faq-item">
          <h4>What's the Team plan?</h4>
          <p>
            The Team plan is for coaches, therapists, communities, or any group
            who want to use this together. Each member gets their own Sol practice,
            and you can compare soul fields across the group.
          </p>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>

<style>
  .subscribe-page {
    --gold: #d4a854;
    --gold-glow: rgba(212, 168, 84, 0.3);
    --dark: #0a0908;
    --dark-surface: #141210;
    --text: #f0e8d8;
    --text-muted: rgba(240, 232, 216, 0.6);

    font-family: 'Cormorant Garamond', Georgia, serif;
    background: var(--dark);
    color: var(--text);
    min-height: 100vh;
    padding: 6rem 2rem 4rem;
  }

  .subscribe-content {
    max-width: 900px;
    margin: 0 auto;
  }

  .page-header {
    text-align: center;
    margin-bottom: 3rem;
  }

  .page-header h1 {
    font-size: 2.5rem;
    font-weight: 300;
    color: var(--text);
    margin-bottom: 0.5rem;
  }

  .page-header p {
    font-size: 1.1rem;
    color: var(--text-muted);
  }

  /* Founding Member block */
  .founding-block {
    background: linear-gradient(135deg, rgba(212, 168, 84, 0.08) 0%, rgba(212, 168, 84, 0.03) 100%);
    border: 1px solid rgba(212, 168, 84, 0.35);
    padding: 2rem;
    margin-bottom: 1.5rem;
    position: relative;
    overflow: hidden;
  }
  .founding-block::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 2px;
    background: linear-gradient(90deg, transparent, var(--gold), transparent);
  }
  .founding-inner {
    display: flex;
    gap: 2rem;
    align-items: center;
    flex-wrap: wrap;
  }
  .founding-left { flex: 1; min-width: 260px; }
  .founding-right {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
    min-width: 180px;
  }
  .founding-badge {
    display: inline-block;
    font-size: 0.62rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    padding: 0.3rem 0.7rem;
    background: rgba(212, 168, 84, 0.15);
    border: 1px solid rgba(212, 168, 84, 0.3);
    color: var(--gold);
    margin-bottom: 0.75rem;
  }
  .founding-headline {
    font-size: 1.3rem;
    font-weight: 300;
    color: var(--text);
    margin: 0 0 0.5rem;
    line-height: 1.3;
  }
  .founding-sub {
    font-size: 0.9rem;
    color: var(--text-muted);
    margin: 0 0 1rem;
    line-height: 1.6;
  }
  .founding-features {
    list-style: none;
    padding: 0; margin: 0;
    font-size: 0.875rem;
    color: rgba(240, 232, 216, 0.55);
  }
  .founding-features li::before { content: '✦ '; color: var(--gold); font-size: 0.7rem; }
  .founding-features li { margin-bottom: 0.3rem; }
  .founding-price {
    text-align: center;
  }
  .founding-amount {
    display: block;
    font-size: 3rem;
    font-weight: 300;
    color: var(--gold);
    font-family: 'Geist Mono', monospace;
    line-height: 1;
  }
  .founding-period {
    font-size: 0.8rem;
    color: var(--text-muted);
  }
  .founding-btn {
    width: 100%;
    padding: 0.875rem 1.25rem;
    background: var(--gold);
    color: var(--dark);
    border: none;
    font-family: inherit;
    font-size: 0.95rem;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.2s;
    white-space: nowrap;
  }
  .founding-btn:hover {
    background: #e5b865;
    box-shadow: 0 0 24px var(--gold-glow);
  }
  .founding-note {
    font-size: 0.72rem;
    color: var(--text-muted);
    margin: 0;
  }

  /* Founding checkout inline form */
  .founding-form {
    background: rgba(212, 168, 84, 0.04);
    border: 1px solid rgba(212, 168, 84, 0.2);
    padding: 1.5rem;
    margin-bottom: 1.5rem;
  }
  .founding-form-label {
    font-size: 0.875rem;
    color: var(--text-muted);
    margin: 0 0 0.75rem;
  }
  .founding-form-row {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
  }
  .founding-email-input {
    flex: 1;
    min-width: 200px;
    padding: 0.75rem 1rem;
    background: var(--dark);
    border: 1px solid rgba(212, 168, 84, 0.25);
    color: var(--text);
    font-family: inherit;
    font-size: 1rem;
  }
  .founding-email-input::placeholder { color: rgba(240,232,216,0.3); }
  .founding-email-input:focus { outline: none; border-color: var(--gold); }
  .founding-submit-btn {
    padding: 0.75rem 1.5rem;
    background: var(--gold);
    color: var(--dark);
    border: none;
    font-family: inherit;
    font-size: 0.95rem;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.2s;
    white-space: nowrap;
  }
  .founding-submit-btn:hover:not(:disabled) {
    background: #e5b865;
  }
  .founding-submit-btn:disabled { opacity: 0.6; cursor: not-allowed; }
  .founding-cancel-link {
    margin-top: 0.75rem;
    font-size: 0.8rem;
    color: var(--text-muted);
    cursor: pointer;
    text-decoration: underline;
  }
  .founding-cancel-link:hover { color: var(--gold); }

  /* Divider between founding and plans */
  .plans-divider {
    text-align: center;
    position: relative;
    margin-bottom: 2rem;
  }
  .plans-divider::before {
    content: '';
    position: absolute;
    top: 50%;
    left: 0; right: 0;
    height: 1px;
    background: rgba(212, 168, 84, 0.08);
  }
  .plans-divider span {
    position: relative;
    background: var(--dark);
    padding: 0 1rem;
    font-size: 0.75rem;
    letter-spacing: 0.08em;
    color: rgba(240, 232, 216, 0.25);
  }

  .billing-toggle {
    display: flex;
    justify-content: center;
    gap: 0.5rem;
    margin-bottom: 2rem;
    background: var(--dark-surface);
    padding: 0.25rem;
    border-radius: 8px;
    max-width: 300px;
    margin-left: auto;
    margin-right: auto;
  }

  .billing-option {
    flex: 1;
    padding: 0.75rem 1.25rem;
    background: transparent;
    border: none;
    color: var(--text-muted);
    font-family: inherit;
    font-size: 0.9rem;
    cursor: pointer;
    border-radius: 6px;
    transition: all 0.3s;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
  }

  .billing-option:hover {
    color: var(--text);
  }

  .billing-option.active {
    background: var(--gold);
    color: var(--dark);
  }

  .save-badge {
    font-size: 0.65rem;
    font-weight: 600;
    text-transform: uppercase;
    padding: 0.15rem 0.4rem;
    background: rgba(34, 197, 94, 0.2);
    color: #22c55e;
    border-radius: 4px;
  }

  .billing-option.active .save-badge {
    background: rgba(0, 0, 0, 0.2);
    color: var(--dark);
  }

  .plans-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 2rem;
    margin-bottom: 3rem;
  }

  @media (max-width: 768px) {
    .plans-grid {
      grid-template-columns: 1fr;
    }
  }

  .plan-card {
    position: relative;
    background: var(--dark-surface);
    border: 1px solid rgba(212, 168, 84, 0.15);
    padding: 2rem;
    transition: all 0.3s;
    cursor: pointer;
  }

  .plan-card:hover {
    border-color: rgba(212, 168, 84, 0.3);
    transform: translateY(-4px);
  }

  .plan-card.featured {
    border-color: var(--gold);
    background: linear-gradient(180deg, rgba(212, 168, 84, 0.05) 0%, var(--dark-surface) 100%);
  }

  .plan-card.selected {
    border-color: var(--gold);
    box-shadow: 0 0 30px var(--gold-glow);
  }

  .featured-badge {
    position: absolute;
    top: -12px;
    left: 50%;
    transform: translateX(-50%);
    font-size: 0.65rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 0.4rem 0.75rem;
    background: var(--gold);
    color: var(--dark);
  }

  .plan-header {
    text-align: center;
    margin-bottom: 1.5rem;
  }

  .plan-header h2 {
    font-size: 1.75rem;
    font-weight: 400;
    color: var(--text);
    margin-bottom: 0.25rem;
  }

  .plan-desc {
    font-size: 0.9rem;
    color: var(--text-muted);
  }

  .plan-price {
    text-align: center;
    margin-bottom: 1.5rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid rgba(212, 168, 84, 0.1);
  }

  .plan-price .currency {
    font-size: 1.5rem;
    color: var(--gold);
    vertical-align: top;
  }

  .plan-price .amount {
    font-size: 4rem;
    font-weight: 300;
    color: var(--gold);
    font-family: 'Geist Mono', monospace;
    line-height: 1;
  }

  .plan-price .period {
    font-size: 1rem;
    color: var(--text-muted);
  }

  .value-highlight {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.875rem 1rem;
    background: linear-gradient(135deg, rgba(212, 168, 84, 0.1) 0%, rgba(212, 168, 84, 0.05) 100%);
    border-left: 3px solid var(--gold);
    margin-bottom: 1.5rem;
    font-size: 0.95rem;
    color: var(--text);
  }

  .value-highlight .value-icon {
    color: var(--gold);
    font-size: 1.25rem;
  }

  .plan-features strong {
    color: var(--text);
    font-weight: 500;
  }

  .plan-guarantee {
    display: flex;
    justify-content: center;
    gap: 0.75rem;
    padding: 0.75rem;
    margin-bottom: 1rem;
    font-size: 0.8rem;
    color: var(--text-muted);
    border-top: 1px solid rgba(212, 168, 84, 0.1);
  }

  .plan-guarantee span {
    display: flex;
    align-items: center;
  }

  .seats-selector {
    background: rgba(212, 168, 84, 0.05);
    padding: 1rem;
    margin-bottom: 1.5rem;
    text-align: center;
  }

  .seats-selector label {
    display: block;
    font-size: 0.85rem;
    color: var(--text-muted);
    margin-bottom: 0.5rem;
  }

  .seats-controls {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    margin-bottom: 0.5rem;
  }

  .seats-btn {
    width: 36px;
    height: 36px;
    background: transparent;
    border: 1px solid rgba(212, 168, 84, 0.3);
    color: var(--gold);
