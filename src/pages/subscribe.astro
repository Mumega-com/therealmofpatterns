  }

  .plan-btn .arrow {
    transition: transform 0.3s;
  }

  .plan-btn:hover .arrow {
    transform: translateX(4px);
  }

  /* Checkout Form */
  .checkout-form {
    background: var(--dark-surface);
    border: 1px solid rgba(212, 168, 84, 0.2);
    padding: 2rem;
    margin-bottom: 3rem;
  }

  .form-header {
    text-align: center;
    margin-bottom: 1.5rem;
  }

  .form-header h3 {
    font-size: 1.5rem;
    font-weight: 400;
    color: var(--text);
    margin-bottom: 0.25rem;
  }

  .form-header p {
    font-size: 0.9rem;
    color: var(--text-muted);
  }

  .form-field {
    margin-bottom: 1rem;
  }

  .form-field label {
    display: block;
    font-size: 0.85rem;
    color: var(--text-muted);
    margin-bottom: 0.5rem;
  }

  .form-field input {
    width: 100%;
    padding: 0.875rem 1rem;
    background: var(--dark);
    border: 1px solid rgba(212, 168, 84, 0.2);
    color: var(--text);
    font-size: 1rem;
    font-family: inherit;
    transition: border-color 0.3s;
  }

  .form-field input::placeholder {
    color: rgba(240, 232, 216, 0.3);
  }

  .form-field input:focus {
    outline: none;
    border-color: var(--gold);
  }

  .submit-btn {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    padding: 1rem;
    font-size: 1.1rem;
    font-family: inherit;
    background: var(--gold);
    color: var(--dark);
    border: none;
    cursor: pointer;
    transition: all 0.3s;
  }

  .submit-btn:hover:not(:disabled) {
    background: #e5b865;
    box-shadow: 0 0 20px var(--gold-glow);
  }

  .submit-btn:disabled {
    opacity: 0.6;
    cursor: not-allowed;
  }

  .loading svg {
    width: 24px;
    height: 24px;
    animation: spin 1s linear infinite;
  }

  .loading .spinner {
    stroke-linecap: round;
  }

  @keyframes spin {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
  }

  .form-note {
    text-align: center;
    margin-top: 1rem;
    font-size: 0.8rem;
    color: var(--text-muted);
  }

  /* FAQ */
  .faq-section {
    padding-top: 2rem;
    border-top: 1px solid rgba(212, 168, 84, 0.1);
  }

  .faq-section h3 {
    font-size: 1.5rem;
    font-weight: 400;
    color: var(--text);
    margin-bottom: 1.5rem;
    text-align: center;
  }

  .faq-item {
    margin-bottom: 1.5rem;
  }

  .faq-item h4 {
    font-size: 1.1rem;
    font-weight: 400;
    color: var(--gold);
    margin-bottom: 0.5rem;
  }

  .faq-item p {
    font-size: 0.95rem;
    color: var(--text-muted);
    line-height: 1.7;
  }

  /* Enterprise Section */
  .enterprise-section {
    margin-bottom: 3rem;
    padding: 2rem;
    background: linear-gradient(135deg, rgba(147, 51, 234, 0.08) 0%, rgba(212, 168, 84, 0.05) 100%);
    border: 1px solid rgba(147, 51, 234, 0.25);
    position: relative;
  }

  .enterprise-content {
    max-width: 600px;
    margin: 0 auto;
    text-align: center;
  }

  .enterprise-badge {
    display: inline-block;
    font-size: 0.7rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    padding: 0.5rem 1rem;
    background: linear-gradient(135deg, #9333ea 0%, #d4a854 100%);
    color: white;
    margin-bottom: 1.25rem;
  }

  .enterprise-section h3 {
    font-size: 1.75rem;
    font-weight: 400;
    color: var(--text);
    margin-bottom: 0.75rem;
  }

  .enterprise-section > .enterprise-content > p {
    font-size: 1rem;
    color: var(--text-muted);
    margin-bottom: 1.5rem;
    line-height: 1.6;
  }

  .enterprise-features {
    list-style: none;
    padding: 0;
    margin: 0 0 1.5rem;
    text-align: left;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0.75rem;
  }

  @media (max-width: 600px) {
    .enterprise-features {
      grid-template-columns: 1fr;
    }
  }

  .enterprise-features li {
    display: flex;
    align-items: flex-start;
    gap: 0.5rem;
    font-size: 0.9rem;
    color: var(--text-muted);
  }

  .enterprise-features .icon {
    color: #9333ea;
    font-size: 0.75rem;
    margin-top: 0.2rem;
  }

  .enterprise-features strong {
    color: var(--text);
    font-weight: 500;
  }

  .enterprise-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.875rem 2rem;
    background: linear-gradient(135deg, #9333ea 0%, #7c3aed 100%);
    color: white;
    font-size: 1rem;
    font-family: inherit;
    text-decoration: none;
    border: none;
    cursor: pointer;
    transition: all 0.3s;
  }

  .enterprise-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 30px rgba(147, 51, 234, 0.3);
  }

  .enterprise-btn .arrow {
    transition: transform 0.3s;
  }

  .enterprise-btn:hover .arrow {
    transform: translateX(4px);
  }

  .enterprise-note {
    margin-top: 1rem;
    font-size: 0.85rem;
    color: rgba(240, 232, 216, 0.5);
  }
</style>

<script>
  // ── Founding Member flow ────────────────────────────────
  const foundingBtn    = document.getElementById('foundingBtn');
  const foundingForm   = document.getElementById('foundingForm') as HTMLDivElement;
  const foundingBlock  = document.getElementById('foundingBlock') as HTMLDivElement;
  const foundingSubmit = document.getElementById('foundingSubmit') as HTMLButtonElement;
  const foundingSubmitText    = document.getElementById('foundingSubmitText');
  const foundingSubmitSpinner = document.getElementById('foundingSubmitSpinner');
  const foundingCancel = document.getElementById('foundingCancel');

  foundingBtn?.addEventListener('click', () => {
    foundingBlock.style.display = 'none';
    foundingForm.style.display  = 'block';
    foundingForm.scrollIntoView({ behavior: 'smooth', block: 'center' });
    (document.getElementById('foundingEmail') as HTMLInputElement)?.focus();
  });

  foundingCancel?.addEventListener('click', () => {
    foundingForm.style.display  = 'none';
    foundingBlock.style.display = 'block';
  });

  foundingSubmit?.addEventListener('click', async () => {
    const email = (document.getElementById('foundingEmail') as HTMLInputElement)?.value?.trim();
    if (!email || !email.includes('@')) {
      alert('Please enter a valid email address.');
      return;
    }

    foundingSubmit.disabled = true;
    if (foundingSubmitText) foundingSubmitText.style.display = 'none';
    if (foundingSubmitSpinner) foundingSubmitSpinner.style.display = 'inline';

    try {
      const res = await fetch('/api/create-founding-checkout', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email }),
      });
      const data = await res.json();
      if (data.url) {
        window.location.href = data.url;
      } else {
        throw new Error(data.error || 'Checkout unavailable');
      }
    } catch (err: unknown) {
      const message = err instanceof Error ? err.message : 'Something went wrong. Please try again.';
      alert(message);
      foundingSubmit.disabled = false;
      if (foundingSubmitText) foundingSubmitText.style.display = 'inline';
      if (foundingSubmitSpinner) foundingSubmitSpinner.style.display = 'none';
    }
  });

  // Allow Enter key in email field
  document.getElementById('foundingEmail')?.addEventListener('keydown', (e) => {
    if ((e as KeyboardEvent).key === 'Enter') foundingSubmit?.click();
  });

  // ── Subscription plans ──────────────────────────────────
  // Get URL params
  const urlParams = new URLSearchParams(window.location.search);
  const planParam = urlParams.get('plan');

  // DOM elements
  const individualBtn = document.getElementById('individualBtn');
  const squadBtn = document.getElementById('squadBtn');
  const checkoutForm = document.getElementById('checkoutForm');
  const circleNameField = document.getElementById('circleNameField');
  const seatCount = document.getElementById('seatCount') as HTMLInputElement;
  const totalPrice = document.getElementById('totalPrice');
  const decreaseSeats = document.getElementById('decreaseSeats');
  const increaseSeats = document.getElementById('increaseSeats');
  const emailForm = document.getElementById('emailForm');
  const submitBtn = document.getElementById('submitBtn');
  const submitText = document.getElementById('submitText');
  const loadingSpinner = document.getElementById('loadingSpinner');
  const formTitle = document.getElementById('formTitle');
  const formSubtitle = document.getElementById('formSubtitle');

  // Billing toggle elements
  const monthlyBtn = document.getElementById('monthlyBtn');
  const annualBtn = document.getElementById('annualBtn');
  const individualPriceAmount = document.querySelector('[data-plan="individual"] .plan-price .amount');
  const squadPriceAmount = document.querySelector('[data-plan="squad"] .plan-price .amount');
  const individualPeriod = document.querySelector('[data-plan="individual"] .plan-price .period');
  const squadPeriod = document.querySelector('[data-plan="squad"] .plan-price .period');

  let selectedPlan: 'individual' | 'squad' | null = null;
  let billingPeriod: 'monthly' | 'annual' = 'monthly';

  // Pricing
  const PRICES = {
    individual: { monthly: 9, annual: 7 },  // Annual is ~22% off
    squad: { monthly: 29, annual: 23 },
  };

  // Auto-select plan from URL
  if (planParam === 'individual' || planParam === 'squad') {
    selectPlan(planParam);
  }

  // Billing toggle handlers
  monthlyBtn?.addEventListener('click', () => setBillingPeriod('monthly'));
  annualBtn?.addEventListener('click', () => setBillingPeriod('annual'));

  function setBillingPeriod(period: 'monthly' | 'annual') {
    billingPeriod = period;

    // Update toggle button styles
    monthlyBtn?.classList.toggle('active', period === 'monthly');
    annualBtn?.classList.toggle('active', period === 'annual');

    // Update displayed prices
    const individualPrice = PRICES.individual[period];
    const squadPrice = PRICES.squad[period];

    if (individualPriceAmount) individualPriceAmount.textContent = String(individualPrice);
    if (squadPriceAmount) squadPriceAmount.textContent = String(squadPrice);

    // Update period text to show annual billing note
    if (individualPeriod) {
      individualPeriod.textContent = period === 'annual' ? '/mo (billed yearly)' : '/month';
    }
    if (squadPeriod) {
      squadPeriod.textContent = period === 'annual' ? '/seat/mo (billed yearly)' : '/seat/month';
    }

    // Update total price for squad
    updateTotalPrice();

    // Update form subtitle if plan is selected
    if (selectedPlan) {
      updateFormSubtitle();
    }
  }

  function updateFormSubtitle() {
    if (!formSubtitle) return;

    if (selectedPlan === 'individual') {
      const price = PRICES.individual[billingPeriod];
      if (billingPeriod === 'annual') {
        formSubtitle.textContent = `$${price}/mo × 12 = $${price * 12}/year (save $${(PRICES.individual.monthly - price) * 12})`;
      } else {
        formSubtitle.textContent = 'Enter your email to continue to checkout';
      }
    } else if (selectedPlan === 'squad') {
      const seats = parseInt(seatCount?.value || '3');
      const pricePerSeat = PRICES.squad[billingPeriod];
      const total = seats * pricePerSeat;
      if (billingPeriod === 'annual') {
        formSubtitle.textContent = `${seats} seats × $${pricePerSeat}/mo × 12 = $${total * 12}/year`;
      } else {
        formSubtitle.textContent = `${seats} seats at $${pricePerSeat}/seat = $${total}/month`;
      }
    }
  }

  // Plan selection
  individualBtn?.addEventListener('click', () => selectPlan('individual'));
  squadBtn?.addEventListener('click', () => selectPlan('squad'));

  function selectPlan(plan: 'individual' | 'squad') {
    selectedPlan = plan;

    // Update card styles
    document.querySelectorAll('.plan-card').forEach(card => {
      card.classList.remove('selected');
    });
    document.querySelector(`[data-plan="${plan}"]`)?.classList.add('selected');

    // Show checkout form
    if (checkoutForm) {
      checkoutForm.style.display = 'block';

      // Scroll to form
      checkoutForm.scrollIntoView({ behavior: 'smooth', block: 'center' });
    }

    // Toggle circle name field
    if (circleNameField) {
      circleNameField.style.display = plan === 'squad' ? 'block' : 'none';
    }

    // Update form title
    if (formTitle) {
      formTitle.textContent = plan === 'individual'
        ? 'Start your Pro trial'
        : 'Create your Team';
    }

    updateFormSubtitle();
  }

  // Seat count controls
  function updateTotalPrice() {
    const seats = parseInt(seatCount?.value || '3');
    const pricePerSeat = PRICES.squad[billingPeriod];
    const total = seats * pricePerSeat;
    if (totalPrice) {
      if (billingPeriod === 'annual') {
        totalPrice.textContent = `$${total}/mo`;
      } else {
        totalPrice.textContent = `$${total}`;
      }
    }
    if (selectedPlan === 'squad') {
      updateFormSubtitle();
    }
  }

  decreaseSeats?.addEventListener('click', () => {
    const current = parseInt(seatCount?.value || '3');
    if (current > 3 && seatCount) {
      seatCount.value = (current - 1).toString();
      updateTotalPrice();
    }
  });

  increaseSeats?.addEventListener('click', () => {
    const current = parseInt(seatCount?.value || '3');
    if (current < 50 && seatCount) {
      seatCount.value = (current + 1).toString();
      updateTotalPrice();
    }
  });

  seatCount?.addEventListener('change', () => {
    let value = parseInt(seatCount.value);
    if (isNaN(value) || value < 3) value = 3;
    if (value > 50) value = 50;
    seatCount.value = value.toString();
    updateTotalPrice();
  });

  // Form submission
  emailForm?.addEventListener('submit', async (e) => {
    e.preventDefault();

    if (!selectedPlan) return;

    const email = (document.getElementById('email') as HTMLInputElement)?.value;
    const circleName = (document.getElementById('circleName') as HTMLInputElement)?.value;
    const seats = parseInt(seatCount?.value || '3');

    // Show loading
    if (submitBtn) submitBtn.setAttribute('disabled', 'true');
    if (submitText) submitText.style.display = 'none';
    if (loadingSpinner) loadingSpinner.style.display = 'block';

    try {
      // Create Stripe checkout session
      const response = await fetch('/api/create-subscription-checkout', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          plan: selectedPlan,
          email,
          circleName: selectedPlan === 'squad' ? circleName : undefined,
          seats: selectedPlan === 'squad' ? seats : 1,
          billingPeriod,
        }),
      });

      const data = await response.json();

      if (data.url) {
        // Redirect to Stripe
        window.location.href = data.url;
      } else {
        throw new Error(data.error || 'Failed to create checkout');
      }
    } catch (error) {
      console.error('Checkout error:', error);
      alert('Something went wrong. Please try again.');

      // Reset button
      if (submitBtn) submitBtn.removeAttribute('disabled');
      if (submitText) submitText.style.display = 'block';
      if (loadingSpinner) loadingSpinner.style.display = 'none';
    }
  });
</script>
