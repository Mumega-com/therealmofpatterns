---
/**
 * Cosmic Channel Live Viewer
 *
 * A continuous alchemical broadcast - the Astrology Weather Network
 */
import BaseLayout from '../../layouts/BaseLayout.astro';

const today = new Date().toLocaleDateString('en-US', {
  weekday: 'long',
  year: 'numeric',
  month: 'long',
  day: 'numeric'
});
---

<BaseLayout title="Cosmic Channel LIVE | The Realm of Patterns">
  <div id="live-container" class="live-container">
    <!-- Background atmosphere -->
    <div class="atmosphere">
      <div id="stars"></div>
    </div>

    <!-- Header bar -->
    <header class="broadcast-header">
      <div class="logo">
        <span class="live-dot"></span>
        <span class="channel-name">COSMIC CHANNEL</span>
      </div>
      <div class="stats">
        <span class="stat" id="viewer-count">👁️ --</span>
        <span class="stat" id="scene-number">Scene #--</span>
      </div>
    </header>

    <!-- Main stage -->
    <main class="stage-container">
      <!-- Scene display -->
      <div class="scene-frame">
        <div class="scene-loading" id="scene-loading">
          <div class="loading-spinner"></div>
          <p>Connecting to the cosmic stream...</p>
        </div>
        <img id="scene-image" class="scene-image" alt="Live alchemical scene" />
        <canvas id="scene-canvas" class="scene-canvas"></canvas>
      </div>

      <!-- Energy meters -->
      <div class="energy-bar">
        <div class="meter">
          <label>Resonance (κ)</label>
          <div class="meter-fill" id="kappa-meter" style="width: 50%"></div>
          <span class="meter-value" id="kappa-value">--</span>
        </div>
        <div class="meter">
          <label>Schumann</label>
          <div class="meter-fill schumann" id="schumann-meter" style="width: 50%"></div>
          <span class="meter-value" id="schumann-value">-- Hz</span>
        </div>
        <div class="stage-indicator" id="stage-indicator">
          <span class="stage-glyph">⚗️</span>
          <span class="stage-name">Loading...</span>
        </div>
      </div>
    </main>

    <!-- River's narration -->
    <div class="narration-bar" id="narration-bar">
      <span class="narrator">🌊 River:</span>
      <span class="narration-text" id="narration-text">Awaiting transmission...</span>
    </div>

    <!-- Chat panel (collapsible) -->
    <aside class="chat-panel" id="chat-panel">
      <div class="chat-header">
        <span>💬 Live Chat</span>
        <button class="chat-toggle" id="chat-toggle">−</button>
      </div>
      <div class="chat-messages" id="chat-messages">
        <p class="system-message">Welcome to Cosmic Channel. The stream is continuous.</p>
      </div>
      <div class="chat-input-area">
        <input type="text" id="chat-input" placeholder="Send a message..." maxlength="200" />
        <button id="chat-send">→</button>
      </div>
      <div class="reaction-bar">
        <button class="reaction" data-symbol="☉">☉</button>
        <button class="reaction" data-symbol="☽">☽</button>
        <button class="reaction" data-symbol="☿">☿</button>
        <button class="reaction" data-symbol="♀">♀</button>
        <button class="reaction" data-symbol="♂">♂</button>
        <button class="reaction" data-symbol="♃">♃</button>
        <button class="reaction" data-symbol="♄">♄</button>
        <button class="reaction" data-symbol="✨">✨</button>
      </div>
    </aside>

    <!-- Date/time display -->
    <footer class="broadcast-footer">
      <span class="date">{today}</span>
      <span class="time" id="current-time">--:--:--</span>
      <span class="status" id="connection-status">Connecting...</span>
    </footer>
  </div>
</BaseLayout>

<style>
  /* ====== BASE ====== */
  .live-container {
    position: relative;
    min-height: 100vh;
    background: #050508;
    color: #e8e4dc;
    font-family: 'Cormorant Garamond', Georgia, serif;
    overflow: hidden;
  }

  /* ====== ATMOSPHERE ====== */
  .atmosphere {
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: 0;
  }

  #stars {
    position: absolute;
    inset: 0;
    background-image:
      radial-gradient(1px 1px at 20px 30px, #fff, transparent),
      radial-gradient(1px 1px at 40px 70px, rgba(255,215,0,0.6), transparent),
      radial-gradient(1px 1px at 90px 40px, #fff, transparent);
    background-size: 200px 200px;
    animation: twinkle 4s ease-in-out infinite alternate;
  }

  @keyframes twinkle {
    0% { opacity: 0.4; }
    100% { opacity: 0.8; }
  }

  /* ====== HEADER ====== */
  .broadcast-header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.75rem 1.5rem;
    background: rgba(5, 5, 8, 0.9);
    border-bottom: 1px solid rgba(212, 175, 55, 0.3);
    z-index: 100;
  }

  .logo {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .live-dot {
    width: 10px;
    height: 10px;
    background: #dc2626;
    border-radius: 50%;
    animation: pulse-live 1.5s ease-in-out infinite;
  }

  @keyframes pulse-live {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.4; }
  }

  .channel-name {
    font-size: 1rem;
    font-weight: 600;
    letter-spacing: 0.15em;
    color: #d4af37;
  }

  .stats {
    display: flex;
    gap: 1.5rem;
  }

  .stat {
    font-size: 0.875rem;
    color: #a8a29e;
    font-family: 'Geist Mono', monospace;
  }

  /* ====== MAIN STAGE ====== */
  .stage-container {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 4rem 1rem 1rem;
    z-index: 10;
  }

  .scene-frame {
    position: relative;
    width: 100%;
    max-width: 1200px;
    aspect-ratio: 16 / 9;
    background: #0a0a0f;
    border: 2px solid rgba(212, 175, 55, 0.4);
    border-radius: 4px;
    overflow: hidden;
  }

  .scene-loading {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    background: #0a0a0f;
  }

  .scene-loading.hidden {
    display: none;
  }

  .loading-spinner {
    width: 50px;
    height: 50px;
    border: 3px solid rgba(212, 175, 55, 0.2);
    border-top-color: #d4af37;
    border-radius: 50%;
    animation: spin 1s linear infinite;
  }

  @keyframes spin {
    to { transform: rotate(360deg); }
  }

  .scene-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0;
    transition: opacity 2s ease-in-out;
  }

  .scene-image.visible {
    opacity: 1;
  }

  .scene-canvas {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  /* ====== ENERGY BAR ====== */
  .energy-bar {
    display: flex;
    gap: 2rem;
    align-items: center;
    margin-top: 1rem;
    padding: 1rem;
    background: rgba(10, 10, 15, 0.9);
    border: 1px solid rgba(212, 175, 55, 0.2);
    border-radius: 4px;
  }

  .meter {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    min-width: 150px;
  }

  .meter label {
    font-size: 0.75rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #a8a29e;
  }

  .meter-fill {
    height: 6px;
    background: linear-gradient(90deg, #d4af37, #f0d78c);
    border-radius: 3px;
    transition: width 1s ease-out;
  }

  .meter-fill.schumann {
    background: linear-gradient(90deg, #6b9ac4, #9fc5e8);
  }

  .meter-value {
    font-family: 'Geist Mono', monospace;
    font-size: 0.875rem;
    color: #d4af37;
  }

  .stage-indicator {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 1rem;
    background: rgba(212, 175, 55, 0.1);
    border-radius: 4px;
  }

  .stage-glyph {
    font-size: 1.5rem;
  }

  .stage-name {
    font-size: 0.875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  /* ====== NARRATION BAR ====== */
  .narration-bar {
    position: fixed;
    bottom: 4rem;
    left: 50%;
    transform: translateX(-50%);
    max-width: 800px;
    width: calc(100% - 2rem);
    padding: 1rem 1.5rem;
    background: rgba(10, 10, 15, 0.95);
    border: 1px solid rgba(107, 154, 196, 0.3);
    border-radius: 4px;
    text-align: center;
    z-index: 50;
  }

  .narrator {
    color: #6b9ac4;
    font-weight: 600;
  }

  .narration-text {
    color: #e8e4dc;
    font-style: italic;
  }

  /* ====== CHAT PANEL ====== */
  .chat-panel {
    position: fixed;
    right: 1rem;
    top: 4rem;
    bottom: 5rem;
    width: 300px;
    display: flex;
    flex-direction: column;
    background: rgba(10, 10, 15, 0.95);
    border: 1px solid rgba(212, 175, 55, 0.2);
    border-radius: 4px;
    z-index: 60;
  }

  .chat-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.75rem 1rem;
    border-bottom: 1px solid rgba(212, 175, 55, 0.2);
    font-size: 0.875rem;
    font-weight: 600;
  }

  .chat-toggle {
    background: none;
    border: none;
    color: #d4af37;
    font-size: 1.25rem;
    cursor: pointer;
  }

  .chat-messages {
    flex: 1;
    overflow-y: auto;
    padding: 0.75rem;
    font-size: 0.875rem;
  }

  .chat-messages p {
    margin: 0.5rem 0;
    padding: 0.5rem;
    border-radius: 4px;
    background: rgba(255, 255, 255, 0.03);
  }

  .system-message {
    color: #6b9ac4;
    font-style: italic;
  }

  .chat-input-area {
    display: flex;
    gap: 0.5rem;
    padding: 0.75rem;
    border-top: 1px solid rgba(212, 175, 55, 0.2);
  }

  #chat-input {
    flex: 1;
    padding: 0.5rem;
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(212, 175, 55, 0.2);
    border-radius: 4px;
    color: #e8e4dc;
    font-family: inherit;
  }

  #chat-send {
    padding: 0.5rem 1rem;
    background: #d4af37;
    border: none;
    border-radius: 4px;
    color: #0a0a0f;
    cursor: pointer;
  }

  .reaction-bar {
    display: flex;
    justify-content: center;
    gap: 0.25rem;
    padding: 0.5rem;
    border-top: 1px solid rgba(212, 175, 55, 0.1);
  }

  .reaction {
    padding: 0.25rem 0.5rem;
    background: none;
    border: 1px solid rgba(212, 175, 55, 0.2);
    border-radius: 4px;
    color: #d4af37;
    font-size: 1rem;
    cursor: pointer;
    transition: all 0.2s;
  }

  .reaction:hover {
    background: rgba(212, 175, 55, 0.2);
  }

  /* ====== FOOTER ====== */
  .broadcast-footer {
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    display: flex;
    justify-content: space-between;
    padding: 0.75rem 1.5rem;
    background: rgba(5, 5, 8, 0.9);
    border-top: 1px solid rgba(212, 175, 55, 0.2);
    font-size: 0.75rem;
    color: #a8a29e;
    font-family: 'Geist Mono', monospace;
    z-index: 100;
  }

  #connection-status {
    color: #6b9ac4;
  }

  #connection-status.connected {
    color: #22c55e;
  }

  #connection-status.error {
    color: #dc2626;
  }

  /* ====== RESPONSIVE ====== */
  @media (max-width: 768px) {
    .chat-panel {
      display: none;
    }

    .energy-bar {
      flex-wrap: wrap;
      gap: 1rem;
    }

    .meter {
      min-width: 100px;
    }
  }
</style>

<script>
  // Cosmic Channel Live Viewer Script
  let ws: WebSocket | null = null;
  let reconnectAttempts = 0;
  const maxReconnectAttempts = 5;

  // DOM Elements
  const sceneImage = document.getElementById('scene-image') as HTMLImageElement;
  const sceneLoading = document.getElementById('scene-loading');
  const viewerCount = document.getElementById('viewer-count');
  const sceneNumber = document.getElementById('scene-number');
  const kappaValue = document.getElementById('kappa-value');
  const kappaMeter = document.getElementById('kappa-meter');
  const schumannValue = document.getElementById('schumann-value');
  const schumannMeter = document.getElementById('schumann-meter');
  const stageIndicator = document.getElementById('stage-indicator');
  const narrationText = document.getElementById('narration-text');
  const chatMessages = document.getElementById('chat-messages');
  const chatInput = document.getElementById('chat-input') as HTMLInputElement;
  const chatSend = document.getElementById('chat-send');
  const connectionStatus = document.getElementById('connection-status');
  const currentTime = document.getElementById('current-time');

  // Stage emojis
  const stageEmojis: Record<string, string> = {
    nigredo: '🌑',
    albedo: '🌕',
    citrinitas: '☀️',
    rubedo: '❤️‍🔥'
  };

  function connect() {
    // WebSocket URL - update to actual deployment URL
    const wsUrl = `wss://cosmic-channel.therealmofpatterns.workers.dev/ws`;

    try {
      ws = new WebSocket(wsUrl);

      ws.onopen = () => {
        console.log('Connected to Cosmic Channel');
        if (connectionStatus) {
          connectionStatus.textContent = 'Connected';
          connectionStatus.className = 'status connected';
        }
        reconnectAttempts = 0;
      };

      ws.onmessage = (event) => {
        try {
          const message = JSON.parse(event.data);
          handleMessage(message);
        } catch (e) {
          console.error('Message parse error:', e);
        }
      };

      ws.onclose = () => {
        if (connectionStatus) {
          connectionStatus.textContent = 'Disconnected';
          connectionStatus.className = 'status error';
        }
        attemptReconnect();
      };

      ws.onerror = (error) => {
        console.error('WebSocket error:', error);
      };
    } catch (e) {
      console.error('Connection error:', e);
      // Fall back to demo mode
      startDemoMode();
    }
  }

  function attemptReconnect() {
    if (reconnectAttempts < maxReconnectAttempts) {
      reconnectAttempts++;
      if (connectionStatus) {
        connectionStatus.textContent = `Reconnecting (${reconnectAttempts}/${maxReconnectAttempts})...`;
      }
      setTimeout(connect, 3000 * reconnectAttempts);
    } else {
      if (connectionStatus) {
        connectionStatus.textContent = 'Connection lost';
      }
      // Fall back to demo mode
      startDemoMode();
    }
  }

  function handleMessage(message: any) {
    switch (message.type) {
      case 'scene':
        updateScene(message.data);
        break;
      case 'chat':
        addChatMessage(message.data);
        break;
      case 'stats':
        updateStats(message.data);
        break;
      case 'narration':
        updateNarration(message.data.text);
        break;
      case 'reaction':
        showReaction(message.data.symbol);
        break;
      case 'pong':
        // Keepalive response
        break;
    }
  }

  function updateScene(scene: any) {
    if (sceneLoading) sceneLoading.classList.add('hidden');

    if (sceneImage && scene.imageUrl) {
      sceneImage.src = scene.imageUrl;
      sceneImage.classList.add('visible');
    }

    if (kappaValue) kappaValue.textContent = `${Math.round(scene.kappa * 100)}%`;
    if (kappaMeter) kappaMeter.style.width = `${scene.kappa * 100}%`;

    if (schumannValue) schumannValue.textContent = `${scene.schumann.toFixed(2)} Hz`;
    if (schumannMeter) schumannMeter.style.width = `${(scene.schumann / 15) * 100}%`;

    if (stageIndicator) {
      const glyph = stageIndicator.querySelector('.stage-glyph');
      const name = stageIndicator.querySelector('.stage-name');
      if (glyph) glyph.textContent = stageEmojis[scene.stage] || '⚗️';
      if (name) name.textContent = scene.stage.charAt(0).toUpperCase() + scene.stage.slice(1);
    }

    if (sceneNumber) sceneNumber.textContent = `Scene #${scene.sceneNumber}`;

    if (scene.narration) {
      updateNarration(scene.narration);
    }
  }

  function updateStats(stats: any) {
    if (viewerCount) viewerCount.textContent = `👁️ ${stats.viewerCount}`;
    if (sceneNumber) sceneNumber.textContent = `Scene #${stats.sceneNumber}`;
  }

  function updateNarration(text: string) {
    if (narrationText) {
      narrationText.style.opacity = '0';
      setTimeout(() => {
        narrationText.textContent = text;
        narrationText.style.opacity = '1';
      }, 500);
    }
  }

  function addChatMessage(data: any) {
    if (!chatMessages) return;

    const p = document.createElement('p');
    const shortId = data.userId.split('-').pop()?.slice(0, 4) || '????';
    p.innerHTML = `<strong>@${shortId}:</strong> ${escapeHtml(data.content)}`;
    chatMessages.appendChild(p);
    chatMessages.scrollTop = chatMessages.scrollHeight;

    // Limit chat history
    while (chatMessages.children.length > 50) {
      chatMessages.removeChild(chatMessages.firstChild!);
    }
  }

  function showReaction(symbol: string) {
    // Create floating reaction animation
    const reaction = document.createElement('div');
    reaction.className = 'floating-reaction';
    reaction.textContent = symbol;
    reaction.style.cssText = `
      position: fixed;
      left: ${Math.random() * 80 + 10}%;
      bottom: 10%;
      font-size: 2rem;
      opacity: 1;
      transition: all 2s ease-out;
      pointer-events: none;
      z-index: 1000;
    `;
    document.body.appendChild(reaction);

    setTimeout(() => {
      reaction.style.transform = 'translateY(-100px)';
      reaction.style.opacity = '0';
    }, 100);

    setTimeout(() => reaction.remove(), 2000);
  }

  function sendChat() {
    if (!ws || ws.readyState !== WebSocket.OPEN || !chatInput) return;

    const content = chatInput.value.trim();
    if (!content) return;

    ws.send(JSON.stringify({
      type: 'chat',
      content
    }));

    chatInput.value = '';
  }

  function sendReaction(symbol: string) {
    if (!ws || ws.readyState !== WebSocket.OPEN) return;

    ws.send(JSON.stringify({
      type: 'reaction',
      symbol
    }));
  }

  function escapeHtml(text: string): string {
    const div = document.createElement('div');
    div.textContent = text;
    return div.innerHTML;
  }

  function updateClock() {
    if (currentTime) {
      currentTime.textContent = new Date().toLocaleTimeString('en-US', {
        hour12: false,
        hour: '2-digit',
        minute: '2-digit',
        second: '2-digit'
      });
    }
  }

  // Demo mode when WebSocket unavailable
  function startDemoMode() {
    if (connectionStatus) {
      connectionStatus.textContent = 'Demo Mode';
      connectionStatus.className = 'status';
    }

    // Simulate scene updates
    const demoScenes = [
      { stage: 'citrinitas', kappa: 0.65, schumann: 7.83, narration: 'Golden light breaks through the threshold. At 65% resonance, Earth breathes in harmony.' },
      { stage: 'albedo', kappa: 0.45, schumann: 7.92, narration: 'Clarity rises like the moon through clouds. Earth\'s heartbeat quickens.' },
      { stage: 'rubedo', kappa: 0.82, schumann: 7.76, narration: 'The Great Work approaches completion. At 82% resonance, deep integration unfolds.' },
    ];

    let sceneIndex = 0;
    let sceneNum = 1;

    setInterval(() => {
      const scene = demoScenes[sceneIndex];
      updateScene({
        ...scene,
        sceneNumber: sceneNum++,
        imageUrl: null // Would use fallback
      });
      sceneIndex = (sceneIndex + 1) % demoScenes.length;
    }, 30000); // Every 30 seconds in demo

    // Initial scene
    updateScene({
      ...demoScenes[0],
      sceneNumber: 1,
      imageUrl: null
    });

    if (sceneLoading) sceneLoading.classList.add('hidden');
  }

  // Initialize
  function init() {
    // Update clock every second
    updateClock();
    setInterval(updateClock, 1000);

    // Chat send handlers
    chatSend?.addEventListener('click', sendChat);
    chatInput?.addEventListener('keypress', (e) => {
      if (e.key === 'Enter') sendChat();
    });

    // Reaction handlers
    document.querySelectorAll('.reaction').forEach(btn => {
      btn.addEventListener('click', () => {
        const symbol = btn.getAttribute('data-symbol');
        if (symbol) sendReaction(symbol);
      });
    });

    // Keepalive ping
    setInterval(() => {
      if (ws && ws.readyState === WebSocket.OPEN) {
        ws.send(JSON.stringify({ type: 'ping' }));
      }
    }, 30000);

    // Connect to WebSocket
    connect();
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }
</script>
