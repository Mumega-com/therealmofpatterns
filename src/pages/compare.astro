  .report-features li::before { content: '✓'; color: var(--gold); flex-shrink: 0; }
  .report-cta-right { display: flex; flex-direction: column; align-items: center; gap: 0.75rem; min-width: 180px; }
  .report-price { display: flex; flex-direction: column; align-items: center; }
