---
import BaseLayout from '../../layouts/BaseLayout.astro';

const WHY_ARTICLES = [
  {
    slug: 'tired',
    title: 'Why Am I So Tired?',
    question: 'Why do I feel exhausted even when I sleep enough?',
    dimension: 'Action (μ₆)',
    symbol: 'Δ',
  },
  {
    slug: 'stuck',
    title: 'Why Do I Feel Stuck?',
    question: "Why can't I move forward in my life?",
    dimension: 'Phase (μ₁)',
    symbol: 'P',
  },
  {
    slug: 'anxious',
    title: 'Why Am I So Anxious?',
    question: "Why won't the anxiety go away?",
    dimension: 'Field (μ₈)',
    symbol: 'Φ',
  },
  {
    slug: 'unmotivated',
    title: 'Why Am I So Unmotivated?',
    question: "Why can't I find the drive to do anything?",
    dimension: 'Value (μ₄)',
    symbol: 'V',
  },
  {
    slug: 'restless',
    title: 'Why Am I So Restless?',
    question: "Why can't I feel settled?",
    dimension: 'Expansion (μ₅)',
    symbol: 'N',
  },
  {
    slug: 'overwhelmed',
    title: 'Why Am I So Overwhelmed?',
    question: 'Why does everything feel like too much?',
    dimension: 'Cognition (μ₃)',
    symbol: 'μ',
  },
  {
    slug: 'disconnected',
    title: 'Why Do I Feel Disconnected?',
    question: "Why do I feel alone even when I'm with people?",
    dimension: 'Relation (μ₇)',
    symbol: 'R',
  },
  {
    slug: 'creative-block',
    title: 'Why Do I Have Creative Block?',
    question: "Why can't I create anymore?",
    dimension: 'Expansion (μ₅)',
    symbol: 'N',
  },
];
---

<BaseLayout
  title="Why Am I...? - Pattern Insights"
  description="Understand common feelings through the lens of your cosmic pattern. Discover why you feel tired, stuck, anxious, or unmotivated."
>
  <div class="why-index">
    <div class="index-container">
      <header class="page-header">
        <h1>
          <span class="kasra-only">PATTERN_DIAGNOSTICS</span>
          <span class="river-only">The Mirror of Self</span>
          <span class="sol-only">Why Am I...?</span>
        </h1>
        <p class="subtitle">
          <span class="kasra-only">Dimensional analysis of common field states.</span>
          <span class="river-only">Understanding life's challenges through the cosmic lens.</span>
          <span class="sol-only">Make sense of how you're feeling using your pattern.</span>
        </p>
      </header>

      <div class="articles-grid">
        {WHY_ARTICLES.map((article) => (
          <a href={`/why/${article.slug}`} class="article-card">
            <div class="card-symbol">{article.symbol}</div>
            <div class="card-content">
              <h2>{article.title}</h2>
              <p class="card-question">{article.question}</p>
              <span class="card-dimension">{article.dimension}</span>
            </div>
          </a>
        ))}
      </div>

      <section class="cta-section">
        <h3>
          <span class="kasra-only">PERSONALIZED_DIAGNOSTICS</span>
          <span class="river-only">Your Personal Reading</span>
          <span class="sol-only">Get Answers for YOU</span>
        </h3>
        <p>
          <span class="kasra-only">These insights are generalized. For analysis calibrated to your unique 16D signature:</span>
          <span class="river-only">These patterns speak to all. For wisdom specific to your soul:</span>
          <span class="sol-only">These are general insights. Want answers based on YOUR pattern?</span>
        </p>
        <a href="/sol/checkin" class="cta-btn">
          <span class="kasra-only">INITIATE_PERSONAL_SCAN</span>
          <span class="river-only">Receive Your Reading</span>
          <span class="sol-only">Check My Pattern</span>
        </a>
      </section>
    </div>
  </div>
</BaseLayout>

<style>
  .why-index {
    --gold: #d4a854;
    --dark: #0a0908;
    --dark-surface: #141210;
    --text: #f0e8d8;
    --text-muted: rgba(240, 232, 216, 0.6);

    font-family: 'Cormorant Garamond', Georgia, serif;
    background: var(--dark);
    color: var(--text);
    min-height: 100vh;
    padding: 6rem 2rem 4rem;
  }

  .index-container {
    max-width: 900px;
    margin: 0 auto;
  }

  .page-header {
    text-align: center;
    margin-bottom: 3rem;
  }

  .page-header h1 {
    font-size: 2.5rem;
    font-weight: 300;
    color: var(--text);
    margin-bottom: 0.75rem;
  }

  .subtitle {
    font-size: 1.1rem;
    color: var(--text-muted);
  }

  .articles-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.25rem;
    margin-bottom: 3rem;
  }

  @media (max-width: 640px) {
    .articles-grid {
      grid-template-columns: 1fr;
    }
  }

  .article-card {
    display: flex;
    gap: 1.25rem;
    padding: 1.5rem;
    background: var(--dark-surface);
    border: 1px solid rgba(212, 168, 84, 0.15);
    text-decoration: none;
    transition: all 0.3s;
  }

  .article-card:hover {
    border-color: var(--gold);
    transform: translateY(-2px);
    box-shadow: 0 4px 20px rgba(212, 168, 84, 0.15);
  }

  .card-symbol {
    flex-shrink: 0;
    width: 48px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.5rem;
    color: var(--gold);
    background: rgba(212, 168, 84, 0.1);
    border-radius: 50%;
  }

  .card-content {
    flex: 1;
    min-width: 0;
  }

  .card-content h2 {
    font-size: 1.1rem;
    font-weight: 500;
    color: var(--text);
    margin-bottom: 0.5rem;
  }

  .card-question {
    font-size: 0.9rem;
    color: var(--text-muted);
    line-height: 1.5;
    margin-bottom: 0.5rem;
  }

  .card-dimension {
    font-size: 0.75rem;
    color: var(--gold);
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  .cta-section {
    text-align: center;
    padding: 2.5rem;
    background: var(--dark-surface);
    border: 1px solid rgba(212, 168, 84, 0.2);
  }

  .cta-section h3 {
    font-size: 1.5rem;
    font-weight: 400;
    color: var(--text);
    margin-bottom: 0.75rem;
  }

  .cta-section p {
    font-size: 1rem;
    color: var(--text-muted);
    margin-bottom: 1.5rem;
    max-width: 500px;
    margin-left: auto;
    margin-right: auto;
  }

  .cta-btn {
    display: inline-block;
    padding: 0.875rem 1.5rem;
    background: var(--gold);
    color: var(--dark);
    text-decoration: none;
    font-weight: 500;
    transition: all 0.2s;
  }

  .cta-btn:hover {
    background: #e5b964;
    box-shadow: 0 0 20px rgba(212, 168, 84, 0.3);
  }
</style>
