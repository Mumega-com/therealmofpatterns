---
import BaseLayout from '../../layouts/BaseLayout.astro';

export function getStaticPaths() {
  return [
    { params: { slug: 'tired' }, props: { slug: 'tired' } },
    { params: { slug: 'stuck' }, props: { slug: 'stuck' } },
    { params: { slug: 'anxious' }, props: { slug: 'anxious' } },
    { params: { slug: 'unmotivated' }, props: { slug: 'unmotivated' } },
    { params: { slug: 'restless' }, props: { slug: 'restless' } },
    { params: { slug: 'overwhelmed' }, props: { slug: 'overwhelmed' } },
    { params: { slug: 'disconnected' }, props: { slug: 'disconnected' } },
    { params: { slug: 'creative-block' }, props: { slug: 'creative-block' } },
  ];
}

interface WhyContent {
  title: string;
  question: string;
  intro: string;
  dimension: string;
  dimensionName: string;
  explanation: string;
  shadow: string;
  signs: string[];
  actions: string[];
  optimalTimes: string;
}

const WHY_CONTENT: Record<string, WhyContent> = {
  'tired': {
    title: 'Why Am I So Tired?',
    question: 'Why do I feel exhausted even when I sleep enough?',
    intro: 'Fatigue that persists despite rest often signals a misalignment between your natural energy rhythm and how you are living. Chronic tiredness frequently stems from the Drive dimension being out of balance.',
    dimension: '♂',
    dimensionName: 'Drive (Mars)',
    explanation: 'The Drive dimension governs your capacity for output, initiative, and physical vitality. When Mars transits create tension with your natal pattern, or when your Drive energy is suppressed, exhaustion follows. Your body is asking you to recalibrate.',
    shadow: 'The shadow of Drive is paralysis or forced hyperactivity. You may be either pushing too hard against your natural rhythm, or avoiding action so completely that energy stagnates. Both create fatigue.',
    signs: [
      'Tired in the morning but wired at night',
      'Energy spikes that crash quickly',
      'Feeling drained by tasks that used to energize you',
      'Physical heaviness without physical cause',
    ],
    actions: [
      'Check your daily Drive reading to find your high-energy windows',
      'Schedule demanding tasks during your optimal windows, not against them',
      'Consider that fatigue may be wisdom - your body protecting you from wrong action',
      'Track your energy for 7 days to find your natural rhythm',
    ],
    optimalTimes: 'Drive energy peaks typically occur in late morning (9-11am) and again in mid-afternoon (3-5pm) for most patterns. Your personal peaks depend on your natal Mars placement.',
  },
  'stuck': {
    title: 'Why Do I Feel Stuck?',
    question: 'Why can\'t I move forward in my life?',
    intro: 'Feeling stuck usually indicates an Identity dimension transition. Like a seed that must crack its shell before sprouting, you may be in a necessary reset period before transformation.',
    dimension: '☉',
    dimensionName: 'Identity (Sun)',
    explanation: 'The Identity dimension represents your core sense of self and direction. When undergoing a shift, old structures must dissolve before new ones can form. What feels like stuckness is often the quiet before emergence.',
    shadow: 'The shadow of Identity is either rigidly clinging to an outdated sense of self, or chaotically abandoning who you are before the new form is ready. Patience is required.',
    signs: [
      'Old goals feel meaningless but new ones haven\'t appeared',
      'Sensing you\'re between chapters of your life',
      'Resistance to change paired with dissatisfaction with stability',
      'Dreams of transformation, fear of the unknown',
    ],
    actions: [
      'Accept the reset stage - dissolution precedes renewal',
      'Journal about who you were vs. who you sense yourself becoming',
      'Reduce pressure to perform while in transition',
      'Look for small signs of new growth rather than forcing clarity',
    ],
    optimalTimes: 'Identity transitions often accelerate during New Moons and when the Sun aspects your natal Sun. These are windows for setting new intentions.',
  },
  'anxious': {
    title: 'Why Am I So Anxious?',
    question: 'Why won\'t the anxiety go away?',
    intro: 'Persistent anxiety often reflects disturbance in the Awareness dimension - your interface with collective and transcendent consciousness. When Awareness is activated without grounding, the result is free-floating anxiety.',
    dimension: '♆',
    dimensionName: 'Awareness (Neptune)',
    explanation: 'The Awareness dimension connects you to larger patterns - collective consciousness, spiritual sensitivity, the unseen. When over-activated or ungrounded, you pick up on energies that aren\'t yours, sensing threats you can\'t name.',
    shadow: 'The shadow of Awareness is either dissolution into collective anxiety (losing yourself in world fears) or complete disconnection (nihilism, spiritual bypassing). Balance requires grounding.',
    signs: [
      'Anxiety without clear cause',
      'Absorbing others\' emotions easily',
      'Feeling better in nature, worse in crowds',
      'Sense of impending doom not attached to specifics',
    ],
    actions: [
      'Ground daily: physical movement, nature, body awareness',
      'Distinguish your feelings from collective disturbances',
      'Limit exposure to news and social media during high-sensitivity periods',
      'Practice boundaries between self and world',
    ],
    optimalTimes: 'Awareness sensitivity peaks during Neptune transits and Full Moons. Use these times for spiritual practice, not major decisions.',
  },
  'unmotivated': {
    title: 'Why Am I So Unmotivated?',
    question: 'Why can\'t I find the drive to do anything?',
    intro: 'Lack of motivation often signals that your Heart dimension is misaligned with your actions. You may be trying to pursue goals that don\'t actually matter to you at a deep level.',
    dimension: '♀',
    dimensionName: 'Heart (Venus)',
    explanation: 'The Heart dimension represents what you truly treasure - not what you think you should want, but what genuinely pulls your soul. When Heart is disconnected from action, motivation dies.',
    shadow: 'The shadow of Heart is pursuing false values (status, approval, inherited goals) or refusing to value anything (cynicism, detachment). Neither generates authentic motivation.',
    signs: [
      'Success feels empty',
      'Can\'t explain why you\'re pursuing your current goals',
      'Envy of people who seem passionate',
      'Procrastination on everything, not just hard things',
    ],
    actions: [
      'Question every "should" - whose value is this?',
      'Notice what you do without needing motivation',
      'Reconnect with childhood interests before social conditioning',
      'Allow yourself to want what you actually want',
    ],
    optimalTimes: 'Heart clarity often emerges during Venus returns (yearly) and when Venus aspects your natal Venus. These are windows for reassessing what matters.',
  },
  'restless': {
    title: 'Why Am I So Restless?',
    question: 'Why can\'t I feel settled?',
    intro: 'Restlessness typically indicates activation in the Growth dimension. Your growth-seeking nature is calling for more, but may not yet have found its direction.',
    dimension: '♃',
    dimensionName: 'Growth (Jupiter)',
    explanation: 'The Growth dimension governs learning, adventure, and meaning-making. When Growth is activated, staying still feels like dying. You need new horizons.',
    shadow: 'The shadow of Growth is either scattered chasing of novelty (never going deep) or fear-based refusal to grow (stagnation). Balance requires choosing growth paths wisely.',
    signs: [
      'Boredom with routines that used to satisfy',
      'Yearning for travel, learning, or adventure',
      'Starting many things, finishing few',
      'Feeling confined by current life circumstances',
    ],
    actions: [
      'Honor the call for growth - it\'s not restlessness, it\'s readiness',
      'Choose one growth direction rather than scattering energy',
      'Find adventures within your constraints if large changes aren\'t possible',
      'Study something new to feed the hungry dimension',
    ],
    optimalTimes: 'Growth peaks during Jupiter transits and when Jupiter aspects your natal Jupiter (every 12 years is a major cycle). These are windows for bold moves.',
  },
  'overwhelmed': {
    title: 'Why Am I So Overwhelmed?',
    question: 'Why does everything feel like too much?',
    intro: 'Overwhelm often reflects a Mind dimension overload combined with insufficient Structure grounding. You\'re processing more than your system can handle without proper foundation.',
    dimension: '☿',
    dimensionName: 'Mind (Mercury)',
    explanation: 'The Mind dimension governs mental processing, understanding, and communication. When overloaded without breaks, the system crashes. Modern life often demands constant cognitive output.',
    shadow: 'The shadow of Mind is either mental paralysis (can\'t think clearly) or obsessive analysis (can\'t stop thinking). Both indicate system stress.',
    signs: [
      'Simple decisions feel impossible',
      'Can\'t prioritize - everything seems urgent',
      'Brain fog or racing thoughts',
      'Forgetting things more than usual',
    ],
    actions: [
      'Reduce mental load: delegate, defer, delete tasks',
      'Ground through your body: nature, movement, simple sensory experience',
      'Single-task instead of multi-task during overwhelm periods',
      'Schedule mental rest as seriously as mental work',
    ],
    optimalTimes: 'Mental clarity improves during Mercury\'s clear periods (not retrograde) and when Mercury makes harmonious aspects. Schedule important thinking then.',
  },
  'disconnected': {
    title: 'Why Do I Feel Disconnected?',
    question: 'Why do I feel alone even when I\'m with people?',
    intro: 'Feeling disconnected often signals a Connection dimension deficit or shadow state. Your capacity for intimate connection may be blocked or unfed.',
    dimension: '☽',
    dimensionName: 'Connection (Moon)',
    explanation: 'The Connection dimension governs love, partnership, empathy, and the capacity for genuine meeting. Disconnection arises when this dimension is wounded, neglected, or in shadow.',
    shadow: 'The shadow of Connection is either desperate clinging (fear of being alone) or rigid isolation (fear of being consumed). True connection requires neither extreme.',
    signs: [
      'Feeling like nobody really knows you',
      'Relationships feel performative or transactional',
      'Intimacy feels dangerous',
      'Missing connection even in partnerships',
    ],
    actions: [
      'Risk being seen - share something real with someone safe',
      'Practice receiving, not just giving',
      'Examine what disconnection protects you from',
      'Quality over quantity - deepen one relationship rather than spreading thin',
    ],
    optimalTimes: 'Connection openings occur during Venus transits and Friday evenings (Venus-ruled). Use these times for connection attempts.',
  },
  'creative-block': {
    title: 'Why Do I Have Creative Block?',
    question: 'Why can\'t I create anymore?',
    intro: 'Creative block typically indicates that the Growth dimension and Heart dimension are misaligned. Your creative energy wants to flow, but something is blocking the channel.',
    dimension: '♃',
    dimensionName: 'Growth (Jupiter)',
    explanation: 'Creative flow requires both the Growth dimension (generating new possibilities) and the Heart dimension (caring enough to manifest them). Block occurs when either is suppressed or when inner criticism silences emerging work.',
    shadow: 'The shadow of creativity is either perfectionism (nothing is good enough to express) or chaos (everything spills out without form). Both prevent completed work.',
    signs: [
      'Ideas that won\'t become reality',
      'Harsh self-criticism before work even begins',
      'Comparing your process to others\' finished products',
      'Loss of play in creative work',
    ],
    actions: [
      'Create something with zero stakes - for you only, to be destroyed after',
      'Separate generating from editing - they require different states',
      'Feed the creative well: consume art, experience beauty, play',
      'Lower the bar dramatically - create anything rather than something good',
    ],
    optimalTimes: 'Creative flow peaks during Leo and Sagittarius transits, and when Jupiter aspects your natal Sun. These are windows for bold expression.',
  },
};

const { slug } = Astro.props;
const content = WHY_CONTENT[slug];

if (!content) {
  return Astro.redirect('/404');
}

const breadcrumbs = [
  { name: 'Home', url: '/' },
  { name: 'Why Am I...?', url: '/why' },
  { name: content.title, url: `/why/${slug}` },
];
---

<BaseLayout
  title={`${content.title} - Pattern Insight`}
  description={content.question + ' ' + content.intro.slice(0, 120)}
  breadcrumbs={breadcrumbs}
>
  <article class="why-article">
    <div class="article-container">
      <header class="article-header">
        <span class="article-category">Pattern Insight</span>
        <h1>{content.title}</h1>
        <p class="lead-question">{content.question}</p>
      </header>

      <div class="article-content">
        <section class="intro-section">
          <p class="intro-text">{content.intro}</p>

          <div class="dimension-card">
            <div class="dimension-symbol">{content.dimension}</div>
            <div class="dimension-info">
              <span class="dimension-name">{content.dimensionName}</span>
              <span class="dimension-label">Primary Dimension</span>
            </div>
          </div>
        </section>

        <section class="explanation-section">
          <h2>The Pattern Explanation</h2>
          <p>{content.explanation}</p>
        </section>

        <section class="shadow-section">
          <h2>The Shadow Side</h2>
          <p>{content.shadow}</p>
        </section>

        <section class="signs-section">
          <h2>Signs You're Experiencing This</h2>
          <ul class="signs-list">
            {content.signs.map((sign) => (
              <li>{sign}</li>
            ))}
          </ul>
        </section>

        <section class="actions-section">
          <h2>What You Can Do</h2>
          <ol class="actions-list">
            {content.actions.map((action) => (
              <li>{action}</li>
            ))}
          </ol>
        </section>

        <section class="timing-section">
          <h2>Optimal Times</h2>
          <p>{content.optimalTimes}</p>
        </section>

        <!-- CTA -->
        <section class="cta-section">
          <h3>Understand Your Unique Pattern</h3>
          <p>
            This general insight applies to everyone. For guidance specific to YOUR energy pattern
            and YOUR current state, discover your personal profile.
          </p>
          <div class="cta-buttons">
            <a href="/discover" class="cta-primary">Map your natal field</a>
            <a href="/subscribe" class="cta-secondary">Sol Pro →</a>
          </div>
        </section>
      </div>

      <!-- Related Articles -->
      <nav class="related-articles">
        <h3>Related Questions</h3>
        <div class="related-grid">
          {Object.entries(WHY_CONTENT)
            .filter(([key]) => key !== slug)
            .slice(0, 4)
            .map(([key, article]) => (
              <a href={`/why/${key}`} class="related-card">
                <span class="related-question">{article.question}</span>
              </a>
            ))}
        </div>
      </nav>
    </div>
  </article>
</BaseLayout>

<style>
  .why-article {
    --gold: #d4a854;
    --dark: #0a0908;
    --dark-surface: #141210;
    --text: #f0e8d8;
    --text-muted: rgba(240, 232, 216, 0.6);

    font-family: 'Cormorant Garamond', Georgia, serif;
    background: var(--dark);
    color: var(--text);
    min-height: 100vh;
    padding: 6rem 2rem 4rem;
  }

  .article-container {
    max-width: 720px;
    margin: 0 auto;
  }

  .article-header {
    text-align: center;
    margin-bottom: 3rem;
    padding-bottom: 2rem;
    border-bottom: 1px solid rgba(212, 168, 84, 0.2);
  }

  .article-category {
    display: inline-block;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--gold);
    margin-bottom: 1rem;
  }

  .article-header h1 {
    font-size: 2.5rem;
    font-weight: 300;
    color: var(--text);
    margin-bottom: 1rem;
    line-height: 1.2;
  }

  .lead-question {
    font-size: 1.25rem;
    color: var(--text-muted);
    font-style: italic;
  }

  .article-content section {
    margin-bottom: 2.5rem;
  }

  .intro-text {
    font-size: 1.15rem;
    line-height: 1.8;
    color: var(--text);
    margin-bottom: 2rem;
  }

  .dimension-card {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    padding: 1.5rem;
    background: rgba(212, 168, 84, 0.08);
    border-left: 4px solid var(--gold);
  }

  .dimension-symbol {
    font-size: 2.5rem;
    color: var(--gold);
    font-family: 'Georgia', serif;
    width: 60px;
    height: 60px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(212, 168, 84, 0.1);
    border-radius: 50%;
  }

  .dimension-info {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .dimension-name {
    font-size: 1.25rem;
    color: var(--text);
    font-weight: 500;
  }

  .dimension-label {
    font-size: 0.8rem;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  h2 {
    font-size: 1.5rem;
    font-weight: 400;
    color: var(--gold);
    margin-bottom: 1rem;
  }

  .article-content p {
    font-size: 1.1rem;
    line-height: 1.8;
    color: var(--text-muted);
  }

  .signs-list, .actions-list {
    padding-left: 1.5rem;
  }

  .signs-list li, .actions-list li {
    font-size: 1.05rem;
    line-height: 1.7;
    color: var(--text-muted);
    margin-bottom: 0.75rem;
  }

  .signs-list li::marker {
    color: var(--gold);
  }

  .actions-list li::marker {
    color: var(--gold);
  }

  .cta-section {
    text-align: center;
    padding: 2.5rem;
    background: var(--dark-surface);
    border: 1px solid rgba(212, 168, 84, 0.2);
  }

  .cta-section h3 {
    font-size: 1.5rem;
    font-weight: 400;
    color: var(--text);
    margin-bottom: 0.75rem;
  }

  .cta-section p {
    font-size: 1rem;
    color: var(--text-muted);
    margin-bottom: 1.5rem;
  }

  .cta-buttons {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  .cta-primary {
    padding: 0.875rem 1.5rem;
    background: var(--gold);
    color: var(--dark);
    text-decoration: none;
    font-weight: 500;
    transition: all 0.2s;
  }

  .cta-primary:hover {
    background: #e5b964;
    box-shadow: 0 0 20px rgba(212, 168, 84, 0.3);
  }

  .cta-secondary {
    padding: 0.875rem 1.5rem;
    border: 1px solid var(--gold);
    color: var(--gold);
    text-decoration: none;
    transition: all 0.2s;
  }

  .cta-secondary:hover {
    background: rgba(212, 168, 84, 0.1);
  }

  .related-articles {
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px solid rgba(212, 168, 84, 0.1);
  }

  .related-articles h3 {
    font-size: 1.25rem;
    color: var(--text-muted);
    margin-bottom: 1.5rem;
    text-align: center;
  }

  .related-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1rem;
  }

  @media (max-width: 640px) {
    .related-grid {
      grid-template-columns: 1fr;
    }
  }

  .related-card {
    padding: 1.25rem;
    background: var(--dark-surface);
    border: 1px solid rgba(212, 168, 84, 0.15);
    text-decoration: none;
    transition: all 0.2s;
  }

  .related-card:hover {
    border-color: var(--gold);
    transform: translateY(-2px);
  }

  .related-question {
    font-size: 0.95rem;
    color: var(--text);
    line-height: 1.5;
  }
</style>
