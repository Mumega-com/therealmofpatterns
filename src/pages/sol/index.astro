---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Today's Forecast | Sol" description="Your friendly daily guide to navigating energy and focus">
  <div class="sol-page">
    <!-- Warm Background -->
    <div class="warm-bg">
      <div class="blob blob-1"></div>
      <div class="blob blob-2"></div>
      <div class="blob blob-3"></div>
      <div class="floating-shapes" id="floating-shapes"></div>
    </div>

    <!-- Header -->
    <header class="sol-header">
      <div class="header-content">
        <div class="greeting-section">
          <div class="greeting-text">
            <h1 class="greeting-title" id="greeting-title">What moves in you today</h1>
            <p class="greeting-subtitle" id="greeting"></p>
          </div>
        </div>

        <a href="/sol/checkin" class="checkin-btn">
          <span class="btn-text">Daily reflection</span>
          <span class="btn-badge">5 min</span>
        </a>
      </div>

      <!-- Oracle sentence -->
      <div class="oracle-sentence" id="oracle-sentence">
        The field is quiet. Return when you are ready to listen.
      </div>

      <!-- Energy Overview -->
      <div class="energy-overview">
        <div class="energy-card">
          <div class="energy-ring" id="energy-ring">
            <svg viewBox="0 0 100 100">
              <circle class="ring-bg" cx="50" cy="50" r="42" />
              <circle class="ring-fill" cx="50" cy="50" r="42" id="ring-fill" />
            </svg>
            <div class="energy-value" id="energy-value">--</div>
          </div>
          <div class="energy-info">
            <span class="energy-label">Field alignment</span>
            <span class="energy-status" id="energy-status">Reading...</span>
          </div>
        </div>

        <div class="quick-stats">
          <div class="quick-stat">
            <span class="stat-sym">◑</span>
            <span class="stat-value" id="best-time">Morning</span>
            <span class="stat-label">Peak window</span>
          </div>
          <div class="quick-stat">
            <span class="stat-sym">◈</span>
            <span class="stat-value" id="streak">--</span>
            <span class="stat-label">Days of reflection</span>
          </div>
        </div>
      </div>
    </header>

    <!-- Main Content -->
    <main class="sol-main">
      <div class="content-grid">
        <!-- Forecast Section -->
        <section class="content-card forecast-card">
          <div class="card-header">
            <span class="card-emoji">◎</span>
            <h2 class="card-title">Today's Reading</h2>
          </div>
          <div class="card-content" id="sol-forecast"></div>
        </section>

        <!-- Windows Section -->
        <section class="content-card windows-card">
          <div class="card-header">
            <span class="card-emoji">⧗</span>
            <h2 class="card-title">Field Windows</h2>
          </div>
          <div class="card-content" id="sol-windows"></div>
        </section>
      </div>

      <!-- Weekly Synthesis -->
      <div id="weekly-synthesis"></div>

      <!-- Pro upgrade nudge (shown only to free users, injected by JS) -->
      <div id="pro-nudge"></div>

      <!-- Tips Section -->
      <section class="tips-section">
        <div class="tip-card" id="daily-tip">
          <div class="tip-content">
            <span class="tip-label">Field note</span>
            <span id="tip-text">Notice where your attention naturally moves today — that is the field speaking.</span>
          </div>
        </div>
      </section>
    </main>

    <!-- Quick Nav — links NOT already in the header -->
    <nav class="sol-quick-nav">
      <a href="/reading" class="quick-nav-link">
        <span class="quick-nav-icon">&#9789;</span>
        <span>Reading</span>
      </a>
      <a href="/history" class="quick-nav-link">
        <span class="quick-nav-icon">&#9776;</span>
        <span>History</span>
      </a>
      <a href="/journey" class="quick-nav-link">
        <span class="quick-nav-icon">&#9830;</span>
        <span>Journey</span>
      </a>
      <a href="/soul" class="quick-nav-link">
        <span class="quick-nav-icon">&#10210;</span>
        <span>Soul Field</span>
      </a>
      <a href="/profile" class="quick-nav-link">
        <span class="quick-nav-icon">&#9673;</span>
        <span>Profile</span>
      </a>
      <a href="/settings" class="quick-nav-link">
        <span class="quick-nav-icon">&#9881;</span>
        <span>Settings</span>
      </a>
    </nav>

    <!-- Footer -->
    <footer class="sol-footer">
      <p class="footer-text">
        Sol reads the field. What you do with it is yours.
      </p>
    </footer>
  </div>
</BaseLayout>

<style>
  .sol-page {
    min-height: 100vh;
    padding: 1.5rem;
    font-family: 'Inter', -apple-system, sans-serif;
    position: relative;
    overflow-x: hidden;
    background: #0a0908;
    color: #f0e8d8;
  }

  /* Warm Background */
  .warm-bg {
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: 0;
    overflow: hidden;
  }

  .blob {
    position: absolute;
    border-radius: 50%;
    filter: blur(60px);
    animation: blob-move 20s ease-in-out infinite;
  }

  .blob-1 {
    width: 350px;
    height: 350px;
    background: radial-gradient(circle, rgba(212, 168, 84, 0.25) 0%, transparent 70%);
    top: -100px;
    right: -50px;
    animation-delay: 0s;
  }

  .blob-2 {
    width: 280px;
    height: 280px;
    background: radial-gradient(circle, rgba(167, 139, 250, 0.15) 0%, transparent 70%);
    bottom: 10%;
    left: -80px;
    animation-delay: -7s;
  }

  .blob-3 {
    width: 220px;
    height: 220px;
    background: radial-gradient(circle, rgba(212, 168, 84, 0.12) 0%, transparent 70%);
    top: 50%;
    right: 20%;
    animation-delay: -14s;
  }

  @keyframes blob-move {
    0%, 100% { transform: translate(0, 0) scale(1); }
    33% { transform: translate(30px, -20px) scale(1.05); }
    66% { transform: translate(-20px, 30px) scale(0.95); }
  }

  .floating-shapes {
    position: absolute;
    inset: 0;
    overflow: hidden;
  }

  .floating-shapes span {
    position: absolute;
    opacity: 0.15;
    animation: shape-float 15s ease-in-out infinite;
  }

  @keyframes shape-float {
    0%, 100% { transform: translateY(0) rotate(0deg); }
    50% { transform: translateY(-30px) rotate(10deg); }
  }

  /* Header */
  .sol-header {
    position: relative;
    z-index: 1;
    max-width: 800px;
    margin: 0 auto 2rem;
  }

  .header-content {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    margin-bottom: 2rem;
  }

  @media (min-width: 640px) {
    .header-content {
      flex-direction: row;
      justify-content: space-between;
      align-items: center;
    }
  }

  .greeting-section {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .wave-emoji {
    font-size: 3rem;
    animation: wave 2.5s ease-in-out infinite;
    transform-origin: 70% 70%;
  }

  @keyframes wave {
    0%, 100% { transform: rotate(0deg); }
    10% { transform: rotate(14deg); }
    20% { transform: rotate(-8deg); }
    30% { transform: rotate(14deg); }
    40% { transform: rotate(-4deg); }
    50% { transform: rotate(10deg); }
    60%, 100% { transform: rotate(0deg); }
  }

  .greeting-title {
    font-size: 1.75rem;
    font-weight: 600;
    color: #f0e8d8;
    margin-bottom: 0.25rem;
    font-family: 'Cormorant Garamond', Georgia, serif;
  }

  .greeting-subtitle {
    font-size: 1rem;
    color: rgba(240, 232, 216, 0.6);
  }

  .oracle-sentence {
    font-family: 'Cormorant Garamond', Georgia, serif;
    font-size: 1.05rem;
    font-style: italic;
    color: rgba(212, 168, 84, 0.75);
    line-height: 1.6;
    text-align: center;
    padding: 0.75rem 1.5rem;
    margin: 0.5rem 0 1.25rem;
    border-left: 2px solid rgba(212, 168, 84, 0.25);
    border-right: 2px solid rgba(212, 168, 84, 0.25);
    animation: oracle-fade-in 1.2s ease-out;
  }

  @keyframes oracle-fade-in {
    from { opacity: 0; transform: translateY(-6px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .checkin-btn {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.875rem 1.5rem;
    background: linear-gradient(135deg, #d4a854 0%, #c49a4a 100%);
    color: #0a0908;
    text-decoration: none;
    border-radius: 16px;
    font-weight: 600;
    font-size: 0.95rem;
    box-shadow: 0 4px 15px rgba(212, 168, 84, 0.3);
    transition: all 0.3s ease;
  }

  .checkin-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(212, 168, 84, 0.4);
  }

  .btn-emoji {
    font-size: 1.25rem;
  }

  .btn-badge {
    font-size: 0.75rem;
    padding: 0.2rem 0.5rem;
    background: rgba(255, 255, 255, 0.2);
    border-radius: 8px;
    font-weight: 500;
  }

  /* Energy Overview */
  .energy-overview {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
    padding: 1.5rem;
    background: rgba(26, 24, 20, 0.6);
    border: 1px solid rgba(212, 168, 84, 0.1);
    border-radius: 24px;
  }

  @media (min-width: 640px) {
    .energy-overview {
      grid-template-columns: auto 1fr;
      gap: 2rem;
    }
  }

  .energy-card {
    display: flex;
    align-items: center;
    gap: 1.25rem;
  }

  .energy-ring {
    position: relative;
    width: 90px;
    height: 90px;
  }

  .energy-ring svg {
    width: 100%;
    height: 100%;
    transform: rotate(-90deg);
  }

  .ring-bg {
    fill: none;
    stroke: rgba(240, 232, 216, 0.1);
    stroke-width: 8;
  }

  .ring-fill {
    fill: none;
    stroke: url(#energy-gradient);
    stroke-width: 8;
    stroke-linecap: round;
    stroke-dasharray: 264;
    stroke-dashoffset: 264;
    transition: stroke-dashoffset 1.5s ease-out;
  }

  .energy-value {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.5rem;
    font-weight: 700;
    color: #d4a854;
  }

  .energy-info {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .energy-label {
    font-size: 0.8rem;
    color: rgba(240, 232, 216, 0.4);
    font-weight: 500;
  }

  .energy-status {
    font-size: 1.1rem;
    font-weight: 600;
    color: #f0e8d8;
  }

  .quick-stats {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1rem;
  }

  .quick-stat {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: 1rem;
    background: rgba(240, 232, 216, 0.04);
    border: 1px solid rgba(212, 168, 84, 0.08);
    border-radius: 16px;
  }

  .stat-sym {
    font-size: 1.25rem;
    color: rgba(212, 168, 84, 0.5);
    margin-bottom: 0.5rem;
  }

  .stat-value {
    font-size: 1rem;
    font-weight: 600;
    color: #f0e8d8;
    margin-bottom: 0.25rem;
  }

  .stat-label {
    font-size: 0.75rem;
    color: rgba(240, 232, 216, 0.4);
  }

  /* Main Content */
  .sol-main {
    position: relative;
    z-index: 1;
    max-width: 800px;
    margin: 0 auto;
  }

  .content-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
    margin-bottom: 1.5rem;
  }

  @media (min-width: 768px) {
    .content-grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  .content-card {
    background: rgba(26, 24, 20, 0.6);
    border: 1px solid rgba(212, 168, 84, 0.1);
    border-radius: 20px;
    overflow: hidden;
  }

  .card-header {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 1.25rem 1.5rem;
    border-bottom: 1px solid rgba(212, 168, 84, 0.08);
  }

  .card-emoji {
    font-size: 1.5rem;
  }

  .card-title {
    font-size: 1rem;
    font-weight: 600;
    color: #f0e8d8;
  }

  .card-content {
    padding: 1.5rem;
  }

  /* Tips Section */
  .tips-section {
    margin-top: 1.5rem;
  }

  .tip-card {
    padding: 1.25rem 1.5rem;
    background: rgba(212, 168, 84, 0.06);
    border: 1px solid rgba(212, 168, 84, 0.12);
    border-radius: 16px;
  }

  .tip-content {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    font-size: 0.95rem;
    color: rgba(240, 232, 216, 0.65);
    line-height: 1.6;
    font-style: italic;
  }

  .tip-label {
    font-size: 0.7rem;
    font-style: normal;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(212, 168, 84, 0.6);
  }

  /* Pro nudge */
  .pro-nudge-link {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    max-width: 800px;
    margin: 1rem auto;
    padding: 0.875rem 1.25rem;
    background: rgba(212, 168, 84, 0.04);
    border: 1px solid rgba(212, 168, 84, 0.12);
    text-decoration: none;
    color: rgba(240, 232, 216, 0.55);
    font-size: 0.875rem;
    font-family: 'Cormorant Garamond', Georgia, serif;
    transition: border-color 0.2s, color 0.2s;
  }
  .pro-nudge-link:hover {
    border-color: rgba(212, 168, 84, 0.25);
    color: rgba(240, 232, 216, 0.8);
  }
  .pro-nudge-icon { color: rgba(212, 168, 84, 0.5); }
  .pro-nudge-text { flex: 1; }
  .pro-nudge-cta { color: #d4a854; white-space: nowrap; }

  /* Footer */
  .sol-footer {
    position: relative;
    z-index: 1;
    max-width: 800px;
    margin: 3rem auto 0;
    padding-top: 1.5rem;
    border-top: 1px solid rgba(212, 168, 84, 0.1);
  }

  .footer-text {
    text-align: center;
    font-size: 0.875rem;
    color: rgba(240, 232, 216, 0.3);
  }

  .heart {
    display: inline-block;
    animation: heartbeat 1.5s ease-in-out infinite;
  }

  @keyframes heartbeat {
    0%, 100% { transform: scale(1); }
    50% { transform: scale(1.2); }
  }

  /* Responsive */
  /* Quick Nav */
  .sol-quick-nav {
    position: relative;
    z-index: 1;
    max-width: 800px;
    margin: 2rem auto 0;
    display: flex;
    justify-content: center;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .quick-nav-link {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.625rem 1.25rem;
    background: rgba(26, 24, 20, 0.6);
    border: 1px solid rgba(212, 168, 84, 0.1);
    border-radius: 12px;
    color: rgba(240, 232, 216, 0.7);
    text-decoration: none;
    font-size: 0.9rem;
    font-weight: 500;
    transition: all 0.2s ease;
  }

  .quick-nav-link:hover {
    background: rgba(212, 168, 84, 0.08);
    border-color: rgba(212, 168, 84, 0.3);
    color: #d4a854;
  }

  .quick-nav-icon {
    color: #d4a854;
    font-size: 1.1rem;
  }

  @media (min-width: 768px) {
    .sol-page {
      padding: 2rem;
    }

    .greeting-title {
      font-size: 2rem;
    }

    .energy-ring {
      width: 100px;
      height: 100px;
    }
  }
</style>

<script>
  import { createElement } from 'react';
  import { createRoot } from 'react-dom/client';
  import { NarratorCard } from '../../components/shared/NarratorCard';
  import { SolWindows } from '../../components/sol/SolWindows';
  import { WeeklySynthesis } from '../../components/sol/WeeklySynthesis';
  import { setMode, $forecast } from '../../stores'; // $forecast used by energy ring
  import { getCheckinHistory } from '../../lib/checkin-storage';
  import { computeFromBirthData } from '../../lib/16d-engine';

  // Set mode to Sol
  setMode('sol');

  // Oracle sentence — derived from today's dominant transit dimension
  const ORACLE_SENTENCES = [
    "Sun illuminates something at the center of you that has been waiting to be acknowledged.",
    "Saturn is present in the field. What you have agreed to carry — does it still belong to you?",
    "Mercury quickens the mind today. Notice what it is circling but not quite naming.",
    "Venus draws attention to what you value. Something there has not been fully honoured.",
    "Jupiter opens a question of becoming. What would you grow toward if you stopped managing the risk?",
    "Mars moves in the dimension of drive. The energy that wants to act — what keeps redirecting it?",
    "The Moon is active in the field of connection. What relationship is quietly asking something of you?",
    "Something at the edge of awareness presses toward consciousness. The field is listening.",
  ];

  function setOracleSentence() {
    const el = document.getElementById('oracle-sentence');
    if (!el) return;
    try {
      const stored = localStorage.getItem('rop_birth_data_full');
      if (!stored) {
        el.textContent = ORACLE_SENTENCES[new Date().getDay() % ORACLE_SENTENCES.length];
        return;
      }
      const birthData = JSON.parse(stored);
      const now = new Date();
      const todayBirth = {
        year: now.getFullYear(), month: now.getMonth() + 1, day: now.getDate(),
        hour: now.getHours(), minute: now.getMinutes(),
        latitude: birthData.latitude, longitude: birthData.longitude,
        timezone_offset: -now.getTimezoneOffset() / 60,
      };
      const tv = Array.from(computeFromBirthData(todayBirth)).slice(0, 8) as number[];
      const dominant = tv.indexOf(Math.max(...tv));
      el.textContent = ORACLE_SENTENCES[dominant];
    } catch {
      el.textContent = ORACLE_SENTENCES[new Date().getDay() % ORACLE_SENTENCES.length];
    }
  }

  // Create floating shapes
  function createFloatingShapes() {
    const container = document.getElementById('floating-shapes');
    if (!container) return;

    const shapes = ['◦', '○', '◎', '◌'];

    for (let i = 0; i < 8; i++) {
      const span = document.createElement('span');
      span.innerHTML = shapes[Math.floor(Math.random() * shapes.length)];
      span.style.left = `${Math.random() * 100}%`;
      span.style.top = `${Math.random() * 100}%`;
      span.style.fontSize = `${12 + Math.random() * 18}px`;
      span.style.color = `rgba(212, 168, 84, ${0.1 + Math.random() * 0.2})`;
      span.style.animationDelay = `${Math.random() * 15}s`;
      span.style.animationDuration = `${12 + Math.random() * 8}s`;
      container.appendChild(span);
    }
  }

  // Set greeting based on time
  function setGreeting() {
    const greetingEl = document.getElementById('greeting');
    if (!greetingEl) return;

    const hour = new Date().getHours();
    let greeting = "The field is read. The rest is yours.";
    if (hour < 6)  greeting = "Something in you is awake before the rest of you. That is worth attending to.";
    else if (hour < 12) greeting = "The morning carries a particular quality of attention. What is present before the day's noise arrives?";
    else if (hour < 17) greeting = "The afternoon often reveals what the morning concealed. What has clarified since you began?";
    else greeting = "The day settles. What did it ask of you? What did you answer?";
    greetingEl.textContent = greeting;
  }

  // Update energy ring
  function updateEnergyRing() {
    const forecast = $forecast.get();
    const kappa = forecast.kappa || 0.73;
    const percent = Math.round(kappa * 100);

    // Update value
    const valueEl = document.getElementById('energy-value');
    if (valueEl) valueEl.textContent = `${percent}%`;

    // Update ring
    const ringEl = document.getElementById('ring-fill');
    if (ringEl) {
      const offset = 264 - (264 * kappa);
      ringEl.style.strokeDashoffset = offset.toString();
    }

    // Update status
    const statusEl = document.getElementById('energy-status');
    if (statusEl) {
      if (kappa >= 0.8) statusEl.textContent = "Strong coherence — the field is aligned";
      else if (kappa >= 0.6) statusEl.textContent = "The currents are favorable";
      else if (kappa >= 0.4) statusEl.textContent = "The psyche is consolidating";
      else statusEl.textContent = "Something has withdrawn — that is information";
    }
  }

  // Daily field notes (rotate by day)
  const tips = [
    "Notice where your attention naturally moves today — that is the field speaking.",
    "Psychological resistance often appears as fatigue. What are you approaching that you would rather not?",
    "The dimension you feel least today often carries the most unconscious material.",
    "What you are avoiding in the outer world frequently mirrors what is unresolved in the inner one.",
    "High coherence is not always the goal. Sometimes the field needs to break down before it reorganizes.",
  ];

  function setDailyTip() {
    const tipEl = document.getElementById('tip-text');
    if (tipEl) {
      const dayIndex = new Date().getDate() % tips.length;
      tipEl.textContent = tips[dayIndex];
    }
  }

  // Update streak from actual data
  function updateStreak() {
    const streakEl = document.getElementById('streak');
    if (streakEl) {
      const history = getCheckinHistory();
      const streak = history.streak || 0;
      streakEl.textContent = streak === 1 ? '1 day' : `${streak} days`;
    }
  }

  // Initialize
  function initDashboard() {
    createFloatingShapes();
    setGreeting();
    setOracleSentence();
    setDailyTip();
    updateStreak();

    // Add gradient definition for energy ring
    const svg = document.querySelector('.energy-ring svg');
    if (svg) {
      const defs = document.createElementNS('http://www.w3.org/2000/svg', 'defs');
      defs.innerHTML = `
        <linearGradient id="energy-gradient" x1="0%" y1="0%" x2="100%" y2="0%">
          <stop offset="0%" style="stop-color:#fbbf24" />
          <stop offset="100%" style="stop-color:#f59e0b" />
        </linearGradient>
      `;
      svg.insertBefore(defs, svg.firstChild);
    }

    // Delay energy ring animation
    setTimeout(updateEnergyRing, 500);

    // Subscribe to forecast changes
    $forecast.subscribe(updateEnergyRing);

    // Mount React components
    const forecastEl = document.getElementById('sol-forecast');
    if (forecastEl) {
      createRoot(forecastEl).render(createElement(NarratorCard, { compact: true }));
    }

    const windowsEl = document.getElementById('sol-windows');
    if (windowsEl) {
      createRoot(windowsEl).render(createElement(SolWindows));
    }

    const weeklyEl = document.getElementById('weekly-synthesis');
    if (weeklyEl) {
      createRoot(weeklyEl).render(createElement(WeeklySynthesis));
    }

    // Pro nudge — only for free users
    const user = JSON.parse(localStorage.getItem('rop_user') || '{}');
    if (!user.isPro) {
      const nudgeEl = document.getElementById('pro-nudge');
      if (nudgeEl) {
        nudgeEl.innerHTML = `
          <a href="/subscribe?plan=individual" class="pro-nudge-link">
            <span class="pro-nudge-icon">◎</span>
            <span class="pro-nudge-text">Sol goes deeper for Pro members — weekly synthesis, richer readings</span>
            <span class="pro-nudge-cta">Learn more →</span>
          </a>`;
      }
    }
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initDashboard);
  } else {
    initDashboard();
  }
</script>
