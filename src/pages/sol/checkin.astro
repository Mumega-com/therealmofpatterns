---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Daily Reflection | Sol" description="Five dimensions of the field. A brief daily encounter with what is actually moving in you.">
  <div class="sol-checkin-page">
    <!-- Warm Background -->
    <div class="warm-bg">
      <div class="blob blob-1"></div>
      <div class="blob blob-2"></div>
      <div class="blob blob-3"></div>
      <div class="sparkles" id="sparkles"></div>
    </div>

    <!-- Header -->
    <header class="sol-header">
      <a href="/sol" class="back-link">
        <span class="back-arrow">&#8592;</span>
        <span>Back to dashboard</span>
      </a>

      <div class="header-content">
        <div class="symbol-container">
          <span class="field-symbol">◉</span>
        </div>
        <h1 class="page-title">Daily Reflection</h1>
        <p class="page-subtitle">
          Five dimensions of the field.<br />What does each ask of you today?
        </p>
      </div>

      <!-- Progress preview -->
      <div class="progress-preview">
        <div class="progress-dots">
          <span class="progress-dot active"></span>
          <span class="progress-dot"></span>
          <span class="progress-dot"></span>
          <span class="progress-dot"></span>
          <span class="progress-dot"></span>
        </div>
        <span class="progress-label">5 dimensions</span>
      </div>
    </header>

    <!-- Check-in Component -->
    <main class="sol-main">
      <div id="sol-checkin" class="checkin-container"></div>
    </main>

    <!-- Info Footer -->
    <footer class="sol-footer">
      <div class="footer-card">
        <p class="footer-tip">
          The field does not need you to get it right. It only asks that you meet it honestly.
        </p>
      </div>
    </footer>

    <!-- Confetti container -->
    <div id="confetti-container" class="confetti-container"></div>
  </div>
</BaseLayout>

<style>
  .sol-checkin-page {
    min-height: 100vh;
    padding: 1.5rem;
    font-family: 'Inter', -apple-system, sans-serif;
    position: relative;
    overflow: hidden;
    background: #0a0908;
    color: #f0e8d8;
  }

  /* Warm Background */
  .warm-bg {
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: 0;
    overflow: hidden;
  }

  .blob {
    position: absolute;
    border-radius: 50%;
    filter: blur(80px);
    opacity: 0.35;
    animation: blob-float 15s ease-in-out infinite;
  }

  .blob-1 {
    width: 300px;
    height: 300px;
    background: radial-gradient(circle, rgba(212, 168, 84, 0.3) 0%, transparent 70%);
    top: -100px;
    right: -50px;
    animation-delay: 0s;
  }

  .blob-2 {
    width: 250px;
    height: 250px;
    background: radial-gradient(circle, rgba(167, 139, 250, 0.2) 0%, transparent 70%);
    bottom: 20%;
    left: -50px;
    animation-delay: -5s;
  }

  .blob-3 {
    width: 200px;
    height: 200px;
    background: radial-gradient(circle, rgba(212, 168, 84, 0.15) 0%, transparent 70%);
    bottom: -50px;
    right: 20%;
    animation-delay: -10s;
  }

  @keyframes blob-float {
    0%, 100% { transform: translate(0, 0) scale(1); }
    25% { transform: translate(20px, -30px) scale(1.1); }
    50% { transform: translate(-30px, 20px) scale(0.9); }
    75% { transform: translate(30px, 30px) scale(1.05); }
  }

  .sparkles {
    position: absolute;
    inset: 0;
    overflow: hidden;
    pointer-events: none;
  }

  .sparkles span {
    position: absolute;
    color: #d4a854;
    opacity: 0;
    animation: sparkle-float 4s ease-in-out infinite;
  }

  @keyframes sparkle-float {
    0%, 100% { opacity: 0; transform: scale(0.5) rotate(0deg); }
    50% { opacity: 0.8; transform: scale(1) rotate(180deg); }
  }

  /* Header */
  .sol-header {
    position: relative;
    z-index: 1;
    max-width: 500px;
    margin: 0 auto 2rem;
    text-align: center;
  }

  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.875rem;
    color: rgba(240, 232, 216, 0.4);
    text-decoration: none;
    margin-bottom: 2rem;
    transition: all 0.3s ease;
  }

  .back-link:hover {
    color: #d4a854;
  }

  .back-arrow {
    display: inline-block;
    transition: transform 0.3s ease;
  }

  .back-link:hover .back-arrow {
    transform: translateX(-4px);
  }

  .header-content {
    margin-bottom: 1.5rem;
  }

  .symbol-container {
    margin-bottom: 1.25rem;
  }

  .field-symbol {
    font-size: 3rem;
    color: rgba(212, 168, 84, 0.7);
    display: block;
    animation: field-pulse 4s ease-in-out infinite;
  }

  @keyframes field-pulse {
    0%, 100% { opacity: 0.7; transform: scale(1); }
    50% { opacity: 1; transform: scale(1.06); }
  }

  .page-title {
    font-size: 2rem;
    font-weight: 600;
    color: #f0e8d8;
    margin-bottom: 0.5rem;
    font-family: 'Cormorant Garamond', Georgia, serif;
  }

  .page-subtitle {
    font-size: 1rem;
    color: rgba(240, 232, 216, 0.6);
    line-height: 1.6;
  }

  /* Progress Preview */
  .progress-preview {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
  }

  .progress-dots {
    display: flex;
    gap: 0.5rem;
  }

  .progress-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: rgba(212, 168, 84, 0.2);
    transition: all 0.3s ease;
  }

  .progress-dot.active {
    background: linear-gradient(135deg, #d4a854 0%, #c49a4a 100%);
    box-shadow: 0 2px 8px rgba(212, 168, 84, 0.4);
  }

  .progress-label {
    font-size: 0.75rem;
    color: rgba(240, 232, 216, 0.4);
    font-weight: 500;
    letter-spacing: 0.02em;
  }

  /* Main */
  .sol-main {
    position: relative;
    z-index: 1;
    margin-bottom: 3rem;
  }

  .checkin-container {
    max-width: 500px;
    margin: 0 auto;
  }

  /* Footer */
  .sol-footer {
    position: relative;
    z-index: 1;
    max-width: 500px;
    margin: 0 auto;
  }

  .footer-card {
    padding: 1rem 1.25rem;
    background: rgba(26, 24, 20, 0.6);
    border-radius: 16px;
    border: 1px solid rgba(212, 168, 84, 0.1);
  }

  .footer-tip {
    font-size: 0.875rem;
    color: rgba(240, 232, 216, 0.45);
    line-height: 1.6;
    margin: 0;
    font-style: italic;
  }

  /* Confetti */
  .confetti-container {
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: 100;
    overflow: hidden;
  }

  .confetti-container .confetti {
    position: absolute;
    width: 10px;
    height: 10px;
    opacity: 0;
  }

  .confetti-container.active .confetti {
    animation: confetti-fall 3s ease-out forwards;
  }

  @keyframes confetti-fall {
    0% {
      transform: translateY(-100px) rotate(0deg);
      opacity: 1;
    }
    100% {
      transform: translateY(100vh) rotate(720deg);
      opacity: 0;
    }
  }

  /* Responsive */
  @media (min-width: 640px) {
    .sol-checkin-page {
      padding: 2rem;
    }

    .page-title {
      font-size: 2.5rem;
    }

    .main-emoji {
      font-size: 5rem;
    }
  }
</style>

<script>
  import { createElement } from 'react';
  import { createRoot } from 'react-dom/client';
  import { CheckinFlowEnhanced } from '../../components/checkin/CheckinFlowEnhanced';
  import { setMode } from '../../stores';

  // Set mode to Sol
  setMode('sol');

  // Subtle particle drift on completion
  function triggerConfetti() {
    const container = document.getElementById('confetti-container');
    if (!container) return;

    container.innerHTML = '';
    const colors = ['#d4a854', '#c49a4a', '#e8c87a', '#a8834a', '#f0d89a', '#b89060'];

    for (let i = 0; i < 50; i++) {
      const confetti = document.createElement('div');
      confetti.className = 'confetti';
      confetti.style.left = `${Math.random() * 100}%`;
      confetti.style.backgroundColor = colors[Math.floor(Math.random() * colors.length)];
      confetti.style.borderRadius = Math.random() > 0.5 ? '50%' : '0';
      confetti.style.animationDelay = `${Math.random() * 0.5}s`;
      confetti.style.animationDuration = `${2 + Math.random() * 2}s`;
      container.appendChild(confetti);
    }

    container.classList.add('active');

    setTimeout(() => {
      container.classList.remove('active');
    }, 4000);
  }

  // Update progress dots
  function updateProgressDots(current: number, total: number) {
    const dots = document.querySelectorAll('.progress-dot');
    dots.forEach((dot, i) => {
      if (i < current) {
        dot.classList.add('active');
      } else {
        dot.classList.remove('active');
      }
    });
  }

  // Initialize
  document.addEventListener('DOMContentLoaded', () => {
    const checkinEl = document.getElementById('sol-checkin');
    if (checkinEl) {
      createRoot(checkinEl).render(
        createElement(CheckinFlowEnhanced, {
          onComplete: (results) => {
            console.log('Check-in complete:', results);
            triggerConfetti();
          }
        })
      );
    }
  });
</script>
