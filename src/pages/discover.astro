---
import BaseLayout from '../layouts/BaseLayout.astro';
import { DiscoverFlow } from '../components/discover/DiscoverFlow';
---

<BaseLayout
  title="Discover Your Pattern | The Realm of Patterns"
  description="Enter your birthday and instantly see your unique cosmic pattern. 30 seconds to your 8-dimensional identity signature."
  showFooter={false}
>
  <div class="discover-page">
    <!-- Background -->
    <div class="discover-bg">
      <div class="glow glow-1"></div>
      <div class="glow glow-2"></div>
    </div>

    <!-- Back link -->
    <nav class="discover-nav">
      <a href="/" class="back-link">&larr; Home</a>
    </nav>

    <!-- Main content -->
    <main class="discover-main">
      <DiscoverFlow client:load />
    </main>

    <!-- Branding footer -->
    <footer class="discover-footer">
      <span>The Realm of Patterns</span>
    </footer>
  </div>
</BaseLayout>

<style>
  .discover-page {
    min-height: 100vh;
    padding: 1.5rem;
    position: relative;
    overflow: hidden;
    background: #0a0908;
  }

  /* Background glows */
  .discover-bg {
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: 0;
  }

  .glow {
    position: absolute;
    border-radius: 50%;
    filter: blur(100px);
    opacity: 0.4;
    animation: float 12s ease-in-out infinite;
  }

  .glow-1 {
    width: 400px;
    height: 400px;
    background: radial-gradient(circle, rgba(212, 168, 84, 0.3) 0%, transparent 70%);
    top: -150px;
    right: -100px;
    animation-delay: 0s;
  }

  .glow-2 {
    width: 300px;
    height: 300px;
    background: radial-gradient(circle, rgba(167, 139, 250, 0.2) 0%, transparent 70%);
    bottom: -100px;
    left: -50px;
    animation-delay: -6s;
  }

  @keyframes float {
    0%, 100% { transform: translate(0, 0); }
    50% { transform: translate(30px, -20px); }
  }

  /* Nav */
  .discover-nav {
    position: relative;
    z-index: 1;
    max-width: 500px;
    margin: 0 auto 1rem;
  }

  .back-link {
    font-size: 0.85rem;
    color: rgba(240, 232, 216, 0.4);
    text-decoration: none;
    transition: color 0.2s;
  }

  .back-link:hover {
    color: #d4a854;
  }

  /* Main */
  .discover-main {
    position: relative;
    z-index: 1;
  }

  /* Footer */
  .discover-footer {
    position: relative;
    z-index: 1;
    text-align: center;
    padding: 3rem 0 1rem;
    font-size: 0.75rem;
    color: rgba(240, 232, 216, 0.2);
    font-family: 'Cormorant Garamond', Georgia, serif;
    letter-spacing: 0.1em;
  }

  @media (max-width: 480px) {
    .discover-page {
      padding: 1rem;
    }
  }
</style>
