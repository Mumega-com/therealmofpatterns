---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { SolForecast } from '../../components/sol/SolForecast';
import { EmailCapture } from '../../components/shared/EmailCapture';

export function getStaticPaths() {
  // Generate pages from 30 days back to 365 days ahead so links keep
  // working even if the site isn't redeployed for a long stretch.
  const dates = [];
  const today = new Date();

  for (let i = -30; i < 365; i++) {
    const date = new Date(today);
    date.setDate(date.getDate() + i);
    const dateStr = date.toISOString().split('T')[0];
    dates.push({
      params: { date: dateStr },
      props: { date: dateStr },
    });
  }

  return dates;
}

interface Props {
  date: string;
}

const { date } = Astro.props;

// Parse date for display
const dateObj = new Date(date);
const displayDate = dateObj.toLocaleDateString('en-US', {
  weekday: 'long',
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const isToday = date === new Date().toISOString().split('T')[0];

// Navigation helpers
function getPrevDate(dateStr: string): string {
  const d = new Date(dateStr);
  d.setDate(d.getDate() - 1);
  return `/forecast/${d.toISOString().split('T')[0]}`;
}

function getNextDate(dateStr: string): string {
  const d = new Date(dateStr);
  d.setDate(d.getDate() + 1);
  return `/forecast/${d.toISOString().split('T')[0]}`;
}

const prevDate = getPrevDate(date);
const nextDate = getNextDate(date);

// SEO metadata
const title = isToday
  ? `Today's Energy Forecast - ${displayDate}`
  : `Energy Forecast for ${displayDate}`;
const description = `Personal energy forecast and optimal activity windows for ${displayDate}. Discover your coherence patterns and best times for focus, creativity, and rest.`;
---

<BaseLayout title={title} description={description}>
  <div class="forecast-page">
    <!-- Header -->
    <header class="forecast-header">
      <nav class="forecast-nav">
        <a href="/" class="opacity-60 hover:opacity-100">← Home</a>
        <div class="flex gap-4">
          <a href={prevDate} class="opacity-60 hover:opacity-100">← Previous</a>
          <a href={nextDate} class="opacity-60 hover:opacity-100">Next →</a>
        </div>
      </nav>

      <div class="text-center mt-8">
        {isToday && <span class="badge mb-2">Today</span>}
        <h1 class="text-3xl font-semibold mb-2">{displayDate}</h1>
        <p class="opacity-70">Your Daily Forecast</p>
      </div>
    </header>

    <!-- Main Content -->
    <main class="forecast-main">
      <SolForecast client:load nextDate={nextDate} />
    </main>

    <!-- Email Capture -->
    <section class="forecast-cta">
      <EmailCapture client:visible variant="card" />
    </section>

    <!-- Personalization CTA -->
    <div class="personalize-cta">
      <a href="/discover">Get your personalized forecast &rarr;</a>
    </div>

    <!-- SEO Content -->
    <section class="forecast-seo">
      <h2>Understanding Your Energy Forecast</h2>
      <p>
        Your daily energy forecast helps you understand the natural rhythms
        that influence focus, creativity, and wellbeing. By tracking your
        alignment score, you can identify optimal times for different activities.
      </p>

      <h3>What is Your Alignment Score?</h3>
      <p>
        Your alignment score measures how well your personal energy pattern
        matches the current planetary conditions. Higher scores indicate
        greater alignment and typically correlate with improved focus,
        creativity, and decision-making.
      </p>

      <h3>Best Times for Action</h3>
      <p>
        Throughout each day, your alignment fluctuates. We identify the best
        windows — periods where your energy is highest and best suited
        for specific activities like deep work, creative projects, important
        conversations, or rest.
      </p>
    </section>
  </div>
</BaseLayout>

<style>
  .forecast-page {
    max-width: 48rem;
    margin: 0 auto;
    padding: 1.5rem;
  }

  .forecast-nav {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .badge {
    display: inline-block;
    padding: 0.25rem 0.75rem;
    border-radius: 9999px;
    font-size: 0.75rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    background: var(--sol-accent, #d4a854);
    color: white;
  }

  .forecast-main {
    margin: 2rem 0;
  }

  .forecast-cta {
    margin: 3rem 0;
    padding: 2rem 0;
    border-top: 1px solid rgba(212, 168, 84, 0.15);
    border-bottom: 1px solid rgba(212, 168, 84, 0.15);
  }

  .personalize-cta {
    margin: 2rem 0;
    text-align: center;
  }

  .personalize-cta a {
    display: inline-block;
    padding: 0.875rem 2rem;
    border: 1px solid rgba(212, 168, 84, 0.3);
    border-radius: 8px;
    color: #d4a854;
    text-decoration: none;
    font-size: 1rem;
    font-weight: 500;
    transition: all 0.2s;
  }

  .personalize-cta a:hover {
    background: rgba(212, 168, 84, 0.1);
    border-color: rgba(212, 168, 84, 0.5);
  }

  .forecast-seo {
    margin-top: 3rem;
    opacity: 0.6;
  }

  .forecast-seo h2 {
    font-size: 1.25rem;
    font-weight: 600;
    margin-bottom: 1rem;
  }

  .forecast-seo h3 {
    font-size: 1rem;
    font-weight: 600;
    margin-top: 1.5rem;
    margin-bottom: 0.5rem;
  }

  .forecast-seo p {
    margin-bottom: 1rem;
    line-height: 1.7;
  }
</style>
