---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Best Time To Calculator - Find Your Optimal Windows"
  description="Discover the best times for important activities based on your cosmic pattern. Free tool for finding optimal windows."
>
  <div class="calculator-page">
    <div class="calculator-container">
      <header class="page-header">
        <h1>
          <span class="kasra-only">OPTIMAL_WINDOW_CALCULATOR</span>
          <span class="river-only">Sacred Timing Oracle</span>
          <span class="sol-only">Best Time To...</span>
        </h1>
        <p class="subtitle">
          <span class="kasra-only">Compute high-coherence windows for specific operations.</span>
          <span class="river-only">Discover when the cosmic currents favor your intentions.</span>
          <span class="sol-only">Find the best times for important stuff based on your energy.</span>
        </p>
      </header>

      <!-- Activity Selection -->
      <div class="activity-grid" id="activityGrid">
        <button class="activity-card" data-activity="decisions">
          <span class="activity-icon">&#9881;</span>
          <span class="activity-name kasra-only">MAKE_DECISIONS</span>
          <span class="activity-name river-only">Make Decisions</span>
          <span class="activity-name sol-only">Make Decisions</span>
          <span class="activity-desc kasra-only">High-stakes choices requiring clarity</span>
          <span class="activity-desc river-only">When clarity guides your choice</span>
          <span class="activity-desc sol-only">Big choices that matter</span>
        </button>

        <button class="activity-card" data-activity="creative">
          <span class="activity-icon">&#10022;</span>
          <span class="activity-name kasra-only">CREATE</span>
          <span class="activity-name river-only">Create</span>
          <span class="activity-name sol-only">Create</span>
          <span class="activity-desc kasra-only">Generative work, innovation</span>
          <span class="activity-desc river-only">When the muse is present</span>
          <span class="activity-desc sol-only">Art, writing, brainstorming</span>
        </button>

        <button class="activity-card" data-activity="communicate">
          <span class="activity-icon">&#10070;</span>
          <span class="activity-name kasra-only">COMMUNICATE</span>
          <span class="activity-name river-only">Communicate</span>
          <span class="activity-name sol-only">Talk to People</span>
          <span class="activity-desc kasra-only">Negotiations, presentations</span>
          <span class="activity-desc river-only">When words carry power</span>
          <span class="activity-desc sol-only">Meetings, calls, pitches</span>
        </button>

        <button class="activity-card" data-activity="focus">
          <span class="activity-icon">&#9679;</span>
          <span class="activity-name kasra-only">DEEP_FOCUS</span>
          <span class="activity-name river-only">Deep Focus</span>
          <span class="activity-name sol-only">Focus Work</span>
          <span class="activity-desc kasra-only">Sustained cognitive tasks</span>
          <span class="activity-desc river-only">When the mind is still</span>
          <span class="activity-desc sol-only">Study, coding, analysis</span>
        </button>

        <button class="activity-card" data-activity="physical">
          <span class="activity-icon">&#9889;</span>
          <span class="activity-name kasra-only">PHYSICAL_ACTIVITY</span>
          <span class="activity-name river-only">Physical Activity</span>
          <span class="activity-name sol-only">Exercise</span>
          <span class="activity-desc kasra-only">High-intensity operations</span>
          <span class="activity-desc river-only">When the body awakens</span>
          <span class="activity-desc sol-only">Workouts, sports, movement</span>
        </button>

        <button class="activity-card" data-activity="social">
          <span class="activity-icon">&#10083;</span>
          <span class="activity-name kasra-only">SOCIAL_INTERFACE</span>
          <span class="activity-name river-only">Social Connection</span>
          <span class="activity-name sol-only">Hang Out</span>
          <span class="activity-desc kasra-only">Social field interactions</span>
          <span class="activity-desc river-only">When hearts open</span>
          <span class="activity-desc sol-only">Friends, dates, parties</span>
        </button>

        <button class="activity-card" data-activity="rest">
          <span class="activity-icon">&#9790;</span>
          <span class="activity-name kasra-only">REST_CYCLE</span>
          <span class="activity-name river-only">Rest</span>
          <span class="activity-name sol-only">Rest</span>
          <span class="activity-desc kasra-only">Recovery operations</span>
          <span class="activity-desc river-only">When stillness calls</span>
          <span class="activity-desc sol-only">Naps, relaxation, downtime</span>
        </button>

        <button class="activity-card" data-activity="launch">
          <span class="activity-icon">&#128640;</span>
          <span class="activity-name kasra-only">LAUNCH</span>
          <span class="activity-name river-only">Launch</span>
          <span class="activity-name sol-only">Start Something</span>
          <span class="activity-desc kasra-only">Initiating new projects</span>
          <span class="activity-desc river-only">When new beginnings beckon</span>
          <span class="activity-desc sol-only">New projects, announcements</span>
        </button>
      </div>

      <!-- Results Panel -->
      <div class="results-panel" id="resultsPanel" style="display: none;">
        <div class="results-header">
          <h2 id="resultsTitle">Best Time To...</h2>
          <button class="close-btn" id="closeResults">&times;</button>
        </div>

        <div class="results-content">
          <!-- Today's Windows -->
          <div class="time-section">
            <h3>
              <span class="kasra-only">TODAY'S_WINDOWS</span>
              <span class="river-only">Today's Windows</span>
              <span class="sol-only">Today</span>
            </h3>
            <div class="time-slots" id="todaySlots">
              <!-- Populated by JS -->
            </div>
          </div>

          <!-- Tomorrow's Windows -->
          <div class="time-section">
            <h3>
              <span class="kasra-only">TOMORROW'S_WINDOWS</span>
              <span class="river-only">Tomorrow's Windows</span>
              <span class="sol-only">Tomorrow</span>
            </h3>
            <div class="time-slots" id="tomorrowSlots">
              <!-- Populated by JS -->
            </div>
          </div>

          <!-- Weekly Overview -->
          <div class="weekly-section">
            <h3>
              <span class="kasra-only">7_DAY_PROJECTION</span>
              <span class="river-only">The Week Ahead</span>
              <span class="sol-only">This Week</span>
            </h3>
            <div class="weekly-grid" id="weeklyGrid">
              <!-- Populated by JS -->
            </div>
          </div>
        </div>

        <!-- Upgrade CTA -->
        <div class="upgrade-cta">
          <p>
            <span class="kasra-only">For personalized optimal windows based on your 16D signature:</span>
            <span class="river-only">For timing tuned to your unique pattern:</span>
            <span class="sol-only">Want times based on YOUR energy pattern?</span>
          </p>
          <a href="/subscribe" class="cta-btn">
            <span class="kasra-only">ACTIVATE_PERSONAL_TIMING</span>
            <span class="river-only">Receive Personal Timing</span>
            <span class="sol-only">Get My Best Times</span>
          </a>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>

<style>
  .calculator-page {
    --gold: #d4a854;
    --gold-glow: rgba(212, 168, 84, 0.3);
    --dark: #0a0908;
    --dark-surface: #141210;
    --text: #f0e8d8;
    --text-muted: rgba(240, 232, 216, 0.6);

    font-family: 'Cormorant Garamond', Georgia, serif;
    background: var(--dark);
    color: var(--text);
    min-height: 100vh;
    padding: 6rem 2rem 4rem;
  }

  .calculator-container {
    max-width: 900px;
    margin: 0 auto;
  }

  .page-header {
    text-align: center;
    margin-bottom: 3rem;
  }

  .page-header h1 {
    font-size: 2.5rem;
    font-weight: 300;
    color: var(--text);
    margin-bottom: 0.75rem;
  }

  .subtitle {
    font-size: 1.1rem;
    color: var(--text-muted);
  }

  .activity-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 1rem;
  }

  .activity-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 1.5rem 1rem;
    background: var(--dark-surface);
    border: 1px solid rgba(212, 168, 84, 0.15);
    cursor: pointer;
    transition: all 0.3s;
    text-align: center;
    font-family: inherit;
    color: inherit;
  }

  .activity-card:hover {
    border-color: var(--gold);
    transform: translateY(-2px);
    box-shadow: 0 4px 20px rgba(212, 168, 84, 0.15);
  }

  .activity-card.selected {
    border-color: var(--gold);
    background: rgba(212, 168, 84, 0.1);
  }

  .activity-icon {
    font-size: 2rem;
    color: var(--gold);
    margin-bottom: 0.75rem;
  }

  .activity-name {
    font-size: 1rem;
    color: var(--text);
    font-weight: 500;
    margin-bottom: 0.25rem;
  }

  .activity-desc {
    font-size: 0.8rem;
    color: var(--text-muted);
  }

  .results-panel {
    margin-top: 2rem;
    background: var(--dark-surface);
    border: 1px solid rgba(212, 168, 84, 0.2);
    animation: slideDown 0.3s ease-out;
  }

  @keyframes slideDown {
    from { opacity: 0; transform: translateY(-10px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .results-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1rem 1.5rem;
    border-bottom: 1px solid rgba(212, 168, 84, 0.1);
  }

  .results-header h2 {
    font-size: 1.25rem;
    font-weight: 400;
    color: var(--gold);
  }

  .close-btn {
    width: 32px;
    height: 32px;
    background: transparent;
    border: none;
    color: var(--text-muted);
    font-size: 1.5rem;
    cursor: pointer;
    transition: color 0.2s;
  }

  .close-btn:hover {
    color: var(--text);
  }

  .results-content {
    padding: 1.5rem;
  }

  .time-section {
    margin-bottom: 2rem;
  }

  .time-section h3 {
    font-size: 1rem;
    color: var(--text-muted);
    margin-bottom: 1rem;
    font-weight: 400;
  }

  .time-slots {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .time-slot {
    display: flex;
    flex-direction: column;
    padding: 0.75rem 1rem;
    background: rgba(212, 168, 84, 0.08);
    border-left: 3px solid var(--gold);
  }

  .time-slot.high {
    border-left-color: #22c55e;
    background: rgba(34, 197, 94, 0.08);
  }

  .time-slot.medium {
    border-left-color: var(--gold);
  }

  .time-slot.low {
    border-left-color: #ef4444;
    background: rgba(239, 68, 68, 0.08);
  }

  .slot-time {
    font-size: 1.1rem;
    color: var(--text);
    font-weight: 500;
  }

  .slot-quality {
    font-size: 0.75rem;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .weekly-section h3 {
    font-size: 1rem;
    color: var(--text-muted);
    margin-bottom: 1rem;
    font-weight: 400;
  }

  .weekly-grid {
    display: grid;
    grid-template-columns: repeat(7, 1fr);
    gap: 0.5rem;
  }

  @media (max-width: 640px) {
    .weekly-grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  .day-card {
    padding: 0.75rem 0.5rem;
    text-align: center;
    background: var(--dark);
    border: 1px solid rgba(212, 168, 84, 0.1);
  }

  .day-card.best {
    border-color: #22c55e;
    background: rgba(34, 197, 94, 0.1);
  }

  .day-card.good {
    border-color: var(--gold);
    background: rgba(212, 168, 84, 0.1);
  }

  .day-card.avoid {
    border-color: #ef4444;
    background: rgba(239, 68, 68, 0.05);
  }

  .day-name {
    font-size: 0.7rem;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .day-date {
    font-size: 1.1rem;
    color: var(--text);
    margin: 0.25rem 0;
  }

  .day-quality {
    font-size: 0.65rem;
    color: var(--text-muted);
  }

  .day-card.best .day-quality { color: #22c55e; }
  .day-card.good .day-quality { color: var(--gold); }
  .day-card.avoid .day-quality { color: #ef4444; }

  .upgrade-cta {
    padding: 1.5rem;
    border-top: 1px solid rgba(212, 168, 84, 0.1);
    text-align: center;
  }

  .upgrade-cta p {
    font-size: 0.9rem;
    color: var(--text-muted);
    margin-bottom: 1rem;
  }

  .cta-btn {
    display: inline-block;
    padding: 0.75rem 1.5rem;
    background: var(--gold);
    color: var(--dark);
    text-decoration: none;
    font-weight: 500;
    transition: all 0.2s;
  }

  .cta-btn:hover {
    background: #e5b964;
    box-shadow: 0 0 20px var(--gold-glow);
  }
</style>

<script>
  const activityGrid = document.getElementById('activityGrid');
  const resultsPanel = document.getElementById('resultsPanel');
  const resultsTitle = document.getElementById('resultsTitle');
  const closeResults = document.getElementById('closeResults');
  const todaySlots = document.getElementById('todaySlots');
  const tomorrowSlots = document.getElementById('tomorrowSlots');
  const weeklyGrid = document.getElementById('weeklyGrid');

  const activityNames: Record<string, { kasra: string; river: string; sol: string }> = {
    decisions: { kasra: 'MAKE_DECISIONS', river: 'Make Decisions', sol: 'Make Decisions' },
    creative: { kasra: 'CREATE', river: 'Create', sol: 'Create' },
    communicate: { kasra: 'COMMUNICATE', river: 'Communicate', sol: 'Talk to People' },
    focus: { kasra: 'DEEP_FOCUS', river: 'Deep Focus', sol: 'Focus Work' },
    physical: { kasra: 'PHYSICAL_ACTIVITY', river: 'Physical Activity', sol: 'Exercise' },
    social: { kasra: 'SOCIAL_INTERFACE', river: 'Social Connection', sol: 'Hang Out' },
    rest: { kasra: 'REST_CYCLE', river: 'Rest', sol: 'Rest' },
    launch: { kasra: 'LAUNCH', river: 'Launch', sol: 'Start Something' },
  };

  // Get mode from data attribute
  const getMode = () => {
    return (document.documentElement.dataset.mode as 'kasra' | 'river' | 'sol') || 'sol';
  };

  // Generate pseudo-random but deterministic windows based on date and activity
  function generateWindows(activity: string, date: Date) {
    const seed = date.getDate() + date.getMonth() * 31 + activity.charCodeAt(0);
    const random = (n: number) => ((seed * (n + 1) * 9301 + 49297) % 233280) / 233280;

    const windows = [];
    const numWindows = 2 + Math.floor(random(1) * 3);

    for (let i = 0; i < numWindows; i++) {
      const hour = 6 + Math.floor(random(i + 2) * 16); // 6 AM to 10 PM
      const quality = random(i + 3) > 0.6 ? 'high' : random(i + 3) > 0.3 ? 'medium' : 'low';
      windows.push({
        time: `${hour.toString().padStart(2, '0')}:00 - ${(hour + 2).toString().padStart(2, '0')}:00`,
        quality,
      });
    }

    return windows.sort((a, b) => parseInt(a.time) - parseInt(b.time));
  }

  function generateWeeklyQuality(activity: string) {
    const mode = getMode();
    const days = [];
    const today = new Date();
    const dayNames = ['Sun', 'Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat'];
    const qualityLabels = {
      kasra: { best: 'OPTIMAL', good: 'NOMINAL', avoid: 'SUBOPTIMAL' },
      river: { best: 'Blessed', good: 'Favorable', avoid: 'Challenging' },
      sol: { best: 'Best!', good: 'Good', avoid: 'Skip' },
    };

    for (let i = 0; i < 7; i++) {
      const date = new Date(today);
      date.setDate(today.getDate() + i);
      const seed = date.getDate() + date.getMonth() * 31 + activity.charCodeAt(0) + i * 7;
      const quality = ((seed * 9301 + 49297) % 233280) / 233280;

      let qualityClass = 'good';
      let qualityLabel = qualityLabels[mode].good;
      if (quality > 0.7) {
        qualityClass = 'best';
        qualityLabel = qualityLabels[mode].best;
      } else if (quality < 0.3) {
        qualityClass = 'avoid';
        qualityLabel = qualityLabels[mode].avoid;
      }

      days.push({
        name: dayNames[date.getDay()],
        date: date.getDate(),
        quality: qualityClass,
        label: qualityLabel,
      });
    }

    return days;
  }

  function showResults(activity: string) {
    const mode = getMode();

    // Update title
    if (resultsTitle) {
      const name = activityNames[activity]?.[mode] || activity;
      resultsTitle.textContent =
        mode === 'kasra'
          ? `OPTIMAL_WINDOWS: ${name}`
          : mode === 'river'
          ? `Best Times to ${name}`
          : `Best Time to ${name}`;
    }

    // Generate today's windows
    const today = new Date();
    const todayWindows = generateWindows(activity, today);
    if (todaySlots) {
      todaySlots.innerHTML = todayWindows
        .map(
          (w) => `
        <div class="time-slot ${w.quality}">
          <span class="slot-time">${w.time}</span>
          <span class="slot-quality">${w.quality === 'high' ? '★ Best' : w.quality === 'medium' ? '◆ Good' : '○ Fair'}</span>
        </div>
      `
        )
        .join('');
    }

    // Generate tomorrow's windows
    const tomorrow = new Date();
    tomorrow.setDate(today.getDate() + 1);
    const tomorrowWindows = generateWindows(activity, tomorrow);
    if (tomorrowSlots) {
      tomorrowSlots.innerHTML = tomorrowWindows
        .map(
          (w) => `
        <div class="time-slot ${w.quality}">
          <span class="slot-time">${w.time}</span>
          <span class="slot-quality">${w.quality === 'high' ? '★ Best' : w.quality === 'medium' ? '◆ Good' : '○ Fair'}</span>
        </div>
      `
        )
        .join('');
    }

    // Generate weekly overview
    const weekly = generateWeeklyQuality(activity);
    if (weeklyGrid) {
      weeklyGrid.innerHTML = weekly
        .map(
          (d) => `
        <div class="day-card ${d.quality}">
          <div class="day-name">${d.name}</div>
          <div class="day-date">${d.date}</div>
          <div class="day-quality">${d.label}</div>
        </div>
      `
        )
        .join('');
    }

    // Show panel
    if (resultsPanel) {
      resultsPanel.style.display = 'block';
      resultsPanel.scrollIntoView({ behavior: 'smooth', block: 'start' });
    }
  }

  // Event listeners
  activityGrid?.querySelectorAll('.activity-card').forEach((card) => {
    card.addEventListener('click', () => {
      // Update selection
      activityGrid.querySelectorAll('.activity-card').forEach((c) => c.classList.remove('selected'));
      card.classList.add('selected');

      // Show results
      const activity = card.getAttribute('data-activity');
      if (activity) {
        showResults(activity);
      }
    });
  });

  closeResults?.addEventListener('click', () => {
    if (resultsPanel) {
      resultsPanel.style.display = 'none';
    }
    activityGrid?.querySelectorAll('.activity-card').forEach((c) => c.classList.remove('selected'));
  });
</script>
