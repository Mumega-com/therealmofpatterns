---
import '../styles/global.css';
import { Header } from '../components/shared/Header';
import { Footer } from '../components/shared/Footer';

export interface Props {
  title?: string;
  description?: string;
  mode?: 'kasra' | 'river' | 'sol';
  stage?: 'nigredo' | 'albedo' | 'citrinitas' | 'rubedo';
  lang?: string;
  showHeader?: boolean;
  showFooter?: boolean;
  transparentHeader?: boolean;
  ogImage?: string;
  breadcrumbs?: { name: string; url: string }[];
  faqItems?: { question: string; answer: string }[];
  structuredData?: Record<string, unknown>[];
}

const {
  title = 'The Realm of Patterns',
  description = 'A daily depth psychology practice powered by Jungian astrology. Your 8-dimensional natal profile meets today\'s sky.',
  mode = 'sol',
  stage = 'citrinitas',
  lang = 'en',
  showHeader = true,
  showFooter = true,
  transparentHeader = false,
  ogImage = '/assets/brand/hero-cosmic.png',
  breadcrumbs = [],
  faqItems = [],
  structuredData = []
} = Astro.props;

const siteUrl = 'https://therealmofpatterns.com';
const canonicalUrl = new URL(Astro.url.pathname, siteUrl).toString();

const organizationSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'The Realm of Patterns',
  url: siteUrl,
  logo: `${siteUrl}/assets/brand/logo.png`,
  description: 'A daily depth psychology practice powered by Jungian astrology and an 8-dimensional natal engine.'
};

const schemas: Record<string, unknown>[] = [
  {
    '@context': 'https://schema.org',
    '@type': 'WebApplication',
    name: 'The Realm of Patterns',
    url: siteUrl,
    description: 'A daily depth psychology practice powered by Jungian astrology and an 8-dimensional natal engine.',
    applicationCategory: 'LifestyleApplication',
    operatingSystem: 'Web',
    offers: {
      '@type': 'Offer',
      price: '0',
      priceCurrency: 'USD'
    },
    author: {
      '@type': 'Organization',
      name: 'The Realm of Patterns',
      url: siteUrl
    }
  },
  organizationSchema,
  ...(breadcrumbs.length > 0
    ? [{
        '@context': 'https://schema.org',
        '@type': 'BreadcrumbList',
        itemListElement: breadcrumbs.map((item, index) => ({
          '@type': 'ListItem',
          position: index + 1,
          name: item.name,
          item: item.url.startsWith('http') ? item.url : new URL(item.url, siteUrl).toString()
        }))
      }]
    : []),
  ...(faqItems.length > 0
    ? [{
        '@context': 'https://schema.org',
        '@type': 'FAQPage',
        mainEntity: faqItems.map((item) => ({
          '@type': 'Question',
          name: item.question,
          acceptedAnswer: {
            '@type': 'Answer',
            text: item.answer
          }
        }))
      }]
    : []),
  ...structuredData
];
---

<!DOCTYPE html>
<html lang={lang} data-mode={mode} data-stage={stage}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" type="image/png" href="/assets/brand/logo.png" />
    <link rel="apple-touch-icon" href="/assets/brand/logo.png" />
    <link rel="manifest" href="/manifest.json" />
    <meta name="mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <meta name="apple-mobile-web-app-title" content="RoP" />
    <title>{title}</title>

    <!-- Preload fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;1,400&family=Geist+Mono:wght@400;500&display=swap" rel="stylesheet" />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={`${siteUrl}${ogImage}`} />
    <meta property="og:site_name" content="The Realm of Patterns" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={`${siteUrl}${ogImage}`} />

    <!-- Theme color -->
    <meta name="theme-color" content="#0a0908" />

    <!-- Structured Data -->
    {schemas.map((schema) => (
      <script type="application/ld+json" set:html={JSON.stringify(schema)} />
    ))}

    <!-- Plausible Analytics -->
    <script defer data-domain="therealmofpatterns.com" src="https://plausible.io/js/script.js"></script>
  </head>
  <body class="min-h-screen bg-[#0a0908] text-[#f0e8d8] transition-colors duration-300">
    {showHeader && <Header client:load transparent={transparentHeader} />}

    <main class={showHeader ? 'pt-14' : ''}>
      <slot />
    </main>

    {showFooter && <Footer />}

    <script>
      // Sol-default: single voice experience
      document.documentElement.dataset.mode = 'sol';

      // Register service worker for PWA
      if ('serviceWorker' in navigator) {
        navigator.serviceWorker.register('/sw.js').catch((error) => {
          console.log('Service worker registration failed:', error);
        });
      }
    </script>
  </body>
</html>
