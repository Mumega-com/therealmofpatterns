# The Realm of Patterns - Local Development Variables
# Copy this to .dev.vars and fill in your values

# Stripe (required for payments)
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key

# Stripe Price IDs (create in Stripe Dashboard → Products)
STRIPE_PRO_MONTHLY_PRICE_ID=price_xxx   # Pro $9/mo
STRIPE_PRO_ANNUAL_PRICE_ID=price_xxx    # Pro $7/mo billed yearly ($84)
STRIPE_TEAM_MONTHLY_PRICE_ID=price_xxx  # Team $29/seat/mo
STRIPE_TEAM_ANNUAL_PRICE_ID=price_xxx   # Team $23/seat/mo billed yearly

# Social Media (optional)
TWITTER_BEARER_TOKEN=your_twitter_bearer_token
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/your_webhook

# Cloudflare (for wrangler CLI)
CLOUDFLARE_API_TOKEN=your_cloudflare_api_token
CLOUDFLARE_ACCOUNT_ID=your_account_id
