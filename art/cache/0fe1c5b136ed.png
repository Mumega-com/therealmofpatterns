<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1024 1024">
  <defs>
    <radialGradient id="bg" cx="50%" cy="50%" r="70%">
      <stop offset="0%" style="stop-color:#DC143C;stop-opacity:0.8"/>
      <stop offset="100%" style="stop-color:#0a0a1a;stop-opacity:1"/>
    </radialGradient>
    <radialGradient id="glow" cx="50%" cy="50%" r="50%">
      <stop offset="0%" style="stop-color:#FF4500;stop-opacity:0.76"/>
      <stop offset="100%" style="stop-color:#FF4500;stop-opacity:0"/>
    </radialGradient>
    <filter id="blur">
      <feGaussianBlur stdDeviation="3"/>
    </filter>
  </defs>

  <!-- Background -->
  <rect width="1024" height="1024" fill="url(#bg)"/>

  <!-- Central glow -->
  <circle cx="512" cy="512" r="300" fill="url(#glow)" filter="url(#blur)"/>

  <!-- Flame -->
  <path d="M512 262 L612 512 L562 512 L562 762 L462 762 L462 512 L412 512 Z"
        fill="#FF4500" opacity="0.22799999999999998"/>
  <path d="M512 262 L612 512 L562 512 L562 762 L462 762 L462 512 L412 512 Z"
        fill="none" stroke="#FF4500" stroke-width="3" opacity="0.76"/>
  <path d="M512 312 L582 492 L552 492 L552 712 L472 712 L472 492 L442 492 Z"
        fill="none" stroke="#FF4500" stroke-width="1" opacity="0.38"/>
</svg>