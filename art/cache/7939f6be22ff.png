<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1024 1024">
  <defs>
    <radialGradient id="bg" cx="50%" cy="50%" r="70%">
      <stop offset="0%" style="stop-color:#B87333;stop-opacity:0.8"/>
      <stop offset="100%" style="stop-color:#0a0a1a;stop-opacity:1"/>
    </radialGradient>
    <radialGradient id="glow" cx="50%" cy="50%" r="50%">
      <stop offset="0%" style="stop-color:#FFB6C1;stop-opacity:0.705"/>
      <stop offset="100%" style="stop-color:#FFB6C1;stop-opacity:0"/>
    </radialGradient>
    <filter id="blur">
      <feGaussianBlur stdDeviation="3"/>
    </filter>
  </defs>

  <!-- Background -->
  <rect width="1024" height="1024" fill="url(#bg)"/>

  <!-- Central glow -->
  <circle cx="512" cy="512" r="300" fill="url(#glow)" filter="url(#blur)"/>

  <!-- Flower of Life -->
  <circle cx="512" cy="512" r="100" fill="none" stroke="#FFB6C1" stroke-width="2" opacity="0.705"/>
  <circle cx="612" cy="512" r="100" fill="none" stroke="#FFB6C1" stroke-width="1" opacity="0.49349999999999994"/>
  <circle cx="562" cy="599" r="100" fill="none" stroke="#FFB6C1" stroke-width="1" opacity="0.49349999999999994"/>
  <circle cx="462" cy="599" r="100" fill="none" stroke="#FFB6C1" stroke-width="1" opacity="0.49349999999999994"/>
  <circle cx="412" cy="512" r="100" fill="none" stroke="#FFB6C1" stroke-width="1" opacity="0.49349999999999994"/>
  <circle cx="462" cy="425" r="100" fill="none" stroke="#FFB6C1" stroke-width="1" opacity="0.49349999999999994"/>
  <circle cx="562" cy="425" r="100" fill="none" stroke="#FFB6C1" stroke-width="1" opacity="0.49349999999999994"/>

  <circle cx="512" cy="512" r="200" fill="none" stroke="#FFB6C1" stroke-width="1" opacity="0.3525"/>
</svg>